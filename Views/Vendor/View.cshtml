@model RMS.Client.Models.Vendor.VendorWithDetailDto
<div id="less_info">
    @if (Model != null)
    {
        <div class="flex items-center gap-4 mb-5">
            <a asp-action="Index" asp-controller="Vendor" class="py-2 px-2 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base" title="Back">
                <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M11.707 5.293a1 1 0 0 1 0 1.414L7.414 11H19a1 1 0 1 1 0 2H7.414l4.293 4.293a1 1 0 0 1-1.414 1.414l-6-6a1 1 0 0 1 0-1.414l6-6a1 1 0 0 1 1.414 0z" /></svg>
            </a>

            <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Detailed View: @Model.vendorname</h2>
        </div>
        <div class="customer-info-wrapper my-4 bg-[#fafafa] py-3 px-4 rounded overflow-x-auto flex items-stretch gap-5">
            <div class="border-r border-r-slate-300 flex items-center gap-3 pr-4">
                <div class="customer-logo-wrapper w-10 h-10 bg-white rounded-full flex items-center justify-center">
                    <img class="w-6 h-6 rounded-full object-cover" src=" /assets/images/employment.svg" alt="">
                </div>
                <div>
                    <p class="text-xs font-medium text-[#4B4E5C] whitespace-nowrap">Vendor</p>
                    <p class="text-2xl font-black text-[#4B4E5C] whitespace-nowrap">
                        @if (string.IsNullOrEmpty(Model.vendorname))
                        {
                            <span>N/A</span>
                        }
                        else
                        {
                            @Model.vendorname
                        }
                    </p>
                </div>
            </div>
            <div class="flex items-center border-r border-r-slate-300 pr-4">
                <div>
                    <p class="text-xs text-[#4B4E5C] whitespace-nowrap">Email</p>
                    <p class="text-xs text-[#4B4E5C] whitespace-nowrap">
                        @if (string.IsNullOrEmpty(Model.email))
                        {
                            <span>N/A</span>
                        }
                        else
                        {
                            @Model.email
                        }
                    </p>
                </div>
            </div>
            <div class="flex items-center border-r border-r-slate-300 pr-4">
                <div>
                    <p class="text-xs text-[#4B4E5C] whitespace-nowrap">Phone No:</p>
                    <p class="text-xs text-[#4B4E5C] whitespace-nowrap">
                        @if (string.IsNullOrEmpty(Model.phone1))
                        {
                            <span>N/A</span>
                        }
                        else
                        {
                            @Model.phone1
                        }
                    </p>
                </div>
            </div>
            <div class="flex items-center border-r border-r-slate-300 pr-4">
                <div>
                    <p class="text-xs text-[#4B4E5C] whitespace-nowrap">Location:</p>
                    <p class="text-xs text-[#4B4E5C] whitespace-nowrap">
                        @if (string.IsNullOrEmpty(Model.address1))
                        {
                            <span>N/A</span>
                        }
                        else
                        {
                            @Model.address1
                        }
                    </p>
                </div>
            </div>
            <div class="flex items-center">
                <button id="all_info_btn" type="button" class="whitespace-nowrap py-2 px-4 inline-flex justify-center items-center gap-2 rounded-full border border-transparent font-semibold bg-black text-white hover:bg-black focus:outline-none focus:ring-2 focus:ring-black focus:ring-offset-2 transition-all text-xs xl:text-sm">
                    All Info
                </button>
            </div>

            <div class="bg-white p-3 rounded flex items-center gap-3">

                <div>
                    <p class="text-xs font-medium text-[#4B4E5C] whitespace-nowrap">Total Resources</p>
                    <p class="text-2xl font-black text-[#4B4E5C] whitespace-nowrap">
                        @((Model.employees != null) ? Model.employees.Count() : 0)

                    </p>
                </div>



            </div>
            <a type="button" id="btnAdd" asp-action="AddVendorEmployee" asp-controller="Vendor" asp-route-vendorid="@Model.vendorid" class="self-end ml-auto mr-2 py-3 px-4 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 font-semibold bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm w-full sm:w-auto">
                <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M18 12.998h-5v5a1 1 0 0 1-2 0v-5H6a1 1 0 0 1 0-2h5v-5a1 1 0 0 1 2 0v5h5a1 1 0 0 1 0 2z" /></svg>
                Add
            </a>
        </div>
    }
