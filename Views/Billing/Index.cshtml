        function filterRecord(mode = null) {
            var _mode = mode == null ? $("#ctlMode").val() : mode;
            var _fdate = $("#ctlFdate").val();
            var _tdate = $("#ctlTdate").val();

            postForm("@Url.Action("Index", "Billing")", {
                m: _mode,
                fd: _fdate,
                td: _tdate
            });
        }

        function filterTable(btn, colInd) {
            const values = [];
            btn.closest(".hs-dropdown").querySelectorAll("input:checked").forEach(chkbox => {
                values.push(chkbox.value);
            })
            HSDropdown.close(btn.closest(".hs-dropdown"));
            setTimeout(() => {
                if (values.length) {
                    datatable.columns(Number(colInd)).search('^(' + values.join("|") + ')$', true, false).draw();
                } else {
                    datatable.columns(Number(colInd)).search("", true, false).draw();
                }
                updateTotalBilling(datatable);
            }, 200)
        }

        function clearFilter(btn, colInd) {
            btn.closest(".hs-dropdown").querySelectorAll("input:checked").forEach(chkbox => {
                chkbox.checked = false;
            })
            btn.closest(".hs-dropdown").querySelector("input[type='search']").value = "";
            const _inpEvent = new Event("input");
            btn.closest(".hs-dropdown").querySelector("input[type='search']").dispatchEvent(_inpEvent);
            HSDropdown.close(btn.closest(".hs-dropdown"));
            setTimeout(() => {
                datatable.columns(Number(colInd)).search("", true, false).draw();
                updateTotalBilling(datatable);
            }, 200)
        }

        function calculateTotalBillingByMonth(dt) {
            const allTh = document.querySelector("table thead tr:last-child").querySelectorAll("th");
            const mode = document.querySelector("#ctlMode").value;
            console.log(allTh);
            for (let i = 0; i < allTh.length; i += 2) {
                console.log(i, i + (mode === "employeewise" ? 9 : 8));
                let totalProvRowBilling = dt.api().column(i + (mode === "employeewise" ? 9 : 8)).data().reduce((a, b) => {
                    const aEl = document.createElement("div");
                    const bEl = document.createElement("div");
                    aEl.innerHTML = a;
                    bEl.innerHTML = b;
                    return Number(aEl.innerText.trim()) + Number(bEl.innerText.trim());
                });
                let totalActualRowBilling = dt.api().column(i + (mode === "employeewise" ? 10 : 9)).data().reduce((a, b) => {
                    const aEl = document.createElement("div");
                    const bEl = document.createElement("div");
                    aEl.innerHTML = a;
                    bEl.innerHTML = b;
                    return Number(aEl.innerText.trim()) + Number(bEl.innerText.trim());
                });
                if (isNaN(totalProvRowBilling)) {
                    totalProvRowBilling = 0;
                }
                if (isNaN(totalActualRowBilling)) {
                    totalActualRowBilling = 0;
                }
                allTh[i].innerHTML += `<div class="hs-tooltip block" style="margin-top: .25rem;">
                                                                                                                                    <span class="hs-tooltip-toggle text-white text-center text-sm" style="display: block; padding-inline: .4rem; border-radius: 1rem; background-color: #EAECFF; color: rgb(75, 85, 99);">${formatCurrency(totalProvRowBilling)}</span>
                                                                                            <span class="hs-tooltip-content hs-tooltip-shown:opacity-100 hs-tooltip-shown:visible opacity-0 transition-opacity inline-block absolute invisible z-10 py-1 px-2 bg-gray-900 text-xs font-medium text-white rounded shadow-sm" role="tooltip">
                                                                                              Total Billing
                                                                                            </span>
                                                                                        </div>`;
                allTh[i + 1].innerHTML += `<div class="hs-tooltip block" style="margin-top: .25rem;">
                                                                                                                            <span class="hs-tooltip-toggle text-white text-center text-sm" style="display: block; padding-inline: .4rem; border-radius: 1rem; background-color: #00cc8320; color: #00cc83;">${formatCurrency(totalActualRowBilling)}</span>
                                                                                                    <span class="hs-tooltip-content hs-tooltip-shown:opacity-100 hs-tooltip-shown:visible opacity-0 transition-opacity inline-block absolute invisible z-10 py-1 px-2 bg-gray-900 text-xs font-medium text-white rounded shadow-sm" role="tooltip">
                                                                                                      Total Billing
                                                                                                    </span>
                                                                                                </div>`;
            }
            dt.api().draw();
        }

        function updateTotalBilling(dt) {
            const allTh = document.querySelector("table thead").querySelectorAll("th");
            console.log(allTh);
            // console.log();
            // console.log(dt.rows());
            const filteredRows = dt.rows({ search: 'applied' }).nodes();
            for (let i = 9; i < allTh.length; i++) {
                let totalRowBilling = 0;
                for (let j = 0; j < filteredRows.length; j++) {
                    totalRowBilling += Number(filteredRows[j].children[i].innerText);
                }
                if (isNaN(totalRowBilling)) {
                    totalRowBilling = 0;
                }

                console.log(totalRowBilling);
                allTh[i].querySelector(".hs-tooltip-toggle").innerText = formatCurrency(totalRowBilling);
            }
        }

        function formatCurrency(num) {
            return num.toLocaleString('en-IN', {
                maximumFractionDigits: 2,
                style: 'currency',
                currency: 'INR'
            });
        }

        function handleFilterSearch(input) {
            const allFilterItems = input.closest(".hs-dropdown-menu").querySelector(".filter-item-list").querySelectorAll("span");
            allFilterItems.forEach(item => {
                if (item.innerText.trim().toLowerCase().includes(input.value.trim().toLowerCase())) {
                    item.closest(".filter-item").style.display = "flex"
                } else {
                    item.closest(".filter-item").style.display = "none";
                }
            })
        }



