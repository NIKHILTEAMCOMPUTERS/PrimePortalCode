                                                    decimal? cost = 0;
                                                    decimal? provisionCost = 0;

                                                    foreach (var month in cols)
                                                    {
                                                        var _month = month;
                                                        if (_month.Contains("Sept"))
                                                        {
                                                            _month = _month.Replace("Sept", "Sep");
                                                        }

                                                        if (groupedCostList.Any(c => c.Key.monthYear == _month))
                                                        {
                                                            cost = groupedCostList.FirstOrDefault(c => c.Key.monthYear == _month)?.Value.Sum(x => x.cost);
                                                            provisionCost = groupedCostList.FirstOrDefault(c => c.Key.monthYear == _month)?.Value.Sum(x => x.ProvisionCost);

                                                        }
                                                        else
                                                        {
                                                            cost = 0;
                                                            provisionCost = 0;
                                                        }


                                                        <td style="border-left: 1px solid #f0f0f0;" class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 text-center">@provisionCost</td>
                                                        <td style="border-right: 1px solid #f0f0f0;" class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 text-center">@cost</td>

                                                    }

                                                }

                                                // @foreach (var li in groupedCostList)
                                                // {
                                                //     <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                //         <p>@li.Value</p>
                                                //     </td>
                                                // }
                                            }
                                        </tr>
                                    }
                                }
                            }
                        </tbody>

                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

