@using System.Globalization;
@model IEnumerable<RMS.Client.Models.Contract.Billing>
@{
   
    // Function to parse date with detailed logging
    DateTime ParseMonthYear(string monthYear)
    {
        try
        {
            
            // Convert monthYear to uppercase to ensure consistent parsing
            string monthYearUpper = monthYear.ToUpperInvariant();
            DateTime parsedDate = DateTime.ParseExact("01-" + monthYearUpper, "dd-MMM-yy", CultureInfo.InvariantCulture);
            
            return parsedDate;
        }
        catch (FormatException ex)
        {
           
            return DateTime.MinValue;
        }
    }
    List<DateTime> columns = Model.Select(c => Convert.ToDateTime("01" + c.monthYear)).OrderBy(x => x).ToList().Distinct().ToList();
    var cols = columns.Select(c => c.ToString("MMM-yy")).ToList();
    var colLists = new List<string> { "Code", "Resource Name", "Customer Name", "Project Name", "Delivery Anchor", "Practice", "SubPractice", "StartDate", "EndDate" };

}



