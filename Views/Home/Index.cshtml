@model RMS.Client.Models.Dashboard.HRDashboard
@{
    ViewData["Title"] = "Dashboard - ";
    bool lPReadPermit = false;
    bool lPWritePermit = false;
    bool lPDeletePermit = false;

    bool lEReadPermit = false;
    bool lEWritePermit = false;
    bool lEDeletePermit = false;
    if (ViewBag.AuthPages != null)
    {
        var pages = (List<RMS.Client.Models.Account.AuthorizePages>)ViewBag.AuthPages;
        var pageFound = pages.FirstOrDefault(x => x.Controller == "Project");
        if (pageFound != null)
        {
            lPReadPermit = pageFound.Isreadpermit ?? false;
            lPWritePermit = pageFound.Iswritepermit ?? false;
            lPDeletePermit = pageFound.Isdeletepermit ?? false;
        }

        pageFound = pages.FirstOrDefault(x => x.Controller == "Employee");
        if (pageFound != null)
        {
            lEReadPermit = pageFound.Isreadpermit ?? false;
            lEWritePermit = pageFound.Iswritepermit ?? false;
            lEDeletePermit = pageFound.Isdeletepermit ?? false;
        }
    }
    var pColLists = new List<string> { "Project Name", "Contract Start Date", "Company Name","PO Number", "PO Amount", "Practice", "Sub-Practice", "Project Type", "Project Status" };
    var eColLists = new List<string> { "TMC", "Resource Name", "Practice","Reporting Head", "Project Name", "Project Type", "Billing", "Customer Name", "DA", "Sub-Practice", "Status" };

    if (lPReadPermit)
        pColLists.Add("Detailed View");

    if (lPWritePermit)
        pColLists.Add("Edit");

    //if (lEReadPermit)
    //    eColLists.Add("Detailed View");

    if (lEWritePermit)
        eColLists.Add("Edit");
}

@section PageStyles {
    <style>
        .last-column-fixed th:last-child, .last-column-fixed td:last-child {
            z-index: 21;
        }

        .dataTables_scroll:has(th:last-child [data-popper-placement]) td:last-child {
            position: unset !important;
        }
    </style>
}

<div class="overflow-x-auto bg-white shadow-custom rounded">
    <nav class="flex space-x-2" aria-label="Tabs" role="tablist">
        <button type="button" onclick="fnShowProject()"
                class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600 active"
                id="tabs-with-underline-item-1" data-hs-tab="#tabs-with-underline-1"
                aria-controls="tabs-with-underline-1" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-projects-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Active Projects</span>
                <span class="text-2xl font-extrabold block text-left">@Model.Projects.Count</span>
            </div>
        </button>
        <button type="button" onclick="fnShowOverrunProject()"
                class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600"
                id="tabs-with-underline-item-1" data-hs-tab="#tabs-with-underline-1"
                aria-controls="tabs-with-underline-1" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-projects-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Overrun Projects</span>
                <span class="text-2xl font-extrabold block text-left">
                    @ViewBag.Overruncount
                </span>
            </div>

        </button>
        <button type="button" onclick="fnShowEmployee(this)" data-type="1"
                class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600"
                id="tabs-with-underline-item-2" data-hs-tab="#tabs-with-underline-2"
                aria-controls="tabs-with-underline-2" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-employees-icon.svg" alt="">
            <div>
                    <span class="text-base font-semibold block text-left">Total Employees</span>
                    <span class="text-2xl font-extrabold block text-left">@Model.EmployeeCount</span>
            </div>
        </button>
        <button type="button" onclick="fnShowEmployee(this)" data-type="2"
                class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600"
                id="tabs-with-underline-item-3" data-hs-tab="#tabs-with-underline-2"
                aria-controls="tabs-with-underline-3" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/overrun-employees-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Overrun Employees</span>
                <span class="text-2xl font-extrabold block text-left">@Model.EmployeeOverrun</span>
            </div>
        </button>
        <button type="button" onclick="fnShowEmployee(this)" data-type="3"
                class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600"
                id="tabs-with-underline-item-4" data-hs-tab="#tabs-with-underline-2"
                aria-controls="tabs-with-underline-3" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/onbench-employees-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">On Bench Employees</span>
                <span class="text-2xl font-extrabold block text-left">@Model.EmployeeOnbench</span>
            </div>
        </button>
        <button type="button" onclick="fnShowEmployee(this)" data-type="4"
                class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600"
                id="tabs-with-underline-item-5" data-hs-tab="#tabs-with-underline-2"
                aria-controls="tabs-with-underline-3" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/deployed-employees-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Deployed Employees</span>
                <span class="text-2xl font-extrabold block text-left">@Model.EmployeeDeployed</span>
            </div>
        </button>
    </nav>
</div>

<div class="mt-3 bg-white">
    <div id="tabs-with-underline-1" role="tabpanel" aria-labelledby="tabs-with-underline-item-1">
        <div class="status-bar flex gap-5 items-center overflow-x-auto p-2 flex-wrap">
            <div class="info flex-1 flex items-center gap-3  2xl:gap-5 flex-wrap">
                <a class="" asp-action="Index" asp-controller="Project">
                    <span class="font-bold text-gray-700 text-base 2xl:text-2xl">Total Projects :</span>
                    <span class="font-black text-gray-700 text-base 2xl:text-2xl">@ViewBag.TotalProjects</span>
                </a>
                <div class="hidden md:flex items-center gap-2">
                    <img class="h-5 w-auto max-w-6" src="~/assets/images/completed-icon.svg" alt="Project status icon">
                    <span class="text-base font-semibold whitespace-nowrap">Completed Projects</span>
                    <span class="text-base font-bold">@ViewBag.Completedcount</span>
                </div>
                
                <div class="hidden md:flex items-center gap-2">
                    <img class="h-5 w-auto max-w-6" src="~/assets/images/progress-icon.svg" alt="Project status icon">
                    <span class="text-base font-semibold whitespace-nowrap">In Progress</span>
                    <span class="text-base font-bold" id="lblInProgressProjects">0</span>
                </div>
               
                <div class="hidden md:flex items-center gap-2">
                    <img class="h-5 w-auto max-w-6" src="~/assets/images/draft.svg" alt="Project status icon">
                    <span class="text-base font-semibold whitespace-nowrap">Draft</span>
                    <span class="text-base font-bold" id="lblDraftProjects">0</span>
                </div>

            </div>
            <div class="flex gap-5">
                @if (lPWritePermit)
                {
                    <p-link text="New Project" action="Create" controller="Project" isbutton="false"></p-link>
                }
            </div>
        </div>
        <div class="flex flex-col">
            <div class="-m-1.5 overflow-x-auto">
                <div class="p-1.5 min-w-full block align-middle">
                    <div class="overflow-hidden">
                        <table id="tblProject" class="last-column-fixed min-w-full divide-y divide-gray-200">
                            <thead>
                                <tr>
                                    @foreach (var col in pColLists)
                                    {
                                        <th scope="col"
                                            class="whitespace-nowrap px-2 py-3 text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                            @col
                                            @if (col != "Edit" && col != "Detailed View" && col != "Project Name")
                                            {
                                                <div style="vertical-align: middle;" class="filter-dropdown mx-1 hs-dropdown relative sm:inline-flex z-20 [--auto-close:inside]">
                                                    <button id="hs-dropdown-auto-close-inside" type="button" class="hs-dropdown-toggle p-1 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-gray-100 text-gray-800 shadow-sm disabled:opacity-50 disabled:pointer-events-none">
                                                        <svg class="w-4 h-4 text-gray-800" xmlns="http://www.w3.org/2000/svg"
                                                             width="512" height="512" viewBox="0 0 512 512">
                                                            <path fill="currentColor"
                                                                  d="M472 168H40a24 24 0 0 1 0-48h432a24 24 0 0 1 0 48m-80 112H120a24 24 0 0 1 0-48h272a24 24 0 0 1 0 48m-96 112h-80a24 24 0 0 1 0-48h80a24 24 0 0 1 0 48" />
                                                        </svg>
                                                    </button>

                                                    <div class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden mt-2 bg-white shadow-md rounded-lg p-2 mt-2" aria-labelledby="hs-dropdown-auto-close-inside">
                                                    <div class="mb-1">
                                                <input type="search" oninput="handleFilterSearch(this);" placeholder="Search" class="py-2 px-4 block w-full border-gray-200 rounded-lg text-xs focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                            </div>    
                                                    <div class="filter-item-list" style="height: 10rem; overflow-y: auto;"></div>

                                                    </div>
                                                </div>
                                            }
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200" id="tblProjectBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="tabs-with-underline-2" class="hidden" role="tabpanel" aria-labelledby="tabs-with-underline-item-2">
        
        <div class="flex flex-col">
            <div class="-m-1.5 overflow-x-auto">
                <div class="p-1.5 min-w-full block align-middle">
                    <div class="overflow-hidden" style="overflow:scroll">
                        <table id="tblEmployee" class="last-column-fixed min-w-full divide-y divide-gray-200">
                            <thead>
                                <tr>
                                    @foreach (var col in eColLists)
                                    {
                                        <th scope="col"
                                            class="whitespace-nowrap px-2 py-3 text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                            @col
                                            @if (col != "Edit" && col != "Detailed View" && col != "Project Name")
                                            {
                                                <div style="vertical-align: middle;" class="filter-dropdown mx-1 hs-dropdown relative sm:inline-flex z-20 [--auto-close:inside]">
                                                    <button id="hs-dropdown-auto-close-inside" type="button" class="hs-dropdown-toggle p-1 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-gray-100 text-gray-800 shadow-sm disabled:opacity-50 disabled:pointer-events-none">
                                                        <svg class="w-4 h-4 text-gray-800" xmlns="http://www.w3.org/2000/svg"
                                                             width="512" height="512" viewBox="0 0 512 512">
                                                            <path fill="currentColor"
                                                                  d="M472 168H40a24 24 0 0 1 0-48h432a24 24 0 0 1 0 48m-80 112H120a24 24 0 0 1 0-48h272a24 24 0 0 1 0 48m-96 112h-80a24 24 0 0 1 0-48h80a24 24 0 0 1 0 48" />
                                                        </svg>
                                                    </button>

                                                    <div class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden mt-2 bg-white shadow-md rounded-lg p-2 mt-2" aria-labelledby="hs-dropdown-auto-close-inside">
                                                        <div class="mb-1">
                                                            <input type="search" oninput="handleFilterSearch(this);" placeholder="Search" class="py-2 px-4 block w-full border-gray-200 rounded-lg text-xs focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                                        </div>
                                                        <div class="filter-item-list" style="height: 10rem; overflow-y: auto;"></div>

                                                    </div>
                                                </div>
                                            }
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200" id="tblEmployeeBody"></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts{
    <script type="text/javascript">
        //let datatable = new DataTable("#tblProject", {scrollX: true});
        //var dtemployee = new DataTable("#tblEmployee", { scrollX: true });

        window.addEventListener("dtResize", () => {
            projectDatatable?.columns?.adjust();
            empDatatable?.columns?.adjust();
        });

        $(document).ready(function(){
            fnShowProject();
        });

        function formatDate(str) {
            const date = new Date(str);
            return `${date.getDate() < 10 ? '0' + date.getDate() : date.getDate()}-${date.getMonth() + 1}-${date.getFullYear()}`;
        }

        function formatCurrency(str) {

        }
        let projectDatatable;
        function fnShowProject(){
            document.querySelector("#loader").style.display = "flex";
            setTimeout(() => {
                $("#lblTotalProjects").html("0");
                $("#lblCompletedProjects").html("0");
                $("#lblPendingProjects").html("0");
                $("#lblInProgressProjects").html("0");
                $("#lblOnHoldProjects").html("0");
                $("#lblDraftProjects").html("0");
                $("#tblProjectBody").empty();

                //datatable.destroy();
                if ($.fn.DataTable.isDataTable("#tblProject")) {
                    $('#tblProject').DataTable().clear().destroy();
                }


                // $("#loader").show();

                $.ajax({
                    async: false,
                    url: "@Url.Action("GetProjectInfo", "Home")",
                    type: "POST",
                    cache: false,
                    contentType: false,
                    processData: false,
                    success: function (res) {
                        var result = res.projects;
                        var _htmlBody = '';
                        for (i = 0; i < result.length; i++) {
                            _htmlBody += '<tr>';
                            _htmlBody += '    <td class="px-2 py-4 text-sm font-medium text-gray-800 "><p style="max-width: 200px;">' + result[i].projectName + '</p></td>';
                            _htmlBody += '    <td class="px-2 py-4 text-sm text-gray-800 ">' + (result[i].contractStartDate == null ? "" : formatDate(result[i].contractStartDate)) + '</td>';
                            _htmlBody += '    <td class="px-2 py-4 text-sm text-gray-800 "><p style="max-width: 200px;">' + result[i].customerCompanyname + '</p></td>';
                            _htmlBody += '    <td class="px-2 py-4 text-sm text-gray-800 "><p style="max-width: 200px;">' + result[i].ponumber + '</p></td>';
                            _htmlBody += '    <td class="px-2 py-4 text-sm text-gray-800 ">' + (result[i].amount == null ? "" : Intl.NumberFormat().format(result[i].amount)) + '</td>';
                            _htmlBody += '    <td class="px-2 py-4 text-sm text-gray-800 ">' + result[i].practiceName + '</td>';
                            _htmlBody += '    <td class="px-2 py-4 text-sm text-gray-800 ">' + result[i].subPracticeName + '</td>';
                            _htmlBody += '    <td class="px-2 py-4 text-sm text-gray-800 ">' + result[i].projectTypeName + '</td>';
                            _htmlBody += '    <td class="px-2 py-4 text-sm text-gray-800 ">';

                            if (result[i].status == "Progress") {
                                _htmlBody += '<span class="status progress">Progress</span>';
                            } else if (result[i].status == "Completed") {
                                _htmlBody += '<span class="status completed">Completed</span>';
                            } else if (result[i].status == "Pending") {
                                _htmlBody += '<span class="status pending">Pending</span>';
                            } else if (result[i].status == "Hold") {
                                _htmlBody += '<span class="status hold">Hold</span>';
                            } else if (result[i].status == "Expired") {
                                _htmlBody += '<span class="status overrun">Overrun</span>';
                            }
                            else {
                                _htmlBody += '<span class="status" style="background-color: #ddd;--tw-text-opacity: 1;">Draft</span>';
                            }


                            _htmlBody += '    </td>';

                            if (@lPReadPermit.ToString().ToLower() == true) {
                                _htmlBody += '    <td class="px-2 py-4 whitespace-nowrap text-sm text-gray-800 ">';
                                _htmlBody += '        <a class="text-gray-800 hover:text-blue-700 underline" href="/Project/View?id=' + result[i].projectId + '">View All Details</a>';
                                _htmlBody += '    </td>';
                            }

                            if (@lPWritePermit.ToString().ToLower() == true) {
                                _htmlBody += '    <td class="px-2 py-4 whitespace-nowrap text-sm font-medium">';
                                _htmlBody += '        <a href="/Project/Create?projectid=' + result[i].projectId + '"';
                                _htmlBody += '                class="inline-flex flex-shrink-0 justify-center items-center gap-2 h-6 w-6 rounded-md border border-transparent font-medium bg-white text-gray-700 shadow-sm align-middle hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-white transition-all text-xs"';
                                _htmlBody += '                href="#">';
                                _htmlBody += '            <svg class="w-5 h-5 text-gray-800 hover:text-emerald-500"';
                                _htmlBody += '                    xmlns="http://www.w3.org/2000/svg" width="24" height="24"';
                                _htmlBody += '                    viewBox="0 0 24 24">';
                                _htmlBody += '                <g fill="none">';
                                _htmlBody += '                    <path d="M24 0v24H0V0h24ZM12.593 23.258l-.011.002l-.071.035l-.02.004l-.014-.004l-.071-.035c-.01-.004-.019-.001-.024.005l-.004.01l-.017.428l.005.02l.01.013l.104.074l.015.004l.012-.004l.104-.074l.012-.016l.004-.017l-.017-.427c-.002-.01-.009-.017-.017-.018Zm.265-.113l-.013.002l-.185.093l-.01.01l-.003.011l.018.43l.005.012l.008.007l.201.093c.012.004.023 0 .029-.008l.004-.014l-.034-.614c-.003-.012-.01-.02-.02-.022Zm-.715.002a.023.023 0 0 0-.027.006l-.006.014l-.034.614c0 .012.007.02.017.024l.015-.002l.201-.093l.01-.008l.004-.011l.017-.43l-.003-.012l-.01-.01l-.184-.092Z" />';
                                _htmlBody += '                    <path fill="currentColor"';
                                _htmlBody += '                            d="M13 3a1 1 0 0 1 .117 1.993L13 5H5v14h14v-8a1 1 0 0 1 1.993-.117L21 11v8a2 2 0 0 1-1.85 1.995L19 21H5a2 2 0 0 1-1.995-1.85L3 19V5a2 2 0 0 1 1.85-1.995L5 3h8Zm6.243.343a1 1 0 0 1 1.497 1.32l-.083.095l-9.9 9.899a1 1 0 0 1-1.497-1.32l.083-.094l9.9-9.9Z" />';
                                _htmlBody += '                </g>';
                                _htmlBody += '            </svg>';
                                _htmlBody += '        </a>';
                                _htmlBody += '    </td>';
                            }

                            _htmlBody += '</tr>';
                        }

                        var _totalProjects = result.length;
                        var _completedProjects = res.completed;
                        var _pendingProjects = res.pending;
                        var _inprogressProjects = res.progress;
                        var _onholdProjects = res.hold;
                        var _draftProjects = res.draft;
                        

                        $("#lblTotalProjects").html(_totalProjects);
                        $("#lblCompletedProjects").html(_completedProjects);
                        $("#lblPendingProjects").html(_pendingProjects);
                        $("#lblInProgressProjects").html(_inprogressProjects);
                        $("#lblOnHoldProjects").html(_onholdProjects);
                        $("#lblDraftProjects").html(_draftProjects);
                        
                        $("#tblProjectBody").html(_htmlBody);

                        setTimeout(function () {

                            projectDatatable = new DataTable("#tblProject", {
                                ordering: false,
                                dom: "lBfrtip",
                                buttons: [
                                    'excel',
                                ],
                                "fnInitComplete": function (oSettings, json) {
                                    document.querySelector("#loader").style.display = "none";
                                    const _dt = this.api();
                                    console.log("initdone")
                                    // $("#loader").hide();
                                    document.querySelector("#loader").style.display = "none";
                                    // docu
                                    const allTh = document.querySelectorAll(".dataTables_scroll:has(#tblProject) .dataTables_scrollHead table thead th");
                                    const allThWithFilter = [];
                                    Array.from(allTh).forEach((item, index) => {
                                        if (item.querySelector(".hs-dropdown")) {
                                            allThWithFilter.push({ item, index });
                                        }
                                    });
                                    console.log(allThWithFilter);
                                    allThWithFilter.forEach(item => {
                                        // console.log(Number(item.index));
                                        const column = _dt.columns(Number(item.index)).data().unique().sort();
                                        console.log(column);
                                        // const column = document.querySelectorAll(`td:nth-child(${item.index + 1})`);
                                        const uniqueColumnContentSet = new Set();

                                        column[0].forEach(colItem => {
                                            if (colItem.includes("hs-dropdown")) {
                                                const tempElem = document.createElement("div");
                                                tempElem.innerHTML = colItem;
                                                uniqueColumnContentSet.add(tempElem.querySelector("button span").innerText);
                                            } else if (colItem.includes("span") || colItem.includes("</p>")) {
                                                const tempElem = document.createElement("div");
                                                tempElem.innerHTML = colItem;
                                                uniqueColumnContentSet.add(tempElem.innerText.trim());
                                            } else {
                                                uniqueColumnContentSet.add(colItem.trim());
                                            }
                                        });

                                        // console.log(uniqueColumnContent);
                                        const uniqueColumnContent = Array.from(uniqueColumnContentSet).sort();

                                        const dropdownBody = item?.item.querySelector(".hs-dropdown-menu .filter-item-list");
                                        dropdownBody.innerHTML = "";
                                        console.log(dropdownBody);
                                        uniqueColumnContent.forEach(dItem => {
                                            const dropdownItem = document.createElement("div");
                                            dropdownItem.classList.add("relative", "flex", "items-start", "py-2", "px-3", "rounded-lg", "hover:bg-gray-100","filter-item");
                                            let checkBoxId = `chk-${Math.floor(Math.random() * 9999999)}`;
                                            dropdownItem.innerHTML = `<div class="flex items-center">
                                                                                        <input value="${dItem}" id="${checkBoxId}" type="checkbox" class="shrink-0 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                                                                    </div>
                                                                                    <label for="${checkBoxId}" class="flex-1 ms-2">
                                                                                        <span class="block text-xs text-gray-800">${dItem}</span>
                                                                                    </label>`;
                                            dropdownBody.appendChild(dropdownItem);
                                        })
                                        if (!dropdownBody.nextElementSibling) {
                                            dropdownBody.parentElement.innerHTML += `<div class="flex gap-2"><button onclick="clearFilterP(this, ${item?.index});" class="flex mt-2 w-full items-center justify-center gap-x-3.5 py-2 px-3 rounded-lg text-xs text-gray-800 bg-gray-100 hover:bg-gray-50 focus:outline-none focus:bg-gray-100">Clear</button><button onclick="filterTableP(this, ${item?.index});" class="flex mt-2 w-full items-center justify-center gap-x-3.5 py-2 px-3 rounded-lg text-xs text-gray-800 bg-gray-100 hover:bg-gray-50 focus:outline-none focus:bg-gray-100" href="#">Apply</button></div>`
                                        }
                                    })
                                },
                                destroy: true,
                                scrollX: true,
