        function getCurrentMonthStr() {
            const _currentDate = new Date();
            return _currentDate.toLocaleString('default', { month: 'short' }) + "-" + String(_currentDate.getFullYear()).match(/.{1,2}/g)[1];
        }

        function handleFilterSearch(input) {
            const allFilterItems = input.closest(".hs-dropdown-menu").querySelector(".filter-item-list").querySelectorAll("span");
            allFilterItems.forEach(item => {
                if (item.innerText.trim().toLowerCase().includes(input.value.trim().toLowerCase())) {
                    item.closest(".filter-item").style.display = "flex"
                } else {
                    item.closest(".filter-item").style.display = "none";
                }
            })
        }

        function toggleInnerActive(btn) {
            document.querySelector(".innerTab.active").classList.remove("active");
            btn.classList.add("active");

            fnShowEmployee(document.querySelector("#tabs-with-underline-item-4"))
        }
    </script>
}