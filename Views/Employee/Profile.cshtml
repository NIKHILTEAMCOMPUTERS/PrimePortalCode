@model RMS.Client.Models.Employee.Profile
@section PageStyles {
    <style>
        .ss-main.multi-select {
            min-width: 18rem;
        }

        .skill-remove {
            top: 0;
            right: 0;
            opacity: 0;
            pointer-events: none;
            background-color: white;
            padding-left: .5rem;
            transform: scale(0);
            transition: all .125s ease;
            transform-origin: top right;
        }

        .skill-card:hover .skill-remove {
            opacity: 1;
            pointer-events: all;
            transform: scale(1)
        }

        .secondary-skills-wrapper.selfOnly .managerRating {
            display: none;
        }

        .secondary-skills-wrapper.selfOnly .selfRating {
            display: inline-flex;
        }

        .secondary-skills-wrapper.managerOnly .managerRating {
            display: inline-flex;
        }

        .secondary-skills-wrapper.managerOnly .selfRating {
            display: none;
        }
    </style>
}
@{
    var colList = new List<string> { "Contract Start Date", "Contract End Date", "Practice", "Sub-Practice", "Project Type", "Customer", "Delivery Anchor", "Status", "Action" };
    var employeeid = ViewBag.Employeeid;
    var role = Context.Session.GetString("RoleName");
}
<input type="hidden" value="@employeeid" id="hiddenEmployeeId"/>
<div class="flex items-center gap-4 mb-4">
    <button onclick="window.history.back();" class="py-2 px-2 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base" title="Back">
        <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M11.707 5.293a1 1 0 0 1 0 1.414L7.414 11H19a1 1 0 1 1 0 2H7.414l4.293 4.293a1 1 0 0 1-1.414 1.414l-6-6a1 1 0 0 1 0-1.414l6-6a1 1 0 0 1 1.414 0z" /></svg>
    </button>
    <div>
        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Employee Profile</h2>
    </div>
</div>
<div class="bg-[#f9f9f9] p-4 rounded">
    <div class="flex gap-4 flex-wrap items-center mb-4">
        <div class="bg-white rounded p-4 flex gap-4 items-center">
            <div class="relative w-20 h-20 rounded-full">
                @* <form id="profilePictureUpdateForm">
                    <label for="profile-input" class="w-6 h-6 rounded-full bg-slate-600 absolute left-0 top-0 flex">
                        <input type="file" name="profile" id="profile-input" class="hidden" onchange="handleProfileChange(this);">
                        <svg class="w-4 h-4 text-white m-auto" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 21h18M12.222 5.828L15.05 3L20 7.95l-2.828 2.828m-4.95-4.95l-5.607 5.607a1 1 0 0 0-.293.707v4.536h4.536a1 1 0 0 0 .707-.293l5.607-5.607m-4.95-4.95l4.95 4.95" /></svg>
                    </label>
                </form> *@
                <img class="w-full h-full object-cover" src="~/assets/images/default_user_icon.png" alt="User Profile">
            </div>
            <div>
                @{
                    var name = Model.Employeename.Split(' ');
                }

                <p class="font-bold text-xl">@name[0]</p>
                <p class="font-bold text-xl">@name[1]</p>
            </div>
        </div>
        <div>
            <div class="flex items-center gap-x-6 2xl:gap-x-8 gap-y-4 flex-wrap">
                <p class="whitespace-nowrap">Designation: <span class="font-bold">@Model.DesignationName</span></p>
                <p class="whitespace-nowrap">TMC: <span class="font-bold">@Model.Userid</span></p>
                <p class="whitespace-nowrap">Date of joining: <span class="font-bold">@Model.Dateofjoining</span></p>
                <p class="whitespace-nowrap">Department: <span class="font-bold">@Model.DepartmentName</span></p>
                <p class="whitespace-nowrap">Location: <span class="font-bold">@Model.BranchName</span></p>
                <p class="whitespace-nowrap">Reporting Manager: <span class="font-bold">@Model.ReportheadName</span></p>
            </div>
            @* <div class="mt-4">
                <div class="inline-flex bg-white rounded shadow py-3 px-6">
                    <input type="checkbox" class="shrink-0 mt-0.5 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="resigned-flag">
                    <label for="resigned-flag" class="text-sm text-gray-500 ms-3">Resigned</label>
                </div>
            </div> *@
        </div>
    </div>
    @* <div class="flex flex-wrap items-start justify-between gap-x-4 gap-y-8 mb-6">
        <div>
            <div class="flex items-center gap-4 mb-4">
                <img src="~/assets/images/default_user_icon.png" alt="" class="w-16 h-16 2xl:w-20 2xl:h-20 rounded-full object-cover">

                <div>
                    <h2 class="font-extrabold text-lg 2xl:text-2xl text-[#4B4E5C]">@Model.EmployeeName</h2>
                    <h2 class="font-extrabold text-base 2xl:text-xl text-[#4B4E5C]">TMC: @Model.UserId</h2>
                </div>
            </div>

        </div>
        <div>
            <p>Date of Joining: @Model.DateOfJoining</p>
            <p>Department: @Model.DepartmentName</p>
            <p>Location: @Model.BranchName</p>
            <p>Phone: @Model.ContactNo</p>
        </div>
        <div>
            <p>Email Id: @Model.CompanyEmail</p>
            <p>DOB: @Model.DateOfBirth</p>
        </div>
    </div> *@
    <h2 class="font-extrabold text-xl text-[#4B4E5C]">Assigned Roles</h2>
    <div class="roles-wrapper flex items-center gap-2 flex-wrap mt-2">
        @if (Model.EmployeeRoles != null)
        {
            foreach (var rolename in Model.EmployeeRoles) {
                <span class="px-4 py-2 text-xs bg-white rounded-full border">@rolename.Rolename</span>
            }
        }
    </div>

    <div class="flex flex-col sm:flex-row items-center flex-wrap gap-4 mt-4">
        <div class="bg-white rounded p-4 col-span-3 flex-[4] w-full">
            <p class="font-bold mb-2">Contact Details</p>
            <div class="flex items-center gap-4 flex-wrap">
                <div>
                    <p class="text-sm">Phone:</p>
                    <p class="font-bold">@Model.Contactno</p>
                </div>
                <div>
                    <p class="text-sm">Email Id:</p>
                    <p class="font-bold">@Model.Companyemail</p>
                </div>
                <div>
                    <p class="text-sm">Date Of Birth:</p>
                    <p class="font-bold">@Model.Dateofbirth</p>
                </div>
            </div>
        </div>
        @* <div class="bg-white rounded p-4 col-span-2 flex-[3] w-full">
            <p class="font-bold mb-2">Demography</p>
            
        </div> *@
        <div class="bg-white rounded p-4 col-span-1 flex-[2] w-full">
            <p class="font-bold mb-2">Experience</p>
            <div class="flex items-center gap-4 flex-wrap">
                <div>
                    <p class="text-sm">Total Experience:</p>
                    <p class="font-bold">
                        @{
                            try
                            {
                                int totalDays = Convert.ToInt32(Model.pastworkexperience) + Convert.ToInt32(Model.teamworkexperience);
                                int totalYears = totalDays / 365;
                                int totalMonths = (totalDays % 365) / 30;
                                int totalRemainingDays = (totalDays % 365) % 30;
                                @($"{totalYears} Y {totalMonths} M {totalRemainingDays} D")
                                ;
                            }
                            catch (Exception)
                            {
                                @("N/A")
                                // Display a default message in case of an error
                            }
                        }
                    </p>
                </div>
                <div>
                    <p class="text-sm">Past Experience:</p>
                    <p class="font-bold">
                        @{
                            try
                            {
                                int pastDays = Convert.ToInt32(Model.pastworkexperience);
                                int pastYears = pastDays / 365;
                                int pastMonths = (pastDays % 365) / 30;
                                int pastRemainingDays = (pastDays % 365) % 30;
                                @($"{pastYears} Y {pastMonths} M {pastRemainingDays} D")
                                ;
                            }
                            catch (Exception)
                            {
                                @("N/A")
                                // Default message in case of an error
                            }
                        }
                    </p>
                </div>
                <div>
                    <p class="text-sm">Team Computer Experience:</p>
                    <p class="font-bold">
                        @{
                            try
                            {
                                int teamDays = Convert.ToInt32(Model.teamworkexperience);
                                int teamYears = teamDays / 365;
                                int teamMonths = (teamDays % 365) / 30;
                                int teamRemainingDays = (teamDays % 365) % 30;
                                @($"{teamYears} Y {teamMonths} M {teamRemainingDays} D")
                                ;
                            }
                            catch (Exception)
                            {
                                @("N/A")
                                // Default message in case of an error
                            }
                        }
                    </p>
                </div>
            </div>
        </div>


    </div>
</div>




<div class="mt-4">
    <nav class="flex space-x-2" aria-label="Tabs" role="tablist">
                <button type="button"
                class="hs-tab-active:bg-gray-800 bg-gray-200 hs-tab-active:text-white py-2 px-5 inline-flex items-center gap-2 text-sm font-medium text-center text-gray-500 rounded-lg hover:text-emerald-400 active"
                id="skills-tab" data-hs-tab="#skills-tab-content"
                aria-controls="pills-on-gray-color-1" role="tab">
            Skills
        </button>
    </nav>


    <div class="mt-3">
        

        <div id="skills-tab-content" role="tabpanel" aria-labelledby="skills-tab-content">
            <!-- <div class="mb-4 mt-4">
                <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Skills</h2>
                <p>Add Or Update Skills</p>
            </div> -->
            <div class="flex flex-col sm:flex-row items-start gap-y-4 gap-x-8 mt-4">
                <div class="order-2 sm:order-1">
                    <div class="flex items-center gap-2 mb-4 sm:mb-6">
                        <h2 class="font-extrabold text-xl text-[#4B4E5C]">Primary Skills</h2>
                        @* @if (Model?.PrimarySkill != null)
                        {
                            <button onclick="handlePrimarySkillEdit();">
                                <svg class="w-6 h-6 text-slate-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                                    <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                                        <path d="m16.475 5.408l2.117 2.117m-.756-3.982L12.109 9.27a2.118 2.118 0 0 0-.58 1.082L11 13l2.648-.53c.41-.082.786-.283 1.082-.579l5.727-5.727a1.853 1.853 0 1 0-2.621-2.621" />
                                        <path d="M19 15v3a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h3" />
                                    </g>
                                </svg>
                            </button>
                        } *@
                    </div>
                    <div>
                        @if (Model?.PrimarySkill != null)
                        {
                            <p class="font-semibold mb-1">@Model?.PrimarySkill?.SkillName</p>
                            <p class="mb-1">Exp: @(Model?.PrimarySkill?.Experinceinmonth.HasValue == true ? ((double)Model.PrimarySkill.Experinceinmonth.Value / 12.0).ToString("0.##") : "N/A") years</p>
                                <p class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-slate-100 text-sm">
                                <svg class="w-5 h-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                                    <path fill="currentColor" d="m5.825 22l1.625-7.025L2 10.25l7.2-.625L12 3l2.8 6.625l7.2.625l-5.45 4.725L18.175 22L12 18.275z" />
                                </svg>
                                @{
                                    decimal? rating = Model?.PrimarySkill?.ManagerRating != null ? Model?.PrimarySkill?.ManagerRating : 0;
                                }

                                @rating /5
                            </p>
                        }
                        else
                        {
                            @if (role != "Employee") {
                                <button onclick="handlePrimarySkillEdit();" class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-transparent bg-[#00cc83] text-white hover:bg-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm 2xl:text-base">
                                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 32 32">
                                        <path fill="currentColor" d="M16 2A14.172 14.172 0 0 0 2 16a14.172 14.172 0 0 0 14 14a14.172 14.172 0 0 0 14-14A14.172 14.172 0 0 0 16 2Zm8 15h-7v7h-2v-7H8v-2h7V8h2v7h7Z"></path>
                                        <path fill="none" d="M24 17h-7v7h-2v-7H8v-2h7V8h2v7h7v2z"></path>
                                    </svg>
                                    Add Primary Skill
                                </button>
                            }
                        }
                    </div>
                </div>
                <div class="flex-1 order-3 sm:order-2">
                    <div class="flex items-center gap-2 mb-4 sm:mb-6">
                        <h2 class="font-extrabold text-xl text-[#4B4E5C]">Secondary Skills</h2>
                        @if (Model?.SecondarySkill != null && Model?.SecondarySkill.Count > 0)
                        {
                            <button onclick="handleSecondarySkillEdit();">
                                <svg class="w-6 h-6 text-slate-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                                    <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                                        <path d="m16.475 5.408l2.117 2.117m-.756-3.982L12.109 9.27a2.118 2.118 0 0 0-.58 1.082L11 13l2.648-.53c.41-.082.786-.283 1.082-.579l5.727-5.727a1.853 1.853 0 1 0-2.621-2.621" />
                                        <path d="M19 15v3a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h3" />
                                    </g>
                                </svg>
                            </button>
                        }
                    </div>
                    <div class="secondary-skills-wrapper flex items-center gap-4 flex-wrap selfOnly">
                        @if (Model?.SecondarySkill != null && Model?.SecondarySkill.Count > 0)
                        {
                            foreach (var skill in Model?.SecondarySkill)
                            {
                                <div class="relative skill-card">
                                    <p class="font-semibold mb-1">@skill.SkillName</p>
                                    <p class="mb-1">Exp: @(((double)(skill.Experinceinmonth ?? 0) / 12.0).ToString("0.##")) years</p>

                                    <p class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-slate-100 text-sm managerRating">
                                        <svg class="w-5 h-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                                            <path fill="currentColor" d="m5.825 22l1.625-7.025L2 10.25l7.2-.625L12 3l2.8 6.625l7.2.625l-5.45 4.725L18.175 22L12 18.275z" />
                                        </svg>

                                        @{
                                            decimal? mratings = skill.ManagerRating != null ? skill.ManagerRating : 0;
                                        }
                                        @mratings /5
                                    </p>
                                    <p class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-emerald-100 text-sm selfRating">
                                        <svg class="w-5 h-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                                            <path fill="currentColor" d="m5.825 22l1.625-7.025L2 10.25l7.2-.625L12 3l2.8 6.625l7.2.625l-5.45 4.725L18.175 22L12 18.275z" />
                                        </svg>

                                        @{
                                            decimal? sratings = skill.SelfRating != null ? skill.SelfRating : 0;
                                        }
                                        @sratings /5
                                    </p>
                                    <div class="absolute skill-remove" onclick="removeSkill(this)" data-employeeskillid="@skill.EmployeeskillId">
                                        <button>
                                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 1024 1024"><path fill="#ff5252" d="M512 64a448 448 0 1 1 0 896a448 448 0 0 1 0-896M288 512a38.4 38.4 0 0 0 38.4 38.4h371.2a38.4 38.4 0 0 0 0-76.8H326.4A38.4 38.4 0 0 0 288 512" /></svg>
                                        </button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <button onclick="handleSecondarySkillEdit();" class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-transparent bg-gray-700 text-white hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 transition-all text-sm 2xl:text-base">
                                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 32 32">
                                    <path fill="currentColor" d="M16 2A14.172 14.172 0 0 0 2 16a14.172 14.172 0 0 0 14 14a14.172 14.172 0 0 0 14-14A14.172 14.172 0 0 0 16 2Zm8 15h-7v7h-2v-7H8v-2h7V8h2v7h7Z"></path>
                                    <path fill="none" d="M24 17h-7v7h-2v-7H8v-2h7V8h2v7h7v2z"></path>
                                </svg>
                                Add Secondary Skill
                            </button>
                        }

                    </div>
                </div>
                <div class="flex items-center gap-4 order-1 sm:order-3 ">
                    <p class="font-extrabold text-xl text-[#4B4E5C]">Rating</p>
                    <select name="" id="" class="k-input min-w-[10rem]" onchange="switchRating(this);">
                        <option value="1">Self</option>
                        <option value="2">Manager</option>
                    </select>
                </div>
            </div>
        </div>

    </div>
</div>


<div id="add-skill-modal"
     class="hs-overlay hidden w-full h-full fixed top-0 left-0 z-[60] overflow-x-hidden overflow-y-auto">
    <div class="hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:duration-500 mt-0 opacity-0 ease-out transition-all md:max-w-4xl md:w-full m-3 md:mx-auto">
        <div class="flex flex-col bg-white border shadow-sm rounded-xl ">
            <div class="flex justify-between items-center py-3 px-4 ">
                <div>
                    <h3 class="font-bold text-xl">Add Secondary Skills</h3>
                    <p>Edit or view skill details</p>
                </div>
                <button type="button"
                        class="hs-dropdown-toggle inline-flex flex-shrink-0 justify-center items-center h-8 w-8 rounded-md text-gray-500 hover:text-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 focus:ring-offset-white transition-all text-sm"
                        data-hs-overlay="#add-skill-modal">
