@section Scripts{
    <script type="text/javascript">
        const secondarySkills = @Html.Raw(Json.Serialize(Model?.SecondarySkill)) || [];
        const primarySkill = [@Html.Raw(Json.Serialize(Model.PrimarySkill))];
        // const primarySkill = [];

        const skillList = @Html.Raw(Json.Serialize(ViewBag.skilllist));

        @if (ViewData["error"] != null)
        {
            <text>
                toastr.error("@ViewData["error"]", "Error", { "iconClass": 'new-error' });
            </text>
        }
        @if (ViewData["success"] != null)
        {
            <text>
                toastr.success("@ViewData["success"]");
            </text>
        }

                                                                                                const datatable = new DataTable("#tblProjects", {
            scrollX: true,
        });

 

        function addSkillRow() {
            const newRow = document.createElement("div");
            // <div class="skill-input-row grid grid-cols-1 sm:grid-cols-3 gap-4">

            //                 </div>
            newRow.classList.add("skill-input-row", "grid", "grid-cols-1", "sm:grid-cols-3", "gap-4", "mb-4");
            newRow.innerHTML = `<div>
                                                                                            <label for="">Skill Name</label>
                                                                                            <select name="" id="" class="k-input w-full" onchange="handleSkillSelect(this);">
                                                                                                <option value="">Select Skill</option>
                                                                                                ${getSkillOptions()}
                                                                                            </select>
                                                                                        </div>
                                                                                        <div>
                                                                                            <label for="">Skill Experience</label>
                                                                                            <input type="number" class="k-input w-full experience" />
                                                                                        </div>
                                                                                        <div>
                                                                                            <label for="">Skill Rating</label>
                                                                                            <div class="flex items-center gap-2">
                                                                                                <input type="number" name="" id="" class="k-input w-full rating" max="5" placeholder="Out of 5">
                                                                                                <button onclick="deleteRow(this);" class="py-3 px-4 inline-flex justify-center items-center gap-2 rounded-md border-2 border-red-200 font-semibold text-red-500 hover:text-white hover:bg-red-500 hover:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 focus:ring-offset-2 transition-all text-sm">
                                                                                                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="1024" height="1024" viewBox="0 0 1024 1024"><path fill="currentColor" d="M360 184h-8c4.4 0 8-3.6 8-8v8h304v-8c0 4.4 3.6 8 8 8h-8v72h72v-80c0-35.3-28.7-64-64-64H352c-35.3 0-64 28.7-64 64v80h72v-72zm504 72H160c-17.7 0-32 14.3-32 32v32c0 4.4 3.6 8 8 8h60.4l24.7 523c1.6 34.1 29.8 61 63.9 61h454c34.2 0 62.3-26.8 63.9-61l24.7-523H888c4.4 0 8-3.6 8-8v-32c0-17.7-14.3-32-32-32zM731.3 840H292.7l-24.2-512h487l-24.2 512z"/></svg>
                                                                                                </button>
                                                                                            </div>
                                                                                        </div>`;
            document.querySelector("#secondary-row-wrapper").appendChild(newRow);
        }

        function deleteRow(btn) {
            btn.closest(".skill-input-row").remove();
        }

        function handlePrimarySkillEdit() {
            setExistingSkillsInModal(primarySkill, "primary");
            HSOverlay.open(document.querySelector("#add-primary-skill-modal"));
        }

        function handleSecondarySkillEdit() {
            setExistingSkillsInModal(secondarySkills, "secondary");
            HSOverlay.open(document.querySelector("#add-skill-modal"));
        }

        function setExistingSkillsInModal(skills, modal) {
            if (!modal || !skills) return;
            if (modal === "primary") {
                setExistingPrimary(skills);
            } else {
                setExistingSecondary(skills);
            }
        }

        function setExistingPrimary(skills) {
            document.querySelector("#primary-row-wrapper").innerHTML = "";
            if (skills.length) {
                skills.forEach(item => {
                    const skillRow = getSkillRow(item?.skillId, item?.experinceinmonths, item?.managerRating, item?.employeeSkillId);
                    document.querySelector("#primary-row-wrapper").appendChild(skillRow);
                })
            } else {
                const skillRow = getSkillRow();
                document.querySelector("#primary-row-wrapper").appendChild(skillRow);
            }
        }

        function setExistingSecondary(skills) {
            // if (!skills.length) return;
            document.querySelector("#secondary-row-wrapper").innerHTML = "";
            if (skills.length) {
                skills.forEach(item => {
                    const skillRow = getSkillRow(item?.skillId, item?.experinceinmonth, item?.selfRating, item?.employeeskillId);
                    document.querySelector("#secondary-row-wrapper").appendChild(skillRow);
                })
            } else {
                const skillRow = getSkillRow();
                document.querySelector("#secondary-row-wrapper").appendChild(skillRow);
            }
        }

        function getSkillRow(skillId = 0, experience = 0, rating = 0, rowId) {
            const row = document.createElement("div");
            row.classList.add("skill-input-row", "grid", "grid-cols-1", "sm:grid-cols-3", "gap-4", "mb-4");
            row.setAttribute("data-rowid", rowId);
            row.setAttribute("id", Date.now());
            row.innerHTML = `<div>
                                                                        <label for="">Skill Name</label>
                                                                        <select name="" id="" class="k-input w-full">
                                                                            <option value="0">Select Skill</option>
                                                                            ${getSkillOptions(skillId)}
                                                                        </select>
                                                                    </div>
                                                                    <div>
                                                                        <label for="">Skill Experience (In Months)</label>
                                                                        <input type="number" class="k-input w-full experience" value="${experience ? experience : ""}" />
                                                                    </div>
                                                                    <div>
                                                                        <label for="">Skill Rating</label>
        <input type="number" name="" id="" class="k-input w-full rating" max="5" placeholder="Out of 5" value="${rating ? rating : ""}"
            oninput="this.value = this.value > 5 ? 5 : (this.value < 0 ? 0 : this.value)">                                                                    </div>`;

            return row;
        }

        function getSkillOptions(skillId = 0) {
            let skillOptionStr = '';
            skillList.forEach(item => {
                skillOptionStr += `<option value="${item?.value}" ${skillId == item?.value ? "selected" : ""}>${item?.text}</option>`;
            })
            return skillOptionStr;
        }


        function handleSkillSubmit(type) {
            if (type === "primary") {
                primarySkillSubmit();
            } else {
                secondarySkillSubmit();
            }
        }

        function validateRows(rows) {
            let flag = true;
            if (!rows || !rows.length) return !flag;

            const skillRowData = {};

            rows.forEach((item, index) => {
                const skillInp = item.querySelector("select");
                const expInp = item.querySelector("input.experience");
                const ratingInp = item.querySelector("input.rating");


                if (!skillInp.value || skillInp.value === '0') {
                    skillInp.classList.add("is-invalid");
                    flag = false;
                } else {
                    skillInp.classList.remove("is-invalid");
                    if (skillRowData[`${skillInp.value}`]) {
                        skillRowData[`${skillInp.value}`] = [...skillRowData[`${skillInp.value}`], { rowInd: index }]
                    } else {
                        skillRowData[`${skillInp.value}`] = [{ rowInd: index }];
                    }
                }

                if (!expInp.value || Number(expInp.value) <= 0) {
                    expInp.classList.add("is-invalid");
                    flag = false;
                } else {
                    expInp.classList.remove("is-invalid");
                }

                if (!ratingInp.value || Number(ratingInp.value) <= 0 || Number(ratingInp.value) > 5) {
                    ratingInp.classList.add("is-invalid");
                    flag = false;
                } else {
                    ratingInp.classList.remove("is-invalid");
                }
            })

            Object.keys(skillRowData).forEach(item => {
                if (skillRowData[`${item}`].length > 1) {
                    flag = false;
                    skillRowData[`${item}`].forEach(r => {
                        rows[r.rowInd].querySelector("select").classList.add("is-invalid");
                    })
                }
            })

            return flag;
        }

        function primarySkillSubmit() {
            const allRows = document.querySelectorAll("#primary-row-wrapper .skill-input-row");
            const isValid = validateRows(allRows);
            if (!isValid) return;
            $('#loader').show();
            const formSkillData = [];
            allRows.forEach(item => {
                const _formSkillDataItem = {
                    Skillid: item.querySelector("select").value,
                    Experinceinmonths: item.querySelector("input.experience").value,
                    Selfreting: item.querySelector("input.rating").value,
                    Employeeid: $("#hiddenEmployeeId").val(),
                    isPrimary: true,
                }
                const rowId = item.getAttribute("data-rowid");
                if (rowId && rowId !== 'undefined') {
                    _formSkillDataItem.employeeSkillId = rowId;
                }
                formSkillData.push(_formSkillDataItem);
            })

            const fdata = new FormData();
            fdata.append("jobject", JSON.stringify(formSkillData));

            $.ajax({
                url: "@Url.Action("UpdateSkill", "Employee")",
                type: "POST",
                cache: false,
                data: fdata,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res);
                    if (res.success == true) {
                        //
                        // HSOverlay.close(document.querySelector("#prov-billing-overlay"));
                        window.location.reload();
                        toastr.success("Primary skills updated")
                    } else {
                        $('#loader').hide();
                        toastr.error(res?.msg);
                    }
                },
                error: function (err) {
                    toastr.error(err);
                }
            });
        }
        function secondarySkillSubmit() {
            const allRows = document.querySelectorAll("#secondary-row-wrapper .skill-input-row");
            const isValid = validateRows(allRows);
            if (!isValid) return;
            $('#loader').show();
            const formSkillData = [];
            allRows.forEach(item => {
                const _formSkillDataItem = {
                    Skillid: item.querySelector("select").value,
                    Experinceinmonths: item.querySelector("input.experience").value,
                    Selfreting: item.querySelector("input.rating").value,
                    Employeeid: $("#hiddenEmployeeId").val(),
                }
                const rowId = item.getAttribute("data-rowid");
                if (rowId && rowId !== 'undefined') {
                    _formSkillDataItem.employeeSkillId = rowId;
                }
                formSkillData.push(_formSkillDataItem);
            })

            const fdata = new FormData();
            fdata.append("jobject", JSON.stringify(formSkillData));

            $.ajax({
                url: "@Url.Action("UpdateSkill", "Employee")",
                type: "POST",
                cache: false,
                data: fdata,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res);
                    if (res.success == true) {
                        //
                        // HSOverlay.close(document.querySelector("#prov-billing-overlay"));
                        window.location.reload();
                        toastr.success("Secondary skills updated ")
                    } else {
                        $('#loader').hide();
                        toastr.error(res?.msg);
                    }
                },
                error: function (err) {
                    toastr.error(err);
                }
            });
        }

        function removeSkill(btn) {
            const employeeSkillId = btn.getAttribute("data-employeeskillid");
            if (employeeSkillId) {
                if (!confirm("Do you really want to delete?")) return;
                const fdata = new FormData();
                fdata.append("employeeskillid", employeeSkillId);
                $.ajax({
                    url: "@Url.Action("DeleteEmployeeSkill", "Employee")",
                    type: "POST",
                    cache: false,
                    data: fdata,
                    contentType: false,
                    processData: false,
                    success: function (res) {
                        debugger;
                        const responseContent = JSON.parse(res.data);
                        console.log(res);
                        if (responseContent?.responseCode === 200) {
                            //
                            // HSOverlay.close(document.querySelector("#prov-billing-overlay"));
                            window.location.reload();
                            toastr.success(responseContent?.responseMessage)
                        } else {
                            $('#loader').hide();
                            toastr.error(res?.msg);
                            window.location.reload();
                        }
                    },
                    error: function (err) {
                        toastr.error(err);
                        window.location.reload();
                    }
                });
            }
        }

        function handleProfileChange() {

        }

        function switchRating(select) {
            if (select.value === "1") {
                document.querySelector(".secondary-skills-wrapper").classList.add("selfOnly")
                document.querySelector(".secondary-skills-wrapper").classList.remove("managerOnly")
            } else {
                document.querySelector(".secondary-skills-wrapper").classList.remove("selfOnly")
                document.querySelector(".secondary-skills-wrapper").classList.add("managerOnly")
            }
        }
    </script>
}