                              fill="currentColor" />
                    </svg>
                </button>
            </div>
            <div class="p-4 overflow-y-auto">
                <div style="min-height: 20rem;">
                    <div class="skill-input-row-wrapper mb-4 max-h-96 overflow-y-auto" id="secondary-row-wrapper">
                        <div class="skill-input-row grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
                            <div>
                                <label for="">Skill Name</label>
                                <select name="" id="" class="k-input w-full">
                                    <option value="">Select Skill</option>
                                </select>
                            </div>
                            <div>
                                <label for="">Skill Experience</label>
                                <select name="" id="" class="k-input w-full">
                                    <option value="">Select Experience</option>
                                </select>
                            </div>
                            <div>
                                <label for="">Skill Rating</label>
                                <input type="number" name="" id="" class="k-input w-full" max="5" placeholder="Out of 5">
                            </div>
                        </div>
                    </div>
                    <div>
                        <button onclick="addSkillRow();" type="button" class="text-white bg-black rounded px-4 py-2 hover:opacity-70">Add</button>
                    </div>
                </div>
                <div class="flex justify-center">
                    <button type="button" onclick="handleSkillSubmit('secondary')"
                            class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                        Submit
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="add-primary-skill-modal"
     class="hs-overlay hidden w-full h-full fixed top-0 left-0 z-[60] overflow-x-hidden overflow-y-auto">
    <div class="hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:duration-500 mt-0 opacity-0 ease-out transition-all md:max-w-4xl md:w-full m-3 md:mx-auto">
        <div class="flex flex-col bg-white border shadow-sm rounded-xl ">
            <div class="flex justify-between items-center py-3 px-4 ">
                <div>
                    <h3 class="font-bold text-xl">Add Primary Skill</h3>
                </div>
                <button type="button"
                        class="hs-dropdown-toggle inline-flex flex-shrink-0 justify-center items-center h-8 w-8 rounded-md text-gray-500 hover:text-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 focus:ring-offset-white transition-all text-sm"
                        data-hs-overlay="#add-primary-skill-modal">
