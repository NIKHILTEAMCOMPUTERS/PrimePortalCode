                <div style="min-height: 10rem;">
                    <div class="skill-input-row-wrapper mb-4 max-h-96 overflow-y-auto" id="primary-row-wrapper">
                        <div class="skill-input-row grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
                            <div>
                                <label for="">Skill Name</label>
                                <select name="" id="" class="k-input w-full">
                                    <option value="">Select Skill</option>
                                </select>
                            </div>
                            <div>
                                <label for="">Skill Experience</label>
                                <select name="" id="" class="k-input w-full">
                                    <option value="">Select Experience</option>
                                </select>
                            </div>
                            <div>
                                <label for="">Skill Rating</label>
                                <input type="number" name="" id="" class="k-input w-full" max="5" placeholder="Out of 5">
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flex justify-center">
                    <button type="button" onclick="handleSkillSubmit('primary')"
                            class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                        Submit
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>



