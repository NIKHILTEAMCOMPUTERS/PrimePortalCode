@model IEnumerable<RMS.Client.Models.Employee.Employeedashboard>
@{
    ViewData["Title"] = "Dashboard - ";
}
<div class="flex items-center gap-4 justify-between flex-wrap bg-[#fafafa] rounded p-4 mb-4">
    <div>
        <p class="font-extrabold text-2xl text-gray-600">Welcome! @ViewBag.name</p>
        <p>Get All the Updates of your current & Past projects</p>
    </div>
    <div class="overflow-x-auto">
        <nav class="flex space-x-2" aria-label="Tabs" role="tablist">
            <div class="py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600 active">
                <img class="h-4 w-auto" src="./assets/images/total-projects-icon.svg" alt="">
                <div>
                    <span class="text-base font-semibold block text-left">Total Projects</span>
                    <span class="text-2xl font-extrabold block text-left">@Model.Count()</span>
                </div>
            </div>
            <div class="py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600">
                <img class="h-4 w-auto" src="./assets/images/total-projects-icon.svg" alt="">
                <div>
                    <span class="text-base font-semibold block text-left">Active Projects</span>
                    <span class="text-2xl font-extrabold block text-left">@Model.Where(a => a.CategorySubStatusName == "Deployed" || a.CategorySubStatusName == "Allocation" || a.CategorySubStatusName == "Shadow" || a.CategorySubStatusName == "Projection").Count()</span>
                </div>
            </div>
            <div class="py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600">
                <img class="h-4 w-auto" src="./assets/images/total-projects-icon.svg" alt="">
                <div>
                    <span class="text-base font-semibold block text-left">Past Projects</span>
                    <span class="text-2xl font-extrabold block text-left">@Model.Where(a => a.CategorySubStatusName == "Bench" || a.CategorySubStatusName == "Released").Count()</span>
                </div>
            </div>
            <div class="py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600">
                <img class="h-4 w-auto" src="./assets/images/overrun-employees-icon.svg" alt="">
                <div>
                    <span class="text-base font-semibold block text-left">Current Status</span>
                    <span class="status deployed" style="font-weight: bold;">@ViewBag.employeestatus</span>
                </div>
            </div>
        </nav>
    </div>
</div>

<label for="projects" class="project-switch-wrapper">
    <input type="checkbox" name="" id="projects" class="hidden" onchange="handleProjectTypeChange(this);">
    <div class="project-switch inline-grid grid-cols-2 items-center bg-gray-500 rounded-full relative">
        <span class="whitespace-nowrap py-2 px-4 text-white text-center">Current Projects</span>
        <span class="whitespace-nowrap py-2 px-4 text-white text-center">Past Projects</span>
    </div>
</label>

