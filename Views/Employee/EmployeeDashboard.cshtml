        }

        function handleFilterSearch(input) {
            const allFilterItems = input.closest(".hs-dropdown-menu").querySelector(".filter-item-list").querySelectorAll("span");
            allFilterItems.forEach(item => {
                if (item.innerText.trim().toLowerCase().includes(input.value.trim().toLowerCase())) {
                    item.closest(".filter-item").style.display = "flex"
                } else {
                    item.closest(".filter-item").style.display = "none";
                }
            })
        }

        function handleProjectTypeChange(inp) {
            const currentProjectsDiv = document.querySelector(".currentProjects");
            const pastProjectsDiv = document.querySelector(".pastProjects");

            if (inp.checked) {
                currentProjectsDiv.classList.add("hidden");
                pastProjectsDiv.classList.remove("hidden");
                datatable2.columns.adjust();
            } else {
                currentProjectsDiv.classList.remove("hidden");
