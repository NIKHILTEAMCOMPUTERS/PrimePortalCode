                            @if (Model != null)
                            {
                                if (Model.Count() > 0)
                                {
                                    @foreach (var item in Model.Where(a=> a.CategorySubStatusName == "Deployed" || a.CategorySubStatusName == "Allocation" || a.CategorySubStatusName == "Shadow" || a.CategorySubStatusName == "Projection"))
                                    {
                                        <tr>

                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                                @item.UserId
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                                @item.EmployeeName
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@((item.ReportingHead != null) ? item.ReportingHead : "")</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                                @item.ProjectName.ToString()
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">
                                                @item.ContractStartDate?.ToString("dd/MM/yy")
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@item.CompanyName</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">
                                                @item.PracticeName
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">
                                                @item.SubPracticeName
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@item.ProjectTypeName</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@((item.DeliveryAnchorName != null) ? item.DeliveryAnchorName : "")</td>

                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">
                                                <span class="status @(item.CategorySubStatusName == "Deployed" ? "deployed" : item.CategorySubStatusName == "Bench" ? "bench" : "draft")">@item.CategorySubStatusName</span>
                                            </td>
