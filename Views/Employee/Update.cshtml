                                    <path fill="none" d="M24 17h-7v7h-2v-7H8v-2h7V8h2v7h7v2z"></path>
                                </svg>
                                Add Secondary Skill
                            </button>
                        }

                    </div>
                </div>
                <div class="flex items-center gap-4 order-1 sm:order-3 ">
                    <p class="font-extrabold text-xl text-[#4B4E5C]">Rating</p>
                    <select name="" id="" class="k-input min-w-[10rem]" onchange="switchRating(this);">
                        <option value="2">Manager</option>
