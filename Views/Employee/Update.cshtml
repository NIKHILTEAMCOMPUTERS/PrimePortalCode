@model RMS.Client.Models.Employee.ProjectAssign
@section PageStyles {
    <style>
        .ss-main.multi-select {
            min-width: 18rem;
        }

        .skill-remove {
            top: 0; 
            right: 0; 
            opacity: 0;
            pointer-events: none;
            background-color: white;
            padding-left: .5rem;
            transform: scale(0);
            transition: all .125s ease;
            transform-origin: top right;
        }

        .skill-card:hover .skill-remove {
            opacity: 1;
            pointer-events: all;
            transform: scale(1)
        }

        .secondary-skills-wrapper.selfOnly .managerRating {
            display: none;
        }

        .secondary-skills-wrapper.selfOnly .selfRating {
            display: inline-flex;
        }

        .secondary-skills-wrapper.managerOnly .managerRating {
            display: inline-flex;
        }

        .secondary-skills-wrapper.managerOnly .selfRating {
            display: none;
        }
    </style>
}
@{
    var colList = new List<string> { "Contract Start Date", "Contract End Date", "Practice", "Sub-Practice", "Project Type", "Customer", "Delivery Anchor", "Status", "Action" };
}
<div class="flex items-center gap-4 mb-4">
    <button onclick="window.history.back();" class="py-2 px-2 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base" title="Back">
        <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M11.707 5.293a1 1 0 0 1 0 1.414L7.414 11H19a1 1 0 1 1 0 2H7.414l4.293 4.293a1 1 0 0 1-1.414 1.414l-6-6a1 1 0 0 1 0-1.414l6-6a1 1 0 0 1 1.414 0z" /></svg>
    </button>
    <div>
        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Employee Action Centre</h2>
        <p>Review the employee details to assign project and update status</p>
    </div>
</div>
<div class="p-4 rounded bg-[#f9f9f9] flex flex-wrap items-start justify-between gap-x-4 gap-y-8 mb-6">
    <div>
        <div class="flex items-center gap-4 mb-4">
            <img src="~/assets/images/default_user_icon.png" alt="" class="w-16 h-16 2xl:w-20 2xl:h-20 rounded-full object-cover">

            <div>
                <h2 class="font-extrabold text-lg 2xl:text-2xl text-[#4B4E5C]">@Model.employees.Employeename</h2>
                @*<p>UI/UX Designer</p>*@
                <h2 class="font-extrabold text-base 2xl:text-xl text-[#4B4E5C]">TMC: @Model.employees.TmcId</h2>
            </div>
        </div>
        <div class="flex items-center gap-4">
            <label for="resignedFlag" class="inline-flex items-center px-4 py-2 rounded-full bg-red-100 gap-2">
                <input type="checkbox" id="resignedFlag" checked="@(Model.employees.Udf3 == "1" ? true : false)" onchange="handleResign(this);" class="shrink-0 mt-0.5 border-2 border-red-600 bg-red-100 rounded text-red-600 focus:ring-red-500 disabled:opacity-50 disabled:pointer-events-none">
                <span class="text-red-600 font-medium">Resigned</span>
            </label>
            <label for="trainee" class="inline-flex items-center px-4 py-2 rounded-full bg-slate-100 gap-2">
                <input type="checkbox" id="trainee" checked="@(Model.employees.Ade == true ? true : false)" onchange="handletrainee(this);" class="shrink-0 mt-0.5 border-2 border-slate-600 bg-slate-100 rounded text-slate-600 focus:ring-slate-500 disabled:opacity-50 disabled:pointer-events-none">
                <span class="text-slate-600 font-medium">ADE</span>
            </label>
        </div>
        @*  <div class="inline-flex items-center rounded shadow py-3 px-6 gap-2">
        <input checked="@(Model.employees.Udf3 == "1" ? true : false)" onchange="handleResign(this);" type="checkbox" name="resignedFlag" class="shrink-0 mt-0.5 border-gray-200 rounded-full text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="resignedFlag">
        <label for="resignedFlag" class="block font-bold ">Resigned</label>
        </div> *@
    </div>
    <div>
        <p>Date of Joining: @Model.employees.Dateofjoining</p>
        <p>Department: @Model.employees.Department</p>
        <p>Location: @Model.employees.Branch</p>
        <p>Phone: @Model.employees.Contactno</p>
    </div>
    <div>
        <p>Email Id: @Model.employees.email</p>
        <p>DOB: @Model.employees.Dateofbirth</p>
        @*<p>Address: @Model.employees.E</p>*@
    </div>
    @*<div>
    <p class="font-bold">Reporting Manager</p>
    <p>@Model.employees.Reporthead</p>
    </div>*@
</div>

<div class="mt-4">
    <nav class="flex space-x-2" aria-label="Tabs" role="tablist">
        <button type="button"
                class="hs-tab-active:bg-gray-800 bg-gray-200 hs-tab-active:text-white py-2 px-5 inline-flex items-center gap-2 text-sm font-medium text-center text-gray-500 rounded-lg hover:text-emerald-400 active"
                id="projects-tab-btn" data-hs-tab="#projects-tab-content"
                aria-controls="pills-on-gray-color-2" role="tab">
            Projects
        </button>
        <button type="button"
                class="hs-tab-active:bg-gray-800 bg-gray-200 hs-tab-active:text-white py-2 px-5 inline-flex items-center gap-2 text-sm font-medium text-center text-gray-500 rounded-lg hover:text-emerald-400"
                id="skills-tab" data-hs-tab="#skills-tab-content"
                aria-controls="pills-on-gray-color-1" role="tab">
            Skills
        </button>
    </nav>


    <div class="mt-3">
        <div id="projects-tab-content" role="tabpanel">
            <div class="mt-4">
                <nav class="flex space-x-2" aria-label="Tabs" role="tablist">
                    <button type="button"
                            class="hs-tab-active:font-bold hs-tab-active:border-emerald-400 hs-tab-active:text-emerald-400 px-1 inline-flex items-center gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-black hover:text-emerald-600 active"
                            id="pills-on-gray-color-item-2" data-hs-tab="#active-contracts-content"
                            aria-controls="pills-on-gray-color-2" role="tab">
                        Active Projects
                    </button>
                    <button type="button"
                            class="hs-tab-active:font-bold hs-tab-active:border-emerald-400 hs-tab-active:text-emerald-400 px-1 inline-flex items-center gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-black hover:text-emerald-600"
                            id="pills-on-gray-color-item-1" data-hs-tab="#past-contracts-content"
                            aria-controls="pills-on-gray-color-1" role="tab">
                        Past Projects
                    </button>
                </nav>
                <div class="mt-3">
                    <div id="active-contracts-content" role="tabpanel"
                         aria-labelledby="pills-on-gray-color-item-2">
                        <form class="mb-6">
                            <input type="hidden" asp-for="employeeid" />
                            @* <input type="hidden" id="hidProjectId" value="@Model.employees.Projectid" />
                            <input type="hidden" id="hidSubStatusId" value="@Model.employees.Categorysubstatusid" />*@
                            <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
                                <div>
                                    <label for="">Project</label>
                                    <select class="multi-select" id="ctlProject">
                                        <option value="">--Select--</option>
                                        @foreach (var project in ViewBag.ProjectList)
                                        {
                                            <option value="@project.Value" data-contractno="@project.ContractNo">@project.Text</option>
                                        }
                                    </select>

                                </div>
                                <div>
                                    <label for="">Status</label>
                                    <select class="multi-select" id="ctlStatus" asp-items="ViewBag.SubCategoryStatusList">
                                        <option value="">--Select--</option>
                                    </select>
                                </div>
                                <button type="button" id="btnAdd" class="self-end py-3 px-4 inline-flex justify-center items-center gap-2 rounded-md border border-transparent font-semibold bg-black text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm w-full sm:w-auto">
                                    <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M18 12.998h-5v5a1 1 0 0 1-2 0v-5H6a1 1 0 0 1 0-2h5v-5a1 1 0 0 1 2 0v5h5a1 1 0 0 1 0 2z" /></svg>
                                    Add
                                </button>
                                <button type="button" id="btnSubmit" class="ml-auto self-end py-3 px-4 inline-flex justify-center items-center gap-2 rounded-md border border-transparent font-semibold bg-emerald-500 text-white hover:bg-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm w-full sm:w-auto">
                                    <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M12 21q-1.875 0-3.513-.713t-2.85-1.924q-1.212-1.213-1.924-2.85T3 12q0-1.875.713-3.513t1.924-2.85q1.213-1.212 2.85-1.924T12 3q2.05 0 3.888.875T19 6.35V5q0-.425.288-.713T20 4q.425 0 .713.288T21 5v4q0 .425-.288.713T20 10h-4q-.425 0-.713-.288T15 9q0-.425.288-.713T16 8h1.75q-1.025-1.4-2.525-2.2T12 5Q9.075 5 7.037 7.038T5 12q0 2.925 2.038 4.963T12 19q2.375 0 4.25-1.425t2.475-3.675q.125-.4.45-.6t.725-.15q.425.05.675.362t.15.688q-.725 2.975-3.15 4.888T12 21Zm1-9.4l2.5 2.5q.275.275.275.7t-.275.7q-.275.275-.7.275t-.7-.275l-2.8-2.8q-.15-.15-.225-.337T11 11.975V8q0-.425.288-.713T12 7q.425 0 .713.288T13 8v3.6Z" /></svg>
                                    Update
                                </button>
                            </div>
                        </form>
                        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-6 flex-wrap w-full">
                            <div class="-m-1.5 overflow-x-auto w-full">
                                <div class="p-1.5 min-w-full block align-middle w-full">
                                    <div class="border rounded-lg overflow-hidden w-full">
                                        <div class="p-2 flex items-center justify-between flex-wrap gap-4">
                                            <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Project List</h2>
                                            <div class="mt-1 mx-1 sm:mt-1 hs-dropdown relative sm:inline-flex z-20 [--auto-close:inside]">
                                                <button type="button" id="filterTableColDropdown"
                                                        class="hs-dropdown-toggle group py-3 px-4 inline-flex justify-center items-center gap-2 rounded-md border border-transparent font-semibold text-white bg-emerald-500 hover:text-white focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm">
                                                    <svg class="w-5 h-5 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M14 12v7.88c.04.3-.06.62-.29.83a.996.996 0 0 1-1.41 0l-2.01-2.01a.989.989 0 0 1-.29-.83V12h-.03L4.21 4.62a1 1 0 0 1 .17-1.4c.19-.14.4-.22.62-.22h14c.22 0 .43.08.62.22a1 1 0 0 1 .17 1.4L14.03 12H14Z" /></svg>
                                                    Filter Columns
                                                </button>

                                                <div style="max-height: 10rem; overflow-y: auto;" class="hs-dropdown-menu z-10 transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden mt-2 bg-white shadow-md rounded-lg p-2 z-30" aria-labelledby="hs-dropdown-auto-close-inside">

                                                    @{
                                                        int index = 0;
                                                        foreach (var cols in colList)
                                                        {
                                                                            <div class="relative flex flex items-start py-2 px-3 rounded-md hover:bg-gray-100">
                                                                                <div class="flex">
                                                                                    <input onchange="toggleColVisibility(@(index+4), this);" type="checkbox" class="shrink-0 mt-0.5 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500" id="col-@(index)" checked>
                                                                                    <label for="col-@(index)" class="text-sm text-gray-500 ml-3 dark:text-gray-400">@cols</label>
                                                                                </div>
                                                                            </div>
                                                            index++;
                                                        }
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                        <table class="min-w-full divide-y divide-gray-200" id="tblProjects">
                                            <thead class="bg-gray-50">
                                                <tr>
                                                    <th class="hidden"></th>
                                                    <th class="hidden"></th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Project
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Contract
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Contract Start Date
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Contract End Date
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Project Status
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Practice
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Sub Practice
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Project Type
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Customer
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Delivery Anchor
                                                    </th>
                                                   @*  <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Project Status
                                                    </th> *@
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Employee Status
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Action
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-gray-200">

                                                @if (Model.employees.employeeProjects != null && Model.employees.employeeProjects.Count > 0)
                                                {
                                                    foreach (var proj in Model.employees.employeeProjects)
                                                    {

                                                        var contractNo = "";
                                                        int? contractId = 0;
                                                        int? contractStatusId = null;

                                                        if (proj.contracts != null && proj.contracts.Count > 0)
                                                        {
                                                            contractNo = proj.contracts[0].ContractNo;
                                                            contractId = proj.contracts[0].ContractId;
                                                            contractStatusId = proj.contracts[0].Statusid;
                                                        }

                                                        @if (contractStatusId != null && contractStatusId != 6 && proj.Categorysubstatusname != "Released")
                                                        {
                                                            <tr>
                                                                <td style="display:none" class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Projectid</td>
                                                                <td style="display:none" class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Categorysubstatusid</td>

                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800"><a class="underline" title="Go To Project" asp-action="View" asp-controller="Project" asp-route-id="@proj.Projectid">@(proj.Projectname == null ? proj.CustomerCompanyname == null ? "" : proj.CustomerCompanyname : proj.Projectname)</a></td>

                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                                    <a asp-action="Detail" class="underline" title="Go To Contract" asp-controller="Contract" asp-route-id="@contractId">@contractNo</a>
                                                                </td>

                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@Convert.ToDateTime(@proj.contracts[0].Contractstartdate).ToString("dd/MM/yyyy")</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@Convert.ToDateTime(@proj.contracts[0].Contractenddate).ToString("dd/MM/yyyy")</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                                    <div class="hs-dropdown relative inline-flex">
                                                                        @{
                                                                            bool isDeployed = Convert.ToDateTime(proj.contracts[0].Contractenddate) > DateTime.Today;
                                                                            string statusName = isDeployed ? "Active" : "Over Run";
                                                                            string statusClass = isDeployed ? "deployed" : "overrun";
                                                                        }
                                                                        <button id="hs-dropdown-default" type="button" class="hs-dropdown-toggle status-toggle @statusClass py-2 px-2 inline-flex items-center gap-x-2 text-sm font-medium rounded-full border border-gray-200 bg-white text-gray-800 shadow-sm disabled:opacity-50 disabled:pointer-events-none">
                                                                            <span>@statusName</span>
                                                                            @*  <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                                                                <path fill="currentColor" fill-rule="evenodd" d="M12 21a9 9 0 1 0 0-18a9 9 0 0 0 0 18zM9.707 10.293a1 1 0 1 0-1.414 1.414l3 3a1 1 0 0 0 1.414 0l3-3a1 1 0 0 0-1.414-1.414L12 12.586l-2.293-2.293z" clip-rule="evenodd" />
                                                                </svg> *@
                                                                        </button>

                                                                        @* <div class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden min-w-[15rem] bg-white shadow-md rounded-lg p-2 mt-2 after:h-4 after:absolute after:-bottom-4 after:start-0 after:w-full before:h-4 before:absolute before:-top-4 before:start-0 before:w-full" style="z-index:99;" aria-labelledby="hs-dropdown-default">
                                                            <button onclick="changeStatus(this);" class="w-full flex items-center gap-x-3.5 py-2 px-3 rounded-lg text-sm text-emerald-500 hover:bg-gray-100 focus:outline-none focus:bg-gray-100" data-statusid="5">Deployed</button>
                                                            <button onclick="changeStatus(this);" class="w-full flex items-center gap-x-3.5 py-2 px-3 rounded-lg text-sm text-yellow-400 hover:bg-gray-100 focus:outline-none focus:bg-gray-100" data-statusid="11">Released</button>
                                                            </div> *@
                                                                    </div>
                                                                </td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Practicename</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Subpracticename</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Projecttypename</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.CustomerCompanyname</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                                    @proj?.contracts[0]?.DeliveryAnchorName
                                                                </td>
                                                                @* <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                                    <div class="hs-dropdown relative inline-flex">
                                                                        <button id="hs-dropdown-default" type="button" class="hs-dropdown-toggle status-toggle @(proj.Categorysubstatusname == "Deployed" ? "deployed" : "") @(proj.Categorysubstatusname == "Projection" ? "projection" : "") @(proj.Categorysubstatusname == "Bench" ? "onbench" : "") @(proj.Categorysubstatusname == "Shadow" ? "shadow" : "") @(proj.Categorysubstatusname == "Over Run" ? "overrun" : "") py-2 px-2 inline-flex items-center gap-x-2 text-sm font-medium rounded-full border border-gray-200 bg-white text-gray-800 shadow-sm disabled:opacity-50 disabled:pointer-events-none">
                                                                            <span>@proj.Categorysubstatusname</span>
                                                                            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"> <path fill="currentColor" fill-rule="evenodd" d="M12 21a9 9 0 1 0 0-18a9 9 0 0 0 0 18zM9.707 10.293a1 1 0 1 0-1.414 1.414l3 3a1 1 0 0 0 1.414 0l3-3a1 1 0 0 0-1.414-1.414L12 12.586l-2.293-2.293z" clip-rule="evenodd" /></svg>
                                                                        </button>

                                                                        <div class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden min-w-[15rem] bg-white shadow-md rounded-lg p-2 mt-2 after:h-4 after:absolute after:-bottom-4 after:start-0 after:w-full before:h-4 before:absolute before:-top-4 before:start-0 before:w-full" style="z-index:99;" aria-labelledby="hs-dropdown-default">
                                                                            <button onclick="changeStatus(this);" class="w-full flex items-center gap-x-3.5 py-2 px-3 rounded-lg text-sm text-emerald-500 hover:bg-gray-100 focus:outline-none focus:bg-gray-100" data-statusid="5">Deployed</button>
                                                                            <button onclick="changeStatus(this);" class="w-full flex items-center gap-x-3.5 py-2 px-3 rounded-lg text-sm text-yellow-400 hover:bg-gray-100 focus:outline-none focus:bg-gray-100" data-statusid="11">Released</button>

                                                                        </div>
                                                                    </div>
                                                                </td> *@
                                                                @* <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Categorysubstatusname</td> *@
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                                    <div class="hs-dropdown relative inline-flex">
                                                                        <button id="hs-dropdown-default" type="button" class="hs-dropdown-toggle status-toggle @(proj.Categorysubstatusname == "Deployed" ? "deployed" : "") @(proj.Categorysubstatusname == "Projection" ? "projection" : "") @(proj.Categorysubstatusname == "Bench" ? "onbench" : "") @(proj.Categorysubstatusname == "Shadow" ? "shadow" : "") @(proj.Categorysubstatusname == "Over Run" ? "overrun" : "") py-2 px-2 inline-flex items-center gap-x-2 text-sm font-medium rounded-full border border-gray-200 bg-white text-gray-800 shadow-sm disabled:opacity-50 disabled:pointer-events-none">
                                                                            <span>@proj.Categorysubstatusname</span>
