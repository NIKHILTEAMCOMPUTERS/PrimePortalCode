                    <div id="past-contracts-content" class="hidden" role="tabpanel" aria-labelledby="pills-on-gray-color-item-1">
                        @* <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C] mb-6">Pre Sales Checklist</h2> *@
                        <div class="flex flex-col sm:flex-row items-stretch sm:items-center gap-6 flex-wrap">
                            <div class="-m-1.5 overflow-x-auto w-full">
                                <div class="p-1.5 min-w-full inline-block align-middle">
                                    <div class="border rounded-lg overflow-hidden">
                                        <table class="min-w-full divide-y divide-gray-200" id="tblPastprojects">
                                            <thead class="bg-gray-50">
                                                <tr>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Project
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Contract
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Contract Start Date
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Contract End Date
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Practice
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Sub Practice
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Project Type
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Customer
                                                    </th>
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Delivery Anchor
                                                    </th>
                                                    @* <th scope="col"
                                                    class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                    Deployed on - Released on
                                                    </th> *@
                                                    <th scope="col"
                                                        class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        Status
                                                    </th>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-gray-200">

                                                @if (Model.employees.employeeProjects != null && Model.employees.employeeProjects.Count > 0)
                                                {
                                                    foreach (var proj in Model.employees.employeeProjects)
                                                    {

                                                        var contractNo = "";
                                                        int? contractId = 0;
                                                        int? contractStatusId = null;

                                                        if (proj.contracts != null && proj.contracts.Count > 0)
                                                        {
                                                            contractNo = proj.contracts[0].ContractNo;
                                                            contractId = proj.contracts[0].ContractId;
                                                            contractStatusId = proj.contracts[0].Statusid;
                                                        }

                                                        @if (contractStatusId != null && contractStatusId == 6 || proj.Categorysubstatusname == "Released")
                                                        {
                                                            <tr>
                                                                <td style="display:none" class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Projectid</td>
                                                                <td style="display:none" class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Categorysubstatusid</td>

                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800"><a class="underline" title="Go To Project" asp-action="View" asp-controller="Project" asp-route-id="@proj.Projectid">@(proj.Projectname == null ? proj.CustomerCompanyname == null ? "" : proj.CustomerCompanyname : proj.Projectname)</a></td>

                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">


                                                                    <a asp-action="Detail" class="underline" title="Go To Contract" asp-controller="Contract" asp-route-id="@contractId">@contractNo</a>
                                                                </td>

                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@Convert.ToDateTime(@proj.contracts[0].Contractstartdate).ToString("dd/MM/yyyy")</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@Convert.ToDateTime(@proj.contracts[0].Contractenddate).ToString("dd/MM/yyyy")</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Practicename</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Subpracticename</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.Projecttypename</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@proj.CustomerCompanyname</td>
                                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                                    @proj?.contracts[0]?.DeliveryAnchorName
                                                                </td>

                                                                @* <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                    @(proj?.EffectiveStartDate?.ToString("dd/MM/yyyy") ?? "N/A") - @(proj?.EffectiveEndDate?.ToString("dd/MM/yyyy") ?? "N/A")
                                                    </td> *@

                                                                @if (proj.Categorysubstatusname == "Released")
                                                                {
                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                                        <span class="status overrun">Released</span>
                                                                    </td>
                                                                }
                                                                else
                                                                {
                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                                        <span class="status completed">Completed</span>
                                                                    </td>
                                                                }
                                                            </tr>
                                                        }


                                                    }
                                                }

                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>


        <div id="skills-tab-content" role="tabpanel" class="hidden" aria-labelledby="skills-tab-content">
