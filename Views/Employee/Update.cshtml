                           <p class="mb-1">Exp: @( ((Model.employees?.PrimarySkill?.experinceinmonths ?? 0) / 12.0m).ToString("0.##") ) years</p>

                            <p class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-slate-100 text-sm">
