                                                                <button id="hs-dropdown-auto-close-inside" type="button" class="hs-dropdown-toggle p-1 inline-flex items-center gap-x-2 text-sm font-medium text-gray-800 underline disabled:opacity-50 disabled:pointer-events-none">
                                                                    Deploy
                                                                </button>

                                                                <div style="min-width: 10rem; z-index: 40;" class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden mt-2 bg-white shadow-md rounded-lg p-2 mt-2" aria-labelledby="hs-dropdown-auto-close-inside">
                                                                    <select class="k-input w-full mb-4 selectEmployee">
                                                                        <option value="">Select Employee</option>
                                                                        @foreach (var employee in ViewBag.resource)
                                                                        {
                                                                            <option value="@employee.Employeeid" data-tmcid="@employee.TmcId">@employee.Employeename</option>
                                                                        }
                                                                    </select>
                                                                    <div class="deployment-dates-wrapper">
                                                                        <div class="flex items-center gap-4 mb-4 deployment-date-row">
                                                                            <div class="flex-1">
                                                                                <label>From</label>
                                                                                <input min="@Model.OafData.contractstartdate?.ToString("yyyy-MM-dd")" max="@Model.OafData.contractenddate?.ToString("yyyy-MM-dd")" type="date" class="k-input deployStartDate" />
                                                                            </div>
                                                                            <div class="flex-1">
                                                                                <label>To</label>
                                                                                <input min="@Model.OafData.contractstartdate?.ToString("yyyy-MM-dd")" max="@Model.OafData.contractenddate?.ToString("yyyy-MM-dd")" type="date" class="k-input deployEndDate" />
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <div class="flex justify-end mb-4">
                                                                        <button class="text-blue-400" onclick="addNewDeploymentDate(this);">Add New</button>
                                                                    </div>
                                                                    <select id="selectEmpStatus" class="k-input w-full mb-4 deployStatus" asp-items="@ViewBag.status">
                                                                        <option value="">Select Status</option>
                                                                    </select>
                                                                    <div>
                                                                        <button onclick="assignEmployee(this);" class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">Assign</button>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        </td>
                                                        <td></td>
                                                    }
                                                    else
                                                    {
                                                        <td></td>
                                                        <td></td>
                                                        <td></td>
                                                        <td></td>
                                                        <td></td>
                                                        <td></td>
                                                        <td></td>
                                                    }
                                                </tr>
                                            }
                                        }
                                    </tbody>

                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div id="deployResourceWrapper">
                    <div class="flex flex-col mb-4">
                        <div class="-m-1.5 overflow-x-auto">
                            <div class="p-1.5 min-w-full inline-block align-middle">
                                <div class="border rounded-lg overflow-hidden">
                                    <table class="min-w-full divide-y divide-gray-200" id="assignedEmployeeTable">
                                        <thead class="bg-gray-50">
                                            <tr>
                                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">TMC</th>
                                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">Employee</th>
