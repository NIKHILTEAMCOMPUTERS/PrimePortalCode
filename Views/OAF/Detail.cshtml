        function addEmployeeToSplitTable(rowObj, x = 1, skillCost = 0) {
            console.log(rowObj);
            if (!x || !skillCost) return;
            let advanceAmountFlag = false;

            const advanceAmount = Number(document.querySelector("#advanceAmount")?.innerText?.trim());

            if (advanceAmount && advanceAmount > 0) {
                advanceAmountFlag = true;
            }

            const allMonths = document.querySelectorAll("#assignedEmployeeBillingTable thead th");
            const tbody = document.querySelector("#assignedEmployeeBillingTable tbody");

            const newRow = document.createElement("tr");
            newRow.setAttribute("data-rowInd", rowObj?.rowInd);
            let trHtml = '';

            trHtml += `<td class="py-2 px-6 whitespace-nowrap">${rowObj?.employeeName}</td>`
            trHtml += `<td class="py-2 px-6"><span class="status deployed">Actual Billing</span></td>`

            for (let i = 2; i < allMonths.length; i++) {
                console.log(allMonths[i].innerText);
                // const _monthDays = rowObj?.daysMonths.find(item => Object.keys(item)[0] === allMonths[i].innerText)
                const [_monthDays] = rowObj?.daysMonths.filter(obj => Object.keys(obj).includes(allMonths[i].innerText));
                if (i == 2 && advanceAmountFlag) {
                    let advanceSplit = getAdvanceSplit(advanceAmount);
                    trHtml += `<td class="py-2 px-6 advanceBilling" data-cps="${skillCost}" data-monthdays="${_monthDays ? _monthDays[allMonths[i].innerText] : 0}">${x * advanceSplit}</td>`;
                    updateAdvanceBilling();
                    continue;
                }

                if (rowObj?.deployedMonths.includes(allMonths[i].innerText)) {
                    trHtml += `<td class="py-2 px-6" data-cps="${skillCost}" data-monthdays="${_monthDays ? _monthDays[allMonths[i].innerText] : 0}">${x * getSkillCostByMonthDays(allMonths[i].innerText, skillCost, rowObj?.daysMonths)}</td>`;
                } else {
                    trHtml += `<td class="py-2 px-6" data-cps="0" data-monthdays="0">0</td>`;
                }
            }

            function getSkillCostByMonthDays(month, skillCost, monthDaysObj) {
                if (!monthDaysObj) return 1;
                const [monthDays] = monthDaysObj.filter(obj => Object.keys(obj).includes(month));                
                if (monthDays) {
                    return skillCost / 22 * monthDays[`${month}`];
                } else {
                    return 1;
                }
            }

            newRow.innerHTML = trHtml;

            tbody.appendChild(newRow);
            updateAllocatedValue();
        }

