            const trToUpdate = document.querySelector(`#assignedEmployeeBillingTable tbody tr[data-rowInd='${row.getAttribute("data-rowInd")}']`);

            const advanceBillingExists = document.querySelector("#assignedEmployeeBillingTable td.advanceBilling");

            trToUpdate.querySelectorAll("td").forEach((item, ind) => {
