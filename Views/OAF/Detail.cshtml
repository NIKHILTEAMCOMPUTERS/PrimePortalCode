        function setXvalue(inp) {
            const xValue = inp.options[inp.selectedIndex].getAttribute("data-xvalue");
            document.querySelector("#xvalue").value = xValue ? Number(xValue).toFixed(2) : 0;
        }

        function validateOafExtendForm() {
            let validFlag = true;
            const contractNumber = document.querySelector("#contractno");
            const poNumber = document.querySelector("#ponumber");
            const contractStartDate = document.querySelector("#contractstartdate");
            const contractEndDate = document.querySelector("#contractenddate");
            const amount = document.querySelector("#amount");
            const contactpersonname = document.querySelector("#contactpersonname");
            const contactNo = document.querySelector("#contactNo");
            const costingsheetdrown = document.querySelector("#costingsheetdrown");

            if (document.querySelector("#poArrivedCheckbox").checked) {
                if (!contractNumber.value.trim()) {
                    contractNumber.classList.add("is-invalid");
                    validFlag = false;
                } else {
                    contractNumber.classList.remove("is-invalid");
                }
                if (!poNumber.value.trim()) {
                    poNumber.classList.add("is-invalid");
                    validFlag = false;
                } else {
                    poNumber.classList.remove("is-invalid");
                }
            } else {
                contractNumber.classList.remove("is-invalid");
                poNumber.classList.remove("is-invalid");
            }

            if (!contractStartDate.value) {
                contractStartDate.classList.add("is-invalid");
                validFlag = false;
            } else {
                contractStartDate.classList.remove("is-invalid");
            }
            if (!contractEndDate.value) {
                contractEndDate.classList.add("is-invalid");
                validFlag = false;
            } else {
                contractEndDate.classList.remove("is-invalid");
            }

            if (!amount.value.trim()) {
                amount.classList.add("is-invalid");
                validFlag = false;
            } else {
                amount.classList.remove("is-invalid");
            }

            if (!contactpersonname.value.trim()) {
                contactpersonname.classList.add("is-invalid");
                validFlag = false;
            } else {
                contactpersonname.classList.remove("is-invalid");
            }

            if (!contactNo.value.trim()) {
                contactNo.classList.add("is-invalid");
                validFlag = false;
            } else {
                contactNo.classList.remove("is-invalid");
            }

            if (!costingsheetdrown.value.trim()) {
                costingsheetdrown.classList.add("is-invalid");
                validFlag = false;
            } else {
                costingsheetdrown.classList.remove("is-invalid");
            }

            return validFlag;
        }

        function saveOAFExtend() {
            const isValid = validateOafExtendForm();

            if (!isValid) return;
            document.querySelector("#loader").style.display = "flex";
            const extendData = {
                "Oafid": $("#hidoafid").val(),
                "Contractno": $("#contractno").val(),
                "Ponumber": $("#ponumber").val(),
                "contractstartdate": $("#contractstartdate").val(),
                "contractenddate": $("#contractenddate").val(),
                "Povalue": $("#amount").val(),
                "Clientcoordinator": $("#contactpersonname").val(),
                "Contactno": $("#contactNo").val(),
                "Costsheetid": $("#costingsheetdrown").val(),
                "isExtended": true
            }
            const formData = new FormData();
            formData.append("jsonobject", JSON.stringify(extendData));
            $.ajax({
                type: "POST",
                url: "@Url.Action("OAFExtend", "OAF")",
                data: formData,
                contentType: false,
                processData: false,
                success: function (res) {
                    $("#loader").hide();
                    if (res.success == true) {
                        toastr.success(res.msg);
                        setTimeout(() => {
                            window.location.href = "/OAF/Index"
                        }, 1000)
                    } else {
                        toastr.error(res.msg);
                        $("#loader").hide();
                    }
                }
            });
        }
    </script>
