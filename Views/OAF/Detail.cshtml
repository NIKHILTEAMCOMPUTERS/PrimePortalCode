                resourceDetailItem['employeeid'] = empId;
                resourceDetailItem['costsheetdetailid'] = document.querySelector(`#costSheetTableModal tr[data-ind='${item.getAttribute("data-rowInd")}']`)?.querySelector("input")?.value;
                resourceDetailItem['xvalue'] = parseFloat(item.querySelector("td:nth-child(4)").querySelector("input").value);
                resourceDetailItem['deployement_details'] = getDeploymentDetails(item);
                resourceDetailItem['billing_Details'] = getBillingDetails(rowInd, empId);
                resourceDetails.push(resourceDetailItem);
            });

            return resourceDetails;
        }

        function getTotalSplitBilling() {
            let totalBilling = 0;
            const allTr = document.querySelectorAll("#assignedEmployeeBillingTable tbody tr");

            allTr.forEach(item => {
                const allTh = item.querySelectorAll("td");
                for (let i = 2; i < allTh.length; i++) {
                    totalBilling += Number(allTh[i].innerText);
                }
            })

            return totalBilling;
        }

        function checkBillingExceedPo() {
            const poamount = Number(document.querySelector("#povalue").innerText);
            const totalSplitBilling = getTotalSplitBilling();
            return totalSplitBilling > poamount;
        }

        // resource allocation script
        function postData() {

            const billingExceedPo = checkBillingExceedPo();
            if (billingExceedPo) {
                toastr.error("Total split billing exceeds PO amount.")
                return;
            }

            document.querySelector("#loader").style.display = "flex";
            // Define dynamic variables
            var contractid = parseInt($("#contractid").val(), 10);

            let resourceDetails = getResourceDetails();

            // Sample data with dynamic variables
            var data = {
                "projectId": 0,
                "contractid": contractid,
                "resource_details": resourceDetails
            };

            // Convert data to JSON
            var jsonData = JSON.stringify(data);
            const fData = new FormData();
            fData.append("jsonObject", jsonData);

            // AJAX POST request
            $.ajax({
                type: "POST",
                url: "/oaf/resourceallocation", // Adjust the URL according to your application
                data: fData,
                processData: false,
                contentType: false,
                success: function (response) {
                    console.log("Data successfully posted:", response);
                    toastr.success("Successfully deployed resources");
                    window.location.href = "/OAF"
                    // Handle success response
                },
                error: function (xhr, status, error) {
                    console.error("Error posting data:", error);
                    // Handle error
                    toastr.error("Error: Something went wrong.");
                    window.location.href = "/OAF"
                }
            });
        }

