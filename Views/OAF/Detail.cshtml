                                            <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">Action</th>
                                            <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">Status</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200">
                                        @if (Model.OafData.Costsheetdata != null)
                                        {
                                            var costSheet = Model.OafData.Costsheetdata;
                                            int count = Model.OafData.Costsheetdata.costsheetdetails.Count;
                                            var totalResources = 0;
                                            decimal totalCost = 0;

                                            for (int i = 0; i < count; i++)
                                            {
                                                totalResources += costSheet.costsheetdetails[i].Requiredresource;
                                                totalCost += costSheet.costsheetdetails[i].Skillcost;
                                            }

                                            for (int i = 0; i < (count < 3 ? 3 : count); i++)
                                            {
                                                <tr data-ind="@(i + 1)">
                                                    @if (i == 0)
                                                    {
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">Cost Sheet Name: <span class="font-bold">@costSheet.costsheetname</span></td>
                                                    }
                                                    else if (i == 1)
                                                    {
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">
                                                            Total Resources Required:
                                                            <span class="font-bold">@totalResources</span>
                                                        </td>
                                                    }
                                                    else if (i == 2)
                                                    {
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">
                                                            Total Skills Required:
                                                            <span class="font-bold">@count</span>
                                                        </td>
                                                    }
                                                    else
                                                    {
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800"></td>
                                                    }
                                                    @if (i < count)
                                                    {
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].Skillname</td>
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].skillexperience</td>
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                            @(costSheet.costsheetdetails[i].Xvalue?.ToString("F2"))
                                                        </td>

                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].Perioddays</td>
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].Skillcost</td>
                                                        <input type="hidden" class="costsheetdetailid" Value="@costSheet.costsheetdetails[i].Costsheetdetailid">
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
