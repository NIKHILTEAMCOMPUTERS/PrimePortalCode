        function generateSplitMonths() {
            const tr = document.querySelector("#assignedEmployeeBillingTable thead tr")
            const cStartDateStr = document.querySelector("#cStartDate").getAttribute("data-date");
            const cEndDateStr = document.querySelector("#cEndDate").getAttribute("data-date");

            const cStartDate = new Date(cStartDateStr);
            const cEndDate = new Date(cEndDateStr);

            console.log(cStartDateStr, cEndDateStr);

            const monthsArr = [];

            while (true) {
                const month = cStartDate.toLocaleString('default', { month: 'short' });
                const monthYear = month + '-' + String(cStartDate.getFullYear()).match(/.{1,2}/g)[1];

                const month2 = cEndDate.toLocaleString('default', { month: 'short' });
                const monthYear2 = month2 + '-' + String(cEndDate.getFullYear()).match(/.{1,2}/g)[1];

                monthsArr.push(monthYear);
                cStartDate.setMonth(cStartDate.getMonth() + 1);

                //console.log(monthYear, monthYear2);
                //console.log(cStartDate.getMonth() === cEndDate.getMonth() && cStartDate.getFullYear() === cEndDate.getFullYear())

                if (monthYear === monthYear2) break;
            }

            if (!monthsArr.length || !tr) return;

            monthsArr.forEach(item => {
                tr.innerHTML += `<th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600">${item}</th>`
            })
        }

        function getMonthsFromDates(d1, d2) {
            const cStartDate = new Date(d1);
            const cEndDate = new Date(d2);

            cStartDate.setDate(1)
            cEndDate.setDate(1)


            const monthsArr = [];

            while (true) {
                const month = cStartDate.toLocaleString('default', { month: 'short' });
                const monthYear = month + '-' + String(cStartDate.getFullYear()).match(/.{1,2}/g)[1];

                const month2 = cEndDate.toLocaleString('default', { month: 'short' });
                const monthYear2 = month2 + '-' + String(cEndDate.getFullYear()).match(/.{1,2}/g)[1];

                monthsArr.push(monthYear);
                cStartDate.setMonth(cStartDate.getMonth() + 1);

                if (monthYear === monthYear2) break;
            }

            return monthsArr;
        }

        function getDaysFromDates(start, end) {
            if (!start || !end) {
                return 0;
            }
            const date1 = new Date(start);
            const date2 = new Date(end);
            const diffTime = Math.abs(date2 - date1);
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

            return diffDays;
        }

        function checkDeploymentExceedPeriod(periodDays, allDatesRow) {
            if (periodDays === null || periodDays === undefined || !allDatesRow.length) {
                return false;
            }
            let validFlag = true;
            let totalDeploymentDays = 0;
            allDatesRow.forEach(item => {
                let _startDate = item.querySelector(".deployStartDate")?.value;
                let _endDate = item.querySelector(".deployEndDate")?.value;

                totalDeploymentDays += getDaysFromDates(_startDate, _endDate);
            })

            if (totalDeploymentDays > periodDays) {
                validFlag = false;
            }

            return validFlag;
        }

        function calculateTotalDeploymentCost(dropdown) {
            const _row = dropdown.closest("tr");
            const skillCost = Number(_row.querySelector("td:nth-child(6)").innerText);
            // const period = Number(_row.querySelector("td:nth-child(5)").innerText);
            const xValue = Number(_row.querySelector("td:nth-child(4)").innerText);

            const monthDays = [];

            const allDatesRow = dropdown.querySelectorAll(".deployment-date-row");

            let totalDeploymentDays = 0;
            allDatesRow.forEach(item => {
                let _startDate = item.querySelector(".deployStartDate")?.value;
                let _endDate = item.querySelector(".deployEndDate")?.value;

                totalDeploymentDays += getDaysFromDates(_startDate, _endDate);
            })

            // const period = getMonthsFromDates(_startDate, _endDate);
            // const month

            const totalAmount = Math.floor(Number((skillCost / 22) * (totalDeploymentDays) * xValue));

            if (isNaN(totalAmount)) return 0;
            return totalAmount;
        }

        function validateAssignDropdown(dropdown) {
            if (!dropdown) return;
            let validFlag = true;

            const employee = dropdown.querySelector(".selectEmployee")

            const empStatus = dropdown.querySelector(".deployStatus");
            const allDatesRow = dropdown.querySelectorAll(".deployment-date-row");
            const periodDays = Number(dropdown.closest("tr").querySelector("td:nth-child(5)").innerText);
            const povalue = Number(document.querySelector("#povalue").innerText);
            const allocatedValue = Number(document.querySelector("#allocatedValue").innerText);
            //console.log(employee, startDate.value, endDate.value, empStatus.value);

            if (!employee.value) {
                employee.classList.add("is-invalid")
                validFlag = false;
            } else {
                employee.classList.remove("is-invalid")
            }

            allDatesRow.forEach(item => {
                const startDate = item.querySelector(".deployStartDate");
                const endDate = item.querySelector(".deployEndDate");
                if (!startDate.value) {
                    startDate.classList.add("is-invalid")
                    validFlag = false;
                } else {
                    startDate.classList.remove("is-invalid")
                }

                if (!endDate.value) {
                    endDate.classList.add("is-invalid")
                    validFlag = false;
                } else {
                    endDate.classList.remove("is-invalid")
                }
            })

            const deploymentExceedPeriod = checkDeploymentExceedPeriod(periodDays, allDatesRow);

            if (!deploymentExceedPeriod) {
                validFlag = false;
                toastr.error("Deployment dates exceed period.");
            }

            if (!empStatus.value) {
                empStatus.classList.add("is-invalid")
                validFlag = false;
            } else {
                empStatus.classList.remove("is-invalid")
            }

            const totalDeploymentCost = calculateTotalDeploymentCost(dropdown);

            if (totalDeploymentCost > (povalue - allocatedValue)) {
                toastr.error("Deployment cost exceed total PO value.");
                validFlag = false;
            }

            return validFlag;
        }

