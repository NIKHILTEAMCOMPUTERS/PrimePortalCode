@using System.Globalization;
@model RMS.Client.ViewModels.UpsertOafViewModel;

@section PageStyles {
    <link href="https://unpkg.com/slim-select@latest/dist/slimselect.css" rel="stylesheet">
}
<div class="flex items-center gap-4 mb-5">
    <button onclick="window.history.back();" class="py-2 px-2 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base" title="Back">
        <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M11.707 5.293a1 1 0 0 1 0 1.414L7.414 11H19a1 1 0 1 1 0 2H7.414l4.293 4.293a1 1 0 0 1-1.414 1.414l-6-6a1 1 0 0 1 0-1.414l6-6a1 1 0 0 1 1.414 0z" /></svg>
    </button>
    <div>
        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Action Centre</h2>
    </div>
</div>
@if (Model != null)
{
    <input id="hiddenoafid" value="@Model.OafData.oafid" type="hidden" />
    <p>OAF Details</p>
    <div class="flex items-center gap-4 flex-wrap mt-4">
        <div>
            <p>Sent On</p>
            <p class="font-bold">@Model.OafData.createdDate?.ToString("yyyy-MM-dd")</p>
        </div>
        <div>
            <p>Created By</p>
            <p class="font-bold">@Model.OafData.createdBy</p>
        </div>
    </div>
    <div class="bg-[#f9f9f9] p-4 rounded-md mt-4 mb-6">
        <div class="bg-white rounded p-4 mb-4">
            <p class="text-base 2xl:text-lg font-bold text-gray-600 mb-4">OAF Details</p>
            <div class="grid grid-cols-1 sm:grid-cols-6 sm:flex-row gap-4 mb-4">
                <div>
                    <p class="font-medium">Order Description</p>
                    <p>@Model.OafData.orderdescription</p>
                </div>

            </div>

            <div class="grid grid-cols-1 sm:grid-cols-6 sm:flex-row gap-4 mb-4">
                <div>
                    <p class="font-medium text-left">PO Number</p>
                    <p class="font-bold text-left">@Model.OafData.ponumber</p>
                </div>
                <div>
                    <p class="font-medium text-left">PO Value</p>
                    <p class="font-bold text-left">@Model.OafData.povalue</p>
                </div>
                <div>
                    <p class="font-medium text-left">Advance</p>
                    <p class="font-bold text-left" id="advanceAmount">@Model.OafData.Advanceamount</p>
                </div>
                @if (Model.OafData.projecttypeid == 1)
                {
                    <div>
                        <p class="font-medium text-left">Client Billing Date</p>
                        <p class="font-bold text-left" id="advanceAmount">
                            @if (Model.OafData.CommittedClientBillingDate != null && Model.OafData.CommittedClientBillingDate > 0)
                            {
                                @Model.OafData.CommittedClientBillingDate

                                <span>th</span>
                            }
                            else
                            {
                                @: ""
                            }
                        </p>
                    </div>
                }
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-6 sm:flex-row gap-4 mb-4">
                <div>
                    <p class="font-medium">PO Terms & Conditions</p>
                    @Html.Raw(Model.OafData.potermscondition)
                </div>
            </div>
            @* <p class="text-base 2xl:text-lg font-bold text-gray-600 mb-4">Attachments</p>
        <div class="flex items-center gap-4 mb-4">
        @{
        List<string> attachmentProperties = new List<string>
        {
        "emailattachment",
        "proposalattachment",
        "poattachment",
        "costattachment"
        };

        int count = attachmentProperties.Count(prop => Model.GetType().GetProperty(prop)?.GetValue(Model) != null);
        }

        <p>Total: @count</p>
        <a href="#" onclick="showPreview(this);" class="text-blue-500 underline" data-url="@Model.OafData.emailattachment">Email & Messages</a>
        <a href="#" onclick="showPreview(this);" class="text-blue-500 underline" data-url="@Model.OafData.proposalattachment">Proposal</a>
        <a href="#" onclick="showPreview(this);" class="text-blue-500 underline" data-url="@Model.OafData.poattachment">PO</a>
        <a href="#" onclick="showPreview(this);" class="text-blue-500 underline" data-url="@Model.OafData.costattachment">Cost Sheet Attachment</a>
        </div> *@
            @if (!String.IsNullOrEmpty(Model.OafData.emailattachment) || !String.IsNullOrEmpty(Model.OafData.proposalattachment) || !String.IsNullOrEmpty(Model.OafData.poattachment) || !String.IsNullOrEmpty(Model.OafData.costattachment))
            {
                <p class="text-base 2xl:text-lg font-bold text-gray-600 mb-4">Attachments</p>
                <div class="flex items-center gap-4 mb-4">
                    @{
                        List<string> attachmentProperties = new List<string>
            {
            "emailattachment",
            "proposalattachment",
            "poattachment",
            "costattachment"
            };

                        int count = attachmentProperties.Count(prop => Model.GetType().GetProperty(prop)?.GetValue(Model) != null);
                    }

                    @* <p>Total: @count</p> *@
                    @if (!String.IsNullOrEmpty(Model.OafData.emailattachment))
                    {
                        <a href="#" onclick="showPreview(this);" class="text-blue-500 underline" data-url="@Model.OafData.emailattachment">Email & Messages</a>
                    }
                    @if (!String.IsNullOrEmpty(Model.OafData.proposalattachment))
                    {
                        <a href="#" onclick="showPreview(this);" class="text-blue-500 underline" data-url="@Model.OafData.proposalattachment">Proposal</a>
                    }
                    @if (!String.IsNullOrEmpty(Model.OafData.poattachment))
                    {
                        <a href="#" onclick="showPreview(this);" class="text-blue-500 underline" data-url="@Model.OafData.poattachment">PO</a>
                    }
                    @if (!String.IsNullOrEmpty(Model.OafData.costattachment))
                    {
                        <a href="#" onclick="showPreview(this);" class="text-blue-500 underline" data-url="@Model.OafData.costattachment">Cost Sheet Attachment</a>
                    }
                </div>
            }
            @if (Model != null && Model.OafData.customer != null)
            {
                var cust = Model.OafData.customer; // Access the customer object directly

                <div class="flex items-center flex-wrap mb-4">
                    <div class="flex items-center gap-2 border-r pr-3">
                        <div class="logo w-10 h-10 bg-white rounded-full overflow-hidden flex items-center justify-center">
                            <img class="w-8 h-8 rounded-full object-cover" src="@(string.IsNullOrEmpty(cust.companylogourl) ? "/assets/images/customer_default.svg" : cust.companylogourl)" alt="">
                        </div>
                        <div>
                            <p class="text-[.625rem]">Customer</p>
                            <p class="font-bold">@cust.companyname</p>
                        </div>
                    </div>
                    <div class="flex pl-3 items-center gap-4">
                        <div>
                            <div>
                                <span class="text-sm">Email Id</span>
                            </div>
                            <p class="text-sm">@(cust.companyemail != null ? cust.companyemail : "--")</p>
                        </div>
                        <div>
                            <div>
                                <span class="text-sm">Phone No</span>
                            </div>
                            <p class="text-sm">@(cust.phoneNumber != null ? cust.phoneNumber : "--")</p>
                        </div>
                        <div>
                            <div>
                                <span class="text-sm">Location</span>
                            </div>
                            <p class="text-sm">@(cust.address != null ? cust.address : "--")</p>
                        </div>
                    </div>
                </div>
            }


        </div>
        <p class="text-base 2xl:text-lg font-bold text-gray-600 mb-4">Project Details</p>
        <div class="flex overflow-x-auto gap-x-8 gap-y-4 mb-4">
            <div>
                <p class="text-sm 2xl:text-base font-medium">Project Name</p>
                <p class="text-sm 2xl:text-base">@Model.OafData.projectname</p>
            </div>
            @* <div>
        <p class="text-sm 2xl:text-base font-medium">Project Model</p>
        <p class="text-sm 2xl:text-base">@Model.OafData.projectmodel</p>
        </div> *@
            <div>
                <p class="text-sm 2xl:text-base font-medium">Project Type</p>
                <p class="text-sm 2xl:text-base">@Model.OafData.projecttype</p>
            </div>
            <div>
                <p class="text-sm 2xl:text-base font-medium">Practices</p>
                <p class="text-sm 2xl:text-base">@Model.OafData.practice</p>
            </div>
            <div>
                <p class="text-sm 2xl:text-base font-medium">Sub-Practices</p>
                <p class="text-sm 2xl:text-base">@Model.OafData.subpractice</p>
            </div>
        </div>
        <div class="mb-4">
            <p class="text-sm 2xl:text-base font-medium">Project Description</p>
            <p class="text-sm 2xl:text-base">@Model.OafData.projectdescription</p>

        </div>
        <p class="text-base 2xl:text-lg font-bold text-gray-600 mb-4">Contract Details</p>
        <div class="flex overflow-x-auto gap-x-8 gap-y-4 mb-4">
            <div>
                <p class="text-sm 2xl:text-base font-medium">Contract Number</p>
                <p class="text-sm 2xl:text-base">@Model.OafData.contractno</p>

            </div>
            <div>
                <p class="text-sm 2xl:text-base font-medium">Contract Start Date</p>
                <p class="text-sm 2xl:text-base">@(Model.OafData.contractstartdate == null ? "" : Convert.ToDateTime(Model.OafData.contractstartdate).ToString("dd/MM/yyyy"))</p>
            </div>
            <div>
                <p class="text-sm 2xl:text-base font-medium">Contract End Date</p>
                <p class="text-sm 2xl:text-base">@(Model.OafData.contractenddate == null ? "" : Convert.ToDateTime(Model.OafData.contractenddate).ToString("dd/MM/yyyy"))</p>
            </div>

            <div>
                <p class="text-sm 2xl:text-base font-medium">Client Coordinator</p>
                <p class="text-sm 2xl:text-base">@Model.OafData.clientcoordinator</p>
            </div>
        </div>
        <div class="mb-4">
            <p class="text-sm 2xl:text-base font-medium">Milestones</p>

            <div class="flex flex-col mb-4">
                <div class="-m-1.5 overflow-x-auto">
                    <div class="p-1.5 min-w-full inline-block align-middle">
                        <div class="overflow-hidden">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead>
                                    <tr>
                                        <th scope="col"
                                            class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                            MileStone
                                        </th>
                                        <th scope="col"
                                            class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                            Amount
                                        </th>
                                        <th scope="col"
                                            class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                            Percentage
                                        </th>
                                        <th scope="col"
                                            class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                            Days
                                        </th>
                                    </tr>
                                </thead>

                                <tbody class="divide-y divide-gray-200">
                                    @if (Model.OafData.Milestonlist != null && (Model.OafData.Milestonlist).Count > 0)
                                    {
                                        foreach (var milestone in Model.OafData.Milestonlist)
                                        {
                                            <tr>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                                    @milestone.Milestonedesc
                                                </td>
                                                <td class="px-6 py-4 text-sm text-gray-800 ">
                                                    @milestone.Amount
                                                </td>
                                                <td class="px-6 py-4 text-sm text-gray-800 ">
                                                    @milestone.Percentage
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 "> @milestone.Days</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
<div class="my-4">
    <div class="flex flex-col">
        <div class="-m-1.5 overflow-x-auto">
            <div class="p-1.5 min-w-full inline-block align-middle">
                <div class="border rounded-lg overflow-hidden">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">Costing Sheet</th>
                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">Skills</th>
                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">Experience</th>
                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">No. of Resources</th>
                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">No. of Days</th>
                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">Cost Per Skill</th>
                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">Total Cost</th>
                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">Customer price</th>
                                <th scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">Total Price</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @if (Model.OafData.Costsheetdata != null)
                            {
                                var costSheet = Model.OafData.Costsheetdata;
                                int count = Model.OafData.Costsheetdata.costsheetdetails.Count;
                                var totalResources = 0;
                                decimal? totalCost = 0;
                                decimal? totalPrice = 0;
                                decimal? customerPrice = 0;

                                for (int i = 0; i < count; i++)
                                {
                                    totalResources += costSheet.costsheetdetails[i].Requiredresource;
                                    totalCost += costSheet.costsheetdetails[i].Totalcost;
                                    totalPrice += costSheet.costsheetdetails[i].Totalprice;
                                    customerPrice += costSheet.costsheetdetails[i].Customerprice;
                                }

                                for (int i = 0; i < (count < 3 ? 3 : count); i++)
                                {
                                    <tr>
                                        @if (i == 0)
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">Cost Sheet Name: <span class="font-bold">@costSheet.costsheetname</span></td>
                                        }
                                        else if (i == 1)
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">
                                                Total Resources Required:
                                                <span class="font-bold">@totalResources</span>
                                            </td>
                                        }
                                        else if (i == 2)
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">
                                                Total Skills Required:
                                                <span class="font-bold">@count</span>
                                            </td>
                                        }
                                        else
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800"></td>
                                        }
                                        @if (i < count)
                                        {
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].Skillname</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].skillexperience</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].Requiredresource</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].Perioddays</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].Skillcost</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].Totalcost</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].Customerprice</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@costSheet.costsheetdetails[i].Totalprice</td>
                                        }
                                        else
                                        {
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                            <td></td>
                                        }
                                    </tr>
                                }
                                <tr>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">Total</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800"></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800"></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800"></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800"></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800"></td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">₹@totalCost</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">₹@customerPrice</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">₹@totalPrice</td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            </div>
        </div>
    </div>
</div>



<p class="text-base 2xl:text-lg font-bold text-gray-600 mb-4">Lines Info</p>
<div class="flex flex-col mb-4">
    <div class="-m-1.5 overflow-x-auto">
        <div class="p-1.5 min-w-full inline-block align-middle">
            <div class="overflow-hidden">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead>
                        <tr>
                            <th scope="col"
                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                Line No
                            </th>
                            <th scope="col"
                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                Line Description 1
                            </th>
                            <th scope="col"
                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                Line Description 2
                            </th>
                            <th scope="col"
                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                Amount
                            </th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-gray-200">
                        @if (Model != null)
                        {
                            foreach (var line in Model.OafData.oaflines)
                            {
                                <tr>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                        @line.lineno
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-800 ">
                                        @line.linedescription1
                                    </td>
                                    <td class="px-6 py-4 text-sm text-gray-800 ">
                                        @line.linedescription2
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@line.lineamount</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C] mb-6">Pre Sales Checklist</h2>
<div class="checklist-wrapper">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
        @if (Model != null)
        {
            @foreach (var checklist in Model.OafData.oafchecklists)
            {
                <div class="dh-checklist-fill">

                    <div class="flex items-center gap-2 mb-2">
                        <div class="flex">
                            <input type="checkbox"
                                   class="shrink-0 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500"
                                   id="hs-checkbox-group-4">
                        </div>
                        <span class="font-bold block">
                            <input type="hidden" class="oafchecklistid" value="@checklist.oafchecklistid">
                            @checklist.question
                        </span>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-gray-500">Response From Client</p>
                        <p class="text-sm text-gray-400">
                            @checklist.clientresponse
                        </p>
                    </div>
                    <textarea class="k-input w-full mt-4" name="" id="rejectremarks" cols="30" rows="2"></textarea>
                </div>
            }

        }

    </div>
    <div class="mb-4 additional-information">
        <p class="font-bold text-xl mb-2">Additional Information</p>
        <textarea class="k-input w-full" name="" id="" cols="30" rows="10"></textarea>
    </div>
    @if (Model != null)
    {
        if (Model.OafData.statusid == 2)
        {
            <div class="flex items-center gap-4">
                <button data-hs-overlay="#hs-medium-modal" type="button"
                        class="assign-btn py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                    Approve & Assign DA
                </button>
                <button type="button" onclick="this.closest('.checklist-wrapper').classList.add('edit-mode');"
                        class="reject-btn py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-black bg-white text-black hover:bg-black hover:text-white focus:outline-none focus:ring-2 focus:ring-black focus:ring-offset-2 transition-all text-sm sm:text-base">
                    Reject
                </button>
                <button type="button" onclick="dhresponse()"
                        class="submit-reject-btn py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-black bg-white text-black hover:bg-black hover:text-white focus:outline-none focus:ring-2 focus:ring-black focus:ring-offset-2 transition-all text-sm sm:text-base">
                    Submit
                </button>
                <button type="button" onclick="this.closest('.checklist-wrapper').classList.remove('edit-mode');"
                        class="cancel-reject-btn py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-black bg-white text-black hover:bg-black hover:text-white focus:outline-none focus:ring-2 focus:ring-black focus:ring-offset-2 transition-all text-sm sm:text-base">
                    Cancel
                </button>
            </div>
        }
        else
        {
            @* <p>OAF has already been addressed.</p> *@
            @if (Model.OafData.statusid == 5)
            {
                <div class="bg-teal-50 border-t-2 border-teal-500 rounded-lg p-4 mt-4" role="alert">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <!-- Icon -->
                            <span class="inline-flex justify-center items-center w-8 h-8 rounded-full border-4 border-teal-100 bg-teal-200 text-teal-800">
                                <svg class="flex-shrink-0 w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z" /><path d="m9 12 2 2 4-4" /></svg>
                            </span>
                            <!-- End Icon -->
                        </div>
                        <div class="ms-3">

                            <h3 class="text-gray-800 font-semibold">
                                OAF Approved/Delivery Anchor Assigned!
                            </h3>
                            <p class="text-sm text-gray-700">
                                OAF has already been addressed.
                            </p>
                        </div>
                    </div>

                </div>
            }
        }
        @if (Model.OafData.statusid == 4)
        {
            <div class="bg-red-50 border-t-2 border-red-500 rounded-lg p-4" role="alert">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <span class="inline-flex justify-center items-center w-8 h-8 rounded-full border-4 border-red-100 bg-red-200 text-red-800">
                            <svg class="flex-shrink-0 w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 32 32"><path fill="currentColor" d="M16 2C8.2 2 2 8.2 2 16s6.2 14 14 14s14-6.2 14-14S23.8 2 16 2zm0 26C9.4 28 4 22.6 4 16S9.4 4 16 4s12 5.4 12 12s-5.4 12-12 12z" /><path fill="currentColor" d="M21.4 23L16 17.6L10.6 23L9 21.4l5.4-5.4L9 10.6L10.6 9l5.4 5.4L21.4 9l1.6 1.6l-5.4 5.4l5.4 5.4z" /></svg>
                        </span>
                    </div>
                    <div class="ms-3">
                        <h3 class="text-gray-800 font-semibold">OAF Rejected.</h3>
                        <p class="text-sm text-gray-700">OAF has already been addressed.</p>
                    </div>
                </div>
            </div>
        }
    }
</div>

