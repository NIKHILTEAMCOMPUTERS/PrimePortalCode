        // const assignDaModal = HSOverlay.on("#hs-medium-modal");
        HSOverlay.on('close', (modal) => {
            console.log(modal);
            if (modal.id === "hs-medium-modal") {
                select.setSelected([]);
                document.querySelector("#user-info-wrapper").innerHTML = "";
            } else if (modal.id === "hs-success-modal") {
                window.location.href = "/OAF/Index"
            }
        });

        const select = new SlimSelect({
            select: "#user-list",
            settings: {
                closeOnSelect: true,
            }
        })
        function showPreview(btn) {
            document.querySelector("#filePreviewWrapper").innerHTML = "";
            const fileUrl = btn.getAttribute("data-url");
            let previewElem;
            if (fileUrl.includes("pdf")) {
                previewElem = document.createElement("iframe");
                previewElem.src = fileUrl;
                previewElem.style.height = "70vh";
            } else {
                previewElem = document.createElement("img");
                previewElem.src = fileUrl;
            }
            previewElem.style.width = "100%";
            previewElem.style.maxWidth = "100%";
            document.querySelector("#filePreviewWrapper").appendChild(previewElem);
            HSOverlay.open(document.querySelector("#filePreviewModal"));
        }



        // post method

        //Approval

        function savedata() {
            if (true) {
                document.querySelector("#loader").style.display = "flex";
                const bodyData = {
                    "oafid": $("#hiddenoafid").val(),
                    "statusid": "5",
                    "deliveryanchorid": select.getSelected()[0],
                    "remarks": "",
                    "Oafchecklists": []
                };


                const allQuestionsDiv = document.querySelectorAll(".dh-checklist-fill");
                allQuestionsDiv.forEach(ques => {
                    const _question = {};
                    _question.oafchecklistid = ques.querySelector("input.oafchecklistid").value;
                    _question.remarks = "Approved";
                    _question.statusid = "5";
                    bodyData.Oafchecklists.push(_question);
                });



                const formData = new FormData();

                formData.append("contracts", JSON.stringify(bodyData));
                formData.append("Status", "Approved");
                $.ajax({
                    type: "POST",
                    url: "@Url.Action("DHResponse","OAF")",
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (res) {
                        $("#loader").hide();
                        if (res.success == true) {
                            HSOverlay.open(document.querySelector("#hs-success-modal"))

                        } else {
                            toastr.error(res.msg);
                            $("#loader").hide();
                        }
                    }
                });
            }
        }

        // Rejected

        function dhresponse() {
            if (true) {
                document.querySelector("#loader").style.display = "flex";
                const bodyData = {
                    "oafid": $("#hiddenoafid").val(),
                    "statusid": "4",
                    "remarks": $("#rejectremarks").val(),
                    "Oafchecklists": []
                };


                const allQuestionsDiv = document.querySelectorAll(".dh-checklist-fill");
                allQuestionsDiv.forEach(ques => {
                    const isChecked = ques.querySelector("input[type='checkbox']").checked;
                    const _question = {};
                    _question.oafchecklistid = ques.querySelector("input.oafchecklistid").value;
                    _question.remarks = ques.querySelector("textarea").value,
                        _question.statusid = isChecked ? "4" : "5";
                    bodyData.Oafchecklists.push(_question);
                });



                const formData = new FormData();

                formData.append("contracts", JSON.stringify(bodyData));
                formData.append("Status", "Reject");
                $.ajax({
                    type: "POST",
                    url: "@Url.Action("DHResponse","OAF")",
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (res) {
                        $("#loader").hide();
                        if (res.success == true) {
                            toastr.success(res.msg);
                            setTimeout(() => {
                                window.location.href = "/OAF/Index"
                            }, 1000)
                        } else {
                            toastr.error(res.msg);
                            $("#loader").hide();
                        }
                    }
                });
            }
        }


