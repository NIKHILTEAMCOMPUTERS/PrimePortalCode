@using System.Globalization;
@model RMS.Client.ViewModels.UpsertOafViewModel;
@section PageStyles {
    <link rel="stylesheet" href="~/assets/js/summernote/summernote-lite.min.css" />
    <style>
        .note-editable ol,
        .note-editable ul {
            list-style: style;
        }

        .custom-grid {
            grid-template-columns: 1fr 1fr auto 1fr 1fr auto 1fr 1fr 1fr;
        }

        @@media screen and (max-width: 1100px) {
            .custom-grid {
                grid-template-columns: 1fr 1fr 1fr 1fr 1fr 1fr;
            }
        }

        @@media screen and (max-width: 800px) {
            .custom-grid {
                grid-template-columns: 1fr 1fr 1fr;
            }
        }

        @@media screen and (max-width: 636px) {
            .custom-grid {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media screen and (max-width: 480px) {
            .custom-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

<div class="flex items-center gap-4 mb-5">
    <a asp-action="Index" asp-controller="OAF" class="py-2 px-2 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base" title="Back">
        <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M11.707 5.293a1 1 0 0 1 0 1.414L7.414 11H19a1 1 0 1 1 0 2H7.414l4.293 4.293a1 1 0 0 1-1.414 1.414l-6-6a1 1 0 0 1 0-1.414l6-6a1 1 0 0 1 1.414 0z" /></svg>
    </a>
    <div>
        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Order Acceptance Form</h2>
        <p>Fill the required details below.</p> 
    </div>
</div>
<form class="flex-1 flex flex-col">
    <input type="hidden" id="hidOafId" value="@Model.OafData.oafid" />
    <div class="multipart-wrapper flex-1 flex flex-col">
        <div class="multipart-indicators-wrapper flex items-center border-b">
            <div class="multipart-indicator py-2 px-4 active">OAF Form</div>
            <div class="multipart-indicator py-2 px-4">Lines</div>
            <div class="multipart-indicator py-2 px-4">Presales Checklist</div>
            <!-- <div class="multipart-indicator py-2 px-4">Contact Persons</div> -->
        </div>
        <div class="multipart-form-wrapper mt-4 flex-1 flex flex-col">
            <div class="multipart-form active w-full flex-1 flex flex-col">
                @if (Model.OafData.oafid == 0 || Model.OafData.oafid == null)
                {
                    <div class="d-flex items-center gap-4 mb-4">
                        <div class="inline-flex items-center rounded shadow py-3 px-6 gap-2">
                            <input type="radio" onchange="Disable(this)" name="po-status" class="shrink-0 mt-0.5 border-gray-200 rounded-full text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="poAwaitedCheckbox">

                            <label for="poAwaitedCheckbox" class="block font-bold ">PO Awaited</label>
                        </div>
                        <div class="inline-flex items-center rounded shadow py-3 px-6 gap-2">
                            <input type="radio" onchange="removeDisable(this)" name="po-status" class="shrink-0 mt-0.5 border-gray-200 rounded-full text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="poArrivedCheckbox" checked>

                            <label for="poArrivedCheckbox" class="block font-bold ">PO Available</label>
                        </div>
                    </div>
                }
                <div class="flex-1 overflow-y-auto">
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4">
                        <div>
                            <span class="mb-2 font-medium block">PO Number*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="text" id="ponumber" value="@Model.OafData.ponumber"
                                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:cursor-not-allowed"
                                       placeholder="Enter PO Number" maxlength="30">
                            </div>
                        </div>
                        <div>
                            <span class="mb-2 font-medium block">PO Value*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="number" id="Povalue" value="@Model.OafData.povalue" step="0.01"
                                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                       placeholder="Enter PO Value">
                            </div>
                        </div>
                        <div>
                            <span class="mb-2 font-medium block">Order Description</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="text" id="Orderdescription" value="@Model.OafData.orderdescription"
                                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                       placeholder="Enter Order Description">
                            </div>
                        </div>
                    </div>
                    <div class="mb-4">
                        <span class="mb-2 font-medium block">PO Terms & Conditions</span>
                        <div class="flex items-center gap-3 flex-wrap">
                            <textarea id="summernote"
                                      class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500">@Model.OafData.potermscondition</textarea>
                        </div>
                    </div>
                    <div class="mb-4">
                        <div class="flex items-center gap-4 flex-wrap justify-between mb-2">
                            <div class="flex items-center gap-2">
                                <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Attachments</h2>
                                <div class="hs-tooltip inline-block [--trigger:click]">
                                    <a class="hs-tooltip-toggle block text-center" href="javascript:;">
                                        <span class="w-10 h-10 inline-flex justify-center items-center gap-2 rounded-md bg-gray-50 border border-transparent text-gray-600 hover:bg-emerald-50 hover:border-emerald-200 hover:text-emerald-600">
                                            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M11 17h2v-6h-2v6Zm1-8q.425 0 .713-.288T13 8q0-.425-.288-.713T12 7q-.425 0-.713.288T11 8q0 .425.288.713T12 9Zm0 13q-2.075 0-3.9-.788t-3.175-2.137q-1.35-1.35-2.137-3.175T2 12q0-2.075.788-3.9t2.137-3.175q1.35-1.35 3.175-2.137T12 2q2.075 0 3.9.788t3.175 2.137q1.35 1.35 2.138 3.175T22 12q0 2.075-.788 3.9t-2.137 3.175q-1.35 1.35-3.175 2.138T12 22Zm0-2q3.35 0 5.675-2.325T20 12q0-3.35-2.325-5.675T12 4Q8.65 4 6.325 6.325T4 12q0 3.35 2.325 5.675T12 20Zm0-8Z" /></svg>
                                        </span>
                                        <div class="hs-tooltip-content hs-tooltip-shown:opacity-100 hs-tooltip-shown:visible opacity-0 transition-opacity inline-block absolute invisible z-10 py-3 px-4 bg-white border text-sm text-gray-600 rounded-md shadow-md" role="tooltip">
                                            *Only accept "image,.pdf"
                                        </div>
                                    </a>
                                </div>
                            </div>
                            <div class="flex items-center gap-4">
                                <div>
                                    <input class="hidden" type="file" id="emailmessages" accept="image/*" onchange="handleFileChange(this, '1');">
                                    <label for="emailmessages" class="underline" title="Select only image" style="cursor:pointer;">Attach Snapshot</label>
                                </div>
                                <div>
                                    <input class="hidden" type="file" id="proposal" accept="application/pdf" onchange="handleFileChange(this, '2');">
                                    <label for="proposal" class="underline" title="Select only pdf" style="cursor:pointer;">Attach Proposal</label>
                                </div>
                                <div>
                                    <input class="hidden" type="file" id="po" accept="application/pdf" onchange="handleFileChange(this, '3');">
                                    <label for="po" class="underline" title="Select only pdf" style="cursor:pointer;">Attach PO</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="attachments-wrapper flex items-center gap-4 flex-wrap">
                        @if (Model.OafData.emailattachment != null)
                        {
                            @* < div class="relative group">
                        <p onclick="showPreview('1');" class="text-blue-500 underline cursor-pointer" onclick="showPreview();">Email/Messages</p>`
                        < button type = "button" onclick = "removeFile(this, '${type}');" class= "p-1 absolute right-0 top-0 rounded-full bg-black hover:bg-red-600 translate-x-[50%] translate-y-[-50%] hidden group-hover:block" >
                        < svg class= "w-3 h-3 text-white" xmlns = "http://www.w3.org/2000/svg" width = "24" height = "24" viewBox = "0 0 24 24" >< path fill = "currentColor" d = "M6.4 19L5 17.6l5.6-5.6L5 6.4L6.4 5l5.6 5.6L17.6 5L19 6.4L13.4 12l5.6 5.6l-1.4 1.4l-5.6-5.6L6.4 19Z" /></ svg >
                        </ button >
                        </ div > *@
                            <div class="relative group">
                                <p onclick="showPreview('1', '@Model.OafData.emailattachment');" class="text-blue-500 underline cursor-pointer">Email/Messages</p>
                                <button onclick="removeFile(this, '1');" class="p-1 absolute right-0 top-0 rounded-full bg-black hover:bg-red-600 translate-x-[50%] translate-y-[-50%] hidden group-hover:block">
                                    <svg class="w-3 h-3 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M6.4 19L5 17.6l5.6-5.6L5 6.4L6.4 5l5.6 5.6L17.6 5L19 6.4L13.4 12l5.6 5.6l-1.4 1.4l-5.6-5.6L6.4 19Z" /></svg>
                                </button>
                            </div>
                        }
                        @if (Model.OafData.proposalattachment != null)
                        {
                            @* < div class="relative group">
                        <p onclick="showPreview('2');" class="text-blue-500 underline cursor-pointer" onclick="showPreview();">Proposal</p>`
                        < button type = "button" onclick = "removeFile(this, '${type}');" class= "p-1 absolute right-0 top-0 rounded-full bg-black hover:bg-red-600 translate-x-[50%] translate-y-[-50%] hidden group-hover:block" >
                        < svg class= "w-3 h-3 text-white" xmlns = "http://www.w3.org/2000/svg" width = "24" height = "24" viewBox = "0 0 24 24" >< path fill = "currentColor" d = "M6.4 19L5 17.6l5.6-5.6L5 6.4L6.4 5l5.6 5.6L17.6 5L19 6.4L13.4 12l5.6 5.6l-1.4 1.4l-5.6-5.6L6.4 19Z" /></ svg >
                        </ button >
                        </ div > *@
                            <div class="relative group">
                                <p onclick="showPreview('2', '@Model.OafData.proposalattachment');" class="text-blue-500 underline cursor-pointer">Proposal</p>
                                <button onclick="removeFile(this, '2');" class="p-1 absolute right-0 top-0 rounded-full bg-black hover:bg-red-600 translate-x-[50%] translate-y-[-50%] hidden group-hover:block">
                                    <svg class="w-3 h-3 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M6.4 19L5 17.6l5.6-5.6L5 6.4L6.4 5l5.6 5.6L17.6 5L19 6.4L13.4 12l5.6 5.6l-1.4 1.4l-5.6-5.6L6.4 19Z" /></svg>
                                </button>
                            </div>
                        }
                        @if (Model.OafData.poattachment != null)
                        {
                            @* < div class="relative group">
                        <p onclick="showPreview('3');" class="text-blue-500 underline cursor-pointer" onclick="showPreview();">PO</p>`
                        < button type = "button" onclick = "removeFile(this, '${type}');" class= "p-1 absolute right-0 top-0 rounded-full bg-black hover:bg-red-600 translate-x-[50%] translate-y-[-50%] hidden group-hover:block" >
                        < svg class= "w-3 h-3 text-white" xmlns = "http://www.w3.org/2000/svg" width = "24" height = "24" viewBox = "0 0 24 24" >< path fill = "currentColor" d = "M6.4 19L5 17.6l5.6-5.6L5 6.4L6.4 5l5.6 5.6L17.6 5L19 6.4L13.4 12l5.6 5.6l-1.4 1.4l-5.6-5.6L6.4 19Z" /></ svg >
                        </ button >
                        </ div > *@
                            <div class="relative group">
                                <p onclick="showPreview('3', '@Model.OafData.poattachment');" class="text-blue-500 underline cursor-pointer">PO</p>
                                <button onclick="removeFile(this, '3');" class="p-1 absolute right-0 top-0 rounded-full bg-black hover:bg-red-600 translate-x-[50%] translate-y-[-50%] hidden group-hover:block">
                                    <svg class="w-3 h-3 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M6.4 19L5 17.6l5.6-5.6L5 6.4L6.4 5l5.6 5.6L17.6 5L19 6.4L13.4 12l5.6 5.6l-1.4 1.4l-5.6-5.6L6.4 19Z" /></svg>
                                </button>
                            </div>
                        }
                    </div>
                    <div class="mb-2">
                        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Project Details</h2>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-4">
                        <div>
                            <input type="hidden" id="hidCustomerName" value="@(Model.OafData.customerid == null ? "" : Model.OafData.customerid)" />

                            <span class="mb-2 font-medium block">Customer*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <select id="CustomerDropdown" name="Customerid" asp-items="@Model.Customers"
                                        class="multi-select" onchange="handleCustomerChange(this);">
                                    <option value="">Select Customer</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <span class="mb-2 font-medium block">Project Name*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="text" id="Projectname" value="@Model.OafData.projectname" oninput="this.value = this.value.replace(/[^a-zA-Z ]/g, '');"
                                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                       placeholder="Enter Project Name" maxlength="25">
                            </div>
                        </div>
                        <div>
                            <input type="hidden" id="hidprojectmodel" value="@(Model.OafData.projectmodel == null ? "" : Model.OafData.projectmodel)" />
                            <span class="mb-2 font-medium block">Project Model*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <select class="multi-select" id="Projectmodel">
                                    <option value="">Select Project Model</option>
                                    <option value="1">ON-Site</option>
                                    <option value="2">OFF-Site</option>
                                    <option value="3">Hybrid</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <input type="hidden" id="hidprojecttype" value="@(Model.OafData.projecttypeid == null ? "" : Model.OafData.projecttypeid)" />
                            <span class="mb-2 font-medium block">Project Type*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <select id="projectTypeDropdown" name="ProjectTypeId" asp-items="@Model.ProjectTypes" class="multi-select" onchange="handleProjectTypeChange(this);">
                                    <option value="0" selected>Select Project Type</option>
                                </select>
                            </div>
                        </div>


                        <div>
                            <input type="hidden" id="hidpractice" value="@(Model.OafData.practiceid == null ? "" : Model.OafData.practiceid)" />
                            <span class="mb-2 font-medium block">Practices*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <select id="practiceDropdown" name="PracticeId" class="multi-select">
                                    <option value="0" selected>Select Practice</option>
                                    @foreach (var practiceList in Model.Practices)
                                    {
                                        <option value="@practiceList.Value" data-prac-id="@practiceList.Value" data-prac-n="@practiceList.Text">@practiceList.Text</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div>
                            <input type="hidden" id="hidsubpractice" name="SubPracticeId" value="@Model.OafData.subpracticeid" />
                            <span class="mb-2 font-medium block">Sub-Practices*</span>
                            <div>
                                <select id="subPracticeDropdown"  class="multi-select">
                                </select>
                            </div>
                        </div>

                        <div>
                            <input type="hidden" id="hidaccountmanager" name="accountmanagerid" value="@Model.OafData.accountmanagerid" />
                            <span class="mb-2 font-medium block">Account Manager*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <select id="accountmanagerdropdown" name="accountmanagerid" asp-items="@Model.AccountManagers" class="multi-select">
                                    <option value="" selected>Select Account Manager</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <span class="mb-2 font-medium block">Project Description</span>
                        <textarea type="text" id="Projectdescription"
                                  class="w-full py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                  placeholder="Enter Description ">@Model.OafData.projectdescription</textarea>
                    </div>
                    <div class="mb-2">
                        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Contract Details</h2>
                    </div>
                    <div class="grid grid-cols-1 sm:grid-cols-4 gap-4 mb-4">
                        <div>
                            <span class="mb-2 font-medium block">Contract Number*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="text" id="Contractno" value="@Model.OafData.contractno"
                                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:cursor-not-allowed"
                                       placeholder="Enter Contract Number" maxlength="20">
                            </div>
                        </div>
                        <div>
                            <span class="mb-2 font-medium block">Customer Commitments Start*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="date" asp-for=OafData.contractstartdate id="contractstartdate"
                                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                       oninput="setEndDateMin(this.value)">
                            </div>
                        </div>
                        <div>
                            <span class="mb-2 font-medium block">Customer Commitments End*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="date" asp-for=OafData.contractenddate id="contractenddate"
                                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500" />

                            </div>
                        </div>
                        <div>
                            <span class="mb-2 font-medium block">Client Coordinator</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="text" id="Clientcoordinator" value="@Model.OafData.clientcoordinator" oninput="this.value = this.value.replace(/[^a-zA-Z ]/g, '');"
                                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                       placeholder="Enter Client Coordinator" maxlength="25">
                            </div>
                        </div>
                    </div>

                    @{
                        var oafId = Model.OafData.oafid;
                        var committedClientBillingDate = Model.OafData.CommittedClientBillingDate;
                    }

                    <div class="mb-4 tnmshow hidden">
                        <div class="flex items-end gap-4 flex-wrap">
                            <div>
                                <label>Customer Billing Cycle</label>
                                <select class="k-input" id="customerBillingCycle" onchange="handleCustomerBillingCycleChange(this);">
                                    <option value="0">Select Billing Cycle Date</option>
                                    @for (int i = 1; i <= 30; i++)
                                    {
                                        bool isSelected = (oafId > 0 && committedClientBillingDate.HasValue && i == committedClientBillingDate.Value);
                                        if (isSelected)
                                        {
                                            <option value="@i" selected="selected">@i</option>
                                        }
                                        else
                                        {
                                            <option value="@i">@i</option>
                                        }
                                    }
                                </select>
                            </div>
                            <p class="hidden"></p>
                        </div>
                    </div>



                    <div class="mb-4 tnmhide">
                        <span class="mb-2 font-medium block">Advance</span>
                        @*  <textarea type="text" id="Milestones"
                        class="w-full py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                        placeholder="Enter Milestones">@Model.OafData.milestones</textarea> *@

                        <div class="flex gap-4 flex-wrap">
                            <div class="flex items-stretch rounded border">
                                <div class="border-r px-2 flex items-center">
                                    <span>Advance</span>
                                </div>
                                <div class="border-r pr-2">
                                    <input style="width: 5rem;"  onchange="handleAdvancePercentChange(this)" id="Advancepercent"  value="@Model.OafData.Advancepercent"type="number" class="border-none" min="0" max="50">
                                    <span>%</span>
                                </div>
                                <div class="px-2 flex-1 flex items-center">
                                    <span>Amount</span>
                                    <input readonly id="Advanceamount" value="@Model.OafData.Advanceamount" style="min-width: 8rem" type="number" class="border-none bg-gray-100 rounded w-full ml-2 h-6">
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4 tnmhide">
                        <span class="mb-2 font-medium block">Milestones</span>
                        @*  <textarea type="text" id="Milestones"
                        class="w-full py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                        placeholder="Enter Milestones">@Model.OafData.milestones</textarea> *@

                        <div class="flex gap-4 flex-wrap">
                            <div class="flex gap-4 flex-wrap" id="milestonesContainer">
                                <div class="milestone flex items-stretch rounded border">
                                    <div class="border-r px-2 flex items-center">
                                        <span class="milestone_count">Milestone <span class="milestone-count">1</span></span>
                                    </div>
                                    <div class="border-r pr-2">
                                        <input style="width: 5rem;" onchange="handleMilestonePercentChange(this);" type="number" class="milestone_precentage_inp border-none" min="0" max="100">
                                        <span>%</span>
                                    </div>
                                    <div class="px-2 flex-1 flex items-center">
                                        <span>Amount</span>
                                        <input readonly style="min-width: 8rem" type="number" class="milestone_amount_inp border-none bg-gray-100 rounded w-full ml-2 h-6">
                                    </div>
                                    <div class="px-2 flex items-center">
                                        <span>Days</span>
                                        <input style="width: 5rem" type="number" class="milestone_days_inp border-none bg-gray-100 rounded w-full ml-2 h-6">
                                    </div>
                                </div>
                                <button type="button" id="addMileStoneBtn" onclick="addMilestone();">
                                    <svg class="w-6 h-6 text-gray-600" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 32 32"><path fill="currentColor" d="M16 2A14.173 14.173 0 0 0 2 16a14.173 14.173 0 0 0 14 14a14.173 14.173 0 0 0 14-14A14.173 14.173 0 0 0 16 2m8 15h-7v7h-2v-7H8v-2h7V8h2v7h7Z" /><path fill="none" d="M24 17h-7v7h-2v-7H8v-2h7V8h2v7h7z" /></svg>
                                </button>
                            </div>
                        </div>
                    </div>
                    @* <div class="mb-4">
                        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Create Costing Sheet</h2>
                        <p>Please create the costing sheet by filling the requires information</p>
                    </div> *@
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-2">
                        <div>
                            <div class="flex items-center justify-between gap-3 flex-wrap">
                                <span class="mb-2 font-medium block">Costing sheet*</span>
                                @* <button type="button"
                                        class="px-5 inline-flex justify-center items-center gap-2 rounded-md border outline-none border-transparent text-emerald-500 text-sm 2xl:text-base"
                                        data-hs-overlay="#costing-sheet-modal">
                                    <svg class="w-4 h-4" width="21" height="21" viewBox="0 0 21 21" fill="none"
                                         xmlns="http://www.w3.org/2000/svg">
                                        <path d="M10.5 0C7.72562 0.0334721 5.07431 1.15047 3.11239 3.11239C1.15047 5.07431 0.0334721 7.72562 0 10.5C0.0334721 13.2744 1.15047 15.9257 3.11239 17.8876C5.07431 19.8495 7.72562 20.9665 10.5 21C13.2744 20.9665 15.9257 19.8495 17.8876 17.8876C19.8495 15.9257 20.9665 13.2744 21 10.5C20.9665 7.72562 19.8495 5.07431 17.8876 3.11239C15.9257 1.15047 13.2744 0.0334721 10.5 0ZM16.5 11.25H11.25V16.5H9.75V11.25H4.5V9.75H9.75V4.5H11.25V9.75H16.5V11.25Z"
                                              fill="#00CC83" />
                                        <path d="M16.5 11.25H11.25V16.5H9.75V11.25H4.5V9.75H9.75V4.5H11.25V9.75H16.5V11.25Z"
                                              fill="white" />
                                    </svg>
                                    Create
                                </button> *@
                            </div>
                            <input type="hidden" id="hidcostsheet" value="@(Model.OafData.costsheetid == null ? "" : Model.OafData.costsheetid)" />
                            <div class="flex items-center gap-3 flex-wrap">
                                <select class="multi-select" id="costingsheetdrown" name="costingsheet" onchange="setXvalue(this); setTotalAmount(this);">
                                    <option value="">Select CostSheet</option>
                                </select>
                            </div>
                        </div>
                        <div>
                            <div class="flex items-center justify-between gap-3 flex-wrap">
                                <span class="mb-2 font-medium block">X Value</span>
                            </div>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="number" class="k-input" placeholder="X Value" id="xvalue" value="@Model.OafData.xvalue" readonly>
                            </div>
                        </div>
                        <div>
                            <div class="flex items-center justify-between gap-3 flex-wrap">
                                <span class="mb-2 font-medium block">CostSheet Amount</span>
                            </div>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="number" class="k-input" id="totalamount" value="@Model.OafData.totalamount" readonly>
                            </div>
                        </div>
                    </div>
                    <div>
                        <input class="hidden" type="file" id="costattachment" accept=".xlsx,.xls,.doc,.docx,.pdf" onchange="showFileName(this);">
                        <label for="costattachment" class="py-[.688rem] px-4 inline-flex justify-center items-center gap-2 rounded-md border-2 border-blue-400 font-semibold text-blue-500 hover:text-white hover:bg-blue-500 hover:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all text-sm">
                            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" fill-rule="evenodd" d="M12 4a5 5 0 0 0-5 5v6a1 1 0 1 1-2 0V9a7 7 0 1 1 14 0v8a5 5 0 0 1-10 0V9a3 3 0 0 1 6 0v8a1 1 0 1 1-2 0V9a1 1 0 1 0-2 0v8a3 3 0 0 0 6 0V9a5 5 0 0 0-5-5Z" clip-rule="evenodd" /></svg>
                            @if (Model.OafData.costattachment != null)
                            {
                                <span>@Model.OafData.costattachment.Split("\\").Last()</span>
                            }
                            else
                            {
                                <span>Attach CostSheet</span>
                            }
                        </label>
                        <label>*Only accept ".xlsx,.xls,.doc,.docx,.pdf"</label>
                    </div>
                </div>
                <div class="pt-2 pb-4 sticky -bottom-4 bg-white">
                    <button type="button" onclick="validateFirstPart();"
                            class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                        Next
                    </button>
                </div>
            </div>


            <div class="multipart-form w-full flex-1 flex flex-col">
                <div class="flex items-stretch sm:items-end flex-col sm:flex-row gap-4">
                    <div class="flex-[2]">
                        <label for="">Line Description 1*</label>
                        <input id="ldesc1" type="text" class="k-input w-full">
                    </div>
                    <div class="flex-[2]">
                        <label for="">Line Description 2</label>
                        <input id="ldesc2" type="text" class="k-input w-full">
                    </div>
                    <div class="flex-[1]">
                        <label for="">Line Amount*</label>
                        <input id="lamount" type="number" class="k-input w-full">
                    </div>
                    <button type="button" onclick="addLineItem();"
                            class="py-3 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm">
                        Add/Edit
                    </button>
                </div>
                <div class="flex flex-col my-4 flex-1 overflow-y-auto">
                    <div class="-m-1.5 overflow-x-auto">
                        <div class="p-1.5 min-w-full block align-middle">
                            <div class="overflow-hidden">
                                <table class="min-w-full divide-y divide-gray-200" id="lineItemTable">
                                    <thead>
                                        <tr>
                                            <th scope="col"
                                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                                S.No
                                            </th>
                                            <th scope="col"
                                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                                Line Description 1
                                            </th>
                                            <th scope="col"
                                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                                Line Description 2
                                            </th>
                                            <th scope="col"
                                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                                Amount
                                            </th>
                                            <th scope="col"
                                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                                Action
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200">
                                        @{
                                            if (Model.OafData.oaflines != null && Model.OafData.oaflines.Count > 0)
                                            {
                                                int row = 0;
                                                foreach (var line in Model.OafData.oaflines)
                                                {
                                                                                                                                                <tr>
                                                                                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                                                                                                                                        @(row += 1)
                                                                                                                                                    </td>
                                                                                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">
                                                                                                                                                        @line.linedescription1
                                                                                                                                                    </td>
                                                                                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@line.linedescription2</td>
                                                                                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@line.lineamount</td>
                                                                                                                                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                                                                                                                                        <div class="hs-dropdown relative inline-flex">
                                                                                                                                                            <button id="hs-dropdown-default" type="button"
                                                                                                                                                                    class="hs-dropdown-toggle py-1 px-2 inline-flex justify-center items-center gap-2 border border-transparent rounded-md font-medium text-gray-700 shadow-sm align-middle hover:bg-gray-50 hover:border-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-white focus:ring-emerald-600 transition-all text-sm">
                                                                                                                                                                <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20"><g fill="currentColor"><circle cx="10" cy="15" r="2" /><circle cx="10" cy="10" r="2" /><circle cx="10" cy="5" r="2" /></g></svg>
                                                                                                                                                            </button>

                                                                                                                                                            <div class="hs-dropdown-menu transition-[opacity,margin] duration-[0.1ms] hs-dropdown-open:opacity-100 opacity-0 hidden z-30 mt-2 min-w-[8rem] bg-white shadow-md rounded-lg"
                                                                                                                                                                 aria-labelledby="hs-dropdown-default">
                                                                                                                                                                <button onclick="deleteRow(this);" class="w-full flex items-center gap-x-3.5 py-2 px-3 rounded-md text-sm text-gray-800 hover:bg-gray-100 focus:ring-2 focus:ring-emerald-500">
                                                                                                                                                                    Delete
                                                                                                                                                                </button>
                                                                                                                                                            </div>
                                                                                                                                                        </div>
                                                                                                                                                    </td>
                                                                                                                                                </tr>
                                                }
                                            }
                                            else
                                            {
                                                                                                                                            <tr id="nodata">
                                                                                                                                                <td id="emptyData" colspan="5" class="px-6 py-4 whitespace-nowrap text-sm text-center font-medium text-gray-800 ">
                                                                                                                                                    No Data Yet
                                                                                                                                                </td>
                                                                                                                                            </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="pt-2 pb-4 sticky -bottom-4 bg-white flex items-center gap-4">
                    <button type="button" onclick="showFormStep(1);"
                            class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                        Prev
                    </button>
                    <button type="button" onclick="validateSecondPart();"
                            class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                        Next
                    </button>
                </div>
            </div>


            <div class="multipart-form w-full flex-1 flex flex-col">
                <div class="flex-1 overflow-y-auto">
                    <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C] mb-6">Questions</h2>
                    <div class="presales-questions-wrapper" id="dynamicquestions">
                        @{
                            int quesrow = 0;
                            if (Model.OafData.oafchecklists != null && Model.OafData.oafchecklists.Count > 0)
                            {
                                foreach (var ques in Model.OafData.oafchecklists)
                                {
                                    if (ques.isextra != null && ques.isextra == true)
                                    {
                                                                                                                                    <div class="mb-4 flex items-end gap-4">
                                                                                                                                        <div class="flex-1">
                                                                                                                                            <div class="flex items-center gap-1">
                                                                                                                                                <span class="question_count font-medium">@(quesrow += 1).</span>
                                                                                                                                                <input type="text" class="k-input w-full mb-2" value="@ques.question" placeholder="Enter question">
                                                                                                                                            </div>
                                                                                                                                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                                                                                                                <input type="text" value="@ques.clientresponse"
                                                                                                                                                       class=" py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                                                                                                                                       placeholder="Enter Answer">
                                                                                                                                                <input type="text" value=""
                                                                                                                                                       class="ref-response py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                                                                                                                                       placeholder="Reference Answer">
                                                                                                                                            </div>
                                                                                                                                        </div>
                                                                                                                                        <button onclick="deleteQuestion(this);" class="py-3 px-4 inline-flex justify-center items-center gap-2 rounded-md border-2 border-red-200 font-semibold text-red-500 hover:text-white hover:bg-red-500 hover:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 focus:ring-offset-2 transition-all text-sm">
                                                                                                                                            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="1024" height="1024" viewBox="0 0 1024 1024"><path fill="currentColor" d="M360 184h-8c4.4 0 8-3.6 8-8v8h304v-8c0 4.4 3.6 8 8 8h-8v72h72v-80c0-35.3-28.7-64-64-64H352c-35.3 0-64 28.7-64 64v80h72v-72zm504 72H160c-17.7 0-32 14.3-32 32v32c0 4.4 3.6 8 8 8h60.4l24.7 523c1.6 34.1 29.8 61 63.9 61h454c34.2 0 62.3-26.8 63.9-61l24.7-523H888c4.4 0 8-3.6 8-8v-32c0-17.7-14.3-32-32-32zM731.3 840H292.7l-24.2-512h487l-24.2 512z" /></svg>
                                                                                                                                        </button>
                                                                                                                                    </div>
                                    }
                                    else
                                    {
                                                                                                                                    <div>
                                                                                                                                        <div class="mb-4">
                                                                                                                                            <div class="flex items-center gap-2 mb-2">
                                                                                                                                                <span class="question_count font-medium">@(quesrow += 1)</span>
                                                                                                                                                <label class=" font-medium block"> @ques.question</label>
                                                                                                                                            </div>
                                                                                                                                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                                                                                                                <input type="text" class="k-input w-full" placeholder="Enter Answer" value="@ques.clientresponse" name="Response[]">
                                                                                                                                                <input type="text" class="k-input w-full ref-response" placeholder="Reference Answer" value="" name="Refresponse[]" />
                                                                                                                                            </div>
                                                                                                                                        </div>
                                                                                                                                    </div>
                                    }
                                }
                            }
                        }
                    </div>
                    <div class="flex items-center justify-between flex-wrap p-2">
                        <button onclick="addNewQuestion();" type="button" class="py-[.688rem] px-4 inline-flex justify-center items-center gap-2 rounded-md border-2 border-blue-400 font-semibold text-blue-500 hover:text-white hover:bg-blue-500 hover:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all text-sm">
                            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M18 13h-5v5c0 .55-.45 1-1 1s-1-.45-1-1v-5H6c-.55 0-1-.45-1-1s.45-1 1-1h5V6c0-.55.45-1 1-1s1 .45 1 1v5h5c.55 0 1 .45 1 1s-.45 1-1 1z" /></svg>
                            Add Question
                        </button>
                    </div>
                </div>
                <div class="pt-2 pb-4 sticky -bottom-4 bg-white flex items-center gap-4">
                    <button type="button" onclick="showFormStep(2);"
                            class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                        Prev
                    </button>
                    <button type="button" onclick="savedata();"
                            class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                        Save
                    </button>
                </div>
            </div>


        </div>
    </div>

</form>


<div id="costing-sheet-modal" class="hs-overlay hidden w-full h-full fixed top-0 left-0 z-[60] overflow-x-hidden overflow-y-auto">
    <div class="hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:duration-500 mt-0 opacity-0 ease-out transition-all sm:w-full m-3 sm:mx-auto h-[calc(100%-3.5rem)]" style="max-width: 112rem;">
        <div class="max-h-full overflow-hidden flex flex-col bg-white border shadow-sm rounded-xl">
            <div class="flex justify-between items-center py-3 px-4 border-b">
                <div>
                    <h2 class="font-bold text-gray-800">Costing sheet</h2>
                </div>
                <button type="button" class="hs-dropdown-toggle inline-flex flex-shrink-0 justify-center items-center h-8 w-8 rounded-md text-gray-500 hover:text-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 focus:ring-offset-white transition-all text-sm" data-hs-overlay="#costing-sheet-modal">
                    <span class="sr-only">Close</span>
                    <svg class="w-3.5 h-3.5" width="8" height="8" viewBox="0 0 8 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M0.258206 1.00652C0.351976 0.912791 0.479126 0.860131 0.611706 0.860131C0.744296 0.860131 0.871447 0.912791 0.965207 1.00652L3.61171 3.65302L6.25822 1.00652C6.30432 0.958771 6.35952 0.920671 6.42052 0.894471C6.48152 0.868271 6.54712 0.854471 6.61352 0.853901C6.67992 0.853321 6.74572 0.865971 6.80722 0.891111C6.86862 0.916251 6.92442 0.953381 6.97142 1.00032C7.01832 1.04727 7.05552 1.1031 7.08062 1.16454C7.10572 1.22599 7.11842 1.29183 7.11782 1.35822C7.11722 1.42461 7.10342 1.49022 7.07722 1.55122C7.05102 1.61222 7.01292 1.6674 6.96522 1.71352L4.31871 4.36002L6.96522 7.00648C7.05632 7.10078 7.10672 7.22708 7.10552 7.35818C7.10442 7.48928 7.05182 7.61468 6.95912 7.70738C6.86642 7.80018 6.74102 7.85268 6.60992 7.85388C6.47882 7.85498 6.35252 7.80458 6.25822 7.71348L3.61171 5.06702L0.965207 7.71348C0.870907 7.80458 0.744606 7.85498 0.613506 7.85388C0.482406 7.85268 0.357007 7.80018 0.264297 7.70738C0.171597 7.61468 0.119017 7.48928 0.117877 7.35818C0.116737 7.22708 0.167126 7.10078 0.258206 7.00648L2.90471 4.36002L0.258206 1.71352C0.164476 1.61976 0.111816 1.4926 0.111816 1.36002C0.111816 1.22744 0.164476 1.10028 0.258206 1.00652Z" fill="currentColor" />
                    </svg>
                </button>
            </div>
            <div class="p-4 overflow-y-auto">
                <div class="flex items-center justify-between mb-5">
                    <div>
                        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Create New</h2>
                        <p>Please create the costing sheet by filling the requires information</p>
                    </div>

                </div>

                <form onsubmit="submitCostingSheet(event);">
                    <div class="mb-4">
                        <span class="mb-2 font-medium block">Costing Sheet Name*</span>
                        <div class="flex items-center gap-3 flex-wrap">
                            <input type="text" id="costingSheetName"
                                   class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                   placeholder="Costing Sheet Name">
                        </div>
                    </div>
                    <div id="costingModalWrapper" class="flex flex-col gap-6">
                        <div class="grid custom-grid gap-3">
                            <div>
                                <span class="mb-2 font-medium block">Skill Name*</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <select class="k-input skill_name" onchange="getexp(this);" id="cost">
                                        <option value="">Select Skill</option>
                                    </select>
                                </div>
                            </div>

                            <div>
                                <span class="mb-2 font-medium block">Skill Experience*</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <select class="k-input skill_exp" onchange="CalcAmount(this);" id="exp">
                                        <option value="">Select</option>
                                    </select>
                                </div>
                            </div>

                            <div>
                                <span class="mb-2 font-medium block">Resources*</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input type="text" onchange="CalcAmount(this);" style="width: 5rem"
                                           class="required_resources py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                           placeholder="Required Resources" value="1" readonly>
                                </div>
                            </div>

                            <div>
                                <span class="font-medium block mb-2">Skill Cost</span>
                                <div class="flex items-center gap-3">
                                    <input type="text"
                                           class="skill_cost py-3 px-4 flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                           placeholder="Skill Cost" readonly>
                                </div>
                            </div>
                            <div>
                                <span class="font-medium block mb-2">Period(Days)</span>
                                <div class="flex items-center gap-3">
                                    <input type="text" onchange="handlePeriodChange(this)";
                                           class="period_days cs-period py-3 px-4 flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                           placeholder="Enter Days">
                                </div>
                            </div>
                            <div>
                                <span class="font-medium block mb-2">X Value</span>
                                <div class="flex items-center gap-3">
                                    <input type="text" style="width: 5.25rem"
                                           class="x-value py-3 px-4 flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                           placeholder="X Value" onchange="handleXValueChange(this)">
                                </div>
                            </div>
                            <div>
                                <span class="font-medium block mb-2">Customer Price</span>
                                <div class="flex items-center gap-3">
                                    <input type="text"
                                           class="cus-price py-3 px-4 flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                           placeholder="0" onchange="handleCPChange(this);">
                                </div>
                            </div>
                            <div>
                                <span class="font-medium block mb-2">Total Cost</span>
                                <div class="flex items-center gap-3">
                                    <input type="text"
                                           class="total-cost py-3 px-4 flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
