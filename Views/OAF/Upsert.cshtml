        function addMilestone() {
            var container = document.getElementById('milestonesContainer');
            var milestoneCount = container.querySelectorAll('.milestone').length + 1;

            var milestoneDiv = document.createElement('div');
            milestoneDiv.classList.add('milestone', "flex", "items-stretch", "rounded", "border");

            milestoneDiv.innerHTML += `
                        <div class="border-r px-2 flex items-center">
                            <span class="milestone_count">Milestone <span class="milestone-count">${milestoneCount}</span></span>
                        </div>
                        <div class="border-r pr-2">
                                        <input onchange="handleMilestonePercentChange(this);" style="width: 5rem;" type="number" class="milestone_precentage_inp border-none" min="0" max="100">
                            <span>%</span>
                        </div>
                        <div class="px-2 flex-1 flex items-center">
                            <span>Amount</span>
                                <input readonly style="min-width: 8rem" type="number" class="milestone_amount_inp border-none bg-gray-100 rounded w-full ml-2 h-6">
                        </div>
                                <div class="px-2 flex items-center">
                                    <span>Days</span>
                                        <input style="width: 5rem" type="number" class="milestone_days_inp border-none bg-gray-100 rounded w-full ml-2 h-6">
                                </div>
                        <button class="mr-2" type="button" onclick="removeMilestone(this);">
                            <svg class="w-6 h-6 text-gray-600" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" fill-rule="evenodd" d="M12 21a9 9 0 1 0 0-18a9 9 0 0 0 0 18m-5-8h10v-2H7z" clip-rule="evenodd"/></svg>
                        </button>
            `;

            const mileStoneAddBtn = document.createElement("button");
            mileStoneAddBtn.setAttribute("id", "addMileStoneBtn");
            mileStoneAddBtn.setAttribute("onclick", "addMilestone();");
            mileStoneAddBtn.setAttribute("type", "button");
            mileStoneAddBtn.innerHTML = `<svg class="w-6 h-6 text-gray-600" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 32 32"><path fill="currentColor" d="M16 2A14.173 14.173 0 0 0 2 16a14.173 14.173 0 0 0 14 14a14.173 14.173 0 0 0 14-14A14.173 14.173 0 0 0 16 2m8 15h-7v7h-2v-7H8v-2h7V8h2v7h7Z" /><path fill="none" d="M24 17h-7v7h-2v-7H8v-2h7V8h2v7h7z" /></svg>`;
            
            container.querySelector("#addMileStoneBtn")?.remove();
            container.appendChild(milestoneDiv);
            container.appendChild(mileStoneAddBtn);
        }

        function removeMilestone(btn) {
            btn.closest(".milestone").remove();
            recalculateMilestoneNumbers();
        }

        function recalculateMilestoneNumbers() {
            document.querySelectorAll(".milestone-count").forEach((item, index) => {
                item.innerText = index + 1;
            })
        }

        function getMilestoneItems() {
            const _milestoneItems = [];
            let validFlag = true;

            const allMilestoneDiv = document.querySelectorAll(".milestone");

            if (!allMilestoneDiv?.length) return _milestoneItems;

            if (allMilestoneDiv.length > 2) {
                allMilestoneDiv.forEach(item => {
                    // if (!item.querySelector(".milestone_precentage_inp").value || ) {

                    // }
                    _milestoneItems.push({
                        Milestonedesc: item.querySelector(".milestone_count").innerText,
                        Percentage: item.querySelector(".milestone_precentage_inp").value,
                        Amount: item.querySelector(".milestone_amount_inp").value,
                        Days: item.querySelector(".milestone_days_inp").value,
                    })
                })
            } else {
                allMilestoneDiv.forEach(item => {
                    _milestoneItems.push({
                        Milestonedesc: item.querySelector(".milestone_count").innerText,
                        Percentage: item.querySelector(".milestone_precentage_inp").value,
                        Amount: item.querySelector(".milestone_amount_inp").value,
                        Days: item.querySelector(".milestone_days_inp").value,
                    })
                })
            }

            return _milestoneItems;
        }

        function CalcAmount(inp) {
            const costSheetRow = inp.closest(".grid");
            const skillid = costSheetRow.querySelector(".skill_name").value;
            const _exp = costSheetRow.querySelector(".skill_exp").value;
            const no_of_resources = costSheetRow.querySelector(".required_resources");
            const finalAmountExp = costSheetRow.querySelector(".skill_cost");

            if (skillid) {
                let exp_amount;

                skillsData.forEach(skill => {
                    if (skill.skillid == skillid) {
                        skill.skillcostings.forEach(exp => {
                            if (exp.expname == _exp) {
                                exp_amount = exp.amount;
                            }
                        })
                    }
                })

                if (exp_amount && no_of_resources.value) {
                    const calculatedAmount = Number(exp_amount) * Number(no_of_resources.value);
                    finalAmountExp.value = calculatedAmount;
                } else {
                    finalAmountExp.value = "";
                }
            }
            const changeEvent = new Event("change");
            costSheetRow.querySelector(".cs-period").dispatchEvent(changeEvent);
            costSheetRow.querySelector(".x-value").dispatchEvent(changeEvent);
        }

        function handleXValueChange(inp) {
            const skillCost = inp.closest(".custom-grid").querySelector(".skill_cost")?.value;
            if (!skillCost) return;

            inp.closest(".custom-grid").querySelector(".cus-price").value = Number(skillCost) * Number(inp.value);

            const costSheetPeriod = inp.closest(".custom-grid").querySelector(".cs-period")?.value;

            if (!costSheetPeriod) return;

            inp.closest(".custom-grid").querySelector(".total-price").value = Number((Number(inp.closest(".custom-grid").querySelector(".cus-price")?.value) * Number(costSheetPeriod)) / 22).toFixed(2);
        }

        function handlePeriodChange(inp) {
            const skillCost = inp.closest(".custom-grid").querySelector(".skill_cost")?.value;
            if (!skillCost) return;

            inp.closest(".custom-grid").querySelector(".total-cost").value = Number((Number(skillCost) * Number(inp.value)) / 22).toFixed(2);

            const customerPrice = inp.closest(".custom-grid").querySelector(".cus-price")?.value;

            if (!customerPrice) return;

            inp.closest(".custom-grid").querySelector(".total-price").value = Number((Number(customerPrice) * Number(inp.value)) / 22).toFixed(2);
        }

        function handleCPChange(inp) {
            const row = inp.closest(".custom-grid");
            if (!inp.value || !row.querySelector(".skill_cost").value) return;
            row.querySelector(".x-value").value = Math.round(Number(inp.value) / Number(row.querySelector(".skill_cost").value));
        }

        function handleProjectTypeChange(inp) {
            const projectType = inp.value;
            const tnmhideDivs = document.querySelectorAll(".tnmhide");
            const tnmshowDivs = document.querySelectorAll(".tnmshow");
            if(projectType === "1") {
                tnmhideDivs.forEach(item => {
                    item.classList.add("hidden");
                })

                tnmshowDivs.forEach(item => {
                    item.classList.remove("hidden");
                })
            } else {
                tnmhideDivs.forEach(item => {
                    item.classList.remove("hidden");
                })

                tnmshowDivs.forEach(item => {
                    item.classList.add("hidden");
                })
            }
        }

        function handleCustomerBillingCycleChange(inp) {
            if(inp.value) {
                inp.parentElement.nextElementSibling.innerHTML = `Customer Billing will arrive on ${inp.options[inp.selectedIndex].text}'th of every month.`;
                inp.parentElement.nextElementSibling.classList.remove("hidden");
            } else {
                inp.parentElement.nextElementSibling.innerHTML = "";
                inp.parentElement.nextElementSibling.classList.add("hidden");
            }
        }

        function setSelectedBillingCycle() {
            const selectedOption = document.querySelector("#customerBillingCycle option[data-selected='true']");
            if (!selectedOption) return;
            document.querySelector("#customerBillingCycle").value = selectedOption.innerText.trim();
            document.querySelector("#customerBillingCycle").dispatchEvent(new Event("change"));
        }



