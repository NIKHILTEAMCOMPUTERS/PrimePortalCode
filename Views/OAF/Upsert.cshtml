        function handleFileChange(input, type) {
            let html = `<div class="relative group">`;
            if (type === '1') {
                html += `<p onclick="showPreview('1');" class="text-blue-500 underline cursor-pointer">Email/Messages</p>`;
            } else if (type === '2') {
                html += `<p onclick="showPreview('2');" class="text-blue-500 underline cursor-pointer">Proposal</p>`;
            } else if (type === '3') {
                html += `<p onclick="showPreview('3');" class="text-blue-500 underline cursor-pointer">PO</p>`;
            }
            html += `<button type="button" onclick="removeFile(this, '${type}');" class="p-1 absolute right-0 top-0 rounded-full bg-black hover:bg-red-600 translate-x-[50%] translate-y-[-50%] hidden group-hover:block">
                                                                                <svg class="w-3 h-3 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M6.4 19L5 17.6l5.6-5.6L5 6.4L6.4 5l5.6 5.6L17.6 5L19 6.4L13.4 12l5.6 5.6l-1.4 1.4l-5.6-5.6L6.4 19Z"/></svg>
                                                                            </button>
                                                                        </div>`;

            if (document.querySelector(`[onclick^="showPreview('${type}'"]`)) {
                document.querySelector(`[onclick^="showPreview('${type}'"]`).parentElement.remove();
            }

            document.querySelector(".attachments-wrapper").innerHTML += html;

        }

        function removeFile(btn, fileInput) {
            console.log(fileInput, fileInput === '1');
            if (fileInput === '1') {
                const fileInput = document.querySelector("#emailmessages");
                const parent = fileInput.parentElement;
                fileInput.remove();
                parent.innerHTML = `<input type="file" class="hidden" name="" id="emailmessages" onchange="handleFileChange(this, '1');">` + parent.innerHTML;
            } else if (fileInput === '2') {
                const fileInput = document.querySelector("#proposal");
                const parent = fileInput.parentElement;
                fileInput.remove();
                parent.innerHTML = `<input type="file" class="hidden" name="" id="proposal" onchange="handleFileChange(this, '2');">` + parent.innerHTML;
            } else if (fileInput === '3') {
                const fileInput = document.querySelector("#po");
                const parent = fileInput.parentElement;
                fileInput.remove();
                parent.innerHTML = `<input type="file" class="hidden" name="" id="po" onchange="handleFileChange(this, '3');">` + parent.innerHTML;
            }
            btn.parentElement.remove();
        }

