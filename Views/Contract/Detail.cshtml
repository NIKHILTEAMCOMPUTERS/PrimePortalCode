        .timeline-line {
            height: 1px;
            background-color: rgb(229 231 235);
            position: relative;
        }

            .timeline-line::after {
                content: "";
                position: absolute;
                width: .5rem;
                height: .5rem;
                border-radius: 50%;
                background-color: rgb(20 184 166);
                right: 0;
                top: 50%;
                transform: translateY(-50%);
            }

        .revision-timeline > div:last-child .timeline-line {
            display: none;
        }

        .flipped {
            transform: rotate(90deg);
        }

        .divToExpand {
            transition: all .25s ease;
        }

            .divToExpand:not(.expanded) {
                box-shadow: 0px -13px 38.3px 0px #00000014;
            }

            .divToExpand.expanded {
                transition: all .25s ease;
                position: absolute;
                width: calc(100vw - 2rem);
                right: 1rem;
                top: 0;
                height: calc(100vh - 7rem);
                overflow-y: auto;
                background-color: white;
            }

                .divToExpand.expanded div:has(>#tBillingInfo) {
                    max-height: unset !important;
                }

        .expandBtn {
            background-color: #f3f4f6;
            color: white;
            align-self: center;
            padding: .5rem;
            border-radius: .5rem;
            color: black;
        }

            .expandBtn:hover {
                background-color: #e5e7eb;
            }

            .expandBtn .shrinkIcon {
                display: none;
            }

            .expandBtn.isExpanded .expandIcon {
                display: none;
            }

            .expandBtn.isExpanded .shrinkIcon {
                display: block;
            }

        @@media screen and (min-width: 1000px) {
            .divToExpand.expanded {
                width: calc(100vw - 14rem);
            }
        }

        @@media screen and (min-width: 1280px) {
            .divToExpand.expanded {
                width: calc(100vw - 18rem);
            }
        }
    </style>
}
@{
    var role = @Context.Session.GetString("RoleName");
    DateTime currentDate = DateTime.Today;
}
<div class="flex items-center gap-4 mb-5">
    <a asp-action="Index" asp-asp-controller="Contract" class="py-2 px-2 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base" title="Back">
        <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M11.707 5.293a1 1 0 0 1 0 1.414L7.414 11H19a1 1 0 1 1 0 2H7.414l4.293 4.293a1 1 0 0 1-1.414 1.414l-6-6a1 1 0 0 1 0-1.414l6-6a1 1 0 0 1 1.414 0z" /></svg>
    </a>
    <div>
        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Contract Info:</h2>
    </div>
</div>

<div class="bg-[#f9f9f9] p-4 rounded-md mb-4">

    <div class="p-2 flex items-center flex-wrap mt-2">
        <div class="flex items-center gap-x-8 border-r pr-3">
            <div class="logo w-10 h-10 bg-white rounded-full overflow-hidden flex items-center justify-center">
                <img class="w-6 h-6 rounded-full object-cover" src="~/assets/images/customer_default.svg" alt="">
            </div>
            <div>
                <input type="hidden" id="projectid" value="@Model.ProjectInfo?.ProjectId" />
                <input type="hidden" id="customerid" value="@Model.ProjectInfo?.customerId" />
                <input type="hidden" id="hiddenContractId" value="@Model.Contractid" />
                <p class="text-[.625rem]">Customer</p>
                <p class="font-bold">@Model.ProjectInfo?.CustomerName</p>
            </div>
        </div>
        <div class="flex pl-3 items-center gap-x-8 gap-y-4">
            <div>
                <div>
                    <span class="text-sm">Email Id</span>
                </div>
                <p class="text-sm">@Model.ProjectInfo?.Email</p>
            </div>
            <div>
                <div>
                    <span class="text-sm">Phone No</span>
                </div>
                <p class="text-sm">@Model.ProjectInfo?.ContactNo</p>
            </div>
            <div>
                <div>
                    <span class="text-sm">Location</span>
                </div>
                <p class="text-sm">@Model.ProjectInfo?.Address1 @Model.ProjectInfo?.Address2</p>
            </div>
        </div>
    </div>
    <div class="flex overflow-x-auto gap-x-8 gap-y-4 py-2 mt-4">
        <div>
            <input type="hidden" id="cid" value="@Model.Contractid">
            <p class="text-sm 2xl:text-base">Contract Number:</p>
            <p class="text-sm 2xl:text-base font-bold" id="contractnos">@Model.Contractno</p>
        </div>
        <div>
            <p class="text-sm 2xl:text-base">PO Number:</p>
            <p class="text-sm 2xl:text-base font-bold">@Model.Ponumber</p>
        </div>
        <div>
            <p class="text-sm 2xl:text-base">Practice:</p>
            <p class="text-sm 2xl:text-base font-bold">@Model.ProjectInfo?.PracticeName</p>
        </div>
        <div>
            <p class="text-sm 2xl:text-base">Contract Start Date:</p>
            <p class="text-sm 2xl:text-base font-bold" id="contractstart" data-date="@(Model.Contractstartdate == null ? "" : Convert.ToDateTime(Model.Contractstartdate).ToString("MM/dd/yyyy"))">@(Model.Contractstartdate == null ? "" : Convert.ToDateTime(Model.Contractstartdate).ToString("dd/MM/yyyy"))</p>
        </div>
        <div>
            <p class="text-sm 2xl:text-base">Contract End Date:</p>
            <p class="text-sm 2xl:text-base font-bold" id="contractend" data-date="@(Model.Contractenddate == null ? "" : Convert.ToDateTime(Model.Contractenddate).ToString("MM/dd/yyyy"))">@(Model.Contractenddate == null ? "" : Convert.ToDateTime(Model.Contractenddate).ToString("dd/MM/yyyy"))</p>
        </div>
        <div>
            <p class="text-sm 2xl:text-base">Delivery Anchor:</p>
            <p class="text-sm 2xl:text-base font-bold">@(Model.deliveryAnchorName == null ? "" : Model.deliveryAnchorName)</p>
            <input type="hidden" value="@Model.Deliveryanchorid" id="daid" />
        </div>
        <div>
            <p class="text-sm 2xl:text-base">Project Type:</p>
            <p class="text-sm 2xl:text-base font-bold">@Model.ProjectInfo?.ProjectType</p>
        </div>
        <div>
            <p class="text-sm 2xl:text-base">Status:</p>

            @if (Model.Contractenddate < currentDate && Model.StatusName != "Completed")
            {
                <span class="status over">Expired</span>
            }
            else
            {
                <span class="status @(Model.StatusName == "Active" ? "approved" : Model.StatusName == "Completed" ? "completed" : Model.StatusName == "Approved" ? "approved" : Model.StatusName == "Draft" ? "draft" : Model.StatusName == "Expired" ? "rejected" : "")">
                    @(!string.IsNullOrEmpty(Model.StatusName) ? Model.StatusName : "Pending")

                </span>
            }

        </div>
        @{
            DateTime contractEndDate = Model.Contractenddate;
            DateTime extensionStartDate;

            try
            {
                // Check if the end date is far enough from the minimum valid date, then subtract 3 months
                extensionStartDate = contractEndDate > DateTime.MinValue.AddMonths(3)
                ? contractEndDate.AddMonths(-3)
                : DateTime.MinValue;
            }
            catch (ArgumentOutOfRangeException)
            {
                extensionStartDate = DateTime.MinValue; // Fallback to minimum value if calculation fails
            }
        }
        @if (Model.StatusName != "Completed" &&
        ((currentDate >= extensionStartDate && currentDate <= contractEndDate) ||
        (currentDate > contractEndDate)))
        {
            <div>
                <p class="text-sm 2xl:text-base">Action:</p>
                <div class="flex items-center">
                    <input type="checkbox" id="contractMarkAsComplete" onchange="handleContractMarkComplete(this);" class="shrink-0 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                    <label for="contractMarkAsComplete" class="text-sm text-gray-500 ms-2">Mark as complete</label>
                </div>
            </div>
        }



    </div>
    <div class="border-b pb-4">
        @if (Model.StatusName != "Completed" && Model.Contractenddate > currentDate)
        {

            <div>
                <p class="text-sm 2xl:text-base">Close This Contract?</p>
                <button onclick="handleCloseContract(this);" class="py-2 px-4 font-medium inline-flex justify-center items-center gap-2 rounded-md bg-white text-blue-500 hover:opacity-70 transition-all text-sm sm:text-base">
                    <img src="~/assets/images/contract_close_icon.svg" class="w-4 h-4" />
                    Foreclose
                </button>
            </div>
        }
    </div>
    <div class="flex overflow-x-auto gap-x-8 gap-y-4 pt-2">
        <div>
            <p class="text-sm 2xl:text-base">Project:</p>
            <p class="text-sm 2xl:text-base font-bold">@Model.ProjectInfo?.ProjectName</p>
        </div>
        <div>
            <p class="text-sm 2xl:text-base">Capital:</p>
            <p class="text-sm 2xl:text-base font-bold">@(Model.Amount == null ? "" : Convert.ToDecimal(Model.Amount).ToString("N0"))</p>
        </div>
        <div>
            <p class="text-sm 2xl:text-base">Unallocated Capital:</p>
            <p class="text-sm 2xl:text-base font-bold">@String.Format("{0:0.00}", @Model.unlocatedamount)</p>
        </div>
        <div>
            <p class="text-sm 2xl:text-base">Client Coordinator:</p>
            <p class="text-sm 2xl:text-base font-bold">@Model.Contactpersonname</p>
        </div>
        <div>
            <p class="text-sm 2xl:text-base">Project Acknowledgement Status</p>
            @if (Model.Isprojectestimationdone == true)
            {
                <div>
                    <span class="status approved">Acknowledged</span>
                </div>
            }
            else
            {
                <div>
                    <span class="status rejected">Acknowledgement Pending</span>
                </div>
            }
        </div>
        @if (Model.Isprojectestimationdone != true)
        {
            <div>
                <p class="text-sm 2xl:text-base">Action:</p>
            <div class="flex items-center">
                <input type="checkbox" id="acknoledgement" onchange="handleAcknowledgment(this);" class="shrink-0 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                    <label for="acknoledgement" class="text-sm text-gray-500 ms-2">Acknowledged</label>
            </div>
        </div>
        }
        
    </div>
</div>

<h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C] mb-4">Line Information</h2>

<div class="flex flex-col" style="max-width: 100%;">
    <div class="-m-1.5 overflow-auto" style="height: 10rem;">
        <div class="p-1.5 min-w-full inline-block align-middle">
            <div class="overflow-hidden">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead>
                        <tr>
                            <th scope="col"
                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                Line No
                            </th>
                            <th scope="col"
                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                Line Description 1
                            </th>
                            <th scope="col"
                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                Line Description 2
                            </th>
                            <th scope="col"
                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                Amount
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @{
                            if (Model.Contractlines != null && Model.Contractlines.Count > 0)
                            {
                                foreach (var line in Model.Contractlines)
                                {
                                    <tr>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">@line.Lineno</td>
                                        <td class="px-6 py-4 text-sm text-gray-800" style="min-width: 20rem;">
                                            @line.Linedescription1
                                        </td>
                                        <td class="px-6 py-4 text-sm text-gray-800" style="min-width: 20rem;">
                                            @line.Linedescription2
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@line.Lineamount</td>
                                    </tr>
                                }
                            }
                        }

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

