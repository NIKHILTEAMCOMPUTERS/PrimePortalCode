        function monthDiff(d1, d2) {
            let months;
            months = (d2.getFullYear() - d1.getFullYear()) * 12;
            months -= d1.getMonth();
            months += d2.getMonth();
            return months;
        }

        function generateMonthList(startDate, endDate) {
            const result = [];
            const currentDate = new Date(startDate);

            while (currentDate <= endDate) {
                const month = currentDate.toLocaleString('en-us', { month: 'short' });
                const year = currentDate.getFullYear().toString().substr(-2);
                result.push(`${month}-${year}`);
                currentDate.setMonth(currentDate.getMonth() + 1);
            }

            return result;
        }

        function getBilling(ind, month, data) {
            const _currentMonthBilling = data[ind]?.contractBillings.filter(item => item.billingMonthYear === month);
            if (_currentMonthBilling.length) {
                if (_currentMonthBilling[0]?.costing) {
                    return _currentMonthBilling[0].costing
                } else {
                    return "0.00";
                }
            }
            return "0.00";
        }

        function getProvBilling(ind, month, data) {
            const _currentMonthBilling = data[ind]?.contractBillingsProvisional.filter(item => item.billingMonthYear === month);
            if (_currentMonthBilling.length) {
                if (_currentMonthBilling[0]?.costing) {
                    return _currentMonthBilling[0].costing
                } else {
                    return "0.00";
                }
            }
            return "0.00";
        }

