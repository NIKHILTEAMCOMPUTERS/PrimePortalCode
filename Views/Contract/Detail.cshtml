                if (rowObj?.deployedMonths.includes(allMonths[i].innerText)) {
                    trHtml += `<td class="py-2 px-6" data-cps="${skillCost}" data-monthdays="${_monthDays ? _monthDays[allMonths[i].innerText] : 0}">${Number(x * getSkillCostByMonthDays(allMonths[i].innerText, skillCost, rowObj?.daysMonths)).toFixed(2)}</td>`;
                } else {
                    trHtml += `<td class="py-2 px-6" data-cps="0" data-monthdays="0">0</td>`;
