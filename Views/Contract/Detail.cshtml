@section Scripts {
    <script type="text/javascript">
        window.addEventListener("load", () => {
            // fetchRevisionHistory();
            const params = new URLSearchParams(window.location.search);
            if (params.get("tab") === "billing") {
                document.querySelector("#pills-on-gray-color-item-3").click();
            }
            generateSplitMonths();
            initEmployeeSlimSelect();
            if (@(ViewBag.costsheetdata != null ? 1 : 0)) {
                HSOverlay.open(document.querySelector('#deployResourceModal'));
            }
        })

        document.querySelector("#billingEstimatedDate").setAttribute("min", setMinDateNextMonth());

        function getFormattedDate(dateStr) {
            const date = new Date(Date.parse(dateStr));
            return `${date.getDate()} ${date.toLocaleString('default', { month: 'short' })} ${date.getFullYear()}`;
        }

        function showHiddenTable(btn) {
            btn.closest('tr').nextElementSibling.classList.toggle('show');
            if (btn.closest('tr').nextElementSibling.classList.contains("show")) {
                btn.classList.add("flipped");
            } else {
                btn.classList.remove("flipped");
            }
        }

        async function fetchRevisionHistory(firstLoad = true) {
            const contractId = document.querySelector("#cid").value;
            if (!contractId) {
                return;
            }
            let obj;
            if (firstLoad) {
                obj = { monthyear: getCurrentMonthStr(), contractid: contractId }
            } else {

                obj = { monthyear: getMonthYearStr(document.querySelector("#updateHistoryDate").value), contractid: contractId }
            }
            const formData = new FormData();
            formData.append("obj", JSON.stringify(obj));
            const response = await fetch("/Contract/GetRevisionHistory", {
                method: "POST",
                body: formData
            });
            if (response.status === 200) {
                document.querySelector("#revisionHistoryTbl tbody").innerHTML = "";
                const revisionDataRaw = await response.json();
                const revisionData = JSON.parse(revisionDataRaw?.responseContent);
                if (revisionData && revisionData?.length) {
                    revisionData.forEach((item, index) => {
                        const tr = document.createElement("tr");
                        let trHtml = "";
                        trHtml += `<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800"><button title="Open/Close History" class="${index == 0 ? 'flipped' : ''}" onclick="showHiddenTable(this);">
                                                                                                                                                              <svg class="w-6 h-6 text-gray-800" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="M8 6.82v10.36c0 .79.87 1.27 1.54.84l8.14-5.18a1 1 0 0 0 0-1.69L9.54 5.98A.998.998 0 0 0 8 6.82"/></svg>
                                                                                                                                                           </button></td>`;
                        trHtml += `<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">${item.item.tmc}</td>`;
                        trHtml += `<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">${item.item.resourceName}</td>`;

                        tr.innerHTML = trHtml;

                        document.querySelector("#revisionHistoryTbl tbody").appendChild(tr);

                        if (item?.itemDetails && item?.itemDetails.length) {
                            const nestedTr = document.createElement("tr");
                            nestedTr.classList.add("hiddenTr");
                            if (index === 0) {
                                nestedTr.classList.add("show");
                            }
                            let nestedTrHtml = "";
                            nestedTrHtml += `<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800" colspan='3'>`;
                            nestedTrHtml += ` <div class="revision-timeline flex gap-4 flex-nowrap overflow-x-auto">`;
                            if (item?.itemDetails.length) {
                                item.itemDetails.forEach(historyItem => {
                                    nestedTrHtml += `<div>`;
                                    nestedTrHtml += `   <div class="timeline-item-heading mb-2 flex items-center gap-1">`;
                                    nestedTrHtml += `       <p class="text-gray-500">${getFormattedDate(historyItem.createdDate)} Revision count: <span class="text-red-500">${(historyItem.revisionNumber)}</span> </p>`;
                                    nestedTrHtml += `       <div class="flex-1 timeline-line"></div>`;
                                    nestedTrHtml += `   </div>`;
                                    nestedTrHtml += `   <div class="timeline-item mb-4">`;
                                    nestedTrHtml += `       <div class="mb-2 flex items-center gap-2">
                                                                                                                                                                                <svg class="w-6 h-6 text-blue-500" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="m12.07 18.577l2.407-2.402l-2.408-2.402l-.627.627l1.383 1.383q-1.162.005-2.064-.273q-.903-.28-1.448-.823q-.557-.558-.839-1.266q-.282-.708-.282-1.415q0-.425.094-.85t.274-.806l-.677-.6q-.29.529-.433 1.096q-.142.567-.142 1.154q0 .891.346 1.76t1.023 1.553q.677.687 1.779 1.02q1.102.334 2.263.34l-1.277 1.277zm4.067-4.327q.29-.529.432-1.096q.143-.567.143-1.154q0-.888-.344-1.765t-1.03-1.554q-.667-.687-1.775-1.018q-1.109-.33-2.263-.33l1.277-1.283l-.627-.627l-2.408 2.402l2.408 2.402l.627-.627l-1.389-1.388q1.156 0 2.068.281q.911.282 1.455.828q.545.545.83 1.255q.286.709.286 1.418q0 .425-.093.85t-.274.806zM12.003 21q-1.866 0-3.51-.708q-1.643-.709-2.859-1.924q-1.216-1.214-1.925-2.856Q3 13.87 3 12.003q0-1.866.708-3.51q.709-1.643 1.924-2.859q1.214-1.216 2.856-1.925Q10.13 3 11.997 3q1.866 0 3.51.708q1.643.709 2.859 1.924q1.216 1.214 1.925 2.856Q21 10.13 21 11.997q0 1.866-.708 3.51q-.709 1.643-1.924 2.859q-1.214 1.216-2.856 1.925Q13.87 21 12.003 21" /></svg>
                                                                                                                                                                                <span class="font-bold text-gray-800">Provision Billing Updated</span>
                                                                                                                                                                            </div>`;
                                    nestedTrHtml += `       <span class="mb-1 inline-block" style="padding-inline: .4rem; border-radius: 1rem; background-color: #EAECFF;">${formatCurrency(historyItem.provisionAmount)}</span>`;
                                    nestedTrHtml += `       <p style="padding-inline: .4rem; border-radius: 1rem; background-color: #EAECFF;">Expected Billing Date: ${getFormattedDate(historyItem.estimatedBillingDate)}</p>`;
                                    nestedTrHtml += `   </div>`;
                                    nestedTrHtml += `</div>`;
                                })
                            }
                            nestedTrHtml += ' </div>';
                            nestedTrHtml += '</td>';
                            nestedTr.innerHTML = nestedTrHtml;
                            document.querySelector("#revisionHistoryTbl tbody").appendChild(nestedTr);
                        }
                    })
                }
                console.log("revData", revisionData);
            }
        }

        function openModal() {
            HSOverlay.open(document.querySelector("#hs-medium-modal"))
        }
        function getCurrentMonthStr() {
            const currentDate = new Date();
            const month = currentDate.toLocaleString('en-us', { month: 'short' });
            const year = currentDate.getFullYear().toString().substr(-2);
            return `${month}-${year}`;
        }
        function getMonthYearStr(dateStr) {
            const currentDate = new Date(dateStr);
            const month = currentDate.toLocaleString('en-us', { month: 'short' });
            const year = currentDate.getFullYear().toString().substr(-2);
            return `${month}-${year}`;
        }
        function isCurrentMonthProvBillingChanged() {
            let isChangedFlag = false;
            const currentMonthStr = getCurrentMonthStr();
            const allTh = document.querySelectorAll("#tBillingInfo th");
            let tdCol = null;
            let monthInd = null;
            for (let i = 0; i < allTh.length; i++) {
                console.log(allTh[i].innerText);
                if (allTh[i].querySelector(".month")) {
                    if (allTh[i].querySelector(".month").innerText.trim() === currentMonthStr.toUpperCase() || allTh[i].querySelector(".month").innerText.trim() === currentMonthStr.replace("Sep", "Sept").toUpperCase()) {
                        tdCol = document.querySelectorAll(`#tBillingInfo td:nth-child(${i + 2})`);
                        monthInd = i + 2;
                        break;
                    }
                }
            }
            if (tdCol && tdCol.length) {
                for (let i = 0; i < tdCol.length; i++) {
                    if (tdCol[i].querySelector("input").classList.contains("changed") && Number(tdCol[i].querySelector("input").value) > 0) {
                        isChangedFlag = true;
                        setProvModalBilling(monthInd, currentMonthStr);
                        break;
                    }
                }
            }
            return isChangedFlag;
        }

        function isCurrentMonthActualBillingChanged() {
            let isChangedFlag = false;
            const currentMonthStr = getCurrentMonthStr();
            const allTh = document.querySelectorAll("#tBillingInfo th");
            let tdCol = null;
            let monthInd = null;
            for (let i = 0; i < allTh.length; i++) {
                console.log(allTh[i].innerText);
                if (allTh[i].querySelector(".month")) {
                    if (allTh[i].querySelector(".month").innerText.trim() === currentMonthStr.toUpperCase() || allTh[i].querySelector(".month").innerText.trim() === currentMonthStr.replace("Sep", "Sept").toUpperCase()) {
                        tdCol = document.querySelectorAll(`#tBillingInfo td:nth-child(${i + 2})`);
                        monthInd = i + 2;
                        break;
                    }
                }
            }
            if (tdCol && tdCol.length) {
                for (let i = 0; i < tdCol.length; i++) {
                    if (tdCol[i].querySelector("input:last-child").classList.contains("changed") && Number(tdCol[i].querySelector("input:last-child").value) > 0) {
                        isChangedFlag = true;
                        setProvModalActualBilling(monthInd, currentMonthStr);
                        break;
                    }
                }
            }
            return isChangedFlag;
        }

        function checkOnlySingleBillingExists() {
            const currentMonthStr = getCurrentMonthStr();
            let colInd = 0;
            const monthCols = document.querySelectorAll("#tBillingInfo .month");
            for (let i = 0; i < monthCols.length; i++) {
                if (currentMonthStr.toLowerCase() === monthCols[i].innerText.toLowerCase().trim()) {
                    colInd = i + 1;
                    break;
                }
            }

            const allTd = document.querySelectorAll(`#tBillingInfo tbody td:nth-child(${colInd + 4})`);

            let validFlag = true;

            allTd.forEach((td, index) => {
                console.log(td);
                const _provBilling = Number(td.querySelector("input:first-child").value);
                const _actualBilling = Number(td.querySelector("input:last-child").value);

                if (_provBilling > 0 && _actualBilling > 0) {
                    validFlag = false;
                    td.querySelector("input:first-child").classList.add("is-invalid")
                    td.querySelector("input:last-child").classList.add("is-invalid")
                } else {
                    td.querySelector("input:first-child").classList.remove("is-invalid")
                    td.querySelector("input:last-child").classList.remove("is-invalid")
                }

            })

            return validFlag;
        }

        function submitBilling(isCurrentMonthChanged) {
            let openModalFlag = false;
            if (!isCurrentMonthChanged) {
                if (isCurrentMonthProvBillingChanged()) {
                    openModalFlag = true;
                }
                if (isCurrentMonthActualBillingChanged()) {
                    openModalFlag = true;
                }
                const onlySingleBillingExists = checkOnlySingleBillingExists();
                if (!onlySingleBillingExists) {
                    resetProvBillingOverlay();
                    toastr.error("For the current month, only provisional or actual billing is permitted. Remove one to update billing.");
                    return;
                }
                if (openModalFlag) {
                    HSOverlay.open(document.querySelector("#prov-billing-overlay"));
                    return;
                }
                handlebillingsubmit();
                handleprovisionbillingsubmit();
            } else {
                let provModalDateValidFlag = true;
                const isProvTableDatesValid = validateBillingDates("provision");
                const isActualTableDatesValid = validateBillingDates("actual");

                if (!isProvTableDatesValid) {
                    provModalDateValidFlag = false;
                }
                if (!isActualTableDatesValid) {
                    provModalDateValidFlag = false;
                }
                if (!provModalDateValidFlag) {
                    return;
                }
                handleCurrentMonthProvBillingSubmit();
            }
        }

        function validateBillingDates(table) {
            let allTds;
            let validFlag = true;
            if (table === "provision") {
                allTds = document.querySelectorAll("#provBillingUpdate tbody td:last-child");
            } else if (table === 'actual') {
                allTds = document.querySelectorAll("#BillingUpdate tbody td:last-child");
            }

            allTds.forEach(td => {
                if (td.querySelector("input")) {
                    if (!td.querySelector("input").value) {
                        td.querySelector("input").classList.add("is-invalid");
                        validFlag = false;
                    } else {
                        td.querySelector("input").classList.remove("is-invalid");
                    }
                }
            })

            return validFlag;
        }

        function handleCurrentMonthProvBillingSubmit() {
            document.querySelector("#loader").style.display = "flex";
            let _objRes = [];
            const allTr = document.querySelectorAll("#tBillingInfo tbody tr");
            let areAllDateEntered = true;
            allTr.forEach((tr, trInd) => {
                const allTd = tr.querySelectorAll("td");
                const empId = Number(tr.querySelector("td").innerText.trim());
                allTd.forEach((td, tdInd) => {
                    if (tdInd > 2) {
                        const _obj = {
                            ContractEmployeeId: empId,
                            BillingMonthYear: td.querySelector("input").getAttribute("data-billingMonthYear"),
                            Costing: td.querySelector("input").value,
                        }
                        if (td.querySelector("input").getAttribute("data-billingMonthYear") === getCurrentMonthStr()) {
                            if (document.querySelector(`#provBillingUpdate tbody tr[data-ind="${trInd}"]`)) {
                                _obj.estimatedDate = document.querySelector(`#provBillingUpdate tbody tr[data-ind="${trInd}"] input`).value;
                                if (!document.querySelector(`#provBillingUpdate tbody tr[data-ind="${trInd}"] input`).value) {
                                    areAllDateEntered = false;
                                    document.querySelector(`#provBillingUpdate tbody tr[data-ind="${trInd}"] input`).classList.add("is-invalid");
                                    document.querySelector("#loader").style.display = "none";
                                } else {
                                    document.querySelector(`#provBillingUpdate tbody tr[data-ind="${trInd}"] input`).classList.remove("is-invalid");
                                }
                            } else if (td.querySelector("input").getAttribute("data-estimateddate")) {
                                _obj.estimatedDate = td.querySelector("input").getAttribute("data-estimateddate").trim();
                            }
                        }
                        _objRes.push(_obj);
                    }
                })
            })
            if (!areAllDateEntered) {
                return;
            }
            var fdata = new FormData();
            fdata.append("jsonObject", JSON.stringify(_objRes));
            fdata.append("isProvision", "true")
            $.ajax({
                url: "@Url.Action("Billing", "Contract")",
                type: "POST",
                cache: false,
                data: fdata,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res);
                    if (res.success == true) {
                        // $('#loader').hide();
                        // HSOverlay.close(document.querySelector("#prov-billing-overlay"));
                        console.log("updated prov billing")
                        handleCurrentMonthBillingSubmit();
                    } else {
                        toastr.error(res.msg);
                    }
                },
                error: function (err) {
                    toastr.error(err);
                }
            });
        }
        function handleCurrentMonthBillingSubmit() {
            document.querySelector("#loader").style.display = "flex";
            let _objRes = [];
            const allTr = document.querySelectorAll("#tBillingInfo tbody tr");
            let areAllDateEntered = true;
            allTr.forEach((tr, trInd) => {
                const allTd = tr.querySelectorAll("td");
                const empId = Number(tr.querySelector("td").innerText.trim());
                allTd.forEach((td, tdInd) => {
                    if (tdInd > 2) {
                        const _obj = {
                            ContractEmployeeId: empId,
                            BillingMonthYear: td.querySelector("input:last-child").getAttribute("data-billingMonthYear"),
                            Costing: td.querySelector("input:last-child").value,
                        }
                        if (td.querySelector("input:last-child").getAttribute("data-billingMonthYear") === getCurrentMonthStr()) {
                            if (document.querySelector(`#BillingUpdate tbody tr[data-ind="${trInd}"]`)) {
                                _obj.estimatedDate = document.querySelector(`#BillingUpdate tbody tr[data-ind="${trInd}"] input`).value;
                                if (!document.querySelector(`#BillingUpdate tbody tr[data-ind="${trInd}"] input`).value) {
                                    areAllDateEntered = false;
                                    document.querySelector(`#BillingUpdate tbody tr[data-ind="${trInd}"] input`).classList.add("is-invalid");
                                    document.querySelector("#loader").style.display = "none";
                                } else {
                                    document.querySelector(`#BillingUpdate tbody tr[data-ind="${trInd}"] input`).classList.remove("is-invalid");
                                }
                            } else if (td.querySelector("input:last-child").getAttribute("data-estimateddate")) {
                                _obj.estimatedDate = td.querySelector("input:last-child").getAttribute("data-estimateddate").trim();
                            }
                        }
                        _objRes.push(_obj);
                    }
