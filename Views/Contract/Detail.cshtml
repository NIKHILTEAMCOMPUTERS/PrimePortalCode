        // resource allocation script
        function postData() {

            const billingExceedPo = checkBillingExceedPo();
            if (billingExceedPo) {
                toastr.error("Total split billing exceeds PO amount.")
                return;
            }

            document.querySelector("#loader").style.display = "flex";
            // Define dynamic variables
            var contractid = parseInt($("#contractid").val(), 10);

            let resourceDetails = getResourceDetails();

            // Sample data with dynamic variables
            var data = {
                "projectId": Number(document.querySelector("#projectid").value),
                "contractid": Number(document.querySelector("#hiddenContractId").value),
                "resource_details": resourceDetails
            };

            // Convert data to JSON
            var jsonData = JSON.stringify(data);
            const fData = new FormData();
            fData.append("jsonObject", jsonData);

            // AJAX POST request
            $.ajax({
                type: "POST",
                url: "/OAF/resourceallocation", // Adjust the URL according to your application
                data: fData,
                processData: false,
                contentType: false,
                success: function (response) {
                    console.log("Data successfully posted:", response);
                    toastr.success("Successfully deployed resources");
                    window.location.reload();
                    // Handle success response
                },
                error: function (xhr, status, error) {
                    console.error("Error posting data:", error);
                    // Handle error
                    toastr.error("Error: Something went wrong.");
                    window.location.reload();
                }
            });
        }
        //end here
        function handleAcknowledgment(input) {
            if (input.checked) {
                if (confirm("Do you confirm the acknowledgment of the project estimation from the sales team?")) {
                    console.log("Acknowledgment confirmed.");

                    const formData = new FormData();
                    formData.append("cid", document.querySelector("#hidContractId").value);

                    $.ajax({
                        type: "POST",
                        url: "/Contract/Acknowledgement",
                        data: formData,
                        processData: false,
                        contentType: false,
                        success: function (result) {
                            try {
                                const response = JSON.parse(result?.data);
                                console.log(response);

                                if (response?.status === 200 || response?.responseCode === 200) {
                                    toastr.success("Acknowledgment status updated successfully.");
                                    window.location.reload();
                                } else {
                                    toastr.error("Failed to update acknowledgment status. Please try again.");
                                }
                            } catch (error) {
                                console.error("Error parsing response:", error);
                                toastr.error("An unexpected error occurred while processing the request.");
                            }
                        },
                        error: function () {
                            toastr.error("Unable to process the request. Please check your connection and try again.");
                        }
                    });
                } else {
                    console.log("Acknowledgment canceled by the user.");
                    window.location.reload();
                }
            } else {
                console.log("Input unchecked, reloading the page.");
                window.location.reload();
            }
        }


