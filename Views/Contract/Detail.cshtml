                            <span class="text-base font-semibold block text-left">Active</span>
                        </div>
                    </button>
                    <button type="button"
                            class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-center gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600 innerTab"
                            id="releasedResourceTab"
                            aria-controls="tabs-with-underline-2" data-hs-tab="#releasedResource" role="tab">

                        <div class="flex items-center gap-2">
                            <span class="text-base font-semibold block text-left">Released</span>
                        </div>
                    </button>
                </nav>
            </div>
            <div class="mt-3">
                <div id="activeResource" role="tabpanel">
                    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 tab-contract-employees-wrapper">
                        @{
                            if (Model.ContractEmployees != null && Model.ContractEmployees.Count > 0)
                            {
                                foreach (var emp in Model.ContractEmployees.Where(a => a.employeeSataus != "Released"))
                                {
                                    <div class="flex items-center gap-4">
                                        <div class="relative">
                                            <img src="~/assets/images/default_user_icon.png" alt="" class="w-20 h-20 rounded-full">
                                            <button data-empid="@emp.EmployeeId" class="absolute" style="right: 0; top: 0;" onclick="removeEmployee(this);">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 1024 1024"><path fill="#ff5252" d="M512 64a448 448 0 1 1 0 896a448 448 0 0 1 0-896M288 512a38.4 38.4 0 0 0 38.4 38.4h371.2a38.4 38.4 0 0 0 0-76.8H326.4A38.4 38.4 0 0 0 288 512" /></svg>
                                            </button>
                                        </div>
                                        <div>
                                            <input type="hidden" id="empid" value="@emp.EmployeeId">
                                            <p class="font-bold text-gray-500">@emp.EmployeeName</p>
                                            <p class="text-gray-400">Practice: <span class="font-bold text-gray-500">@emp.PracticeName</span></p>
                                            <p class="text-gray-400">TMC: <span class="font-bold text-gray-500">@emp.TmcCode</span></p>
                                        </div>
                                    </div>
                                }
                            }
                        }
                        @if (role != "DH" && Model.Contractenddate > currentDate)
                        {
                            <div class="flex items-center gap-4">
                                <img src="~/assets/images/default_user_icon.png" alt="" class="w-20 h-20 rounded-full" style="filter: grayscale(1);">
                                <div>
                                    <p class="font-bold text-gray-500 mb-2">New Resource</p>
                                    <button class="flex items-center gap-2 bg-gray-100 text-gray-400 rounded-full px-4 py-1 hover:bg-gray-200" data-hs-overlay="#assignEmpOverlay">
