                        <div class="border rounded-lg overflow-x-auto" style="max-width: 100%; max-height: 20rem;">
                            <table id="initialsBillingInfo" class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-50" style="position: sticky; top: 0; z-index: 10;">
                                    <tr>
                                        <th scope="col" class="px-2 py-2 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase" style="position: sticky; width: 10rem; left: 0; background-color: rgb(249 250 251);">
                                            Employee
                                        </th>
                                        <th scope="col" class="px-2 py-2 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase" style="position: sticky; left: 9rem; background-color: rgb(249 250 251);">
                                            Billing
                                            <br />
                                        </th>
                                        @{
                                            if (Model.Contractstartdate != null && Model.Contractenddate != null)
                                            {
                                                int year = Model.Contractenddate.Year;
                                                int month = Model.Contractenddate.Month;
                                                int daysInMonth = (DateTime.DaysInMonth(year, month));
                                                int daysToAdd = daysInMonth - Model.Contractenddate.Day;
                                                for (var day = Convert.ToDateTime(Model.Contractstartdate).Date;
                                                day.Date <= Convert.ToDateTime(Model.Contractenddate).Date.AddDays(daysToAdd);
                                                day = day.AddMonths(1))
                                                {
                                                    <th data-month="@day" scope="col" class="px-2 py-2 text-center text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                        <span class="month">@day.ToString("MMM-yy")</span>
                                                    </th>
                                                }
                                            }
                                        }

                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-200">
                                    @if (Model.ContractEmployees != null && Model.ContractEmployees.Count > 0)
                                    {
                                        foreach (var emp in Model.ContractEmployees)
                                        {
                                            <tr>
                                                <td style="display:none">@emp.ContractEmployeeId</td>
                                                <td class="px-2 py-2 whitespace-nowrap text-sm font-medium text-gray-800"
                                                    style="position: sticky; left: 0; background-color: white; width: 10rem; overflow: hidden; text-overflow: ellipsis;">
                                                    @emp.EmployeeName (@emp.TmcCode)
                                                </td>
                                                <td class="px-2 py-2 whitespace-nowrap text-sm text-gray-800" style="position: sticky; left: 9rem; background-color: white;">
                                                    <div class="flex flex-col gap-2 item">
                                                        <p class="rounded-full bg-emerald-100 text-emerald-500 py-1 px-2 font-medium text-center" style="max-width: 10rem;">Actual Billing</p>
                                                    </div>
                                                </td>

                                                @if (Model.Contractstartdate != null && Model.Contractenddate != null)
                                                {
                                                    int year = Model.Contractenddate.Year;
                                                    int month = Model.Contractenddate.Month;
                                                    int daysInMonth = (DateTime.DaysInMonth(year, month));
                                                    int daysToAdd = daysInMonth - Model.Contractenddate.Day;
                                                    for (var day = Convert.ToDateTime(Model.Contractstartdate).Date;
                                                    day.Date <= Convert.ToDateTime(Model.Contractenddate).Date.AddDays(daysToAdd);
                                                    day = day.AddMonths(1))
                                                    {
                                                        var monthYear = day.Date.ToString("MMM-yy");
                                                        decimal prevBilling = 0;
                                                        if (Model.ContractEmployees != null)
                                                        {
                                                            prevBilling = emp.initialBillings.FirstOrDefault(x => x.BillingMonthYear == monthYear)?.Costing ?? 0;
                                                        }
                                                        <td class="px-6 text-center py-4 whitespace-nowrap text-sm text-gray-800">
                                                            <div class="flex flex-col items-center gap-2">
                                                                <p class="block font-medium">@prevBilling</p>
                                                            </div>
                                                        </td>
                                                    }
                                                }
                                            </tr>
                                        }
                                    }
                                </tbody>

                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        @if (ViewBag.BillingPermit)
        {
            <div id="pills-on-gray-color-3" class="hidden" role="tabpanel"
                 aria-labelledby="pills-on-gray-color-item-3">
                <div class="flex items-center mb-2 gap-4 flex-wrap">
                    <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C] flex items-center gap-2">
                        Contract Billing
                        @* <a asp-action="ContractBillingProvisionReport" asp-controller="Billing" title="Provision Reports">
                    <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M19 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h6v2H5v12h12v-6zM13 3v2h4.586l-7.793 7.793l1.414 1.414L19 6.414V11h2V3z" /></svg>
                    </a> *@
                    </h2>
                    <div id="calendar-container" class="flex items-center gap-2" style="margin-left: auto;">
                        <label for="start-date">Start:</label>
                        <input type="month" id="start-date" class="k-input" name="start-date" value="@(Model.Contractstartdate == null ? "" : Model.Contractstartdate.ToString("yyyy-MM"))" oninput="setEndDate(this.value)">
                        <label for="end-date">End:</label>

                        <input type="month" id="end-date" class="k-input" name="end-date" value="@(Model.Contractenddate == null ? "" : Model.Contractenddate.ToString("yyyy-MM"))" oninput="disableSubmitIfDateNotMatch();">
                        @if (Model.StatusName != "Completed")
                        {

                            <button type="button" onclick="submitBilling(false);" class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base disabled:opacity-50 disabled:cursur-not-allowed">
                                Submit
                            </button>
                            @* <button type="button" data-hs-overlay="#prov-billing-overlay" id="btnSubmitProvisionBilling2" class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base disabled:opacity-50 disabled:cursur-not-allowed">
                    Submit Provisions
                    </button> *@
                            <button onclick="window.location.reload()" id="resetButton" style="display: none;" type="button" class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base disabled:opacity-50 disabled:cursur-not-allowed">
                                Reset
                            </button>
                        }
                    </div>
                </div>
                @if (Model.StatusName != "Completed")
                {
                    <p class="text-sm text-red-500 mb-4" id="danger-message" style="display: none;">Modifying the billing details is restricted when changes are made to either the start date or end date.*</p>
                }
                <div class="flex flex-col" style="max-width: 100%;">
                    <div class="-m-1.5 overflow-x-auto">
                        <div class="p-1.5 min-w-full inline-block align-middle" style="max-width: 100%;">
                            <div class="border rounded-lg overflow-x-auto" style="max-width: 100%; max-height: 20rem;">
                                <table id="tBillingInfo" class="min-w-full divide-y divide-gray-200">
                                    <thead class="bg-gray-50" style="position: sticky; top: 0; z-index: 10;">
                                        <tr>
                                            <th scope="col" class="px-2 py-2 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase" style="position: sticky; width: 10rem; left: 0; background-color: rgb(249 250 251);">
                                                Employee
                                            </th>
                                            <th scope="col" class="px-2 py-2 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase" style="position: sticky; left: 9rem; background-color: rgb(249 250 251);">
                                                Billing
                                                <br />
                                                <span style="padding-inline: .4rem; border-radius: 1rem; background-color: #EAECFF;" id="totalProvAmount">Total Provision</span>
                                                <br />
                                                <span style="padding-inline: .4rem; border-radius: 1rem; background-color: #00cc8320; color: #00cc83;" id="totalBillingAmount">Total Billing</span>
                                            </th>
                                            @{
                                                if (Model.Contractstartdate != null && Model.Contractenddate != null)
                                                {
                                                    int year = Model.Contractenddate.Year;
                                                    int month = Model.Contractenddate.Month;
                                                    int daysInMonth = (DateTime.DaysInMonth(year, month));
                                                    int daysToAdd = daysInMonth - Model.Contractenddate.Day;
                                                    for (var day = Convert.ToDateTime(Model.Contractstartdate).Date;
                                                    day.Date <= Convert.ToDateTime(Model.Contractenddate).Date.AddDays(daysToAdd);
                                                    day = day.AddMonths(1))
                                                    {
                                                        <th data-month="@day" scope="col" class="px-2 py-2 text-center text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                                            <span class="month">@day.ToString("MMM-yy")</span>
                                                            <br />
                                                            <span style="padding-inline: .4rem; border-radius: 1rem; background-color: #EAECFF;" id="totalProvAmount">₹0</span>
                                                            <br />
                                                            <span style="padding-inline: .4rem; border-radius: 1rem; background-color: #00cc8320; color: #00cc83;" id="totalBillingAmount">₹0</span>
                                                        </th>

                                                    }
                                                }
                                            }

                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200">
                                        @{
                                            if (Model.ContractEmployees != null && Model.ContractEmployees.Count > 0)
                                            {
                                                foreach (var emp in Model.ContractEmployees)
                                                {
                                                    <tr>
                                                        <td style="display:none">@emp.ContractEmployeeId</td>
                                                        <td class="px-2 py-2 whitespace-nowrap text-sm font-medium text-gray-800"
                                                            style="position: sticky; left: 0; background-color: white; width: 10rem; overflow: hidden; text-overflow: ellipsis;">
                                                            @emp.EmployeeName (@emp.TmcCode)
                                                        </td>
                                                        <td class="px-2 py-2 whitespace-nowrap text-sm text-gray-800" style="position: sticky; left: 9rem; background-color: white;">
                                                            <div class="flex flex-col gap-2 item">
                                                                <p class="rounded-full bg-slate-100 text-slate-500 py-1 px-2 font-medium text-center" style="max-width: 10rem;">Provision Billing</p>
                                                                <p class="rounded-full bg-emerald-100 text-emerald-500 py-1 px-2 font-medium text-center" style="max-width: 10rem;">Actual Billing</p>
                                                            </div>
                                                        </td>

                                                        @{
                                                            if (Model.Contractstartdate != null && Model.Contractenddate != null)
                                                            {

                                                                int year = Model.Contractenddate.Year;
                                                                int month = Model.Contractenddate.Month;
                                                                int daysInMonth = (DateTime.DaysInMonth(year, month));
                                                                int daysToAdd = daysInMonth - Model.Contractenddate.Day;
                                                                for (var day = Convert.ToDateTime(Model.Contractstartdate).Date;
                                                                day.Date <= Convert.ToDateTime(Model.Contractenddate).Date.AddDays(daysToAdd);
                                                                day = day.AddMonths(1))
                                                                {

                                                                    var monthYear = day.Date.ToString("MMM-yy");
                                                                    if (monthYear.Contains("Sept"))
                                                                    {
                                                                        monthYear = monthYear.Replace("Sept", "Sep");
                                                                    }
                                                                    decimal prevBilling = 0;
                                                                    decimal? provBilling = 0;
                                                                    DateTime? estimateddate = null;
                                                                    var accestimateddate = emp.ContractBillings.FirstOrDefault(x => x.BillingMonthYear == monthYear)?.Expecteddate;
                                                                    var billingstatus = emp.ContractBillings.FirstOrDefault(x => x.BillingMonthYear == monthYear)?.billingStatus;

                                                                    var status = "";
                                                                    if (emp.ContractBillings == null || emp.ContractBillings.Count == 0)
                                                                    {
                                                                        prevBilling = 0;
                                                                    }
                                                                    else if (emp.ContractBillings.Any(x => x.BillingMonthYear == monthYear))
                                                                    {
                                                                        prevBilling = emp.ContractBillings.FirstOrDefault(x => x.BillingMonthYear == monthYear)?.Costing ?? 0;
                                                                    }
                                                                    if (emp.contractBillingsProvisional == null || emp.contractBillingsProvisional.Count == 0)
                                                                    {
                                                                        provBilling = 0;
                                                                    }
                                                                    else if (emp.contractBillingsProvisional.Any(x => x.BillingMonthYear == monthYear))
                                                                    {
                                                                        provBilling = emp.contractBillingsProvisional.FirstOrDefault(x => x.BillingMonthYear == monthYear)?.Costing ?? 0;
                                                                        status = emp.contractBillingsProvisional.FirstOrDefault(x => x.BillingMonthYear == monthYear)?.status;
                                                                        estimateddate = emp.contractBillingsProvisional.FirstOrDefault(x => x.BillingMonthYear == monthYear)?.Expecteddate;
                                                                    }
                                                                    if (Model.StatusName != "Completed")
                                                                    {
                                                                        bool showElements;
                                                                        var currentMonthYear = DateTime.UtcNow.ToString("MMM-yy");
                                                                        if (currentMonthYear.Contains("Sept"))
                                                                        {
                                                                            currentMonthYear = currentMonthYear.Replace("Sept", "Sep");
                                                                        }
                                                                        var currentDateTime = DateTime.UtcNow.Date;
                                                                        var itemDateTime = DateTime.ParseExact(monthYear, "MMM-yy", CultureInfo.InvariantCulture);

                                                                        if (currentDateTime > itemDateTime)
                                                                        {
                                                                            showElements = (currentDateTime.Month == itemDateTime.Month && currentDateTime.Year == itemDateTime.Year) ? (currentDateTime.Day < 31) : false;
                                                                        }
                                                                        else
                                                                        {
                                                                            showElements = (currentDateTime.Year == itemDateTime.Year && currentDateTime.Month == itemDateTime.Month) ? (currentDateTime.Day < 31) : true;
                                                                        }


                                                                        <td class="px-2 text-center py-2 whitespace-nowrap text-sm text-gray-800">
                                                                            <div class="flex flex-col items-center">
                                                                                <input @((emp.employeeSataus != null && emp.employeeSataus == "Released") ? "disabled" : currentMonthYear != monthYear ? "disabled" : "") @(!showElements ? "disabled" : (status == "Pending" || status == "Approved") ? "disabled" : "") oninput="handleWidth(event, this);" onchange="this.classList.add('changed');" type="text" data-billingMonthYear="@monthYear" class="text-center border-transparent p-1 mb-1 rounded block"
                                                                                       value="@(provBilling == null ? 0 : provBilling)" style="min-width: 5rem; font-size: 1.125rem;" data-estimateddate="@(estimateddate.HasValue ? estimateddate.Value.ToString("yyyy-MM-dd") : ViewBag.nextmonthbillingdate != null ? ViewBag.nextmonthbillingdate : null)"
                                                                                       onblur="if(this.value==='') this.value='0';" min="0" />
                                                                                <input @((billingstatus != null && (billingstatus == "Isbilled" || billingstatus == "ToBeBilled")) ? "disabled" : "")@(!showElements ? "disabled" : "") @((emp.employeeSataus != null && emp.employeeSataus == "Released") ? "disabled" : "") oninput="handleWidth(event, this);" onchange="this.classList.add('changed');" type="text" data-billingMonthYear="@monthYear" data-estimateddate="@(accestimateddate.HasValue ? accestimateddate.Value.ToString("yyyy-MM-dd") : ViewBag.billingdate != null ? ViewBag.billingdate : null)" class="text-center border-transparent p-1 mb-1 rounded block"
                                                                                       value="@(prevBilling == null ? 0 : prevBilling)" style="min-width: 5rem; font-size: 1.125rem;"
                                                                                       onblur="if(this.value==='') this.value='0';" min="0" />
                                                                            </div>

                                                                        </td>
                                                                    }
                                                                    else
                                                                    {
                                                                        <td class="px-6 text-center py-4 whitespace-nowrap text-sm text-gray-800">
                                                                            <div class="flex flex-col items-center gap-2">
                                                                                @*<p class="block font-medium">@(provBilling == null ? 0 : provBilling)</p>*@
                                                                                <p class="block font-medium">@(prevBilling == null ? 0 : prevBilling)</p>
                                                                            </div>
                                                                        </td>
                                                                    }

                                                                }
                                                            }
                                                        }

                                                    </tr>
                                                }
                                            }

                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div id="pills-on-gray-color-1" class="hidden" role="tabpanel" aria-labelledby="pills-on-gray-color-item-1">
            <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C] mb-6">Pre Sales Checklist</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                @{
                    if (Model.Questions != null && Model.Questions.Count > 0)
                    {
                        foreach (var ques in Model.Questions)
                        {
                            <div class="">
                                <span class="mb-2 font-bold block">
                                    @ques.Question
                                </span>
                                <div>
                                    <p class="text-sm font-semibold text-gray-500">Reference Response</p>
                                    <p class="text-sm text-gray-400">
                                        @ques.Refresponse
                                    </p>
                                </div>
                                <div>
                                    <p class="text-sm font-semibold text-gray-500">Response From Client</p>
                                    <p class="text-sm text-gray-400">
                                        @ques.response
                                    </p>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        </div>
        <div id="tab-content-4" class="hidden" role="tabpanel"
             aria-labelledby="pills-on-gray-color-item-3">
            <div class="flex items-center justify-between mb-2 gap-4 flex-wrap">
                <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Provisions Revision History</h2>
                <div class="flex items-center gap-4">
                    <h3 class="font-bold">Select Month :</h3>
                    <input class="k-input ml-auto" type="month" id="updateHistoryDate" onchange="fetchRevisionHistory(false)" />
                </div>
            </div>

            <div class="flex flex-col" style="max-width: 100%;">
                <div class="-m-1.5 overflow-x-auto">
                    <div class="p-1.5 min-w-full inline-block align-middle" style="max-width: 100%;">
                        <div class="border rounded-lg overflow-x-auto" style="max-width: 100%;">
                            <table class="min-w-full divide-y divide-gray-200" id="revisionHistoryTbl">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th width="10%" scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase"></th>
                                        <th width="20%" scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                            Tmc
                                        </th>
                                        <th width="70%" scope="col" class="px-6 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600 uppercase">
                                            Resource Name
                                        </th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-200">
                                    <tr><td colspan="3" class="px-6 py-3 text-center">Choose/Update Month for Provision Revision History Timeline</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>


    </div>
</div>
