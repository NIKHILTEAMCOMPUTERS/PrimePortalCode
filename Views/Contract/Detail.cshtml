            position: sticky;
            left: 0;
        }


        .first-column-fixed th:first-child {
            background-color: rgb(249 250 251) !important;
        }

        .hiddenTr {
            display: none;
        }

            .hiddenTr.show {
                display: table-row;
            }

        .timeline-item {
            position: relative;
        }

        /* .timeline-item::before {
