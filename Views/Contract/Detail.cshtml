                        <div class="inline-flex items-center rounded shadow py-3 px-6 gap-2">
                            <input type="radio" name="po-status" class="shrink-0 mt-0.5 border-gray-200 rounded-full text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="poAwaitedCheckbox" checked>
                            @* <label for="poAwaited" class="text-sm text-gray-500 ms-2 dark:text-gray-400">PO Awaited</label> *@
                            <label for="poAwaitedCheckbox" class="block font-bold ">PO Awaited</label>
                        </div>
                        <div class="inline-flex items-center rounded shadow py-3 px-6 gap-2">
                            <input type="radio" name="po-status" class="shrink-0 mt-0.5 border-gray-200 rounded-full text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="poArrivedCheckbox">
                            @* <label for="poAwaited" class="text-sm text-gray-500 ms-2 dark:text-gray-400">PO Awaited</label> *@
                            <label for="poArrivedCheckbox" class="block font-bold ">PO Renewed</label>
                        </div>
                    </div>
                    <div class="hs-tooltip inline-block [--trigger:click]">
                        <a class="hs-tooltip-toggle block text-center" href="javascript:;">
                            <span class="w-10 h-10 inline-flex justify-center items-center gap-2 rounded-md bg-gray-50 border border-transparent text-gray-600 hover:bg-emerald-50 hover:border-emerald-200 hover:text-emerald-600">
                                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M11 17h2v-6h-2v6Zm1-8q.425 0 .713-.288T13 8q0-.425-.288-.713T12 7q-.425 0-.713.288T11 8q0 .425.288.713T12 9Zm0 13q-2.075 0-3.9-.788t-3.175-2.137q-1.35-1.35-2.137-3.175T2 12q0-2.075.788-3.9t2.137-3.175q1.35-1.35 3.175-2.137T12 2q2.075 0 3.9.788t3.175 2.137q1.35 1.35 2.138 3.175T22 12q0 2.075-.788 3.9t-2.137 3.175q-1.35 1.35-3.175 2.138T12 22Zm0-2q3.35 0 5.675-2.325T20 12q0-3.35-2.325-5.675T12 4Q8.65 4 6.325 6.325T4 12q0 3.35 2.325 5.675T12 20Zm0-8Z" /></svg>
                            </span>
                            <div class="hs-tooltip-content hs-tooltip-shown:opacity-100 hs-tooltip-shown:visible opacity-0 transition-opacity inline-block absolute invisible z-10 py-3 px-4 bg-white border text-sm text-gray-600 rounded-md shadow-md" role="tooltip">
                                *Select "PO Awaited" if you want to extend the contract without providing contract and PO numbers initially; you can update them later upon receiving the PO.
                                OR
                                **Opt for "PO Arrived" to enter the arrived PO details and proceed with the contract extension.
                            </div>
                        </a>
                    </div>
                </div>
                <form class="flex-1 flex flex-col">
                    @if (Model.Contractid != null)
                    {
                        <input type="hidden" id="hidContractId" value="@Model.Contractid" />
                    }

                    <div class="w-full flex-1 flex flex-col">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

                            <div>
                                <span class="mb-2 font-medium block">Contract Number <span class="toggle-mandatory-icon">*</span></span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input readonly style="cursor: not-allowed;" type="text" id="contractno" value=""
                                           class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                           placeholder="Enter Contract Number">
                                </div>
                            </div>
                            <div>
                                <span class="mb-2 font-medium block">PO Number <span class="toggle-mandatory-icon">*</span></span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input readonly style="cursor: not-allowed;" type="text" id="ponumber"
                                           class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                           placeholder="Enter PO Number">
                                </div>
                            </div>
                            <div>
                                <span class="mb-2 font-medium block">Customer</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input type="text" class="k-input" value="@Model.ProjectInfo?.CustomerName" disabled readonly>

                                </div>
                            </div>

                            <div>
                                <span class="mb-2 font-medium block">Project</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input type="text" class="k-input" value="@Model.ProjectInfo?.ProjectName" disabled readonly>

                                </div>
                            </div>

                            <div>
                                <span class="mb-2 font-medium block">Practice</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input type="text" id="practiceInput" class="k-input" placeholder="Practice" asp-for="ProjectInfo.PracticeName" disabled readonly>
                                </div>
                            </div>


                            <div>
                                <span class="mb-2 font-medium block">Contract Start Date*</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input type="date" id="contractstartdate" class="k-input" oninput="setEndDateMin(this.value)" />
                                </div>
                            </div>

                            @*2023-11-23*@
                            <div>
                                <span class="mb-2 font-medium block">Contract End Date*</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input type="date" class="k-input" id="contractenddate" />
                                </div>
                            </div>

                            <div>
                                <span class="mb-2 font-medium block">Amount*</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input type="number" class="k-input" placeholder="Enter Amount" id="amount">
                                </div>
                            </div>
                            <div>
                                <span class="mb-2 font-medium block">Client Coordinator</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input type="text" asp-for="Contactpersonname" class="k-input" placeholder="Enter Client Coordinator" id="contactpersonname">
                                </div>
                            </div>

                            <div>
                                <span class="mb-2 font-medium block">Contact No</span>
                                <div class="flex items-center gap-3 flex-wrap">
                                    <input type="number" asp-for="Contactnumber" class="k-input" placeholder="Enter Contact Number" id="contactNo" pattern="[0-9]{10}" maxlength="10" title="Please enter a 10-digit contact number" oninput="javascript: if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);">
                                </div>
                            </div>

                        </div>
                        <div class="pt-2 pb-4 sticky -bottom-4 bg-white">
                            <button type="button" onclick="savedata();"
                                    class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                                Save
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

