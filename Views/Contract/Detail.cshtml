        function formatDate(date) {
            const options = { month: 'short', year: '2-digit' };
            return date.toLocaleDateString('en-US', options).replace(' ', '-');
        }

        function countDaysInMonths(startDate, endDate) {
            const start = new Date(startDate);
            const end = new Date(endDate);

            const daysInMonths = {};

            // Loop through each month until the end date
            while (start <= end) {
                const month = start.getMonth() + 1; // months are 0-indexed in JS, so add 1
                const year = start.getFullYear();

                // Calculate the last day of the current month
                const lastDayOfMonth = new Date(year, month, 0).getDate();

                // Calculate the days in the current month to count
                let daysCount;
                if (start.getFullYear() === end.getFullYear() && start.getMonth() === end.getMonth()) {
                    // If it's the same month and year, count the days between start and end
                    daysCount = end.getDate() - start.getDate() + 1;
                } else {
                    // Count the days from start date to the end of the month
                    daysCount = lastDayOfMonth - start.getDate() + 1;
                }

                // Add to the result object, formatted as 'YYYY-MM'
                const key = formatDate(start);
                daysInMonths[`${key}`] = (daysInMonths[`${key}`] || 0) + daysCount;

                // Move to the 1st of the next month
                start.setMonth(start.getMonth() + 1, 1); // Ensure the date is reset to the first day of the next month
            }

            return daysInMonths;
        }

