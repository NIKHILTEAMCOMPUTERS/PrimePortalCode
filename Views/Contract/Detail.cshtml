            if (advanceAmount && advanceAmount > 0) {
                advanceAmountFlag = true;
            }

            const allMonths = document.querySelectorAll("#assignedEmployeeBillingTable thead th");
            const tbody = document.querySelector("#assignedEmployeeBillingTable tbody");

