        function showFileName(input) {
            const _selectedFileName = input.files[0]?.name;
            const removeButton = document.querySelector("#removeDocumentButton");
            input.nextElementSibling.querySelector("span").innerHTML = _selectedFileName;

            if (_selectedFileName) {
                removeButton.classList.remove("hidden");
            } else {
                removeButton.classList.add("hidden");
            }
        }
        function removeDocument() {
            const fileInput = document.querySelector("#attachDocument");
            const removeButton = document.querySelector("#removeDocumentButton");

            // Reset the file input
            fileInput.value = "";

            // Reset the displayed file name
            fileInput.nextElementSibling.querySelector("span").innerHTML = "Attach Documents";

            // Hide the Remove Document button
