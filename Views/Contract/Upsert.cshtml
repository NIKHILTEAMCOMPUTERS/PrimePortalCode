@section Scripts {

    <script type="text/javascript">
        let iscontractnounique = true;
        let isponounique = true;
        $(function () {
            document.querySelector(".main").classList.add("flex", "flex-col");
        @if (ViewData["error"] != null)
        {
            <text>
                    toastr.error("@ViewData["error"]", "Error", { "iconClass": 'new-error' });
            </text>
        }
        @if (ViewData["success"] != null)
        {
            <text>
                    toastr.success("@ViewData["success"]");
            </text>
        }

                let _custName = $("#hidCustomerName").val();
            let _projId = $("#hidProjectId").val();

            var _customerId = 0;
            if (_custName != "" && _custName != undefined) {
                $("#CustomerDropdown option").each(function () {
                    if ($(this).text() == _custName) {
                        $(this).attr('selected', 'selected');
                        _customerId = $(this).attr('value');
                        changeCustomer(_customerId, _projId);
                        return false;
                    }
                });
            }
        });

        function setEndDateMin(startDate) {
            const endDateInput = document.getElementById('contractenddate');
            endDateInput.setAttribute('min', startDate);
        }

        function AddMore() {
            const BtnAdd = document.querySelector("#costingModalBtn");
            const card = document.querySelector("#costingModalWrapper");
            const row = card.querySelector("div:first-child");

            const newDiv = document.createElement("div");
            newDiv.classList.add("grid", "grid-cols-1", "sm:grid-cols-4", "gap-3")
            newDiv.innerHTML = row.innerHTML;
            card.append(newDiv);
        }

        function showFormStep(step) {
            const allStepIndicators = document.querySelectorAll(".multipart-indicator")
            const allStepForm = document.querySelectorAll(".multipart-form")

            const _step = step - 1;

            allStepIndicators.forEach((item, index) => {
                item.classList.remove("active");
                allStepForm[index].classList.remove("active");
            })

            allStepIndicators[_step].classList.add("active")
            allStepForm[_step].classList.add("active")
        }

        function addLineItem() {
            const _desc1 = document.querySelector("#ldesc1");
            const _desc2 = document.querySelector("#ldesc2");
            const _amount = document.querySelector("#lamount");
            if (!_desc1.value) {
                _desc1.classList.add("is-invalid")
                return;
            } else {
                _desc1.classList.remove("is-invalid")
            }

            if (!_amount.value) {
                _amount.classList.add("is-invalid")
                return;
            } else {
                _amount.classList.remove("is-invalid")
            }
            const table = document.querySelector("#lineItemTable tbody");
            const isTableEmpty = document.querySelector("#nodata");


            if (!isTableEmpty) {
                const _newTr = `<tr>
                                                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                                                                ${table.children.length + 1}</td>
                                                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">${_desc1.value}
                                                                            </td>
                                                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">${_desc2.value}</td>
                                                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">${_amount.value}</td>
                                                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                                                                <div class="hs-dropdown relative inline-flex">
                                                                                    <button id="hs-dropdown-default" type="button"
                                                                                        class="hs-dropdown-toggle py-1 px-2 inline-flex justify-center items-center gap-2 border border-transparent rounded-md font-medium text-gray-700 shadow-sm align-middle hover:bg-gray-50 hover:border-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-white focus:ring-emerald-600 transition-all text-sm">
                                                                                        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20"><g fill="currentColor"><circle cx="10" cy="15" r="2"/><circle cx="10" cy="10" r="2"/><circle cx="10" cy="5" r="2"/></g></svg>
                                                                                    </button>

                                                                                    <div class="hs-dropdown-menu transition-[opacity,margin] duration-[0.1ms] hs-dropdown-open:opacity-100 opacity-0 hidden z-30 mt-2 min-w-[8rem] bg-white shadow-md rounded-lg"
                                                                                        aria-labelledby="hs-dropdown-default">
                                                                                        <button onclick="deleteRow(this);" class="w-full flex items-center gap-x-3.5 py-2 px-3 rounded-md text-sm text-gray-800 hover:bg-gray-100 focus:ring-2 focus:ring-emerald-500"
                                                                                            >
                                                                                            Delete
                                                                                        </button>
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                        </tr>`;
                table.innerHTML += _newTr;

            } else {
                const _newTr = `<tr>
                                                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                                                                ${table.children.length}</td>
                                                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">${_desc1.value}
                                                                            </td>
                                                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">${_desc2.value}</td>
                                                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">${_amount.value}</td>
                                                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                                                                <div class="hs-dropdown relative inline-flex">
                                                                                    <button id="hs-dropdown-default" type="button"
                                                                                        class="hs-dropdown-toggle py-1 px-2 inline-flex justify-center items-center gap-2 border border-transparent rounded-md font-medium text-gray-700 shadow-sm align-middle hover:bg-gray-50 hover:border-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-white focus:ring-emerald-600 transition-all text-sm">
                                                                                        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20"><g fill="currentColor"><circle cx="10" cy="15" r="2"/><circle cx="10" cy="10" r="2"/><circle cx="10" cy="5" r="2"/></g></svg>
                                                                                    </button>

                                                                                    <div class="hs-dropdown-menu transition-[opacity,margin] duration-[0.1ms] hs-dropdown-open:opacity-100 opacity-0 hidden z-30 mt-2 min-w-[8rem] bg-white shadow-md rounded-lg"
                                                                                        aria-labelledby="hs-dropdown-default">
                                                                                        <button onclick="deleteRow(this);" class="w-full flex items-center gap-x-3.5 py-2 px-3 rounded-md text-sm text-gray-800 hover:bg-gray-100 focus:ring-2 focus:ring-emerald-500"
                                                                                            >
                                                                                            Delete
                                                                                        </button>
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                        </tr>`;
                table.innerHTML = _newTr;
            }
            _desc1.value = "";
            _desc2.value = "";
            _amount.value = "";
        }

        function deleteRow(btn) {
            btn.closest("tr").remove();
            const table = document.querySelector("#lineItemTable tbody");
            const trCount = document.querySelectorAll("#lineItemTable tbody tr").length;
            if (trCount === 0) {
                table.innerHTML = `<tr id="nodata">
                                                                                        <td id="emptyData" colspan="5" class="px-6 py-4 whitespace-nowrap text-sm text-center font-medium text-gray-800 ">
                                                                                            No Data Yet</td>
                                                                                    </tr>`;
            } else {
                recalculateRowCount();
            }
        }

        function recalculateRowCount() {
            const allTr = document.querySelectorAll("#lineItemTable tbody tr");
            allTr.forEach((item, index) => {
                item.querySelector("td").innerHTML = index + 1;
            })
        }

        function addNewQuestion() {
            const questionsWrapper = document.querySelector(".presales-questions-wrapper");
            const _newQuestionDiv = document.createElement("div");
            _newQuestionDiv.classList.add("mb-4", "flex", "items-end", "gap-4");
            _newQuestionDiv.innerHTML = `<div class="flex-1">
                                                                                    <div class="flex items-center gap-1">
                                                                                        <span class="question_count font-medium">${questionsWrapper.children.length + 1}</span>.
                                                                                        <input type="text" class="k-input w-full mb-2" placeholder="Enter question">
                                                                                    </div>
                                                                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                                                        <input type="text"
                                                                                            class=" py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                                                                                    placeholder="Enter Answer">
                                                                                        <input type="text"
                                                                                            class="ref-response py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                                                                                    placeholder="Reference Answer">
                                                                                    </div>
                                                                                </div>
                                                                                <button onclick="deleteQuestion(this);" class="py-3 px-4 inline-flex justify-center items-center gap-2 rounded-md border-2 border-red-200 font-semibold text-red-500 hover:text-white hover:bg-red-500 hover:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 focus:ring-offset-2 transition-all text-sm">
                                                                                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="1024" height="1024" viewBox="0 0 1024 1024"><path fill="currentColor" d="M360 184h-8c4.4 0 8-3.6 8-8v8h304v-8c0 4.4 3.6 8 8 8h-8v72h72v-80c0-35.3-28.7-64-64-64H352c-35.3 0-64 28.7-64 64v80h72v-72zm504 72H160c-17.7 0-32 14.3-32 32v32c0 4.4 3.6 8 8 8h60.4l24.7 523c1.6 34.1 29.8 61 63.9 61h454c34.2 0 62.3-26.8 63.9-61l24.7-523H888c4.4 0 8-3.6 8-8v-32c0-17.7-14.3-32-32-32zM731.3 840H292.7l-24.2-512h487l-24.2 512z"/></svg>
                                                                                </button>`;
            questionsWrapper.appendChild(_newQuestionDiv);
        }

        function deleteQuestion(btn) {
            btn.parentElement.remove();
            recalculateQuestionNumbers();
        }

        function recalculateQuestionNumbers() {
            const allQuestionNumber = document.querySelectorAll(".presales-questions-wrapper .question_count");
            allQuestionNumber.forEach((item, index) => {
                item.innerHTML = index + 1;
            })
        }
        //    setCostingSheetData();







        // drop down code
        const customerDropdown = document.getElementById('CustomerDropdown');
        const projectDropdown = document.getElementById('projectDropdown');
        const practiceInput = document.getElementById('practiceInput');


        customerDropdown.addEventListener('change', async () => {
            const selectedCustomerId = customerDropdown.value;
            await changeCustomer(selectedCustomerId);
        });

        async function changeCustomer(selectedCustomerId, projId = "") {
            var projHtml = '<option value="" prac-id="" prac-n="">Select Project</option>';
            practiceInput.value = '';
            if (selectedCustomerId) {
                const response = await fetch(`/Base/GetProjectAndPracticeByCustomerId?Customerid=${selectedCustomerId}`);
                if (response != null) {
                    const data = await response.json();
                    const optionData = [{ text: "Select Project", value: "" }];

                    data.forEach(item => {
                        const _opt = {
                            text: item?.projectName,
                            value: item?.projectId,
                            data: {
                                "prac-id": item.practiceId,
                                "prac-n": item.practiceName
                            }
                        }
                        optionData.push(_opt);
                    })
                    multiSelect1.setData(optionData);
                    // $(projectDropdown).empty().append(projHtml);

                    if (projId != "" && projId != undefined) {
                        // $(projectDropdown).val(projId);
                        // practiceInput.value = $('#projectDropdown option:selected').attr('prac-n');
                        console.log(projId, typeof projId);
                        setTimeout(() => {
                            multiSelect1.setSelected(Number(projId));
                        }, 300)

                    }

                } else {
                    console.error('Error fetching project and practice data:', response.statusText);
                }
            }
        }

        $(projectDropdown).on('change', function () {
            var selectedPracticeId = $('option:selected', this).attr('data-prac-id');

            if (selectedPracticeId != "" && selectedPracticeId != undefined) {
                practiceInput.value = $('option:selected', this).attr('data-prac-n');
                getQuestionsByPracticeId(selectedPracticeId);
            }
        });


        //[Presales checklist]
        function getQuestionsByPracticeId(practiceId) {
            $.ajax({
                type: 'GET',
                url: `/Contract/GetCheckList?practiceId=${practiceId}`,
                success: function (response) {
                    try {
                        const parsedData = JSON.parse(response);
                        console.log(parsedData);
                        if ($("#hidContractId").val() == '0') {
                            displayDynamicQuestions(parsedData);
                        }

                    } catch (error) {
                        console.error("Error parsing JSON:", error);
                    }
                }
            });
        }
        //  displayDynamicCheckList
        function displayDynamicQuestions(data) {
            const questionsContainer = document.getElementById("dynamicquestions");
            questionsContainer.innerHTML = "";

            if (data) {
                const questions = data;
                questions.forEach((question, index) => {
                    const questionElement = document.createElement("div");

                    questionElement.innerHTML = `<div class ="mb-4"><div class="flex items-center gap-2 mb-2"><span class="question_count font-medium">${index + 1}</span><label class="font-medium block">${question.question}</label></div>
                                                                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                                                    <input type="text" class="k-input w-full" placeholder="Enter Answer" name="Response[]">
                                                                                            <input type="text" class="k-input w-full ref-response" placeholder="Reference Answer" name="Refresponse[]" />
                                                                                        </div></div>`;

                    questionsContainer.appendChild(questionElement);
                });
            }
        }



        // For DATA POSTING
        function validateFirstPart() {
            let invalidFields = {};
            let validFlag = true;
            if (!$("#contractno").val()) {
                validFlag = false;
                invalidFields['contractno'] = true;
                $("#contractno").addClass("is-invalid");
            } else if (!iscontractnounique) {
                validFlag = false;
                invalidFields['contractno'] = true;
                $("#contractno").addClass("is-invalid");
            } else {
                delete invalidFields['contractno'];
                $("#contractno").removeClass("is-invalid");
            }

            if ($("#ponumber").val().toLowerCase() === 'na' || $("#ponumber").val().toLowerCase() === 'n/a' || $("#ponumber").val().toLowerCase() === 'n\a' || $("#ponumber").val().toLowerCase() === 'n_a' || $("#ponumber").val().toLowerCase() === 'n-a') {
                validFlag = false;
                $("#ponumber").addClass("is-invalid");
            } else if (!isponounique) {
                validFlag = false;
            } else {
                $("#ponumber").removeClass("is-invalid");
            }

            if (!$("#CustomerDropdown").val()) {
                validFlag = false;
                invalidFields['CustomerDropdown'] = true;
                $("#CustomerDropdown").addClass("is-invalid");
            } else {

                delete invalidFields['CustomerDropdown'];
                $("#CustomerDropdown").removeClass("is-invalid");
            }

            if (!$("#projectDropdown").val()) {
                validFlag = false;
                invalidFields['projectDropdown'] = true;
                $("#projectDropdown").addClass("is-invalid");
            } else {

                delete invalidFields['projectDropdown'];
                $("#projectDropdown").removeClass("is-invalid");
            }
            if (!$("#DADropdown").val() || $("#DADropdown").val() == '0') {
                isValid = false;
                document.querySelector("#DADropdown").nextElementSibling.classList.add("is-invalid");
            } else {
                document.querySelector("#DADropdown").nextElementSibling.classList.remove("is-invalid");
                // $("#DADropdown").next().removeClass("is-invalid");
            }
            if (!$("#contractstartdate").val()) {
                validFlag = false;
                invalidFields['contractstartdate'] = true;
                $("#contractstartdate").addClass("is-invalid");
            } else {

                delete invalidFields['contractstartdate'];
                $("#contractstartdate").removeClass("is-invalid");
            }

            if (!$("#contactpersonname").val()) {
                validFlag = false;
                invalidFields['contactpersonname'] = true;
                $("#contactpersonname").addClass("is-invalid");
            } else {
                delete invalidFields['contactpersonname'];
                $("#contactpersonname").removeClass("is-invalid");
            }



            if (validFlag) {
                showFormStep(2);
            }
        }
        function validateSecondPart() {
            var lineitemcount = document.querySelectorAll("#lineItemTable tbody tr");
            var validFlag = true;
            if (lineitemcount < 1 || lineitemcount[0].id == "nodata") {
                validFlag = true;
                $("#ldesc1").addClass("is-invalid");
                $("#ldesc2").addClass("is-invalid");
                $("#lamount").addClass("is-invalid");
            }
            else {
                validFlag = true;
                $("#ldesc1").removeClass("is-invalid");
                $("#ldesc2").removeClass("is-invalid");
                $("#lamount").removeClass("is-invalid");
            }
            if (validFlag) {
                showFormStep(3);
            }
        }
        function validateThirdPart() {
            let validFlag = true;
            const allquestions = Array.from(document.querySelector(".presales-questions-wrapper").children);
            allquestions.forEach(ques => {
                const allinputs = ques.querySelectorAll("input:not(.ref-response)");
                allinputs.forEach(inp => {
                    if (!inp.value) {
                        // inp.classList.add("is-invalid");
                        validFlag = true;
                    } else {
                        // inp.classList.remove("is-invalid");
                        validFlag = true;
                    }
                })
            })
            return validFlag;
        }
        function savedata() {
            if (validateThirdPart()) {
                document.querySelector("#loader").style.display = "flex";
                const bodyData = {
                    "contractid": $("#hidContractId").val(),
                    "contractno": $("#contractno").val(),
                    "projectid": $("#projectDropdown").val(),
                    "Deliveryanchorid": $("#DADropdown").val(),
                    "contractstartdate": $("#contractstartdate").val(),
                    "contractenddate": $("#contractenddate").val(),
                    "amount": $("#amount").val(),
                    "contactpersonname": $("#contactpersonname").val(),
                    "costsheetid": $("#costingsheet").val(),
                    "contactnumber": $("#contactNo").val(),
                    "remarks": $("#remarks").val(),
                    "attachment": $("#attachDocument").val(),
                    "contractlines": [],
                    "questions": []
                };
                if (document.querySelector("#po-status")) {
                    if (document.querySelector("#po-status").value === '3') {
                        // "ponumber": $("#ponumber").val(),
                        if (!document.querySelector("#ponumber").value) {
                            bodyData["ponumber"] = `Agreement/${Date.now()}`;
                        } else {
                            if (!document.querySelector("#ponumber").value.toLowerCase().startsWith('agreement')) {
                                bodyData["ponumber"] = `Agreement/${document.querySelector("#ponumber").value}/${Date.now()}`;
                            } else {
                                bodyData["ponumber"] = document.querySelector("#ponumber").value+Date.now();
                            }
                        }
                    } else {
                        bodyData["ponumber"] = $("#ponumber").val();
                    }
                } else {
                    bodyData["ponumber"] = $("#ponumber").val();
                }

                const allListTr = document.querySelectorAll("#lineItemTable tbody tr");
                if (allListTr.length && allListTr[0].id !== "nodata") {
                    allListTr.forEach(tr => {
                        const lineItem = {
                            lineno: `${tr.querySelector('td:nth-child(1)').innerText.trim()}`,
                            linedescription1: `${tr.querySelector('td:nth-child(2)').innerText.trim()}`,
                            linedescription2: `${tr.querySelector('td:nth-child(3)').innerText.trim()}`,
                            lineamount: `${tr.querySelector('td:nth-child(4)').innerText.trim()}`
                        }
                        bodyData.contractlines.push(lineItem);
                    });
                } else {
                    bodyData.contractlines.push({
                        lineno: 1,
                        linedescription1: "N/A",
                        linedescription2: "N/A",
                        amount: 0
                    })
                }


                const allQuestionsDiv = Array.from(document.querySelector(".presales-questions-wrapper").children);
                allQuestionsDiv.forEach(ques => {

                    const _question = {};
                    if (ques.querySelector("label")) {
                        _question.question = ques.querySelector("label").innerText;
                        _question.response = ques.querySelectorAll("input")[0].value;
                        _question.refresponse = ques.querySelectorAll("input")[1].value;
                        _question.isExtra = false;
                    } else {
                        _question.question = ques.querySelectorAll("input")[0].value;
                        _question.response = ques.querySelectorAll("input")[1].value;
                        _question.refresponse = ques.querySelectorAll("input")[2].value;
                        _question.isExtra = true;
                    }
                    bodyData.questions.push(_question);
                });

                console.log(bodyData);

                const formData = new FormData();

                formData.append("contracts", JSON.stringify(bodyData))
                const fileInput = $("#attachDocument")[0];
                if (fileInput.files.length > 0) {
                    formData.append("Attachment", fileInput.files[0]);
                }

                $.ajax({
                    type: "POST",
                    url: "@Url.Action("Upsert", "Contract")",
                    data: formData,
                    contentType: false,
                    processData: false,
                    success: function (res) {
                        $("#loader").hide();
                        if (res.success == true) {
                            toastr.success(res.msg);
                            setTimeout(() => {
                                window.location.href = "/Contract/Index"
                            }, 1000)
                        } else {
                            toastr.error(res.msg);
                            $("#loader").hide();
                        }
                    }
                });
            }
        }

