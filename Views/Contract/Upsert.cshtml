        async function checkbillingexist(inp) {
            if (!inp.value.trim()) {
                return;
            }

            const formData = new FormData();
            var contractid = $("#hidContractId").val();
            var contractno = "@Model.Contractno";
            formData.append("contractno",contractno );
            formData.append("contractid", contractid);
            formData.append("inputdate", inp.value.trim());


            const response = await fetch("/Contract/CheckContractBilling", {
                method: "POST",
                body: formData
            })

            if (response.status === 200) {
                const data = await response.json();
                console.log(data);
                const responseContent = JSON.parse(data.responseContent);
                if (responseContent?.isBiling === true) {
                    toastr.error("Date cannot be changed. Billing already exists. First remove the billing to change date.")
                    inp.value = inp.getAttribute("data-originaldate");
                }
            } else {
                toastr.error("Something went wong");
            }

        }
