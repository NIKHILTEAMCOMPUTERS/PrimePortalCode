        // for validation of contract no
        async function Checkcontract(inp) {
            if (!inp.value.trim()) {
                return;
            }

            const formData = new FormData();
            var contractid = $("#hidContractId").val();
            formData.append("contractno", inp.value.trim());
            formData.append("contractid", contractid);


            const response = await fetch("/Contract/CheckContractno", {
                method: "POST",
                body: formData
            })

            if (response.status === 200) {
                const data = await response.json();
                console.log(data);
                if (data.responseContent != "false") {
                    document.querySelector("#alreadyexist").innerHTML = "Contract No. Already Exist!!"
                    inp.classList.add("is-invalid");
                    iscontractnounique = false;
                }
                else {
                    document.querySelector("#alreadyexist").innerHTML = ""
                    inp.classList.remove("is-invalid");
                    iscontractnounique = true;
                }
            } else {
                toastr.error("Something went wong");
            }
            // url / Contract / CheckContractno
        }

