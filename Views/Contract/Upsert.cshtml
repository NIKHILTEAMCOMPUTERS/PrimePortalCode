@using System.Globalization;
@model RMS.Client.Models.Contract.ContractRequestDto

<div class="flex items-center gap-4 mb-5">
    <a asp-action="Index" asp-controller="Contract" class="py-2 px-2 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base" title="Back">
        <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M11.707 5.293a1 1 0 0 1 0 1.414L7.414 11H19a1 1 0 1 1 0 2H7.414l4.293 4.293a1 1 0 0 1-1.414 1.414l-6-6a1 1 0 0 1 0-1.414l6-6a1 1 0 0 1 1.414 0z" /></svg>
    </a>
    <div>
        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Add/Edit Contract</h2>
        <p>Add the required details for the new Contract</p>
    </div>

</div>
<form class="flex-1 flex flex-col">
    @if (Model.Contractid != null)
    {
        <input type="hidden" id="hidContractId" value="@Model.Contractid" />
    }

    <div class="multipart-wrapper flex-1 flex flex-col">
        <div class="multipart-indicators-wrapper flex items-center border-b">
            <div class="multipart-indicator py-2 px-4 active">Contract Details</div>
            <div class="multipart-indicator py-2 px-4">Lines</div>
            <div class="multipart-indicator py-2 px-4">Presales Checklist</div>
            <!-- <div class="multipart-indicator py-2 px-4">Contact Persons</div> -->
        </div>
        <div class="multipart-form-wrapper mt-4 flex-1 flex flex-col">
            <div class="multipart-form active w-full flex-1 flex flex-col">
                @* @if (Model.Contractid == 0 || Model.Contractid == null)
                {
                <div class="d-flex items-center gap-4 mb-4">
                <div class="inline-flex items-center rounded shadow py-3 px-6 gap-2">
                <input type="radio" name="poOrAgreement" onchange="showPoOrAgreement('po')" class="shrink-0 mt-0.5 border-gray-200 rounded-full text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="poRadio" checked>

                <label for="poRadio" class="block font-bold ">PO Contract</label>
                </div>
                <div class="inline-flex items-center rounded shadow py-3 px-6 gap-2">
                <input type="radio" name="poOrAgreement" onchange="showPoOrAgreement('agreement')" class="shrink-0 mt-0.5 border-gray-200 rounded-full text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="agreementRadio">

                <label for="agreementRadio" class="block font-bold ">Agreement</label>
                </div>
                </div>
                } *@
                <div class="flex-1 overflow-y-auto">
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <span class="mb-2 font-medium flex items-center justify-between">Contract Number* <p id="alreadyexist" class="text-red-500"></p></span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="text" id="contractno" value="@Model.Contractno" onchange="Checkcontract(this)"
                                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                       placeholder="Enter Contract Number" maxlength="20">
                            </div>

                        </div>
                       
                        <div>
                            <label for="ponumber" class="mb-2 font-medium block flex items-center justify-between">PO Number <p id="alreadyexistpo" class="text-red-500"></p></label>
                            <div class="relative">
                                <input type="text" id="ponumber" maxlength="30" value="@Model.Ponumber" class="py-3 px-4 @((Model.Contractid == null || Model.Contractid == 0) ? "ps-40" : "") block w-full border-gray-200 shadow-sm rounded-lg text-sm focus:z-10 focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:cursor-not-allowed " onchange="checkPo(this);">
                                @if (Model.Contractid == null || Model.Contractid == 0)
                                {
                                    <div class="absolute inset-y-0 start-0 flex items-center text-gray-500 ps-px">
                                        <label for="hs-inline-leading-select-country" class="sr-only">PO Status</label>
                                        <select id="po-status" onchange="handlePoStatus(this);" class="block w-full border-transparent rounded-s-lg focus:ring-emerald-600 focus:border-emerald-600 border-r-gray-200 bg-gray-50">
                                            <option value="1">PO Available</option>
                                            <option value="2">PO Awaited</option>
                                            <option value="3">Agreement</option>
                                        </select>
                                    </div>
                                }
                            </div>
                        </div>
                        <div>
                            <input type="hidden" id="hidCustomerName" value="@(Model.ProjectInfo == null ? "" : Model.ProjectInfo.CustomerName)" />
                            <input type="hidden" id="hidProjectId" value="@(Model.ProjectInfo == null ? "" : Model.ProjectInfo.ProjectId)" />

                            <span class="mb-2 font-medium block">Customer</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <select id="CustomerDropdown" name="Customerid" asp-items="@ViewBag.cust"
                                        class="multi-select">
                                    placeholder="Select Customer">
                                    <option value="">Select Customer</option>
                                </select>
                            </div>
                        </div>

                        <div>
                            <span class="mb-2 font-medium block">Project</span>
                            <select id="projectDropdown" name="ProjectId"
                                    class="multi-select"></select>
                        </div>

                        <div>
                            <span class="mb-2 font-medium block">Practice</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="text" id="practiceInput" class="k-input" placeholder="Practice" asp-for="ProjectInfo.PracticeName" disabled readonly>
                            </div>
                        </div>

                        @* <div>
                        <span class="mb-2 font-medium block">Contract Type</span>
                        <select id="contracttype" asp-for="Contracttypeid" asp-items="ViewBag.ContractType" class="py-2 px-4 pr-9 block w-full flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500 sm:p-3">
                        <option value="">Select Contract Type</option>
                        </select>
                        </div> *@


                        <div>
                            <span class="mb-2 font-medium block">Contract Start Date</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="date" asp-for="Contractstartdate" id="contractstartdate" class="k-input" oninput="setEndDateMin(this.value)" />
                            </div>
                        </div>

                        @*2023-11-23*@
                        <div>
                            <span class="mb-2 font-medium block">Contract End Date</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="date" asp-for="Contractenddate" class="k-input" id="contractenddate" data-originaldate="@Model.Contractenddate.ToString("yyyy-MM-dd")" onchange="checkbillingexist(this)" />
                            </div>
                        </div>

                        <div>
                            <span class="mb-2 font-medium block">Amount</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="number" asp-for="Amount" class="k-input" placeholder="Enter Amount" id="amount" maxlength="9">
                            </div>
                        </div>
                        <div>
                            <span class="mb-2 font-medium block">Delivery Anchor *</span>
                            <select id="DADropdown" name="Deliveryanchorid" class="multi-select">
                                <option value="0" selected>Select DA</option>

                                @foreach (var da in ViewBag.DA)
                                {
                                    if (Model.Deliveryanchorid.ToString() == da.Value)
                                    {
                                        <option value="@da.Value" selected>
                                            @da.Text
                                        </option>
                                    }
                                    else
                                    {
                                        <option value="@da.Value">@da.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <span class="mb-2 font-medium block">Client Coordinator</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="text" asp-for="Contactpersonname" class="k-input" placeholder="Enter Client Coordinator" id="contactpersonname" oninput="this.value = this.value.replace(/[^a-zA-Z\s]/g, '').replace(/^\s+/g, '')"
                                       maxlength="50">
                            </div>
                        </div>

                        <div>
                            <span class="mb-2 font-medium block">Contact No*</span>
                            <div class="flex items-center gap-3 flex-wrap">
                                <input type="number" asp-for="Contactnumber" class="k-input" placeholder="Enter Contact Number" id="contactNo" title="Please enter a 10-digit contact number" pattern="[0-9]{10}" maxlength="10" title="Please enter a 10-digit contact number" oninput="javascript: if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);">

                            </div>
                        </div>

                        <div>
                            @* <div class="flex items-center justify-between gap-3 flex-wrap">
                            <span class="mb-2 font-medium block">Costing sheet</span> *@
                            @*<button type="button"
                            class="px-5 inline-flex justify-center items-center gap-2 rounded-md border outline-none border-transparent text-emerald-500 text-sm 2xl:text-base"
                            data-hs-overlay="#costing-sheet-modal">
                            <svg class="w-4 h-4" width="21" height="21" viewBox="0 0 21 21" fill="none"
                            xmlns="http://www.w3.org/2000/svg">
                            <path d="M10.5 0C7.72562 0.0334721 5.07431 1.15047 3.11239 3.11239C1.15047 5.07431 0.0334721 7.72562 0 10.5C0.0334721 13.2744 1.15047 15.9257 3.11239 17.8876C5.07431 19.8495 7.72562 20.9665 10.5 21C13.2744 20.9665 15.9257 19.8495 17.8876 17.8876C19.8495 15.9257 20.9665 13.2744 21 10.5C20.9665 7.72562 19.8495 5.07431 17.8876 3.11239C15.9257 1.15047 13.2744 0.0334721 10.5 0ZM16.5 11.25H11.25V16.5H9.75V11.25H4.5V9.75H9.75V4.5H11.25V9.75H16.5V11.25Z"
                            fill="#00CC83" />
                            <path d="M16.5 11.25H11.25V16.5H9.75V11.25H4.5V9.75H9.75V4.5H11.25V9.75H16.5V11.25Z"
                            fill="white" />
                            </svg>
                            Create
                            </button>*@
                            @*  </div> *@

                            @* <div class="flex items-center gap-3 flex-wrap">
                            <select class="k-input" id="costingsheet" asp-for="Costsheetid" asp-items="ViewBag.GetCostSheet">
                            <option value="">Select Costsheet</option>
                            </select>
                            </div>*@
                        </div>
                    </div>
                </div>
                <div class="pt-2 pb-4 sticky -bottom-4 bg-white">
                    <button type="button" onclick="validateFirstPart();"
                            class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                        Next
                    </button>
                </div>
            </div>


            <div class="multipart-form w-full flex-1 flex flex-col">
                <div class="flex items-stretch sm:items-end flex-col sm:flex-row gap-4">
                    <div class="flex-[2]">
                        <label for="">Line Description 1</label>
                        <input id="ldesc1" type="text" class="k-input w-full">
                    </div>
                    <div class="flex-[2]">
                        <label for="">Line Description 2</label>
                        <input id="ldesc2" type="text" class="k-input w-full">
                    </div>
                    <div class="flex-[1]">
                        <label for="">Line Amount</label>
                        <input id="lamount" type="number" class="k-input w-full" maxlength="9">
                    </div>
                    <button type="button" onclick="addLineItem();"
                            class="py-3 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm">
                        Add/Edit
                    </button>
                </div>
                <div class="flex flex-col my-4 flex-1 overflow-y-auto">
                    <div class="-m-1.5 overflow-x-auto">
                        <div class="p-1.5 min-w-full block align-middle">
                            <div class="overflow-hidden">
                                <table class="min-w-full divide-y divide-gray-200" id="lineItemTable">
                                    <thead>
                                        <tr>
                                            <th scope="col"
                                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                                S.No
                                            </th>
                                            <th scope="col"
                                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                                Line Description 1
                                            </th>
                                            <th scope="col"
                                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                                Line Description 2
                                            </th>
                                            <th scope="col"
                                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                                Amount
                                            </th>
                                            <th scope="col"
                                                class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                                Action
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-gray-200">
                                        @{
                                            if (Model.Contractlines != null && Model.Contractlines.Count > 0)
                                            {
                                                int row = 0;
                                                foreach (var line in Model.Contractlines)
                                                {
                                                    <tr>
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                                            @(row += 1)
                                                        </td>
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">
                                                            @line.Linedescription1
                                                        </td>
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@line.Linedescription2</td>
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@line.Lineamount</td>
                                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                                            <div class="hs-dropdown relative inline-flex">
                                                                <button id="hs-dropdown-default" type="button"
                                                                        class="hs-dropdown-toggle py-1 px-2 inline-flex justify-center items-center gap-2 border border-transparent rounded-md font-medium text-gray-700 shadow-sm align-middle hover:bg-gray-50 hover:border-gray-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-white focus:ring-emerald-600 transition-all text-sm">
                                                                    <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20"><g fill="currentColor"><circle cx="10" cy="15" r="2" /><circle cx="10" cy="10" r="2" /><circle cx="10" cy="5" r="2" /></g></svg>
                                                                </button>

                                                                <div class="hs-dropdown-menu transition-[opacity,margin] duration-[0.1ms] hs-dropdown-open:opacity-100 opacity-0 hidden z-30 mt-2 min-w-[8rem] bg-white shadow-md rounded-lg"
                                                                     aria-labelledby="hs-dropdown-default">
                                                                    <button onclick="deleteRow(this);" class="w-full flex items-center gap-x-3.5 py-2 px-3 rounded-md text-sm text-gray-800 hover:bg-gray-100 focus:ring-2 focus:ring-emerald-500">
                                                                        Delete
                                                                    </button>
                                                                </div>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            }
                                            else
                                            {
                                                <tr id="nodata">
                                                    <td id="emptyData" colspan="5" class="px-6 py-4 whitespace-nowrap text-sm text-center font-medium text-gray-800 ">
                                                        No Data Yet
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="pt-2 pb-4 sticky -bottom-4 bg-white flex items-center gap-4">
                    <button type="button" onclick="showFormStep(1);"
                            class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                        Prev
                    </button>
                    <button type="button" onclick="validateSecondPart();"
                            class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
                        Next
                    </button>
                </div>
            </div>


            <div class="multipart-form w-full flex-1 flex flex-col">
                <div class="flex-1 overflow-y-auto">
                    <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C] mb-6">Questions</h2>
                    <div class="presales-questions-wrapper" id="dynamicquestions">
                        @{
                            int quesrow = 0;
                            if (Model.Questions != null && Model.Questions.Count > 0)
                            {
                                foreach (var ques in Model.Questions)
                                {
                                    if (ques.IsExtra != null && ques.IsExtra == true)
                                    {
                                        <div class="mb-4 flex items-end gap-4">
                                            <div class="flex-1">
                                                <div class="flex items-center gap-1">
                                                    <span class="question_count font-medium">@(quesrow += 1).</span>
                                                    <input type="text" class="k-input w-full mb-2" value="@ques.Question" placeholder="Enter question">
                                                </div>
                                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                    <input type="text" value="@ques.response"
                                                           class=" py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                                           placeholder="Enter Answer">
                                                    <input type="text" value="@ques.Refresponse"
                                                           class="ref-response py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                                                           placeholder="Reference Answer">
                                                </div>
                                            </div>
                                            <button onclick="deleteQuestion(this);" class="py-3 px-4 inline-flex justify-center items-center gap-2 rounded-md border-2 border-red-200 font-semibold text-red-500 hover:text-white hover:bg-red-500 hover:border-red-500 focus:outline-none focus:ring-2 focus:ring-red-200 focus:ring-offset-2 transition-all text-sm">
                                                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="1024" height="1024" viewBox="0 0 1024 1024"><path fill="currentColor" d="M360 184h-8c4.4 0 8-3.6 8-8v8h304v-8c0 4.4 3.6 8 8 8h-8v72h72v-80c0-35.3-28.7-64-64-64H352c-35.3 0-64 28.7-64 64v80h72v-72zm504 72H160c-17.7 0-32 14.3-32 32v32c0 4.4 3.6 8 8 8h60.4l24.7 523c1.6 34.1 29.8 61 63.9 61h454c34.2 0 62.3-26.8 63.9-61l24.7-523H888c4.4 0 8-3.6 8-8v-32c0-17.7-14.3-32-32-32zM731.3 840H292.7l-24.2-512h487l-24.2 512z" /></svg>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div>
                                            <div class="mb-4">
                                                <div class="flex items-center gap-2 mb-2">
                                                    <span class="question_count font-medium">@(quesrow += 1)</span>
                                                    <label class=" font-medium block"> @ques.Question</label>
                                                </div>
                                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                    <input type="text" class="k-input w-full" placeholder="Enter Answer" value="@ques.response" name="Response[]">
                                                    <input type="text" class="k-input w-full ref-response" placeholder="Reference Answer" value="@ques.Refresponse" name="Refresponse[]" />
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            }
                        }
                    </div>
                    <div class="flex items-center justify-between flex-wrap p-2">
                       @*  <div>
                            <input class="hidden" type="file" id="attachDocument" accept=".xlsx,.xls,.doc,.docx,.pdf" onchange="showFileName(this);">
                            <label for="attachDocument" class="py-[.688rem] px-4 inline-flex justify-center items-center gap-2 rounded-md border-2 border-blue-400 font-semibold text-blue-500 hover:text-white hover:bg-blue-500 hover:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all text-sm">
                                <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" fill-rule="evenodd" d="M12 4a5 5 0 0 0-5 5v6a1 1 0 1 1-2 0V9a7 7 0 1 1 14 0v8a5 5 0 0 1-10 0V9a3 3 0 0 1 6 0v8a1 1 0 1 1-2 0V9a1 1 0 1 0-2 0v8a3 3 0 0 0 6 0V9a5 5 0 0 0-5-5Z" clip-rule="evenodd" /></svg>
                                <span>Attach Documents</span>
                            </label>
                            <label>*Only accept ".xlsx,.xls,.doc,.docx,.pdf"</label>
                        </div> *@
                        @if (Model != null)
                        {
                            <div>
                                <input class="hidden" type="file" id="attachDocument" accept=".xlsx,.xls,.doc,.docx,.pdf" onchange="showFileName(this);">
                                <label for="attachDocument" class="py-[.688rem] px-4 inline-flex justify-center items-center gap-2 rounded-md border-2 border-blue-400 font-semibold text-blue-500 hover:text-white hover:bg-blue-500 hover:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all text-sm">
                                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" fill-rule="evenodd" d="M12 4a5 5 0 0 0-5 5v6a1 1 0 1 1-2 0V9a7 7 0 1 1 14 0v8a5 5 0 0 1-10 0V9a3 3 0 0 1 6 0v8a1 1 0 1 1-2 0V9a1 1 0 1 0-2 0v8a3 3 0 0 0 6 0V9a5 5 0 0 0-5-5Z" clip-rule="evenodd" /></svg>
                                    <span>@Model.Attachment</span>
                                </label>
                                <button id="removeDocumentButton" onclick="removeDocument();" type="button">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 1024 1024">
                                        <path fill="#ff5252" d="M512 64a448 448 0 1 1 0 896a448 448 0 0 1 0-896M288 512a38.4 38.4 0 0 0 38.4 38.4h371.2a38.4 38.4 0 0 0 0-76.8H326.4A38.4 38.4 0 0 0 288 512" />
                                    </svg>
                                </button>

                                <label>*Only accept ".xlsx,.xls,.doc,.docx,.pdf"</label>
                            </div>
                        }
                        else
                        {
                            <div>
                                <input class="hidden" type="file" id="attachDocument" accept=".xlsx,.xls,.doc,.docx,.pdf" onchange="showFileName(this);">
                                <label for="attachDocument" class="py-[.688rem] px-4 inline-flex justify-center items-center gap-2 rounded-md border-2 border-blue-400 font-semibold text-blue-500 hover:text-white hover:bg-blue-500 hover:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-all text-sm">
                                    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" fill-rule="evenodd" d="M12 4a5 5 0 0 0-5 5v6a1 1 0 1 1-2 0V9a7 7 0 1 1 14 0v8a5 5 0 0 1-10 0V9a3 3 0 0 1 6 0v8a1 1 0 1 1-2 0V9a1 1 0 1 0-2 0v8a3 3 0 0 0 6 0V9a5 5 0 0 0-5-5Z" clip-rule="evenodd" /></svg>
                                    <span>Attach Documents</span>
