        function showPoOrAgreement(type) {
            if (type === 'po') {
                document.querySelector("#ponumber").setAttribute("placeholder", "Enter PO No/Leave blank if PO is awaited");
                document.querySelector("#ponumber").value = "";
                document.querySelector("#ponumber").parentElement.previousElementSibling.innerHTML = 'PO Number <p id="alreadyexistpo" class="text-red-500"></p>';
            } else if (type === 'agreement') {
                document.querySelector("#ponumber").setAttribute("placeholder", "Enter agreement number if any");
                document.querySelector("#ponumber").value = "Agreement/";
                document.querySelector("#ponumber").disabled = true;
                document.querySelector("#ponumber").parentElement.previousElementSibling.innerHTML = 'Agreement <p id="alreadyexistpo" class="text-red-500"></p>';
            }
        }

        function handlePoStatus(inp) {
            if (inp.value == '2') {
                document.querySelector("#ponumber").parentElement.previousElementSibling.innerHTML = 'PO Number <p id="alreadyexistpo" class="text-red-500"></p>';
                document.querySelector("#ponumber").value = "";
                document.querySelector("#ponumber").disabled = true;
                document.querySelector("#ponumber").classList.remove("is-invalid");
            } else if (inp.value === '3') {
                document.querySelector("#ponumber").parentElement.previousElementSibling.innerHTML = 'Agreement <p id="alreadyexistpo" class="text-red-500"></p>';
                document.querySelector("#ponumber").value = "Agreement/";
                document.querySelector("#ponumber").disabled = true;
                document.querySelector("#ponumber").setAttribute("placeholder", "Enter agreement number if any");
                document.querySelector("#ponumber").classList.remove("is-invalid");
            } else {
                document.querySelector("#ponumber").disabled = false;
                document.querySelector("#ponumber").setAttribute("placeholder", "Enter PO No/Leave blank if PO is awaited");
                document.querySelector("#ponumber").value = "";
                document.querySelector("#ponumber").parentElement.previousElementSibling.innerHTML = 'PO Number <p id="alreadyexistpo" class="text-red-500"></p>';
            }
        }




