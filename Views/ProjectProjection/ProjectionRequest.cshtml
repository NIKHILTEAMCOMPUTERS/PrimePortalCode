@model IEnumerable<RMS.Client.Models.Projection.Projectionrequest>
@using System.Globalization;
@using Microsoft.AspNetCore.Http
@using RMS.Client.Utility
@{
    var roleName = @Context.Session.GetString("RoleName");
}


@section PageStyles {
    <style>
        .approve-all-btn2 {
            opacity: .5;
            pointer-events: none;
        }

        .hidden-row:has(.selectAllProjectWise:checked) .approve-all-btn2 {
            opacity: 1;
            pointer-events: all;
        }

        .hidden-row:has(.selectAllProjectWise:checked) .approve-btn {
            opacity: 0;
            pointer-events: none;
        }

        .editAllBtn {
            opacity: .5;
            pointer-events: none;
            cursor: not-allowed;
            display: flex;
            border: 1px solid #3b82f6;
            color: #3b82f6;
            border-radius: 5rem;
            align-items: center;
            gap: .5rem;
        }

        .swapAllBtn {
            display: flex;
            border: 1px solid #3b82f6;
            color: #3b82f6;
            border-radius: 5rem;
            align-items: center;
            gap: .5rem;
        }

        .hidden-row:has(.selectAllProjectWise:checked) .editAllBtn {
            opacity: 1;
            pointer-events: all;
            cursor: pointer;
        }

        .editAllPanel.active {
            background-color: #d0dbeb;
            padding: 1rem;
            border-radius: .5rem;
            margin-bottom: 1rem;
        }

            .editAllPanel.active .panel-inactive-content {
                display: none !important;
            }

        .panel-active-content {
            display: none !important;
        }

        .editAllPanel.active .panel-active-content {
            display: flex !important;
        }

        .panel-action-btn {
            background-color: white;
            color: black;
            border-radius: .5rem;
            padding: .5rem 1rem;
        }
    </style>
}
<div class="border-b border-gray-200 mb-4">
    <nav class="flex space-x-2 bg-[#fafafa] overflow-x-auto" aria-label="Tabs" role="tablist">
        <div class="py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500"
             id="tabs-with-underline-item-1" data-hs-tab="#tabs-with-underline-1">
            <!-- <img class="h-4 w-auto" src="./assets/images/total-projects-icon.svg" alt=""> -->
            <div>
                <span class="text-2xl font-extrabold block text-left">Requests For Projection</span>
                <span class="text-sm block text-left">
                    List of all Projection which are yet to be Approved
                </span>
            </div>
        </div>      
    </nav>
</div>

<div class="mt-3">

    <div id="project-wise-content" role="tabpanel" aria-labelledby="project-wise-content">
        <div class="flex justify-end mb-4">
            
        </div>
        <div class="flex flex-col" style="height: calc(100vh - 7rem - 15rem); overflow-y: auto;">
            <div class="-m-1.5 overflow-x-auto">
                <div class="p-1.5 min-w-full inline-block align-middle">
                    <div class="overflow-hidden">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead>
                                <tr>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        S.No    
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        Projection Name
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        TMC Id
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        Request From
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        Contract Start Date
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        Contract End Date
                                    </th>
                                    
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        View & Act
                                    </th>

                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                @if (Model != null)
                                {
                                   
                                    int count = 1;
                                    foreach (var item in Model)
                                    {

                                        <tr>
                                            <input type="hidden" class="projectionRequestId" value="@item.Projectionrequestid"/>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                                @count
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800 ">
                                                @item.ProjectionName
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">
                                                @item.Employeeid
                                            </td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@item.RequestFrom</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@item.ContractStartDate.ToString("dd-MM-yyyy")</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">@item.ContractEndDate.ToString("dd-MM-yyyy")</td>
                                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 text-center">
                                                <div class="flex items-center gap-2">
                                                    <button onclick="sendApprovedRequest(this); " class="normal-mode-content approve-btn flex items-center gap-2 border rounded-full py-1 px-2 border-[#40BD5E] text-[#40BD5E] hover:opacity-70">
                                                        <img class="w-4 h-4" src="~/assets/images/btn_tick_btn.svg" alt="">
                                                        Approve
                                                    </button>
                                                    <button onclick="handleRejectSubmit(this);" class="reject-all-btn2 flex items-center gap-2 border rounded-full py-1 px-2 border-[#4B4E5C] hover:opacity-70 disabled:opacity-50 disabled:cursor-not-allowed">
                                                        <img class="w-4 h-4" src="~/assets/images/btn_close_icon.svg" alt="">
                                                        Reject
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                     
                                        count++;

                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="rejectModal" class="hs-overlay hidden w-full h-full fixed top-0 start-0 z-[60] overflow-x-hidden overflow-y-auto [--overlay-backdrop:static]">
    <div class="hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:duration-500 mt-0 opacity-0 ease-out transition-all sm:max-w-lg sm:w-full m-3 sm:mx-auto">
        <div class="flex flex-col bg-white border shadow-sm rounded-xl pointer-events-auto ">
            <div class="flex justify-between items-center py-3 px-4 border-b">
                <h3 class="font-bold text-gray-800">
                    Reject Projection Reject
                </h3>
                <button type="button" class="flex justify-center items-center w-7 h-7 text-sm font-semibold rounded-full border border-transparent text-gray-800 hover:bg-gray-100 disabled:opacity-50 disabled:pointer-events-none" data-hs-overlay="#rejectModal">
                    <span class="sr-only">Close</span>
                    <svg class="flex-shrink-0 w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18" /><path d="m6 6 12 12" /></svg>
                </button>
            </div>
            <div class="p-4 overflow-y-auto">
                <label for="reason" class="font-medium text-sm mb-2">Enter Reason</label>
                <textarea class="k-input w-full" name="rejectReason" id="rejectReason" cols="30" rows="5"></textarea>
            </div>
            <div class="flex justify-end items-center gap-x-2 py-3 px-4 border-t">
                <button type="button" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 disabled:opacity-50 disabled:pointer-events-none " data-hs-overlay="#rejectModal">
                    Close
                </button>
                <button onclick="SendRejectRequest(this);" type="button" id="rejectModalSubmitBtn" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-50 disabled:pointer-events-none">
                    Submit
                </button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script type="text/javascript">
        @if (ViewData["error"] != null)
        {
            <text>
                    toastr.error("@ViewData["error"]", "Error", {"iconClass": 'new-error' });
            </text>
        }
        @if (ViewData["success"] != null)
        {
            <text>
                    toastr.success("@ViewData["success"]");
            </text>
        }


            function sendApprovedRequest(btn) {
                const projectionRequestId = btn.closest("tr").querySelector(".projectionRequestId").value;
                
                const fData = new FormData();
                fData.append("data", JSON.stringify({
                    projectionRequestId,
                    status:"Approved"
                    
                }))
        $.ajax({
            type: "POST",
            url: "@Url.Action("EmployeeReleaseRequest", "ProjectProjection")",
            data: fData,
            contentType: false,
            processData: false,
            success: function (res) {
                console.log(res)
                $("#loader").hide();
                        if (res.success == true){
                            toastr.success("Request has been Approved");   
                        }
                        else {
                            toastr.success("Some error occured");
                        }
                        HSOverlay.close(document.querySelector("#rejectModal"));
                        setTimeout(() => { window.location.reload() }, 1000);

            },
            error: function (err) {
                $("#loader").hide();
                toastr.success("Some error occured");
                setTimeout(() => { window.location.reload() }, 1000);

            }
        });
            }

        function SendRejectRequest(btn) {
            const projectionRequestId = btn.getAttribute("data-projectionrequestid");
            const remarks = document.querySelector("#rejectReason").value;

            if (!remarks) {
                document.querySelector("#rejectReason").classList.add("is-invalid");
                return;
            }

            const fData = new FormData();
            fData.append("data", JSON.stringify({
                projectionRequestId,
                status: "Rejected",
                remarks

            }))
            $.ajax({
                type: "POST",
                url: "@Url.Action("EmployeeReleaseRequest", "ProjectProjection")",
                data: fData,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res)
                    $("#loader").hide();
                    if (res.success == true) {
                        toastr.success("Request has been Rejected");
                    }
                    else{
                        toastr.success("Some error occured");
                    }
                    HSOverlay.close(document.querySelector("#rejectModal"));
                    setTimeout(() => { window.location.reload() }, 1000);

                },
                error: function (err) {
                    $("#loader").hide();
                    toastr.success("Some error occured");
                    setTimeout(() => { window.location.reload() }, 1000);
                }
            });
        }

        function handleRejectSubmit(btn){
            const projectionRequestId = btn.closest("tr").querySelector(".projectionRequestId").value;
            document.querySelector("#rejectModalSubmitBtn").setAttribute("data-projectionrequestid", projectionRequestId);
            HSOverlay.open(document.querySelector("#rejectModal"));
        }

    </script>

}