        // });

        function addResourceToTable(resourceid, resourceName, startDate, endDate, employeeProjectData = null) {
            var tablebody = document.querySelector('#employeeTable tbody');
            var rowLength = document.querySelectorAll("#employeeTable > tbody > tr:not(.employeeProjectData)").length + 1;
            if (!employeeProjectData || employeeProjectData?.length == 0) {
                //Add Employee WIthout Projects

                var row = $(`<tr data-resourceid="${resourceid}" data-resourcename="${resourceName}">`).append(
                    $('<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">').text(rowLength < 10 ? "0" + rowLength : rowLength),
        @*  $('<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">').text(resourceid), *@
                    $('<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">').text(resourceName),
                    $('<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">').text(startDate),
                    $('<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">').text(endDate),
                    $('<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">').html(
                        '<button type="button" data-employeeid="' + resourceid + '" onclick="RemoveEmployee(this)">'
                        + '<svg class="w-6 h-6 text-red-500" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 1024 1024"><path fill="currentColor" d="M512 64a448 448 0 1 1 0 896a448 448 0 0 1 0-896M288 512a38.4 38.4 0 0 0 38.4 38.4h371.2a38.4 38.4 0 0 0 0-76.8H326.4A38.4 38.4 0 0 0 288 512"/></svg>'
                        + '</button>')
                );
                $("#employeeTable > tbody").append(row);
            } else {
                //Add Employee WIth Projects
                const row = document.createElement("tr");
                row.setAttribute("data-resourceid", resourceid);
                row.setAttribute("data-resourcename", resourceName);

                row.innerHTML += `<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800"><div class="flex items-center gap-2">
                                                                                            <button class="toggleProjectBtn p-2 bg-gray-100 rounded" type='button' onclick="showProjects(this);"><svg class="w-6 h-6 toggleProjectsIcon" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-dasharray="12" stroke-dashoffset="12" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12l-7 -7M16 12l-7 7"><animate fill="freeze" attributeName="stroke-dashoffset" dur="0.3s" values="12;0"/></path></svg></button>
                                                                                            <span>${rowLength < 10 ? "0" + rowLength : rowLength}<span><div>
                                                                                    </td>`;
                row.innerHTML += `<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">${resourceName}</td>`
                row.innerHTML += `<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">${startDate}</td>`
                row.innerHTML += `<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">${endDate}</td>`
                row.innerHTML += `<td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">
                                                                                            <button type="button" data-employeeid="${resourceid}" onclick="RemoveEmployeeWithProjects(this)">
                                                                                                <svg class="w-6 h-6 text-red-500" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 1024 1024"><path fill="currentColor" d="M512 64a448 448 0 1 1 0 896a448 448 0 0 1 0-896M288 512a38.4 38.4 0 0 0 38.4 38.4h371.2a38.4 38.4 0 0 0 0-76.8H326.4A38.4 38.4 0 0 0 288 512"/></svg>
                                                                                                </button>
                                                                                </td>`

                const projectDataRow = document.createElement("tr");
                projectDataRow.classList.add("employeeProjectData", "hidden");
                let projectDataRowHtml = ''
                projectDataRowHtml += '<td colspan="5" class="p-4 bg-gray-100">'
                projectDataRowHtml += '<div style="overflow-x: auto;">'
                projectDataRowHtml += '<table>';
                projectDataRowHtml += '<thead>';
                projectDataRowHtml += '<tr>';
                projectDataRowHtml += '<th class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">S.No</th>';
                projectDataRowHtml += '<th class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">Project Name</th>';
                projectDataRowHtml += '<th class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">Contract End Date</th>';
                projectDataRowHtml += '<th class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">Contract End Date</th>';
                projectDataRowHtml += '<th class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">DA Name</th>';
                projectDataRowHtml += '<th class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">Action</th>';
                projectDataRowHtml += '</tr>';
                projectDataRowHtml += '</thead>';
                projectDataRowHtml += '<tbody>';

                employeeProjectData.forEach((item, index) => {
                    projectDataRowHtml += `<tr class="resourceProject" data-daid="${item?.deliveryAnchorId}" data-requestsent="false">`;
                    projectDataRowHtml += `<td class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm text-black">${index + 1}</td>`;
                    projectDataRowHtml += `<td class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm text-black">${item.projectName}</td>`;
                    projectDataRowHtml += `<td class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm text-black">${item.contractStartDate}</td>`;
                    projectDataRowHtml += `<td class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm text-black">${item.contractEndDate}</td>`;
                    projectDataRowHtml += `<td class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm text-black">${item.deliveryAnchorName}</td>`;
                    projectDataRowHtml += `<td class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm text-black">
                                                                                            <button type="button" onclick="sendReleaseRequest(this);" class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-transparent bg-blue-500 text-white hover:bg-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm">Send Request</button>
                                                                                    </td>`;
                    projectDataRowHtml += '</tr>';
                });
                projectDataRowHtml += '</tbody>';
                projectDataRowHtml += '</table>';
                projectDataRowHtml += '</div>';
                projectDataRowHtml += '</td>'

                projectDataRow.innerHTML += projectDataRowHtml;

                tablebody.appendChild(row);
                tablebody.appendChild(projectDataRow);
            }
        }

        function sendReleaseRequest(btn) {
            const employeeId = btn.closest(".employeeProjectData").previousElementSibling.getAttribute("data-resourceid");
            const crmId = document.querySelector("#modelcrmid").value;
            const row = btn.closest("tr");

            const url = new URL(window.location.href);

            // Extract the last part of the URL path as the projection ID
            const projectionId = url.pathname.split('/').pop();

            // Set the projection ID in the element with the ID 'modelProjectionId'
            document.querySelector("#modelProjectionId").value = projectionId;
            //const daId = btn.closest("tr").getAttribute("data-daid");
            const sentTo = btn.closest("tr").getAttribute("data-daid");
            const fData = new FormData();
            fData.append("data", JSON.stringify({
                employeeId,
                crmId,
                sentTo,
                status: "Pending",
                projectionId
        @*  crmId,
            daId  *@
                                                    }))

        $.ajax({
            type: "POST",
            url: "@Url.Action("EmployeeReleaseRequest", "ProjectProjection")",
            data: fData,
            contentType: false,
            processData: false,
            success: function (res) {
                console.log(res)
                row.querySelector("td:last-child").innerHTML = "<span class='status pending'>Request Pending</span>";
                row.setAttribute("data-requestsent", true);
                RemoveActionIfRequestSend(row);
                $("#loader").hide();
            },
            error: function (err) {
                $("#loader").hide();

            }
        });}

        function RemoveEmployee(button) {
            var employeeid = $(button).attr('data-employeeid');
            console.log(employeeid);

            var buttons = $('[data-employeeid=' + employeeid + ']').each(function (index, element) {
                element.closest('   tr').remove();

            });
            recalculateRowCount();
            const removeRow = document.querySelectorAll("#employeeTable tbody > tr");
            if (removeRow.length == 0) {
                document.getElementById("skipButton").style.display = "inline-flex";

            }
        }

        function RemoveEmployeeWithProjects(btn) {
            const empRow = btn.closest("tr");
            const projectRow = empRow.nextElementSibling;

            if (projectRow.classList.contains("employeeProjectData")) {
                projectRow.remove();
            }
            empRow.remove();
            recalculateRowCount();
            const removeRow = document.querySelectorAll("#employeeTable tbody > tr");
            if (removeRow.length == 0) {
                document.getElementById("skipButton").style.display = "inline-flex";

            }
        }


        function handleDeployEmployees() {
            const allRequestSent = checkAllRequestSent();
            if (!allRequestSent) {
                toastr.error("Send Release request all employees");
                return;
            }
            const url = new URL(window.location.href);

            // Extract the last part of the URL path as the projection ID
            const projectionId = url.pathname.split('/').pop();

            // Set the projection ID in the element with the ID 'modelProjectionId'
            document.querySelector("#modelProjectionId").value = projectionId;
            const crmdId = document.querySelector("#modelcrmid").value;

            const allResourceTr = document.querySelectorAll("#employeeTable > tbody > tr:not(.employeeProjectData)");
            if (allResourceTr.length <= 0) {
                toastr.error("Select at least a resource");
                return;
            }
            const resourceList = [];

            allResourceTr.forEach(tr => {
                resourceList.push({
                    DeployedEmployeeId: tr.getAttribute("data-resourceid"),
                    DeployedEmployeeName: tr.getAttribute("data-resourcename"),
                    StartDate: tr.querySelector("td:nth-child(3)").innerText,
                    EndDate: tr.querySelector("td:nth-child(4)").innerText,
                    CategorySubStatusId: 4,
                })
            })

            const data = {
                projectionId,
                CrmId: crmdId,
                DeployedEmployees: resourceList,
            }
            const fData = new FormData();
            fData.append("data", JSON.stringify(data));
            document.querySelector("#loader").style.display = "flex";
            $.ajax({
                type: "POST",
                url: "@Url.Action("PostProjection", "ProjectProjection")",
                data: fData,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res)
                    $("#loader").hide();
                    handleCloseModal("projection");

                    if (res.statusCode == 200) {
                        toastr.success("Projection Created Successfully");
                        const createdProjectionData = JSON.parse(res.responseContent)
                        console.log(createdProjectionData);
                        window.location.reload();

                        document.querySelector("#modelProjectionId").value = createdProjectionData.data.projectionid;
                    } else {
                        toastr.error("Error Creating Projection");
                        $("#loader").hide();
                        handleCloseModal("projection");
                        window.location.reload();
                    }
                },
                error: function (err) {
                    toastr.error("Error Creating Projection");
                    window.location.reload();
                }
            });
        }

        function handleCloseModal() {

            HSOverlay.close(document.querySelector("#extend-contract-modal"))

        }
        const resourceMultiSelectArray = [];
        const skillMultiSelectArray = [];
        function setEndDateMin(startDate) {
            const endDateInput = document.getElementById('contractenddate');
            endDateInput.setAttribute('min', startDate);
        }
        const selectedSkills = document.querySelectorAll(".skillSelect");
        console.log(selectedSkills, "hi");
        selectedSkills.forEach(item => {
            const skillMultiSelect = new SlimSelect({
                select: item
            })
            skillMultiSelect.disable();
            skillMultiSelectArray.push(skillMultiSelect);
        })

        const resourceSelect = document.querySelectorAll(".resourceSelect");
        resourceSelect.forEach(item => {
            const resourceMultiSelect = new SlimSelect({
                select: item
            })
            resourceMultiSelectArray.push(resourceMultiSelect);
        })
        function ResetDropdowns() {
            $('#contractstartdate').val('');
            $('#contractenddate').val('');
            resourceMultiSelectArray.forEach(item => {
                item.setSelected('0');
            })
            skillMultiSelectArray.forEach(item => {
                item.setSelected('0');
            })

        }

        function RemoveActionIfRequestSend(btn) {
            console.log(btn);
            const allRequestTr = btn.closest("tbody").querySelector("tr.resourceProject[data-requestsent='true']");
            console.log(allRequestTr);
            if (allRequestTr) {
                btn.closest("table").closest("tr").previousElementSibling.querySelector("td:last-child").innerHTML = "";
            }
        }

        function checkAllRequestSent() {
            const allRequestTr = document.querySelectorAll("tr.resourceProject[data-requestsent='false']");

            return allRequestTr.length ? false : true;
        }

        function skipProjection() {
            const allResourceTr = document.querySelectorAll("#employeeTable > tbody > tr:not(.employeeProjectData)");
            if (allResourceTr.length <= 0) {

                setTimeout(() => {
                    window.location.href = "/ProjectProjection/Index"
                }, 1000);
            }
            else {
                document.getElementById("skipButton").style.display = "none";
            }
        }

        function RemoveErrorClass(form) {
            const allInput = document.querySelectorAll(form + " .is-invalid");
            allInput.forEach(inp => {
                inp.classList.remove("is-invalid");
            })
        }

        const resourceMultiSelect = new SlimSelect({
            select: "#resourceSelect"
        })
        const skillMultiSelect = new SlimSelect({
            select: "#skillSelect"
        })


        HSDropdown.on("open", (dropdown) => {
            console.log(dropdown);
            const rowIndex = Number(dropdown.closest("tr").getAttribute("data-index"));
            const skillId = Number(dropdown.closest("tr").querySelector("#skillSelectedId").value);
            skillMultiSelectArray[rowIndex].setSelected(skillId);
            skillMultiSelectArray[rowIndex].disable();

        })
        HSDropdown.on("close", (dropdown) => {
            dropdown.querySelector("#benchOnlyResources").checked = false;
            dropdown.querySelector("#contractstartdate").value = '';
            dropdown.querySelector("#contractenddate").value = '';
        })

    </script>
}