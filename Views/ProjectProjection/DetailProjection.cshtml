@section Scripts {

    <script type="text/javascript">
        var skillsData = [];
        $(function () {
        @if (ViewData["error"] != null)
        {
            <text>
                        toastr.error("@ViewData["error"]", "Error", {"iconClass": 'new-error' });
            </text>
        }
        @if (ViewData["success"] != null)
        {
            <text>
                        toastr.success("@ViewData["success"]");
            </text>
        }
                })

        function showProjects(btn) {
            btn.closest("tr").nextElementSibling.classList.toggle("hidden")
        }

        $(document).ready(function () {
            $('.addProjectButton').click(function () {
                // $('#extend-contract-modal').modal('show');
                HSOverlay.open(document.querySelector("#extend-contract-modal"));

                $.ajax({
                    url: '@Url.Action("GetListofSkillsWithExp", "ProjectProjection")',
                    type: 'GET',
                    success: function (data) {
                        skillsData = data;
                        var $skillDropdown = $('#skill');
                        $skillDropdown.empty();
                        $skillDropdown.append($('<option>', {
                            value: '',
                            text: '---Select Skill---'
                        }));
                        console.log(data);

                        $.each(data, function (index, skill) {
                            $skillDropdown.append($('<option>', {
                                value: skill.skillId,
                                text: skill.skill
                            }));
                        });
                    },
                    error: function () {
                        alert('Failed to load skills.');
                    }
                });
            });
        });

        function getEmployee(inp) {
            const rowIndex = Number(inp.closest("tr").getAttribute("data-index"));
            const skillId = inp.value;
            if (skillId == '0') {
                return;
            }
            $.ajax({
                url: '@Url.Action("GetEmployeeBySkills", "Base")',
                type: 'GET',
                data: {
                    skillId: skillId,
                },
                success: function (data) {

                    const dropdowndata = [{ text: "Select Resource", value: '0' }];
                    if (!data.length) {
                        toastr.error("No Resource for this Skill");
                        resourceMultiSelectArray[rowIndex].setData(dropdowndata);
                        return;
                    }
                    data.forEach(item => {
                        dropdowndata.push({
                            text: item?.text,
                            value: item?.value
                        })
                    })
                    resourceMultiSelectArray[rowIndex].setData(dropdowndata);
                    console.log(data);


                },
                error: function () {
                    alert('Failed to load skills.');
                }
            });
        }

        function handleBenchOnly(inp) {
            const rowIndex = Number(inp.closest("tr").getAttribute("data-index"));

            if (inp.checked) {
                // skillMultiSelect.disable();
                // skillMultiSelect.setSelected("0");
                document.querySelector("#loader").style.display = "flex";

                $.ajax({
                    type: "GET",
                    url: '@Url.Action("GetBenchResources", "Employee")',
                    contentType: false,
                    processData: false,
                    success: function (res) {
                        document.querySelector("#loader").style.display = "none";
                        console.log(res);
                        resourceMultiSelectArray[rowIndex].setData(res);
                    },
                    error: function (err) {
                        document.querySelector("#loader").style.display = "none";
                        console.log(err);
                        toastr.error("Error fetching bench resources");
                    }
                });
            } else {
                //skillMultiSelect.enable();
                resourceMultiSelectArray[rowIndex].setData([{ text: "Select Resource", value: "0" }])
            }
        }

        function validateResourceForm(index) {
            let isValid = true;
            const resource = resourceMultiSelectArray[index].getSelected();
            const dropdownMenu = resourceMultiSelectArray[index].selectEl.closest(".hs-dropdown-menu");
            const ExistingResource = document.querySelector(`tr[data-resourceid='${resource[0]}']`)
            const startDate = dropdownMenu.querySelector("#contractstartdate").value;
            const endDate = dropdownMenu.querySelector("#contractenddate").value;

            if (!resource.length || resource[0] === '0') {
                isValid = false;
                toastr.error("Select a resource first.")
        @* document.querySelector("#resourceSelect").classList.add("is-invalid") *@
                                    } else {
        @* document.querySelector("#resourceSelect").classList.remove("is-invalid") *@
                                    }
            if (!startDate) {
                isValid = false;
                dropdownMenu.querySelector("#contractstartdate").classList.add("is-invalid")
            } else {
                dropdownMenu.querySelector("#contractstartdate").classList.remove("is-invalid")
            }
            if (!endDate) {
                isValid = false;
                dropdownMenu.querySelector("#contractenddate").classList.add("is-invalid")
            } else {
                dropdownMenu.querySelector("#contractenddate").classList.remove("is-invalid")
            }
            if (ExistingResource) {
                isValid = false;
                toastr.error("Resource already added");
            }

            return isValid;
        }

        function recalculateRowCount() {
            const allTr = document.querySelectorAll("#employeeTable > tbody > tr:not(.employeeProjectData)");
            allTr.forEach((item, index) => {
                item.querySelector("td span").innerHTML = (index + 1) < 10 ? "0" + (index + 1) : (index + 1);
            })
        }
        function handleaddResource(btn) {
            const rowIndex = Number(btn.closest("tr").getAttribute("data-index"));
            const isResourceFormValid = validateResourceForm(rowIndex);
            if (!isResourceFormValid) return;

            var startDate = btn.closest(".hs-dropdown-menu").querySelector('#contractstartdate').value;
            var endDate = btn.closest(".hs-dropdown-menu").querySelector('#contractenddate').value;
            var resourceid = resourceMultiSelectArray[rowIndex].getSelected()[0];
            var resourceName = resourceMultiSelectArray[rowIndex].selectEl.querySelector(`option[value='${resourceid}']`).innerText.trim();
            var $tablebody = $('#employeeTable tbody');
            // $tablebody.empty();


            const fData = new FormData();
            fData.append("data", JSON.stringify({
                startdate: startDate,
                enddate: endDate,
                employeeid: resourceid
            }))

            document.querySelector("#loader").style.display = "flex";

            $.ajax({
                type: "POST",
                url: "@Url.Action("ActiveEmployeeProject", "ProjectProjection")",
                data: fData,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res)
                    $("#loader").hide();
                    if (res?.success) {
                        addResourceToTable(resourceid, resourceName, startDate, endDate, res?.data)
                    } else {
                        toastr.error("Something went wrong");
                    }
                },
                error: function (err) {
                    $("#loader").hide();
                    toastr.error("Something went wrong");
                }
            });

            HSDropdown.close(btn.closest(".hs-dropdown"))
            ResetDropdowns(rowIndex);
            document.getElementById("skipButton").style.display = "none";
        }

