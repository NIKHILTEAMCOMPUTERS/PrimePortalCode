        function checkAllRequestSent() {
            const allRequestTr = document.querySelectorAll("tr.resourceProject[data-requestsent='false']");

            return allRequestTr.length ? false : true;
        }

        function skipProjection() {
            const allResourceTr = document.querySelectorAll("#employeeTable > tbody > tr:not(.employeeProjectData)");
            if (allResourceTr.length <= 0) {

                setTimeout(() => {
                    window.location.href = "/ProjectProjection/Index"
                }, 1000);
            }
            else {
                document.getElementById("skipButton").style.display = "none";
            }
        }

        function handleDeployEmployees() {
            const allRequestSent = checkAllRequestSent();
            if (!allRequestSent) {
                toastr.error("Send Release request all employees");
                return;
            }
            const projectionId = document.querySelector("#modelProjectionId").value;
            const crmdId = document.querySelector("#modelcrmid").value;

            const allResourceTr = document.querySelectorAll("#employeeTable > tbody > tr:not(.employeeProjectData)");
            if (allResourceTr.length <= 0) {
                toastr.error("Select at least a resource");
                return;
            }
            const resourceList = [];

            allResourceTr.forEach(tr => {
                resourceList.push({
                    DeployedEmployeeId: tr.getAttribute("data-resourceid"),
                    DeployedEmployeeName: tr.getAttribute("data-resourcename"),
                    StartDate: tr.querySelector("td:nth-child(3)").innerText,
                    EndDate: tr.querySelector("td:nth-child(4)").innerText,
                    CategorySubStatusId: 4,
                })
            })

            const data = {
                projectionId,
                CrmId: crmdId,
                DeployedEmployees: resourceList,
            }
            const fData = new FormData();
            fData.append("data", JSON.stringify(data));
            document.querySelector("#loader").style.display = "flex";
            $.ajax({
                type: "POST",
                url: "@Url.Action("PostProjection", "ProjectProjection")",
                data: fData,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res)
                    $("#loader").hide();
                    handleCloseModal("projection");

                    if (res.statusCode == 200) {
                        toastr.success("Projection Created Successfully");
                        const createdProjectionData = JSON.parse(res.responseContent)
                        console.log(createdProjectionData);
                        setTimeout(() => {
                            window.location.href = "/ProjectProjection/Index"
                        }, 1000)
                        document.querySelector("#modelProjectionId").value = createdProjectionData.data.projectionid;
                        showFormPart(2);
                    } else {
                        toastr.error("Error Creating Projection");
                        $("#loader").hide();
                        handleCloseModal("projection");
                        window.location.reload();
                    }
                },
                error: function (err) {
                    toastr.error("Error Creating Projection");
                    window.location.reload();
                }
            });
        }

        function handleFileName(e, input) {
            const [file] = e.target.files;
            if (!file) {
                e.preventDefault();
                return;
            }
            const { size, type } = file;
            if (
                type !== "application/pdf" && type !== "application/wps-office.pdf" &&
                type !== "image/jpg" && type !== "image/jpeg" && type !== "image/png"
            ) {
                e.preventDefault();
                throw "not the right type"
            } else {
                console.log("file valid")
            }
            document.querySelector("#fileName").innerHTML = input.files[0].name;
            handleImagePreview(input.files[0]);
        }

        function handleImagePreview(file) {
            document.querySelector("#previewImage").setAttribute("src", URL.createObjectURL(file))
        }

        function showFormStepCustomer(step) {
            const allStepIndicators = document.querySelectorAll("#customerForm .multipart-indicator")
            const allStepForm = document.querySelectorAll("#customerForm .multipart-form")

            const _step = step - 1;

            allStepIndicators.forEach((item, index) => {
                item.classList.remove("active");
                allStepForm[index].classList.remove("active");
            })

            allStepIndicators[_step].classList.add("active")
            allStepForm[_step].classList.add("active")
        }

        function validateOtherDetails() {
            let validFlag = true;
            if (paymentDropdown.getSelected()[0].length === 0) {
                document.querySelector("#Paymenttermid").classList.add("is-invalid");
                validFlag = false;
            } else {
                document.querySelector("#Paymenttermid").classList.remove("is-invalid");
            }

            if (currencyDropdown.getSelected()[0].length === 0) {
                document.querySelector("#Currencyid").classList.add("is-invalid");
                validFlag = false;
            } else {
                document.querySelector("#Currencyid").classList.remove("is-invalid");
            }

            if (validFlag) {
                showFormStepCustomer(2);
            }
        }

        function handleCustomerSubmit(e) {
            e.preventDefault();

            const isFirstNameValid = validateField("#Firstname");
            const isLastNameValid = validateField("#Lastname");
            const isCompanyNameValid = validateField("[name='Companyname']");
            const isCompanyEmailValid = validateField("[name='Companyemail']");
            const isCountryValid = validateField("#countryDropdown");
            const isStateValid = validateField("#stateDropdown");
            const isCityValid = validateField("#cityDropdown");
            const isPhoneFirst = validateField("[name='Phone1']");
            const isPhoneSecond = validateField("[name='Phone2']");


            if (!isFirstNameValid || !isLastNameValid || !isCompanyNameValid || !isCompanyEmailValid || !isCityValid || !isCountryValid || !isStateValid || !isPhoneFirst || !isPhoneSecond) {
                return;
            }

            document.querySelector("#loader").style.display = "flex";

            const fData = new FormData(document.querySelector("#customerForm"));

            $.ajax({
                type: "POST",
                url: "@Url.Action("CreateCustomer", "ProjectProjection")",
                data: fData,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res);
                    const _newCustomer = JSON.parse(res?.data)
                    addNewCustomerOption(_newCustomer?.data?.customerId, _newCustomer?.data?.customerName);
                    handleCloseModal("customer");
                    HSOverlay.open(document.querySelector("#extend-contract-modal"));
                    $("#loader").hide();
                    if (res.success == true) {
                        toastr.success(res.msg);
        @* setTimeout(() => {
                        window.location.href = "/ProjectProjection/Index"
                        }, 1000) *@
                                                                            } else {
                        toastr.error(res.msg);
                        $("#loader").hide();
        @* window.location.href = "/ProjectProjection/Index" *@
                                                                                                            }
                }
            });

        }

        function addNewCustomerOption(value, text) {
            if (!value || !text) return;
            const newOption = document.createElement('option');
            newOption.value = value;
            newOption.textContent = text;

            // Append the new option to the select element
            customerMultiSelect.selectEl.appendChild(newOption);
        }

