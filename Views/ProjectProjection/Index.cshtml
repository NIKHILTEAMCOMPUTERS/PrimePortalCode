    <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Projections</h2>
    @* <button type="button" data-hs-overlay="#extend-contract-modal"
    class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-transparent bg-[#00cc83] text-white hover:bg-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm 2xl:text-base">
    <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 32 32">
    <path fill="currentColor"
    d="M16 2A14.172 14.172 0 0 0 2 16a14.172 14.172 0 0 0 14 14a14.172 14.172 0 0 0 14-14A14.172 14.172 0 0 0 16 2Zm8 15h-7v7h-2v-7H8v-2h7V8h2v7h7Z" />
    <path fill="none" d="M24 17h-7v7h-2v-7H8v-2h7V8h2v7h7v2z" />
    </svg>
    Add Projection
    </button> *@
</div>

<div class="overflow-x-auto bg-white shadow-custom rounded mb-4">
    <nav class="flex space-x-2" aria-label="Tabs" role="tablist">
        <div type="button"
             class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600 active"
             id="tabs-with-underline-item-1" data-hs-tab="#tabs-with-underline-1"
             aria-controls="tabs-with-underline-1" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-projects-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Total Deals</span>
                <span class="text-2xl font-extrabold block text-left">@Model.Count()</span>
            </div>
        </div>
        <div type="button"
             class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600"
             id="tabs-with-underline-item-1" data-hs-tab="#tabs-with-underline-1"
             aria-controls="tabs-with-underline-1" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-projects-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Converted Deals</span>
                <span class="text-2xl font-extrabold block text-left">
                    @Model.Where(a => a.Projectionid > 0).Count()
                </span>
            </div>

        </div>
    </nav>
</div>

<div class="flex flex-col">
    <div class="-m-1.5 overflow-x-auto">
        <div class="p-1.5 min-w-full block align-middle">
            <div class="overflow-hidden">
                <table id="tblData" class="last-column-fixed min-w-full divide-y divide-gray-200">
                    <thead>
                        <tr>
                            @foreach (var col in colLists)
                            {
                                <th scope="col"
                                    class="whitespace-nowrap px-2 py-3 text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                    @col

                                    @if (col != "Territory Name" && col != "Sales Account Name" && col != "Website" && col != "Action")
                                    {
                                        <div style="vertical-align: middle;" class="filter-dropdown mx-1 hs-dropdown relative sm:inline-flex z-20 [--auto-close:inside]">
                                            <button id="hs-dropdown-auto-close-inside" type="button" class="hs-dropdown-toggle p-1 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-gray-100 text-gray-800 shadow-sm disabled:opacity-50 disabled:pointer-events-none">
                                                <svg class="w-4 h-4 text-gray-800" xmlns="http://www.w3.org/2000/svg"
                                                     width="512" height="512" viewBox="0 0 512 512">
                                                    <path fill="currentColor"
                                                          d="M472 168H40a24 24 0 0 1 0-48h432a24 24 0 0 1 0 48m-80 112H120a24 24 0 0 1 0-48h272a24 24 0 0 1 0 48m-96 112h-80a24 24 0 0 1 0-48h80a24 24 0 0 1 0 48" />
                                                </svg>
                                            </button>

                                            <div class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden mt-2 bg-white shadow-md rounded-lg p-2 mt-2" aria-labelledby="hs-dropdown-auto-close-inside">
                                                <div class="mb-1">
                                                    <input type="search" oninput="handleFilterSearch(this);" placeholder="Search" class="py-2 px-4 block w-full border-gray-200 rounded-lg text-xs focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                                </div>
                                                <div class="filter-item-list" style="height: 10rem; overflow-y: auto;"></div>

                                            </div>
                                        </div>
                                    }
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @if (Model != null)
                        {
                            var sortedModel = Model.OrderByDescending(deal => deal.CreatedAt).ToList();
                            foreach (var item in sortedModel)
                            {
                                <tr>
                                    <input type="hidden" value="@item.Crmid" />
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">
                                        @item.CrmDealsId
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">
                                        @item.DealName
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">
                                        @item.Amount
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">
                                        @item.SalesAccountName
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ">
                                        <span class="px-2 py-1 rounded
                    @(item.StagePosition == 7 ? "bg-green-100 text-green-600" :
                      item.StagePosition == 8 ? "bg-red-100 text-red-600" :
                      (item.StagePosition == 5 || item.StagePosition == 6) ? "bg-red-100 text-red-600" :
                      "bg-red-100 text-red-600")">@item.StageName</span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm">
                                        <span class="@(item.Projectionid > 0 ? "status completed" : "status onbench")">@(item.Projectionid > 0 ? "Converted" : "Not Converted")</span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">
                                        @item.CreatedBy
                                    </td>


                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">
                                        @item.TerritoryName
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">
                                        @item.CreatedAt.ToString("dd/MMM/yyyy")
                                    </td>

                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800  ">
                                        @(string.IsNullOrEmpty(item.Website) ? "N/A" : item.Website)
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                        @if (item.Projectionid > 0)
                                        {
                                            <a href="@Url.Action("DetailProjection", "projectprojection", new { id = item.Projectionid })">
                                                <button style="border-radius: 5rem;" class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-transparent bg-gray-400 text-white hover:bg-gray-500 focus:outline-none focus:ring-2 focus:ring-gray-400 focus:ring-offset-2 transition-all text-sm 2xl:text-base">Linked Projection</button>
                                            </a>
                                        }
                                        else
                                        {
                                            <button onclick="handleConvertProjection(this);" style="border-radius: 5rem;" class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-transparent bg-[#00cc83] text-white hover:bg-emerald-600 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm 2xl:text-base">Convert To Projection</button>
                                        }
                                    </td>

                                </tr>
                            }
                        }

                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

