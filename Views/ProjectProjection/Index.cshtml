        function handleBillingChange(inp) {
            const allTd = inp.closest("tr").querySelectorAll("td");
            const billingTable = document.querySelector("#initialsBillingInfo");
            const dealAmount = Number(billingTable.querySelector("tbody tr td:nth-child(1)").innerText.trim());
            const currentTotalTd = billingTable.querySelector("tbody tr td:nth-child(2)");
            let totalAmount = 0;
            for (let i = 2; i < allTd.length; i++) {
                totalAmount += Number(allTd[i].querySelector("input").value);
            }
            totalAmount = Math.round(totalAmount);

            currentTotalTd.innerText = totalAmount;

            if (totalAmount > dealAmount) {
                currentTotalTd.style.backgroundColor = "#fee2e2";
            } else if (totalAmount < dealAmount) {
                currentTotalTd.style.backgroundColor = "#fef08a";
            } else {
                currentTotalTd.style.backgroundColor = "#dcfce7";
            }
        }

        function generateSplitMonths(startDate, endDate) {

            const cStartDate = new Date(startDate);
            cStartDate.setDate(1);
            const cEndDate = new Date(endDate);

        @* console.log(cStartDateStr, cEndDateStr); *@

                    const monthsArr = [];

            while (true) {
                const month = cStartDate.toLocaleString('default', { month: 'short' });
                const monthYear = month + '-' + String(cStartDate.getFullYear()).match(/.{1,2}/g)[1];

                const month2 = cEndDate.toLocaleString('default', { month: 'short' });
                const monthYear2 = month2 + '-' + String(cEndDate.getFullYear()).match(/.{1,2}/g)[1];

                monthsArr.push(monthYear);
                cStartDate.setMonth(cStartDate.getMonth() + 1);

                //console.log(monthYear, monthYear2);
                //console.log(cStartDate.getMonth() === cEndDate.getMonth() && cStartDate.getFullYear() === cEndDate.getFullYear())

                if (monthYear === monthYear2) break;
            }

            return monthsArr;
        }



