@model RMS.Client.Models.Master.Projects

<div class="flex items-center gap-4 mb-5">
    <a asp-action="Index" asp-controller="Project" class="py-2 px-2 inline-flex justify-center items-center gap-2 rounded-md border border-gray-400 bg-gray-700 text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-gray-500 focus:ring-offset-2 transition-all text-sm sm:text-base" title="Back">
        <svg class="w-4 h-4 text-white" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M11.707 5.293a1 1 0 0 1 0 1.414L7.414 11H19a1 1 0 1 1 0 2H7.414l4.293 4.293a1 1 0 0 1-1.414 1.414l-6-6a1 1 0 0 1 0-1.414l6-6a1 1 0 0 1 1.414 0z" /></svg>
    </a>
    <div>
        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Add/Edit Project</h2>
        <p>Add the required details for the new project</p>
    </div>
    @if (Model.ProjectId == 0 || Model.ProjectId == null)
    {
        <div class="d-flex items-center gap-4 ml-auto">
            <div class="inline-flex items-center rounded shadow py-3 px-6 gap-2">
                <input type="radio" onchange="Disable(this)" name="po-status" class="shrink-0 mt-0.5 border-gray-200 rounded-full text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="poAwaitedCheckbox">

                <label for="poAwaitedCheckbox" class="block font-bold ">PO Awaited</label>
            </div>
            <div class="inline-flex items-center rounded shadow py-3 px-6 gap-2">
                <input type="radio" onchange="removeDisable(this)" name="po-status" class="shrink-0 mt-0.5 border-gray-200 rounded-full text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="poArrivedCheckbox" checked>

                <label for="poArrivedCheckbox" class="block font-bold ">PO Available</label>
            </div>
        </div>
    }
</div>
<form action="/Project/Upsert" method="POST" enctype="multipart/form-data">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
            <span class="mb-2 font-medium block">Customer Name *</span>
            <div class="flex items-center gap-3 flex-wrap">
                <select id="customerDropdown" name="CustomerId" class="multi-select">
                    <option value="0" selected>Select Customer</option>
                    @foreach (var customer in ViewBag.CustomerList)
                    {
                        @*<option value="@customer.Customerid">@(!string.IsNullOrEmpty(customer.Firstname) ? customer.Firstname : customer.Companyname)</option>*@
                        if (Model.CustomerId == customer.CustomerId)
                        {
                            <option value="@customer.CustomerId" selected>
                                @(customer.CustomerCompanyName)
                            </option>
                        }
                        else
                        {
                            <option value="@customer.CustomerId">
                                @(customer.CustomerCompanyName)
                            </option>
                        }
                    }
                </select>
            </div>
        </div>

        <div>
            <span class="mb-2 font-medium block flex items-center justify-between">Project No * <p class="text-red-500" id="alreadyExistProjNo"></p></span>
            <div class="flex items-center gap-3 flex-wrap">
                <input type="text" name="ProjectNo" id="ProjectNo" value="@Model.Projectno" onchange="checkProjectNo(this);"
                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:cursor-not-allowed"
                       placeholder="Enter Project No">
            </div>
        </div>
        <div>
            <span class="mb-2 font-medium block">Project Name *</span>
            <div class="flex items-center gap-3 flex-wrap">
                <input type="text" name="ProjectName" id="ProjectName" value="@Model.ProjectName"
                       class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                       placeholder="Enter Project Name">
            </div>
        </div>
        <div>

            <span class="mb-2 font-medium block">Account Manager *</span>
            <select id="accountmanagerDropdown" name="AccountManagerId" class="multi-select">
                <option value="" selected>Select Account Manager</option>

                @foreach (var ManagerList in ViewBag.AccountManagers)
                {
                    if (Model.AccounmanagerId.ToString() == @ManagerList.Value)
                    {
                        <option value="@ManagerList.Value" selected>
                            @ManagerList.Text
                        </option>
                    }
                    else
                    {
                        <option value="@ManagerList.Value">@ManagerList.Text</option>
                    }
                }
            </select>
        </div>
        <div>
            <span class="mb-2 font-medium block">Project Type *</span>
            <select id="projectTypeDropdown" name="ProjectTypeId" class="multi-select" onchange="handleProjectTypeChange(this);">
                <option value="0" selected>Select Project Type</option>

                @foreach (var projectType in ViewBag.ProjectTypeList)
                {
                    @*<option value="@projectType.Value">@projectType.Text</option>*@
                    if (Model.ProjectTypeId.ToString() == projectType.Value)
                    {
                        <option value="@projectType.Value" selected>
                            @projectType.Text
                        </option>
                    }
                    else
                    {
                        <option value="@projectType.Value">@projectType.Text</option>
                    }
                }
            </select>
        </div>
        <div>
            <span class="mb-2 font-medium block">Project Description</span>
            <div class="flex items-center gap-3 flex-wrap">
                <textarea type="text" name="ProjectDescription" id="ProjectDescription"
                          class="py-3 px-4 block flex-1 border-gray-200 rounded-md text-sm focus:border-emerald-500 focus:ring-emerald-500"
                          placeholder="Enter Project Description" rows="1">@Model.ProjectDescription</textarea>
            </div>
        </div>
        <div>
            <span class="mb-2 font-medium block">Practices *</span>
            <select id="practiceDropdown" name="PracticeId" class="multi-select">
                <option value="" selected>Select Practice</option>

                @foreach (var practiceList in ViewBag.PracticeList)
                {
                    @* <option value="@practiceList.Value">@practiceList.Text</option>*@
                    if (Model.PracticeId.ToString() == @practiceList.Value)
                    {
                        <option value="@practiceList.Value" selected>
                            @practiceList.Text
                        </option>
                    }
                    else
                    {
                        <option value="@practiceList.Value">@practiceList.Text</option>
                    }
                }
            </select>
        </div>
        <div>
            <span class="mb-2 font-medium block">Sub Practice *</span>
            <select id="subPracticeDropdown" name="SubPracticeId" class="multi-select">
            </select>
        </div>
        @{
            var oafId = Model.ProjectId;
            var committedClientBillingDate = Model.CommittedClientBillingDate;
        }
        <div class="tnmshow hidden">
            <label class="mb-2 font-medium block">Customer Billing Cycle</label>
            <div class="flex items-end gap-4 flex-wrap">
                <select class="k-input" id="customerBillingCycle" name="CommittedClientBillingDate" onchange="handleCustomerBillingCycleChange(this);">
                    <option value="0">Select Billing Cycle Date</option>
                    @for (int i = 1; i <= 30; i++)
                    {
                        bool isSelected = (oafId > 0 && committedClientBillingDate.HasValue && i == committedClientBillingDate.Value);
                         if (isSelected)
                    {
                    <option value="@i" selected="selected">@i</option>
                    } 
                          else
                    { 
                        <option value="@i">@i</option>
                         } 
                    }
                </select>
            </div>
            <p class="hidden"></p>
        </div>
        <div><input type="hidden" name="ProjectId" value="@Model.ProjectId"></div>
    </div>
     


    <div class="mt-4">
        <button type="submit" id="saveButton"
                class="py-2 px-5 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm sm:text-base">
            Save
        </button>
    </div>
</form>

