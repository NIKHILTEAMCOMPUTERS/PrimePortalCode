        function saveEmployee() {

            const employeeList = [];

            document.querySelectorAll("#assignEmployeeTable tbody tr").forEach(tr => {
                const _empObj = {
                    employeeid: tr.querySelector("td:nth-child(1) input").value,
                    categorySubStatusId: tr.querySelector("td:nth-child(2) input").value,
                }

                employeeList.push(_empObj);
