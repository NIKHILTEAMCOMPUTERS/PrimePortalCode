                    console.log(subpracticeDropdown);
                    stateSelect.setData(stateData);

                    // Clear the subpracticeDropdown and then add options
                    subpracticeDropdown.innerHTML = '<option value="">Select SubPractice</option>';

                    data.forEach(item => {
                        const option = document.createElement('option');
