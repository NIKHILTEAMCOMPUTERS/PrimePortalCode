@section Scripts
    {


    <script>

        jQuery.validator.addMethod("notEqualTo", function (value, element, param) {
            return this.optional(element) || value != param;
        }, "Please specify a different value");
        $(function () {
            @if (ViewData["error"] != null)
            {
                <text>
                        toastr.error("@ViewData["error"]", "Error", { "iconClass": 'new-error' });
                </text>
            }
            @if (ViewData["success"] != null)
            {
                <text>
                        toastr.success("@ViewData["success"]");
                </text>
            }

            document.querySelector("#projectTypeDropdown").dispatchEvent(new Event("change"));
            document.querySelector("#customerBillingCycle").dispatchEvent(new Event("change"));
        });

        $(document).ready(function () {
            $('#saveButton').click(function (event) {
                var customerDropdown = $('#customerDropdown');
                var projectName = $('#ProjectName');
                var projectNo = $('#ProjectNo');
                // var projectModelDropdown = $('#projectModelDropdown');
                var projectTypeDropdown = $('#projectTypeDropdown');
                var practiceDropdown = $('#practiceDropdown');
                var subPracticeDropdown = $('#subPracticeDropdown');
                var accountmanagerDropdown = $('#accountmanagerDropdown');
                var isValid = true;

                // Reset the border color of all fields
                customerDropdown.css('border', '');
                projectName.css('border', '');
                projectNo.css('border', '');
                // projectModelDropdown.css('border', '');
                projectTypeDropdown.css('border', '');
                practiceDropdown.css('border', '');
                subPracticeDropdown.css('border', '');
                accountmanagerDropdown.css('border', '');
                document.querySelector("#customerDropdown").nextElementSibling.style.border = "";
                document.querySelector("#projectTypeDropdown").nextElementSibling.style.border = "";
                document.querySelector("#practiceDropdown").nextElementSibling.style.border = "";
                document.querySelector("#subPracticeDropdown").nextElementSibling.style.border = "";
                document.querySelector("#accountmanagerDropdown").nextElementSibling.style.border = "";
                // Validation
                if (customerDropdown.val() == "" || customerDropdown.val() == "0") {
                    customerDropdown.css('border', '1px solid red');
                    document.querySelector("#customerDropdown").nextElementSibling.style.border = "1px solid red";
                    isValid = false;
                }

                if ($("#ProjectNo").val().toLowerCase() === 'na' || $("#ProjectNo").val().toLowerCase() === 'n/a' || $("#ProjectNo").val().toLowerCase() === 'n\a' || $("#ProjectNo").val().toLowerCase() === 'n_a' || $("#ProjectNo").val().toLowerCase() === 'n-a') {
                    isValid = false;
                    $("#ProjectNo").addClass("is-invalid");
                } else if (!isprojectnounique) {
                    isValid = false;
                } else {
                    $("#ProjectNo").removeClass("is-invalid");
                }

                if (projectName.val().trim() == "") {
                    projectName.css('border', '1px solid red');
                    isValid = false;
                }

                if (!document.querySelector("#poAwaitedCheckbox").checked && projectNo.val().trim() == "") {
                    projectNo.css('border', '1px solid red');
                    isValid = false;
                }


                // if (projectModelDropdown.val() == "" || projectModelDropdown.val() == "0") {
                //     projectModelDropdown.css('border', '1px solid red');
                //     isValid = false;
                // }
                if (subPracticeDropdown.val() == "" || subPracticeDropdown.val() == "0") {
                    subPracticeDropdown.css('border', '1px solid red');
                    document.querySelector("#subPracticeDropdown").nextElementSibling.style.border = "1px solid red";
                    isValid = false;
                }

                if (projectTypeDropdown.val() == "" || projectTypeDropdown.val() == "0") {
                    projectTypeDropdown.css('border', '1px solid red');
                    document.querySelector("#projectTypeDropdown").nextElementSibling.style.border = "1px solid red";
                    isValid = false;
                }


                if (practiceDropdown.val() == "" || practiceDropdown.val() == "0") {
                    practiceDropdown.css('border', '1px solid red');
                    document.querySelector("#practiceDropdown").nextElementSibling.style.border = "1px solid red";
                    isValid = false;
                }

                if (accountmanagerDropdown.val() == "" || accountmanagerDropdown.val() == "0") {
                    accountmanagerDropdown.css('border', '1px solid red');
                    document.querySelector("#accountmanagerDropdown").nextElementSibling.style.border = "1px solid red";
                    isValid = false;
                }

                // Stop form submission if validation fails
                if (!isValid) {
                    event.preventDefault();
                } else {
                    if (document.querySelector("#poAwaitedCheckbox").checked) {
                        event.preventDefault();
                        projectionproject();
                    } else {
                        document.querySelector("#loader").style.display = "flex";
                    }
                }
            });
