            const projectWithStatus = [{ projectid: document.querySelector("#hidProjectId").value, categorysubstatusid: 0 }];
            const finalObj = {
                employees: employeeList,
                projectWithStatus: projectWithStatus
            }

            const formData = new FormData();
            formData.append("jobject", JSON.stringify(finalObj));

            $.ajax({
                type: "POST",
                url: "@Url.Action("AssignEmployees", "Employee")",
                data: formData,
                contentType: false,
                processData: false,
                success: function (result) {
                    console.log(result);


                    const response = JSON.parse(result?.data);
                    console.log(response);
                    if (response?.status === 200 || response?.responseCode === 200) {
                        toastr.success("Employee Assigned Successfully!!");
                        setTimeout(function () {
                            window.location.href = "@Url.Action("Index", "Project")";
                        }, 2000);
                    } else {
                        toastr.error(response.responseMessage);
                    }
                }
            });

