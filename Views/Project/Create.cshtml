        function projectionproject() {

            const formData = new FormData(document.querySelector("form"));
            // formData.append("project", JSON.stringify(projectObj))
            formData.append("poawaited", true);

            $.ajax({
                type: "POST",
                url: "@Url.Action("Upsert", "Project")",
                data: formData,
                contentType: false,
                processData: false,
                success: function (res) {
                    $("#loader").hide();
                    console.log(res);
                    var projectres = JSON.parse(res);
                    if (projectres.projectid) {
                        toastr.success("Projection Project Created!!");
                        HSOverlay.open(document.querySelector("#dummyContractOverlay"));
                        document.querySelector("#hidProjectId").value = projectres.projectid;
