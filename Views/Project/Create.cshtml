        let isprojectnounique = true;
        // for validation of po no
        async function checkProjectNo(inp) {
            if (!inp.value.trim()) {
                return;
            }

            const formData = new FormData();
            const projectId = window.location.search.split("?projectid=").slice(-1)[0];

            formData.append("projectno", inp.value.trim());
            formData.append("projectid", projectId);


            const response = await fetch("/Project/CheckProjectNumber", {
                method: "POST",
                body: formData
            })

            if (response.status === 200) {
                const data = await response.json();
                console.log(data);
                if (data.responseContent != "false") {
                    document.querySelector("#alreadyExistProjNo").innerHTML = "Project No. Already Exist!!"
                    inp.classList.add("is-invalid");
                    isprojectnounique = false;
                }
                else {
                    document.querySelector("#alreadyExistProjNo").innerHTML = ""
                    inp.classList.remove("is-invalid");
                    isprojectnounique = true;
                }
            } else {
                toastr.error("Something went wong");
            }

        }

        function handleProjectTypeChange(inp) {
            const projectType = inp.value;
            const tnmhideDivs = document.querySelectorAll(".tnmhide");
            const tnmshowDivs = document.querySelectorAll(".tnmshow");
            if (projectType === "1") {
                tnmhideDivs.forEach(item => {
                    item.classList.add("hidden");
                })

                tnmshowDivs.forEach(item => {
                    item.classList.remove("hidden");
                })
            } else {
                tnmhideDivs.forEach(item => {
                    item.classList.remove("hidden");
                })

                tnmshowDivs.forEach(item => {
                    item.classList.add("hidden");
                })
            }
        }

        function handleCustomerBillingCycleChange(inp) {
            if (inp.value && inp.value !== '0') {
                inp.parentElement.nextElementSibling.innerHTML = `Customer Billing will arrive on ${inp.options[inp.selectedIndex].text}'th of every month.`;
                inp.parentElement.nextElementSibling.classList.remove("hidden");
            } else {
                inp.parentElement.nextElementSibling.innerHTML = "";
                inp.parentElement.nextElementSibling.classList.add("hidden");
            }
        }
