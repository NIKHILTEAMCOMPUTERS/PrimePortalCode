            <input type="hidden" id="hidProjectId" value="" />
            <input type="hidden" id="hidCustomerId" value="" />
            <div class="flex flex-col gap-4">
                <div>
                    <span class="mb-2 font-medium block">Delivery Anchor *</span>
                    <div class="flex items-center gap-3 flex-wrap">
                        <select id="DADropdown" name="Deliveryanchorid" class="multi-select">
                            <option value="0" selected>Select DA</option>
                            @foreach (var DA in ViewBag.DA)
                            {
                                <option value="@DA.Value">
                                    @DA.Text
                                </option>
                            }
                        </select>
                    </div>
                </div>
                <div>
                    <span class="mb-2 font-medium block">Contract Start Date*</span>
                    <div class="flex items-center gap-3 flex-wrap">
                        <input type="date" id="contractstartdate" class="k-input" oninput="setEndDateMin(this.value)" />
                    </div>
                </div>

                <div>
                    <span class="mb-2 font-medium block">Contract End Date*</span>
                    <div class="flex items-center gap-3 flex-wrap">
                        <input type="date" class="k-input" id="contractenddate" />
                    </div>
                </div>
                <div>
                    <span class="mb-2 font-medium block">Amount</span>
                    <div class="flex items-center gap-3 flex-wrap">
                        <input type="text" class="k-input" placeholder="Enter Amount" id="amount" oninput="this.value = this.value.replace(/[^0-9]/g, '');">
                    </div>
                </div>

                <div>
                    <span class="mb-2 font-medium block">Client Coordinator</span>
                    <div class="flex items-center gap-3 flex-wrap">
                        <input type="text" class="k-input" placeholder="Enter Client Coordinator" id="contactpersonname">
                    </div>
                </div>

                <div>
                    <span class="mb-2 font-medium block">Contact No</span>
                    <div class="flex items-center gap-3 flex-wrap">
                        <input type="number" class="k-input" placeholder="Enter Contact Number" id="contactNo" pattern="[0-9]{10}" maxlength="10" title="Please enter a 10-digit contact number" oninput="javascript: if (this.value.length > this.maxLength) this.value = this.value.slice(0, this.maxLength);">
