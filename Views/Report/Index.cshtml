@model IEnumerable<RMS.Client.Models.Master.Report>
@{
    ViewData["Title"] = "Financial Report - ";
}
<div class="flex justify-between flex-wrap gap-4 items-center flex-wrap">
    <div class="mb-4">
        <h2 class="font-extrabold text-xl 2xl:text-2xl text-[#4B4E5C]">Provision and Billing Report</h2>
        <p>View detailed billing report</p>
    </div>
