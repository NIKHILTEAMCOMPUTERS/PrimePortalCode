    ViewData["Title"] = "Resource Report - ";


    string sattusflag(string input)
    {
        switch (input)
        {
            case "Over Run":
                return "overrun";
            case "Deployed":
                return "deployed";
            case "Deployed Advanced Billing":
                return "deployed";
            case "Bench":
                return "onbench";
            default:
                return "draft";
        }
    }
}
