    <div class="hs-overlay-open:mt-7 hs-overlay-open:opacity-100 hs-overlay-open:duration-500 mt-0 opacity-0 ease-out transition-all sm:max-w-lg sm:w-full m-3 sm:mx-auto">
        <div class="flex flex-col bg-white border shadow-sm rounded-xl pointer-events-auto ">
            <div class="flex justify-between items-center py-3 px-4 border-b">
                <h3 class="font-bold text-gray-800">
                    Update Employee Practice/Sub-Practice
                </h3>
                <button type="button"
                        class="flex justify-center items-center w-7 h-7 text-sm font-semibold rounded-full border border-transparent text-gray-800 hover:bg-gray-100 disabled:opacity-50 disabled:pointer-events-none"
                        data-hs-overlay="#updatePracticeModal">
                    <span class="sr-only">Close</span>
                    <svg class="flex-shrink-0 w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                         viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                         stroke-linejoin="round">
                        <path d="M18 6 6 18" />
                        <path d="m6 6 12 12" />
                    </svg>
                </button>
            </div>
            <div class="p-4 overflow-y-auto">
                <p class="text-gray-800 mb-4">
                    Select employee practice and sub practice to update
                </p>
                <div class="flex items-center gap-4">
                    <input type="hidden" id="hidEmpIdUpdate" />
                    <select id="practiceDropdown" name="PracticeId" class="multi-select" onchange="handlePracticeChange(this);">
                        <option value="0" selected>Select Practice</option>
                        @foreach (var practiceList in ViewBag.Practices)
                        {
                            <option value="@practiceList.Value" data-prac-id="@practiceList.Value" data-prac-n="@practiceList.Text">@practiceList.Text</option>
                        }
                    </select>
                    <select id="subPracticeDropdown" class="multi-select">
                        <option value="0" selected>Select Sub Practice</option>
                    </select>
                </div>
            </div>
            <div class="flex justify-end items-center gap-x-2 py-3 px-4 border-t">
                <button type="button"
                        class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 disabled:opacity-50 disabled:pointer-events-none "
                        data-hs-overlay="#updatePracticeModal">
                    Close
                </button>
                <button type="button" onclick="updatePractice(this);"
                        class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-50 disabled:pointer-events-none">
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts
    {
    <script type="text/javascript">
        $(function () {
            document.querySelector(".main").classList.add("flex", "flex-col");

        @if (ViewData["error"] != null)
        {
            <text>
                    toastr.error("@ViewData["error"]", "Error", { "iconClass": 'new-error' });
            </text>
        }
        @if (ViewData["success"] != null)
        {
            <text>
                    toastr.success("@ViewData["success"]");
            </text>
        }
                                                })

        const practiceDropdown = new SlimSelect({
            select: "#practiceDropdown",
            settings: {
                disabled: true,
                allowDeselect: false,
                closeOnSelect: true,
                maxValuesShown: 1
            }
        });
        const subPracticeDropdown = new SlimSelect({
            select: "#subPracticeDropdown",
            settings: {
                allowDeselect: false,
                closeOnSelect: true,
                maxValuesShown: 1
            }
        });

        const datatable = new DataTable("#datatable", {
            scrollX: true,
            scrollY: '50vh',
            ordering: false,
            dom: "lBfrtip",
            destroy: true,
            buttons: [{
                extend: 'excelHtml5',
                exportOptions: {
                    trim: false,
                    stripHtml: false,
                    format: {
                        header: function (html, index, node) {
                            return node.innerText.trim();
                        },
                        body: function (data, row, column, node) {
                            return node.innerText.replace(/\s+/g, "");
                        }
                    }
                }
            }],
            "fnInitComplete": function (oSettings, json) {
                dtApi = this;
                // calculateTotalBilling(this);
                document.querySelector("#loader").style.display = "none";
                const _dt = this.api();
                console.log("initdone")
                // $("#loader").hide();
                document.querySelector("#loader").style.display = "none";
                // docu
                const allTh = document.querySelectorAll(".dataTables_scroll:has(#datatable) .dataTables_scrollHead table thead th");
                const allThWithFilter = [];
                Array.from(allTh).forEach((item, index) => {
                    if (item.querySelector(".hs-dropdown")) {
                        allThWithFilter.push({ item, index });
                    }
                });
                console.log(allThWithFilter);
                allThWithFilter.forEach(item => {
                    // console.log(Number(item.index));
                    const column = _dt.columns(Number(item.index)).data().unique().sort();
                    console.log(column);
                    // const column = document.querySelectorAll(`td:nth-child(${item.index + 1})`);
                    const uniqueColumnContentSet = new Set();

                    column[0].forEach(colItem => {
                        if (colItem.includes("hs-dropdown")) {
                            const tempElem = document.createElement("div");
                            tempElem.innerHTML = colItem;
                            uniqueColumnContentSet.add(tempElem.querySelector("button span").innerText);
                        } else if (colItem.includes("span") || colItem.includes("</p>")) {
                            const tempElem = document.createElement("div");
                            tempElem.innerHTML = colItem;
                            uniqueColumnContentSet.add(tempElem.innerText.trim());
                        } else {
                            uniqueColumnContentSet.add(colItem.trim());
                        }
                    });

                    // console.log(uniqueColumnContent);
                    const uniqueColumnContent = Array.from(uniqueColumnContentSet).sort();

                    const dropdownBody = item?.item.querySelector(".hs-dropdown-menu .filter-item-list");
                    dropdownBody.innerHTML = "";
                    console.log(dropdownBody);
                    uniqueColumnContent.forEach(dItem => {
                        const dropdownItem = document.createElement("div");
                        dropdownItem.classList.add("relative", "flex", "items-start", "py-2", "px-3", "rounded-lg", "hover:bg-gray-100", "filter-item");
                        let checkBoxId = `chk-${Math.floor(Math.random() * 9999999)}`;
                        dropdownItem.innerHTML = `<div class="flex items-center">
                                                                                                                                            <input value="${dItem}" id="${checkBoxId}" type="checkbox" class="shrink-0 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                                                                                                                        </div>
                                                                                                                                        <label for="${checkBoxId}" class="flex-1 ms-2">
                                                                                                                                            <span class="block text-xs text-gray-800">${dItem}</span>
                                                                                                                                        </label>`;
                        dropdownBody.appendChild(dropdownItem);
                    })
                    if (!dropdownBody.nextElementSibling) {
                        dropdownBody.parentElement.innerHTML += `<div class="flex gap-2"><button onclick="clearFilter(this, ${item?.index});" class="flex mt-2 w-full items-center justify-center gap-x-3.5 py-2 px-3 rounded-lg text-xs text-gray-800 bg-gray-100 hover:bg-gray-50 focus:outline-none focus:bg-gray-100">Clear</button><button onclick="filterTable(this, ${item?.index});" class="flex mt-2 w-full items-center justify-center gap-x-3.5 py-2 px-3 rounded-lg text-xs text-gray-800 bg-gray-100 hover:bg-gray-50 focus:outline-none focus:bg-gray-100" href="#">Apply</button></div>`
                    }
                })
            },
        });

        function escapeRegExp(string) {
            return string.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); // $& means the whole string
        }

        function filterTable(btn, colInd) {
            const values = [];
            btn.closest(".hs-dropdown").querySelectorAll("input:checked").forEach(chkbox => {
                values.push(chkbox.value);
            })
            HSDropdown.close(btn.closest(".hs-dropdown"));
            setTimeout(() => {
                if (values.length) {
                    const escapedValues = values.map(escapeRegExp);
                    datatable.columns(Number(colInd)).search('^(' + escapedValues.join("|") + ')$', true, false).draw();
                } else {
                    datatable.columns(Number(colInd)).search("", true, false).draw();
                }
                // updateTotalBilling(datatable);
            }, 200)
        }

        function clearFilter(btn, colInd) {
            btn.closest(".hs-dropdown").querySelectorAll("input:checked").forEach(chkbox => {
                chkbox.checked = false;
            })
            btn.closest(".hs-dropdown").querySelector("input[type='search']").value = "";
            const _inpEvent = new Event("input");
            btn.closest(".hs-dropdown").querySelector("input[type='search']").dispatchEvent(_inpEvent);
            HSDropdown.close(btn.closest(".hs-dropdown"));
            setTimeout(() => {
                datatable.columns(Number(colInd)).search("", true, false).draw();
                // updateTotalBilling(datatable);
            }, 200)
        }

        function handleFilterSearch(input) {
            const allFilterItems = input.closest(".hs-dropdown-menu").querySelector(".filter-item-list").querySelectorAll("span");
            allFilterItems.forEach(item => {
                if (item.innerText.trim().toLowerCase().includes(input.value.trim().toLowerCase())) {
                    item.closest(".filter-item").style.display = "flex"
                } else {
                    item.closest(".filter-item").style.display = "none";
                }
            })
        }

        async function handlePracticeChange(inp) {
            const selectedPracticeId = inp.value;
            console.log(inp.value);
            subPracticeDropdown.setData([]);
            if (selectedPracticeId) {
                const response = await fetch(`/Base/GetSubPracticeByPracticeId?practiceId=${selectedPracticeId}`);
                if (response.ok) {
                    const data = await response.json();
                    // console.log(data);
                    const stateData = [{ text: "Select Sub Practice", value: "" }];
                    data.forEach(country => {
                        const _countryVal = {
                            text: country?.text,
                            value: country?.value
                        }
                        stateData.push(_countryVal);
                    })
                    console.log(stateData);
                    subPracticeDropdown.setData(stateData);



                } else {
                    console.error('Error fetching Subpractice data:', response.statusText);
                }
            }
        }

        function handleEdit(btn) {
            const row = btn.closest("tr");
            const practiceId = row.querySelector("td:nth-child(2)").getAttribute("data-practiceid").trim();
            const subPracticeId = row.querySelector("td:nth-child(3)").getAttribute("data-subpracticeid").trim();
            const _empId = btn.getAttribute("data-empId");

            if (!practiceId || !subPracticeId || !_empId) {
                toastr.error("There was some error updating employee");
                return;
            }

            document.querySelector("#hidEmpIdUpdate").value = _empId;
            practiceDropdown.setSelected(practiceId);

            HSOverlay.open(document.querySelector("#updatePracticeModal"));
        }

        function updatePractice(btn) {
            document.querySelector("#loader").style.display = "flex";



            const practiceid = document.querySelector("#subPracticeDropdown").value;
            if (!practiceid) {
                document.querySelector("#subPracticeDropdown").classList.add("is-invalid");
                document.querySelector("#loader").style.display = "none";
                return false;
            } else {
                document.querySelector("#subPracticeDropdown").classList.remove("is-invalid");
            }
            const employeeid = document.querySelector("#hidEmpIdUpdate").value;
            const finalObj = {
                EmployeeId: employeeid,
                SubpracticeId: practiceid
            }

            const formData = new FormData();
            formData.append("jobject", JSON.stringify(finalObj));

            $.ajax({
                type: "POST",
                url: "@Url.Action("UpdateEmployeePracticeSubPractice", "Employee")",
                data: formData,
                contentType: false,
                processData: false,
                success: function (result) {
                    console.log(result);


                    const response = JSON.parse(result?.data);
                    console.log(response);
                    if (response?.status === 200 || response?.responseCode === 200) {
                        toastr.success("Employee Sub-Practice Updated Successfully!!");
                        setTimeout(function () {
                            window.location.reload();
                        }, 2000);
                    } else {
                        toastr.error(response.responseMessage);
                        document.querySelector("#loader").style.display = "none";

                    }
                }
            });

        }
        window.addEventListener("DOMContentLoaded", () => {
            document.querySelector("#practiceDropdown").value = '1';
            document.querySelector("#practiceDropdown").dispatchEvent(new Event("change"));
        })
    </script>

}
