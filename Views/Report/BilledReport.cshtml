        function handleFilterSearch(input) {
            const allFilterItems = input.closest(".hs-dropdown-menu").querySelector(".filter-item-list").querySelectorAll("span");
            allFilterItems.forEach(item => {
                if (item.innerText.trim().toLowerCase().includes(input.value.trim().toLowerCase())) {
                    item.closest(".filter-item").style.display = "flex"
                } else {
                    item.closest(".filter-item").style.display = "none";
                }
            })
        }

        function toggleTextbox(textboxId) {           
            var textbox = document.getElementById(textboxId);
            var proBilling = $(textbox).attr('provisingBilling');
            var checkbox = document.getElementById('chk-' + textboxId.replace('txt-', ''));         
            textbox.disabled = !checkbox.checked;
            if(checkbox.checked){
                $(textbox).val(proBilling);
                // textbox.style.color = 'red';
            }
            else {
                $(textbox).val('0');
                textbox.style.color = '#00cc83';
            }
            
        }

        async function SubmmitBilledData() {
            var billedData = [];
            let validFlag = true;
            const allSelectedCheckbox = document.querySelectorAll('input[type="checkbox"][name="MAB"]:checked');
            if(!allSelectedCheckbox.length) {
                toastr.error("Please select billing to update");
                return;
            }
            allSelectedCheckbox.forEach(function (checkbox) {
                if (checkbox.checked) {
                    var textboxId = 'txt-' + checkbox.id.replace('chk-', '');
                    var textbox = document.getElementById(textboxId);
                    console.log(textboxId);
                    console.log(checkbox.id);
                    if(!textbox.value || (Number(textbox.value) == 0)) {
                        validFlag = false;
                        textbox.classList.add("is-invalid");
                    } else {
                        textbox.classList.remove("is-invalid");
                    }
                    billedData.push({
                        provisionbillingid: checkbox.id.replace('chk-',''),
                        billedamount: textbox.value
                    });
                }
            });
            if (!validFlag) {
                return;
            }
            var jsondata = JSON.stringify(billedData);
             console.log(jsondata);
            $.ajax({
                url: '@Url.Action("UpdateBilledData", "Report")',
                type: 'POST',
                contentType: 'application/json',
                data: jsondata,
                success: function (response) {
                    if (response.success == true) {
                        console.log(response);
                        toastr.success(response.msg);
                         location.reload()
                    } else {
                        toastr.error(response.msg);
                    }
                },
                error: function (err) {
                    toastr.error(err);
                }
            });
        }

