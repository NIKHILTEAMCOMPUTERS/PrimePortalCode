@section Scripts {

    <script>
        $(function () {
            document.querySelector(".main").classList.add("flex", "flex-col");
        @if (ViewData["error"] != null)
        {
            <text>
                    toastr.error("@ViewData["error"]", "Error", { "iconClass": 'new-error' });
            </text>
        }
        @if (ViewData["success"] != null)
        {
            <text>
                    toastr.success("@ViewData["success"]");
            </text>
        }
                $(function () {
                    document.querySelector(".main").classList.add("flex", "flex-col");

        @if (TempData.ContainsKey("error"))
        {
            <text>
                            toastr.error("@TempData["error"]", "Error", { "iconClass": 'new-error' });
            </text>
        }

        @if (TempData.ContainsKey("success"))
        {
            <text>
                            toastr.success("@TempData["success"]");
            </text>
        }
                                                                    });
        });

        function initTabsOnLoad() {
            const tabToInit = window.location.search.split("?tab=")[1];
            if (tabToInit) {
                if (tabToInit === "project") {
                    document.querySelector("#projectWiseTab").click();
                } else if (tabToInit === "employee") {
                    document.querySelector("#employeeWiseTab").click();
                }
            }
        }

        window.addEventListener("DOMContentLoaded", () => {
            initTabsOnLoad();

            (() => {
                const dateLimits = getMinMaxDateCurrentMonth();
                document.querySelector("#swapEstimatedDateAll").setAttribute("min", dateLimits?.minDate)
                document.querySelector("#swapEstimatedDateAll").setAttribute("max", dateLimits?.maxDate)
            })()
        })



        $(document).ready(function () {

            $('#send-all-button').on('click', function () {
                document.querySelector("#loader").style.display = "flex";
                var selectedItems = [];
                const allChkBox = document.querySelectorAll(`tbody input[type="checkbox"]:checked`);
                let allDatesValid = true;
                allChkBox.forEach(chkBox => {
                    const row = chkBox.closest("tr");
                    var billingId = row.getAttribute('data-billingid');
                    var costing = parseFloat(row.querySelector('.ProvisionAmount').innerText.replace('₹', '').replace(',', ''));
                    var estimatedBillingDate = row.querySelector('.estimatedBilligDate').innerText.trim();
                    if (!estimatedBillingDate || estimatedBillingDate == '-') {
                        allDatesValid = false;
                        toastr.error("Every Resource Provision must include Estimated Billing Date!!.")
                        document.querySelector("#loader").style.display = "none";
                        return;
                    }
                    selectedItems.push({
                        "contractbillingid": billingId,
                        "costing": costing,
                        "exptectedbillingdate": estimatedBillingDate
                    });
                })

                if (!allDatesValid) {
                    return;
                }


                console.log(selectedItems);

                // Convert the array to a JSON string
                var selectedItemsJSON = JSON.stringify(selectedItems);

                $.ajax({
                    url: '/Billing/BillingApproval',
                    type: 'POST',
                    contentType: 'application/json',
                    data: selectedItemsJSON, // Send the JSON string as data
                    success: function (response) {
                        console.log(response);
                        toastr.success("Provisions sent for approval to DH!!");
                        window.location.reload();

                    },
                    error: function (error) {
                        console.error(error);
                        window.location.reload();
                    }
                });
            });
        });

        function handleSendAll(btn, mode = "projectwise") {
            document.querySelector("#loader").style.display = "flex";
            var selectedItems = [];
            const allChkBox = btn.closest(".hidden-row").querySelector("tbody").querySelectorAll(`input[type="checkbox"]:checked`);
            let allDatesValid = true;
            allChkBox.forEach(chkBox => {
                const row = chkBox.closest("tr");
                var billingId = row.getAttribute('data-billingid');
                var costing = parseFloat(row.querySelector('.ProvisionAmount').innerText.replace('₹', '').replace(',', ''));
                var estimatedBillingDate = row.querySelector('.estimatedBilligDate').innerText.trim();
                if (!estimatedBillingDate || estimatedBillingDate == '-') {
                    allDatesValid = false;
                    toastr.error("Every Resource Provision must include Estimated Billing Date!!.")
                    document.querySelector("#loader").style.display = "none";
                    return;
                }
                selectedItems.push({
                    "contractbillingid": billingId,
                    "costing": costing,
                    "exptectedbillingdate": estimatedBillingDate
                });
            })

            if (!allDatesValid) {
                return;
            }


            console.log(selectedItems);

            // Convert the array to a JSON string
            var selectedItemsJSON = JSON.stringify(selectedItems);

            $.ajax({
                url: '/Billing/BillingApproval',
                type: 'POST',
                contentType: 'application/json',
                data: selectedItemsJSON, // Send the JSON string as data
                success: function (response) {
                    console.log(response);
                    toastr.success("Provisions sent for approval to DH!!");
                    window.location.href = window.location.href + `?tab=${mode === 'employeewise' ? "employee" : "project"}`;

                },
                error: function (error) {
                    console.error(error);
                    window.location.href = window.location.href + `?tab=${mode === 'employeewise' ? "employee" : "project"}`;
                }
            });
        }

        const provDt = new DataTable("#provBilling", {
            scrollX: true,
            scrollY: '35vh',
            ordering: false,
            destroy: true,
            dom: "lBfrtip",
            pageLength: 50,
            buttons: [{
                extend: 'excelHtml5',
                exportOptions: {
                    trim: false,
                    stripHtml: false,
                    format: {
                        header: function (html, index, node) {
                            return node.innerText;
                        },
                        body: function (data, row, column, node) {
                            return node.innerText;
                        }
                    }
                }
            }],
            "fnInitComplete": function (oSettings, json) {
                const _dt = this.api();
                console.log("initdone")
                // $("#loader").hide();
                document.querySelector("#loader").style.display = "none";
                // docu
                const allTh = document.querySelectorAll(".dataTables_scrollHead table thead th");
                const allThWithFilter = [];
                Array.from(allTh).forEach((item, index) => {
                    if (item.querySelector(".hs-dropdown")) {
                        allThWithFilter.push({ item, index });
                    }
                });
                console.log(allThWithFilter);
                allThWithFilter.forEach(item => {
                    // console.log(Number(item.index));
                    const column = _dt.columns(Number(item.index)).data().unique().sort();
                    // const column = document.querySelectorAll(`td:nth-child(${item.index + 1})`);
                    const uniqueColumnContentSet = new Set();

                    column[0].forEach(colItem => {
                        if (!colItem.includes("span")) {
                            uniqueColumnContentSet.add(colItem);
                        } else {
                            const tempElem = document.createElement("div");
                            tempElem.innerHTML = colItem;
                            uniqueColumnContentSet.add(tempElem.innerText.trim());
                        }
                    });
                    const uniqueColumnContent = Array.from(uniqueColumnContentSet).sort();
                    const dropdownBody = item?.item.querySelector(".hs-dropdown-menu .filter-item-list");
                    dropdownBody.innerHTML = "";
                    uniqueColumnContent.forEach(dItem => {
                        const dropdownItem = document.createElement("div");
                        dropdownItem.classList.add("relative", "flex", "items-start", "py-2", "px-3", "rounded-lg", "hover:bg-gray-100", "filter-item");
                        let checkBoxId = `chk-${Math.floor(Math.random() * 9999999)}`;
                        dropdownItem.innerHTML = `<div class="flex items-center">
                                                                                                                                                                        <input value="${dItem}" id="${checkBoxId}" type="checkbox" class="shrink-0 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                                                                                                                                                    </div>
                                                                                                                                                                    <label for="${checkBoxId}" class="flex-1 ms-2">
                                                                                                                                                                        <span class="block text-xs text-gray-800 text-left">${dItem}</span>
                                                                                                                                                                    </label>`;
                        dropdownBody.appendChild(dropdownItem);
                    })
                    if (!dropdownBody.nextElementSibling) {
                        dropdownBody.parentElement.innerHTML += `<div class="flex gap-2"><button onclick="clearFilter(this, ${item?.index});" class="flex mt-2 w-full items-center justify-center gap-x-3.5 py-2 px-3 rounded-lg text-xs text-gray-800 bg-gray-100 hover:bg-gray-50 focus:outline-none focus:bg-gray-100">Clear</button><button onclick="filterTable(this, ${item?.index});" class="flex mt-2 w-full items-center justify-center gap-x-3.5 py-2 px-3 rounded-lg text-xs text-gray-800 bg-gray-100 hover:bg-gray-50 focus:outline-none focus:bg-gray-100" href="#">Apply</button></div>`
                    }
                })
            }
        });

        provDt.on("page", () => {
            if (document.querySelector("#select-all")) {
                document.querySelector("#select-all").checked = false;
            }
            provDt.columns(0).nodes()[0].forEach(item => {
                if (item.querySelector("input")) {
                    item.querySelector("input").checked = false;
                }
            })
        })

        function filterTable(btn, colInd) {
            const values = [];
            btn.closest(".hs-dropdown").querySelectorAll("input:checked").forEach(chkbox => {
                values.push(chkbox.value);
            })
            HSDropdown.close(btn.closest(".hs-dropdown"));
            setTimeout(() => {
                if (values.length) {
                    console.log(values);
                    provDt.columns(Number(colInd)).search('^(' + values.join("|") + ')$', true, false).draw();
                } else {
                    provDt.columns(Number(colInd)).search("", true, false).draw();
                }
            }, 200)
        }

        function clearFilter(btn, colInd) {
            btn.closest(".hs-dropdown").querySelectorAll("input:checked").forEach(chkbox => {
                chkbox.checked = false;
            })
            btn.closest(".hs-dropdown").querySelector("input[type='search']").value = "";
            const _inpEvent = new Event("input");
            btn.closest(".hs-dropdown").querySelector("input[type='search']").dispatchEvent(_inpEvent);
            HSDropdown.close(btn.closest(".hs-dropdown"));
            setTimeout(() => {
                provDt.columns(Number(colInd)).search("", true, false).draw();
                // updateTotalBilling(datatable);
            }, 200)
        }

        function sendForApprovalSingle(btn, mode = "employeewise") {
            document.querySelector("#loader").style.display = "flex";
            var selectedItems = [];
            if (mode === "employeewise") {
                const row = btn.closest("tr");
                let billingId = row.getAttribute('data-billingid');
                let costing = parseFloat(row.querySelector('.ProvisionAmount').innerText.replace('₹', '').replace(',', ''));
                let estimatedBillingDate = row.querySelector('.estimatedBilligDate').innerText.trim();
                if (!estimatedBillingDate || estimatedBillingDate == '-') {
                    toastr.error("Every Resource Provision must include Estimated Billing Date!!.")
                    document.querySelector("#loader").style.display = "none";
                    return;
                }
                selectedItems.push({
                    "contractbillingid": billingId,
                    "costing": costing,
                    "exptectedbillingdate": estimatedBillingDate
                });
            }
            if (mode === "projectwise") {
                const row = btn.closest("tr");
                let billingId = row.getAttribute('data-billingid');
                let costing = parseFloat(row.querySelector('.ProvisionAmount').innerText.replace('₹', '').replace(',', ''));
                let estimatedBillingDate = row.querySelector('.estimatedBilligDate').innerText.trim();
                if (!estimatedBillingDate || estimatedBillingDate == '-') {
                    toastr.error("Every Resource Provision must include Estimated Billing Date!!.")
                    document.querySelector("#loader").style.display = "none";
                    return;
                }
                selectedItems.push({
                    "contractbillingid": billingId,
                    "costing": costing,
                    "exptectedbillingdate": estimatedBillingDate
                });
            }


            console.log(selectedItems);

            // Convert the array to a JSON string
            var selectedItemsJSON = JSON.stringify(selectedItems);

            $.ajax({
                url: '/Billing/BillingApproval',
                type: 'POST',
                contentType: 'application/json',
                data: selectedItemsJSON, // Send the JSON string as data
                success: function (response) {
                    console.log(response);
                    toastr.success("Provisions sent for approval to DH!!");
                    window.location.href = window.location.href + `?tab=${mode === 'employeewise' ? "employee" : "project"}`;
                },
                error: function (error) {
                    console.error(error);
                    window.location.href = window.location.href + `?tab=${mode === 'employeewise' ? "employee" : "project"}`;
                }
            });
        }


        function getCurrentMonthStr() {
            const currentDate = new Date();
            const month = currentDate.toLocaleString('en-us', { month: 'short' });
            const year = currentDate.getFullYear().toString().substr(-2);
            return `${month}-${year}`;
        }

        function handleSelectAll(inp, mode = "employeewise") {
            let allTr = [];
            console.log(mode);
            if (mode === "employeewise") {
                allTr = document.querySelectorAll("#provBilling tbody tr");
            }
            if (mode === 'projectwise') {
                allTr = inp.closest("table").querySelector("tbody").querySelectorAll("tr");
            }
            console.log(allTr);
            if (inp.checked) {
                allTr.forEach(tr => {
                    const trMonth = mode === 'employeewise' ? tr.querySelector("td:nth-child(3)").innerText.trim() : tr.querySelector("td:nth-child(5)").innerText.trim();
                    console.log(trMonth);
                    if (getCurrentMonthStr().toLowerCase() === trMonth.toLowerCase()) {
                        if (!tr.querySelector("input[type='checkbox']").disabled) {
                            tr.querySelector("input[type='checkbox']").checked = true;
                        }
                    }
                })
            } else {
                allTr.forEach(tr => {
                    const trMonth = mode === 'employeewise' ? tr.querySelector("td:nth-child(3)").innerText.trim() : tr.querySelector("td:nth-child(5)").innerText.trim();
                    console.log(trMonth);
                    if (getCurrentMonthStr().toLowerCase() === trMonth.toLowerCase()) {
                        tr.querySelector("input[type='checkbox']").checked = false;
                    }
                })
            }
        }

        function setEditMode(btn, isEditMode, isRevision = false) {
            const _tr = btn.closest("tr");
            if (isRevision) {
                _tr.querySelector(".save-btn")?.setAttribute("data-isrevision", 'true');
            }
            if (isEditMode) {
                _tr && _tr.classList.add("edit-mode");
            } else {
                _tr && _tr.classList.remove("edit-mode");
                _tr.querySelector(".save-btn").removeAttribute("data-isrevision");
            }
        }

        function getFormattedDate(dateVal) {
            const date = new Date(dateVal);
            const yyyy = date.getFullYear();
            let mm = date.getMonth() + 1; // Months start at 0!
            let dd = date.getDate();

            if (dd < 10) dd = '0' + dd;
            if (mm < 10) mm = '0' + mm;

            return dd + '/' + mm + '/' + yyyy;
        }

        function isDataValid(row) {
            let validFlag = true;

            if (!row.querySelector(".amount-inp").value.trim()) {
                row.querySelector(".amount-inp").classList.add("is-invalid");
                validFlag = false;
            } else {
                row.querySelector(".amount-inp").classList.remove("is-invalid");
            }

            if (!row.querySelector(".estimated-date-inp").value) {
                row.querySelector(".estimated-date-inp").classList.add("is-invalid");
                validFlag = false;
            } else {
                row.querySelector(".estimated-date-inp").classList.remove("is-invalid");
            }

            return validFlag;
        }

        function setEditModeData(btn, mode = "employeewise") {
            const _tr = btn.closest("tr");

            if (!isDataValid(_tr)) {
                return;
            }
            document.querySelector("#loader").style.display = "flex";
            const _amount = _tr.querySelector(".amount-inp").value;
            const _estimatedDate = getFormattedDate(_tr.querySelector(".estimated-date-inp").value);


            let _objRes = [{
                ContractEmployeeId: _tr.getAttribute("data-contractemployeeid"),
                BillingMonthYear: mode === 'employeewise' ? _tr.querySelector("td:nth-child(3)").innerText.trim() : _tr.querySelector("td:nth-child(5)").innerText.trim(),
                Costing: _tr.querySelector(".amount-inp").value,
                estimatedDate: _tr.querySelector(".estimated-date-inp").value,
                isRevised: btn.getAttribute("data-isrevision")
            }];

            var fdata = new FormData();
            fdata.append("jsonObject", JSON.stringify(_objRes));
            fdata.append("isProvision", "true")
            $.ajax({
                url: "@Url.Action("Billing", "Contract")",
                type: "POST",
                cache: false,
                data: fdata,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res);
                    if (res.success == true) {
                        toastr.success(res.msg);
                        window.location.href = window.location.href + `?tab=${mode === 'employeewise' ? "employee" : "project"}`;
                        if (_amount) {
                            _tr.querySelector(".amount-val").innerText = _amount;
                        }

                        if (_estimatedDate) {
                            _tr.querySelector(".estimated-date-val").innerText = _estimatedDate;
                        }

                        setEditMode(btn, false);
                    } else {
                        toastr.error(res.msg);
                        window.location.href = window.location.href + `?tab=${mode === 'employeewise' ? "employee" : "project"}`;
                    }
                },
                error: function (err) {
                    toastr.error(err);
                }
            });
        }

        function handleDateChange(inp) {
            inp.closest("form").submit();
            return;
            const dateVal = inp.value;
            const fData = new FormData();
            fData.append("date", dateVal);
            if (dateVal) {
                $.ajax({
                    async: false,
                    url: "@Url.Action("ContractBillingProvisionReport", "Report")",
                    type: "POST",
                    cache: false,
                    contentType: false,
                    processData: false,
                    data: fData,
                    success: function (res) {
                        console.log(res)
                    },
                    error: function (res) { },
                });
            }
        }

        function handleFilterSearch(input) {
            const allFilterItems = input.closest(".hs-dropdown-menu").querySelector(".filter-item-list").querySelectorAll("span");
            allFilterItems.forEach(item => {
                if (item.innerText.trim().toLowerCase().includes(input.value.trim().toLowerCase())) {
                    item.closest(".filter-item").style.display = "flex"
                } else {
                    item.closest(".filter-item").style.display = "none";
                }
            })
        }
        function toggleHiddenRow(btn) {
            const _hidRow = btn.closest("tr").nextElementSibling;
            if (_hidRow && _hidRow.classList.contains("hidden-row")) {
                _hidRow.classList.toggle("show");
            }
        }

        function handleEditAll(btn) {
            btn.closest(".editAllPanel").classList.add("active");
            const selectedCount = btn.closest(".hidden-row").querySelector("tbody").querySelectorAll("tr:has(input[type='checkbox']:not(:disabled))").length;
            console.log(selectedCount)
            if (selectedCount) {
                btn.closest(".hidden-row").querySelector(".selectedCountContainer").innerHTML = `<span>Total Selected : <span class="font-bold">${selectedCount}<span>`;
            }
        }

        function handleSaveAll(btn) {

            const dateValInp = btn.closest(".hidden-row").querySelector(".panel-date")
            const amountValInp = btn.closest(".hidden-row").querySelector(".panel-amount");

            let validFlag = true;
            if (!dateValInp.value) {
                dateValInp.classList.add("is-invalid");
                validFlag = false;
            } else {
                dateValInp.classList.remove("is-invalid");
            }
            if (!amountValInp.value) {
                amountValInp.classList.add("is-invalid");
                validFlag = false;
            } else {
                amountValInp.classList.remove("is-invalid");
            }

            if (!validFlag) return;
            const _objRes = [];
            console.log(btn.closest(".hidden-row"))
            const allTr = btn.closest(".hidden-row").querySelector("tbody").querySelectorAll("tr:has(input[type='checkbox']:checked)");
            console.log(allTr);
            if (!allTr.length) return;
            allTr.forEach(_tr => {
                _objRes.push({
                    ContractEmployeeId: _tr.getAttribute("data-contractemployeeid"),
                    BillingMonthYear: _tr.querySelector("td:nth-child(5)").innerText.trim(),
                    Costing: amountValInp.value,
                    estimatedDate: dateValInp.value,
                    isRevised: btn.getAttribute("data-isrevision")
                })
            })
            var fdata = new FormData();
            fdata.append("jsonObject", JSON.stringify(_objRes));
            fdata.append("isProvision", "true")
            document.querySelector("#loader").style.display = "flex";

            $.ajax({
                url: "@Url.Action("Billing", "Contract")",
                type: "POST",
                cache: false,
                data: fdata,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res);
                    if (res.success == true) {
                        toastr.success(res.msg);
                        // if (_amount) {
                        //     _tr.querySelector(".amount-val").innerText = _amount;
                        // }

                        // if (_estimatedDate) {
                        //     _tr.querySelector(".estimated-date-val").innerText = _estimatedDate;
                        // }

                        setEditMode(btn, false);
                        window.location.href = window.location.href + '?tab=project';
                    } else {
                        toastr.error(res.msg);
                        window.location.href = window.location.href + '?tab=project';
                    }
                },
                error: function (err) {
                    toastr.error(err);
                }
            });
