        function handlePanelCancel(btn) {
            const panel = btn.closest(".editAllPanel");
            const amountInp = panel.querySelector(".panel-amount");
            const dateInp = panel.querySelector(".panel-date");

            dateInp.classList.remove("is-invalid");
            amountInp.classList.remove("is-invalid");

            dateInp.value = "";
            amountInp.value = "";

            panel.classList.remove("active");
            panel.querySelector(".selectedCountContainer").innerHTML = "";
        }

        function handleSwapBilling(btn) {
            const projectData = btn.closest(".hidden-row").querySelector("tbody").querySelectorAll("tr");
            const dateLimits = getMinMaxDateCurrentMonth();
            let swapTableHTML = '';

            projectData.forEach(item => {
                swapTableHTML += `<tr>`;
                swapTableHTML += `<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">`;
                swapTableHTML += `<div class="flex">`;
                swapTableHTML += `<input onchange="checkactualexist(this);" data-contractemployeeid="${item.getAttribute('data-contractemployeeid')}" value="${item.querySelector("td:nth-child(1)")?.innerHTML.trim()}" type="checkbox" class="shrink-0 mt-0.5 border-black rounded text-black focus:ring-black disabled:opacity-50 disabled:pointer-events-none disabled:opacity-50"/>`;
                swapTableHTML += `</div>`;
                swapTableHTML += `</td>`;

                swapTableHTML += `<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">${item.querySelector("td:nth-child(3)")?.innerHTML.trim()}</td>`;

                swapTableHTML += `<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800"><span class="rounded-full p-2 bg-gray-500 text-white">${item.querySelector("td:nth-child(4)")?.innerHTML.trim()}</span></td>`;

                swapTableHTML += `<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">${item.querySelector("td:nth-child(5)")?.innerHTML.trim()}</td>`;

                swapTableHTML += `<td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800"><input type="date" min='${dateLimits?.minDate}' max='${dateLimits?.maxDate}' class="k-input"></td>`;

                swapTableHTML += `</tr>`;
            })

            document.querySelector("#swapBillingTbl tbody").innerHTML = swapTableHTML;

            const _projectHeading = btn.closest(".hidden-row").querySelector(".project_name").innerText.trim();

            document.querySelector("#swapProjectName").innerHTML = _projectHeading;

            HSOverlay.open(document.querySelector("#swap-billing-overlay"));
        }

        function resetSwapBlling() {
            document.querySelector("#swapBillingTbl tbody").innerHTML = "";
            document.querySelector("#swapProjectName").innerHTML = "";
            document.querySelector("#swapEstimatedDateAll").value = "";
        }

        function validateSwapTableDate() {
            let validFlag = true;
            const allTblDateInput = document.querySelector("#swapBillingTbl tbody").querySelectorAll("tr:has(input[type='checkbox']:checked) input[type='date']");
            allTblDateInput.forEach(inp => {
                if (!inp.value) {
                    inp.classList.add("is-invalid");
                    validFlag = false;
                } else {
                    inp.classList.remove("is-invalid");
                }
            })
            return validFlag;
        }

        function swapBilling() {
            const allSelectedRows = document.querySelector("#swapBillingTbl tbody").querySelectorAll("tr:has(input[type='checkbox']:checked)");

            if (!allSelectedRows.length) {
                toastr.error("No items selected for swapping");
                return;
            }

            const isTblDataValid = validateSwapTableDate();

            if (!isTblDataValid) {
                toastr.error("Please enter dates");
                return;
            }

            const resObj = [];

            allSelectedRows.forEach(item => {
                resObj.push({
                    contrtactbillingprovesionid: item.querySelector("td:nth-child(1)").querySelector("input").value,
                    costing: item.querySelector("td:nth-child(3)").innerText.trim(),
                    BillingMonthyear: item.querySelector("td:nth-child(4)").innerText.trim(),
                    billingdate: item.querySelector("td:nth-child(5)").querySelector("input").value,
                });
            })

            if (!resObj.length) {
                toastr.error("There was some error");
                return;
            }

            const fdata = new FormData();
            fdata.append("swapItem", JSON.stringify(resObj));

            $.ajax({
                url: "@Url.Action("SwapBilling", "Billing")",
                type: "POST",
                cache: false,
                data: fdata,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res);
                    if (res.success == true) {
                        toastr.success(res.msg);

                        window.location.href = window.location.href + '?tab=project';
                    } else {
                        toastr.error(res.msg);
                        window.location.href = window.location.href + '?tab=project';
                    }
                },
                error: function (err) {
                    toastr.error(err);
                }
            });
        }

        function setAllDates2(inp, tblId) {
            const dateToSet = inp.value;
            const allInputs = document.querySelector(`#${tblId} tbody`).querySelectorAll("tr:has(input[type='checkbox']:checked) input[type='date']");

            if (!allInputs.length) {
                toastr.error("No items selected");
                inp.value = "";
                return;
            }

            allInputs.forEach(dateInp => {
                dateInp.value = dateToSet;
            })
        }

        function handleSelectAll2(inp) {
            if (!inp) return;
            const valueToSet = inp.checked;

            const allChkBox = inp.closest("table").querySelector("tbody").querySelectorAll("input[type='checkbox']");

            allChkBox.forEach(item => {
                item.checked = valueToSet;
                if (valueToSet) {
                    const event = new Event("change");
                    item.dispatchEvent(event);
                }
            })
        }

        HSOverlay.on("close", (modal) => {
            if (modal.id === "swap-billing-overlay") {
                resetSwapBlling();
            }
        })


        function checkactualexist(inp) {
            if (!inp.checked) return;
            const fdata = new FormData();
            const contractEmployeeId = inp.getAttribute("data-contractemployeeid");
            const monthYear = inp.closest("tr").querySelector("td:nth-child(4)").innerText.trim();
            const employeeName = inp.closest("tr").querySelector("td:nth-child(2)").innerText.trim();

            if (!contractEmployeeId || !monthYear) return;

            fdata.append("data", JSON.stringify({ contractEmployeeId: contractEmployeeId, monthyear: monthYear }));
            $.ajax({
                url: "@Url.Action("Actualbillingcheck", "Billing")",
                type: "POST",
                cache: false,
                data: fdata,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res);
                    if (res.success == true) {
                        if (res.msg !== 'allowed') {
                            toastr.error(`Unable to swap billing: The billing amount of ${res.msg} already exists for the current month for employee ${employeeName}.`);
                            inp.checked = false;
                        }


                    } else {

                    }
                },
                error: function (err) {
                    toastr.error(err);
                }
            });
        }

        function getMinMaxDateCurrentMonth() {
            const date = new Date();
            const firstDay = new Date(date.getFullYear(), date.getMonth(), 1);
            const lastDay = new Date(date.getFullYear(), date.getMonth() + 1, 0);

            console.log(firstDay, lastDay);

            const minDate = `${firstDay.getFullYear()}-${(firstDay.getMonth() + 1) < 10 ? '0' + (firstDay.getMonth() + 1) : (firstDay.getMonth() + 1)}-${(firstDay.getDate() < 10) ? '0' + firstDay.getDate() : firstDay.getDate()}`;
            const maxDate = `${lastDay.getFullYear()}-${(lastDay.getMonth() + 1) < 10 ? '0' + (lastDay.getMonth() + 1) : (lastDay.getMonth() + 1)}-${(lastDay.getDate() < 10) ? '0' + lastDay.getDate() : lastDay.getDate()}`;

            return { minDate, maxDate };
        }


    </script>

