@model IEnumerable<RMS.Client.Models.Master.ProvisionViewModal>
@using System.Globalization;
@using Microsoft.AspNetCore.Http
@using RMS.Client.Utility
@{
    var roleName = @Context.Session.GetString("RoleName");
}


@section PageStyles {
    <style>
        .approve-all-btn2 {
            opacity: .5;
            pointer-events: none;
        }

        .hidden-row:has(.selectAllProjectWise:checked) .approve-all-btn2 {
            opacity: 1;
            pointer-events: all;
        }

        .hidden-row:has(.selectAllProjectWise:checked) .approve-btn {
            opacity: 0;
            pointer-events: none;
        }

        .editAllBtn {
            opacity: .5;
            pointer-events: none;
            cursor: not-allowed;
            display: flex;
            border: 1px solid #3b82f6;
            color: #3b82f6;
            border-radius: 5rem;
            align-items: center;
            gap: .5rem;
        }

        .swapAllBtn {
            display: flex;
            border: 1px solid #3b82f6;
            color: #3b82f6;
            border-radius: 5rem;
            align-items: center;
            gap: .5rem;
        }

        .hidden-row:has(.selectAllProjectWise:checked) .editAllBtn {
            opacity: 1;
            pointer-events: all;
            cursor: pointer;
        }

        .editAllPanel.active {
            background-color: #d0dbeb;
            padding: 1rem;
            border-radius: .5rem;
            margin-bottom: 1rem;
        }

            .editAllPanel.active .panel-inactive-content {
                display: none !important;
            }

        .panel-active-content {
            display: none !important;
        }

        .editAllPanel.active .panel-active-content {
            display: flex !important;
        }

        .panel-action-btn {
            background-color: white;
            color: black;
            border-radius: .5rem;
            padding: .5rem 1rem;
        }
    </style>
}
<div class="border-b border-gray-200 mb-4">
    <nav class="flex space-x-2 bg-[#fafafa] overflow-x-auto" aria-label="Tabs" role="tablist">
        <div class="py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500"
             id="tabs-with-underline-item-1" data-hs-tab="#tabs-with-underline-1">
            <!-- <img class="h-4 w-auto" src="./assets/images/total-projects-icon.svg" alt=""> -->
            <div>
                <span class="text-2xl font-extrabold block text-left">Requests For Provisions Update</span>
                <span class="text-sm block text-left">
                    List of all Provisions which are approved and yet to be
                    approved
                </span>
            </div>
        </div>
        <button type="button"
                class="py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500"
                id="tabs-with-underline-item-2" data-hs-tab="#tabs-with-underline-2"
                aria-controls="tabs-with-underline-2" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-projects-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Total Resource Provisions</span>
                <span class="text-2xl font-extrabold block text-left">@ViewBag.TotalCount</span>
            </div>
        </button>
        <button type="button"
                class="py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500"
                id="tabs-with-underline-item-3" data-hs-tab="#tabs-with-underline-3"
                aria-controls="tabs-with-underline-3" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-projects-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Approved</span>
                <span class="text-2xl font-extrabold block text-left">@ViewBag.ApprovedCount</span>
            </div>
        </button>
        <button type="button"
                class="py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500"
                id="tabs-with-underline-item-3" data-hs-tab="#tabs-with-underline-3"
                aria-controls="tabs-with-underline-3" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-projects-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Pending for Approval</span>
                <span class="text-2xl font-extrabold block text-left">@ViewBag.PendingCount</span>
            </div>
        </button>
        <button type="button"
                class="py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500"
                id="tabs-with-underline-item-3" data-hs-tab="#tabs-with-underline-3"
                aria-controls="tabs-with-underline-3" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-projects-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Rejected</span>
                <span class="text-2xl font-extrabold block text-left">@ViewBag.RejectedCount</span>
            </div>
        </button>
    </nav>
</div>
<div class="border-b border-gray-200 overflow-x-auto">
    <nav class="flex space-x-2 bg-[#fafafa]" aria-label="Tabs" role="tablist">
        <button type="button"
                class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600 active"
                id="projectWiseTab" data-hs-tab="#project-wise-content"
                aria-controls="project-wise-content" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-projects-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Project Wise</span>
            </div>
        </button>
        <button type="button"
                class="hs-tab-active:font-semibold hs-tab-active:border-emerald-600 py-2 px-5 inline-flex items-baseline gap-2 border-b-[3px] border-transparent text-sm whitespace-nowrap text-gray-500 hover:text-emerald-600"
                id="employeeWiseTab" data-hs-tab="#employee-wise-content"
                aria-controls="employee-wise-content" role="tab">
            <img class="h-4 w-auto" src="~/assets/images/total-employees-icon.svg" alt="">
            <div>
                <span class="text-base font-semibold block text-left">Employee Wise</span>
            </div>
        </button>
    </nav>
</div>
<div class="mt-3">
    <div id="employee-wise-content" class="hidden" role="tabpanel" aria-labelledby="employee-wise-content">
        <div class="flex justify-end gap-4 items-center">
            <button type="button" id="send-all-button"
                    class="mb-4 approve-all-btn py-1 px-4 inline-flex justify-center items-center gap-2 rounded-md border border-emerald-400 bg-[#00cc83] text-white hover:opacity-70 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 transition-all text-sm">
                Send For Approval
            </button>
            <form action="@Url.Action("ContractBillingProvisionReport", "Report")" method="POST">
                <div class="flex items-center gap-4">
                    <label class="text-sm">Month</label>
                    <input name="date" onchange="handleDateChange(this);" class="k-input" type="month" id="ctlFdate" value="@ViewBag.fDate" />
                </div>
            </form>
        </div>
        <div class="flex flex-col">
            <div class="-m-1.5 overflow-x-auto">
                <div class="p-1.5 min-w-full block align-middle">
                    <div class="overflow-hidden">
                        <table class="min-w-full divide-y divide-gray-200" id="provBilling">
                            <thead>
                                <tr>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        <div class="flex items-center gap-2">

                                            @if (roleName != "BillingExecutive" && Model.Count() > 0)
                                            {
                                                <div class="flex">
                                                    <input type="checkbox"
                                                           class="shrink-0 mt-0.5 border-black rounded text-black focus:ring-black disabled:opacity-50 disabled:pointer-events-none"
                                                           id="select-all" onchange="handleSelectAll(this);">
                                                </div>
                                            }

                                            Resource
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        Project
                                        <div style="vertical-align: middle; z-index: 10;" class="filter-dropdown mx-1 hs-dropdown relative sm:inline-flex [--auto-close:inside]">
                                            <button id="hs-dropdown-auto-close-inside" type="button" class="hs-dropdown-toggle p-1 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-gray-100 text-gray-800 shadow-sm disabled:opacity-50 disabled:pointer-events-none">
                                                <svg class="w-4 h-4 text-gray-800" xmlns="http://www.w3.org/2000/svg"
                                                     width="512" height="512" viewBox="0 0 512 512">
                                                    <path fill="currentColor"
                                                          d="M472 168H40a24 24 0 0 1 0-48h432a24 24 0 0 1 0 48m-80 112H120a24 24 0 0 1 0-48h272a24 24 0 0 1 0 48m-96 112h-80a24 24 0 0 1 0-48h80a24 24 0 0 1 0 48" />
                                                </svg>
                                            </button>

                                            <div class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden mt-2 bg-white shadow-md rounded-lg p-2 mt-2" aria-labelledby="hs-dropdown-auto-close-inside">
                                                <div class="mb-1">
                                                    <input type="search" oninput="handleFilterSearch(this);" placeholder="Search" class="py-2 px-4 block w-full border-gray-200 rounded-lg text-xs focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                                </div>
                                                <div class="filter-item-list" style="height: 10rem; overflow-y: auto;"></div>
                                            </div>
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        Month
                                        <div style="vertical-align: middle; z-index: 10;" class="filter-dropdown mx-1 hs-dropdown relative sm:inline-flex [--auto-close:inside]">
                                            <button id="hs-dropdown-auto-close-inside" type="button" class="hs-dropdown-toggle p-1 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-gray-100 text-gray-800 shadow-sm disabled:opacity-50 disabled:pointer-events-none">
                                                <svg class="w-4 h-4 text-gray-800" xmlns="http://www.w3.org/2000/svg"
                                                     width="512" height="512" viewBox="0 0 512 512">
                                                    <path fill="currentColor"
                                                          d="M472 168H40a24 24 0 0 1 0-48h432a24 24 0 0 1 0 48m-80 112H120a24 24 0 0 1 0-48h272a24 24 0 0 1 0 48m-96 112h-80a24 24 0 0 1 0-48h80a24 24 0 0 1 0 48" />
                                                </svg>
                                            </button>

                                            <div class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden mt-2 bg-white shadow-md rounded-lg p-2 mt-2" aria-labelledby="hs-dropdown-auto-close-inside">
                                                <div class="mb-1">
                                                    <input type="search" oninput="handleFilterSearch(this);" placeholder="Search" class="py-2 px-4 block w-full border-gray-200 rounded-lg text-xs focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                                </div>
                                                <div class="filter-item-list" style="height: 10rem; overflow-y: auto;"></div>
                                            </div>
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        Provision Amount
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        Estimated Date
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-center text-xs 2xl:text-sm font-medium text-black uppercase">
                                        Status
                                        <div style="vertical-align: middle; z-index: 10;" class="filter-dropdown mx-1 hs-dropdown relative sm:inline-flex [--auto-close:inside]">
                                            <button id="hs-dropdown-auto-close-inside" type="button" class="hs-dropdown-toggle p-1 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-gray-100 text-gray-800 shadow-sm disabled:opacity-50 disabled:pointer-events-none">
                                                <svg class="w-4 h-4 text-gray-800" xmlns="http://www.w3.org/2000/svg"
                                                     width="512" height="512" viewBox="0 0 512 512">
                                                    <path fill="currentColor"
                                                          d="M472 168H40a24 24 0 0 1 0-48h432a24 24 0 0 1 0 48m-80 112H120a24 24 0 0 1 0-48h272a24 24 0 0 1 0 48m-96 112h-80a24 24 0 0 1 0-48h80a24 24 0 0 1 0 48" />
                                                </svg>
                                            </button>

                                            <div class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden mt-2 bg-white shadow-md rounded-lg p-2 mt-2" aria-labelledby="hs-dropdown-auto-close-inside">
                                                <div class="mb-1">
                                                    <input type="search" oninput="handleFilterSearch(this);" placeholder="Search" class="py-2 px-4 block w-full border-gray-200 rounded-lg text-xs focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                                </div>
                                                <div class="filter-item-list" style="height: 10rem; overflow-y: auto;"></div>
                                            </div>
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        Remarks (DH)
                                    </th>
                                    <th scope="col"
                                        class="px-6 py-3 whitespace-nowrap text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                        <div class="flex items-center gap-2">
                                            Action

                                        </div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                @if (Model != null)
                                {
                                    var currentMonth = DateTime.Now.ToString("MMM-yy", CultureInfo.InvariantCulture);

                                    // Replace "Sept" with "Sep" to match the "MMM-yy" format
                                    if (currentMonth.Contains("Sept"))
                                    {
                                        currentMonth = currentMonth.Replace("Sept", "Sep");
                                    }
                                    foreach (var items in Model)
                                    {
                                        foreach (var item in items.Empwiseprovisiondata)
                                        {
                                            <tr data-billingid="@item.contractbillingprovesionid" data-contractemployeeid="@item.ContractEmployeeId">

                                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-800">

                                                    <div class="flex items-center gap-2">
                                                        @if (roleName != "BillingExecutive")
                                                        {
                                                            <div class="flex">
                                                                <input onchange="handleMultipleSubmit(this)" @(currentMonth == item.MonthYear ? "" : "disabled") @(item.Status == "Pending" ? "disabled" : item.Status == "Approved" ? "disabled" : "") type="checkbox"
                                                                       class="emp-select shrink-0 mt-0.5 border-black rounded text-black focus:ring-black disabled:opacity-50 disabled:pointer-events-none disabled:opacity-50">
                                                            </div>
                                                        }
                                                        @item.ResourceName (@item.TmcId)
                                                    </div>
                                                </td>
                                                <td class="px-6 py-4 text-sm font-medium text-gray-800 ">@item.ProjectName</td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">@item.MonthYear</td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 ProvisionAmount">
                                                    <span class="normal-mode-content amount-val">₹ @item.ProvisionAmount.ToString("#,##0.00")</span>
                                                    <input type="number" value="@item.ProvisionAmount" class="edit-mode-content amount-inp k-input" />
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 estimatedBilligDate">
                                                    <span class="normal-mode-content estimated-date-val">
                                                        @(item.estimatedBilligDate.HasValue ? item.estimatedBilligDate.Value.ToString("dd/MM/yyyy") : "-")
                                                    </span>
                                                    <input type="date" value="@item.estimatedBilligDate" class="edit-mode-content estimated-date-inp k-input" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                                </td>

                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800 text-center">
                                                    <span class="status @(item.Status == "Active" ? "approved" : item.Status == "Completed" ? "completed" : item.Status == "Approved" ? "approved" : item.Status == "Draft" ? "draft" : item.Status == "Rejected" ? "rejected" : item.Status == "Pending" ? "pending" : "")">@(!string.IsNullOrEmpty(item.Status) ? item.Status : "Pending")</span>
                                                </td>
                                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-800">
                                                    @item.RemarkByDH
                                                </td>
                                  

                                                @{
                                                    // Get the current date formatted as "MMM-yy"
                                                    var currentMonthYear = DateHelper.FormatMonthYear(DateTime.Now);

                                                    // Ensure item.MonthYear is transformed correctly
                                                    var itemMonthYear = item.MonthYear;
                                                    DateTime currentDateTime;
                                                    DateTime itemDateTime;

                                                    // Use DateHelper to parse the month-year strings
                                                    bool currentParsed = DateHelper.TryParseMonthYear(currentMonthYear, out currentDateTime);
                                                    bool itemParsed = DateHelper.TryParseMonthYear(itemMonthYear, out itemDateTime);

                                                    // Determine whether to show elements
                                                    bool showElements = currentParsed && itemParsed && itemDateTime == currentDateTime && itemDateTime.Day < 30;
                                                }





                                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                                    @if (roleName == "BillingExecutive")
                                                    {
                                                        <div class="flex items-center gap-2">


                                                            <button style="min-width: max-content; white-space: nowrap;" onclick="setEditModeData(this);" class="edit-mode-content save-btn flex items-center gap-2 border rounded-full py-1 px-2 border-[#4B4E5C] hover:opacity-70">
                                                                <svg class="w-4 h-4 hover:text-emerald-500"
                                                                     xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                                     viewBox="0 0 24 24">
                                                                    <path fill="currentColor"
                                                                          d="M5 21h14a2 2 0 0 0 2-2V8a1 1 0 0 0-.29-.71l-4-4A1 1 0 0 0 16 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2m10-2H9v-5h6zM13 7h-2V5h2zM5 5h2v4h8V5h.59L19 8.41V19h-2v-5a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v5H5z" />
                                                                </svg>
                                                                Save
                                                            </button>
                                                            <button style="min-width: max-content; white-space: nowrap;" onclick="setEditMode(this, false);" class="edit-mode-content flex items-center gap-2 border rounded-full py-1 px-2 border-[#4B4E5C] hover:opacity-70">
                                                                <svg class="w-4 h-4 hover:text-emerald-500" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C6.486 2 2 6.486 2 12s4.486 10 10 10s10-4.486 10-10S17.514 2 12 2M4 12c0-1.846.634-3.542 1.688-4.897l11.209 11.209A7.946 7.946 0 0 1 12 20c-4.411 0-8-3.589-8-8m14.312 4.897L7.103 5.688A7.948 7.948 0 0 1 12 4c4.411 0 8 3.589 8 8a7.954 7.954 0 0 1-1.688 4.897" /></svg>
                                                                Cancel
                                                            </button>
                                                            @*   @if (!showElements && (item.Status == "Draft" || item.Status == "Pending" || item.Status == "Rejected"))
                                            {
                                            <a style="min-width: max-content;" class="normal-mode-content flex items-center gap-2 border rounded-full py-1 px-2 border-[#4B4E5C] hover:opacity-70" href="@Url.Action("DeleteProBilling", "Billing", new { id = item.contractbillingprovesionid })">
                                            <img class="w-4 h-4" src="~/assets/images/btn_close_icon.svg" alt="">
                                            Delete
                                            </a>
                                            } *@

                                                            @if (item.Status == "Approved")
                                                            {
                                                                <button onclick="setEditMode(this, true, true);" style="min-width: max-content;" class="normal-mode-content flex items-center gap-2 border rounded-full py-1 px-2 border-blue-400 text-blue-500 hover:opacity-70">
                                                                    <img class="w-4 h-4" src="~/assets/images/btn_tick_btn.svg" alt="">
                                                                    Create Revision
                                                                </button>
                                                            }
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <div class="flex items-center gap-2">
                                                            @if (itemDateTime <= currentDateTime && showElements && (item.Status == "Rejected" || item.Status != "Approved" && item.Status != "Pending"))
                                                            {
                                                                <button onclick="sendForApprovalSingle(this);" style="min-width: max-content;" class="normal-mode-content approve-btn flex items-center gap-2 border rounded-full py-1 px-2 border-[#40BD5E] text-[#40BD5E] hover:opacity-70">
                                                                    <img class="w-4 h-4" src="~/assets/images/btn_tick_btn.svg" alt="">
                                                                    Send for approval
                                                                </button>
                                                            }

                                                            @if (itemDateTime > currentDateTime)
                                                            {
                                                                <button style="min-width: max-content;" onclick="setEditMode(this, true);" class="normal-mode-content flex items-center gap-2 border rounded-full py-1 px-2 border-[#4B4E5C] hover:opacity-70">
                                                                    <svg class="w-4 h-4 hover:text-emerald-500 focus:text-emerald-500"
                                                                         xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                                         viewBox="0 0 24 24">
                                                                        <g fill="none">
                                                                            <path d="M24 0v24H0V0zM12.593 23.258l-.011.002l-.071.035l-.02.004l-.014-.004l-.071-.035c-.01-.004-.019-.001-.024.005l-.004.010l-.017.428l.005.020l.010.013l.104.074l.015.004l.012-.004l.104-.074l.012-.016l.004-.017l-.017-.427c-.002-.010-.009-.017-.017-.018m.265-.113l-.013.002l-.185.093l-.010.010l-.003.011l.018.43l.005.012l.008.007l.201.093c.012.004.023 0 .029-.008l.004-.014l-.034-.614c-.003-.012-.010-.020-.020-.022m-.715.002a.023.023 0 0 0-.027.006l-.006.014l-.034.614c0 .012.007.020.017.024l.015-.002l.201-.093l.010-.008l.004-.011l.017-.43l-.003-.012l-.010-.010z" />
                                                                            <path fill="currentColor"
                                                                                  d="M13 3a1 1 0 0 1 .117 1.993L13 5H5v14h14v-8a1 1 0 0 1 1.993-.117L21 11v8a2 2 0 0 1-1.85 1.995L19 21H5a2 2 0 0 1-1.995-1.85L3 19V5a2 2 0 0 1 1.85-1.995L5 3zm6.243.343a1 1 0 0 1 1.497 1.32l-.083.095l-9.9 9.899a1 1 0 0 1-1.497-1.32l.083-.094z" />
                                                                        </g>
                                                                    </svg>
                                                                    Edit
                                                                </button>
                                                            }
                                                            else if (showElements && (item.Status == "Rejected" || item.Status == "Draft"))
                                                            {
                                                                <button style="min-width: max-content;" onclick="setEditMode(this, true);" class="normal-mode-content flex items-center gap-2 border rounded-full py-1 px-2 border-[#4B4E5C] hover:opacity-70">
                                                                    <svg class="w-4 h-4 hover:text-emerald-500 focus:text-emerald-500"
                                                                         xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                                         viewBox="0 0 24 24">
                                                                        <g fill="none">
