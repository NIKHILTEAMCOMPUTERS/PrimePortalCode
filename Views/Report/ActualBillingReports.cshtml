        async function SubmmitBilledData() {
            var billedData = [];
            let validFlag = true;
            const allSelectedCheckbox = document.querySelectorAll('input[type="checkbox"][name="MAB"]:checked');
            if (!allSelectedCheckbox.length) {
                toastr.error("Please select billing to update");
                return;
            }
            allSelectedCheckbox.forEach(function (checkbox) {
                if (checkbox.checked) {
                    var textboxId = 'txt-' + checkbox.id.replace('chk-', '');
                    var textbox = document.getElementById(textboxId);
                    console.log(textboxId);
                    console.log(checkbox.id);
                    if (!textbox.value || (Number(textbox.value) == 0)) {
                        validFlag = false;
                        textbox.classList.add("is-invalid");
                    } else {
                        textbox.classList.remove("is-invalid");
                    }
                    billedData.push({
                        provisionbillingid: checkbox.id.replace('chk-', ''),
                        billedamount: textbox.value

                    });
                }
            });
            if (!validFlag) {
                return;
            }
            var jsondata = JSON.stringify(billedData);
            console.log(jsondata);
            $.ajax({
                url: '@Url.Action("UpdateBilledData", "Report")',
                type: 'POST',
                contentType: 'application/json',
                data: jsondata,
                success: function (response) {
                    if (response.success == true) {
                        console.log(response);
                        toastr.success(response.msg);
                        location.reload()
                    } else {
                        toastr.error(response.msg);
                    }
                },
                error: function (err) {
                    toastr.error(err);
                }
            });
        }

