                        }
                    },
                    error: function (err) {
                        toastr.error(err);
                    }
                });
            }
        }

        function setEditMode(btn, isEditMode, isRevision = false) {
            const _tr = btn.closest("tr");
            if (isRevision) {
                _tr.querySelector(".save-btn")?.setAttribute("data-isrevision", 'true');
            }
            if (isEditMode) {
                _tr && _tr.classList.add("edit-mode");
            } else {
                _tr && _tr.classList.remove("edit-mode");
                _tr.querySelector(".save-btn").removeAttribute("data-isrevision");
            }
        }

        function isDataValid(row) {
            let validFlag = true;

            if (!row.querySelector(".amount-inp").value.trim()) {
                row.querySelector(".amount-inp").classList.add("is-invalid");
                validFlag = false;
            } else {
                row.querySelector(".amount-inp").classList.remove("is-invalid");
            }

            if (!row.querySelector(".estimated-date-inp").value) {
                row.querySelector(".estimated-date-inp").classList.add("is-invalid");
                validFlag = false;
            } else {
                row.querySelector(".estimated-date-inp").classList.remove("is-invalid");
            }

            return validFlag;
        }

        function getFormattedDate(dateVal) {
            const date = new Date(dateVal);
            const yyyy = date.getFullYear();
            let mm = date.getMonth() + 1; // Months start at 0!
            let dd = date.getDate();

            if (dd < 10) dd = '0' + dd;
            if (mm < 10) mm = '0' + mm;

            return dd + '/' + mm + '/' + yyyy;
        }

        function setEditModeData(btn) {
            const _tr = btn.closest("tr");

            if (!isDataValid(_tr)) {
                return;
            }
            document.querySelector("#loader").style.display = "flex";
            var selectedItems = [];

            const row = btn.closest("tr");
            var billingId = btn.getAttribute('data-contractbillingid');
            var costing = parseFloat(row.querySelector('.amount-inp').value);
            var estimatedBillingDate = row.querySelector('.estimated-date-inp').value;
            if (!estimatedBillingDate || estimatedBillingDate == '-') {
                toastr.error("Every Resource Provision must include Estimated Billing Date!!.")
                document.querySelector("#loader").style.display = "none";
                return;
            }
            selectedItems.push({
                "contractbillingid": billingId,
                "costing": costing,
                "exptectedbillingdate": getFormattedDate(estimatedBillingDate),
                "IsRevised": true
            });
           
            console.log(selectedItems);

            // Convert the array to a JSON string
            var selectedItemsJSON = JSON.stringify(selectedItems);

            $.ajax({
                url: '/Billing/RevisionApproval',
                type: 'POST',
                contentType: 'application/json',
                data: selectedItemsJSON, // Send the JSON string as data
                success: function (response) {
                    console.log(response);
                    toastr.success("Revision sent for approval to DH!!");
                    window.location.reload();
                },
                error: function (error) {
                    console.error(error);
                    window.location.reload();
                }
            });
        }
       
    </script>
}