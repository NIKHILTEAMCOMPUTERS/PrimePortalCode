        function changeStatusBilled(btn) {
            if (!confirm("Would you like to proceed with updating the billing status? Please note, this action is irreversible.")) {
                btn.value = "";
                return;
            }
            let Expectedbillingdate;
            if (btn.closest("tr").querySelector("td:nth-child(8) input")) {
                Expectedbillingdate = btn.closest("tr").querySelector("td:nth-child(8) input").value;
            } else {
                Expectedbillingdate = btn.closest("tr").querySelector("td:nth-child(8)").innerText.trim();
            }
            const _obj = [{
                contractbillingid: btn.closest("tr").querySelector(".contractbillingid").value,
                isBilled: true,
                Exptectedbillingdate: Expectedbillingdate
            }];
            const fdata = new FormData();
            fdata.append("data", JSON.stringify(_obj));
            $.ajax({
                url: "@Url.Action("UpdateBillingStatus", "Billing")",
                type: "POST",
                cache: false,
                data: fdata,
                contentType: false,
                processData: false,
                success: function (res) {
                    console.log(res);
                    if (res.success == true) {
                        toastr.success("Status Updated");
                        HSOverlay.close(document.querySelector("#prov-billing-overlay"))

                        // window.location.href = 'Report/ActualBillingReports'
                        window.location.reload();
                    } else {
                        toastr.error(res.msg);
                    }
                },
                error: function (err) {
                    toastr.error(err);
                }
            });
        }
