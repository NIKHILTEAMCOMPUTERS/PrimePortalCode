        function handleFileSelectPreview(file, type) {
            if (['xls', 'xlsx'].includes(type)) {
                document.querySelector(".file_preview_wrapper").innerHTML = '<img src="/assets/images/type-excel.svg" style="width: 30%; height: auto; max-height: 100%; object-fit: contain;"/>';
            } else if (['doc', 'docx'].includes(type)) {
                document.querySelector(".file_preview_wrapper").innerHTML = '<img src="/assets/images/type-word.svg" style="width: 30%; height: auto; max-height: 100%; object-fit: contain;"/>';
            } else if (type === 'pdf') {
                document.querySelector(".file_preview_wrapper").innerHTML = '<img src="/assets/images/type-pdf.svg" style="width: 30%; height: auto; max-height: 100%; object-fit: contain;"/>';
            } else if (['jpg', 'jpeg', 'gif', 'png'].includes(type)) {
                document.querySelector(".file_preview_wrapper").innerHTML = `<img src="${URL.createObjectURL(file)}" style="width: 30%; height: auto; max-height: 100%; object-fit: contain;"/>`;
            }
        }

