        function validateCostingSheet() {
            let flag = true;
            if (!document.querySelector("#costingSheetName").value || document.querySelector("#costingSheetName").classList.contains("is-invalid")) {
                document.querySelector("#costingSheetName").classList.add("is-invalid");
                flag = false;
            } else {
                document.querySelector("#costingSheetName").classList.remove("is-invalid");
            }

            const allCostingSheetValues = document.querySelectorAll("#costingModalWrapper > div.grid");

            allCostingSheetValues.forEach(row => {
                const rowInputs = row.querySelectorAll("input, select");
                rowInputs.forEach(input => {
                    if (!input.value) {
                        input.classList.add("is-invalid");
                        flag = false;
                    } else {
                        input.classList.remove("is-invalid");
                    }
                })
            })

            return flag;
        }

        function getexp(skillinput) {
            const costSheetRow = skillinput.closest(".grid");
            const _skillid = skillinput.value;
            const _skillData = skillsData.filter(item => item.skillid == _skillid);
            const select = costSheetRow.querySelector(".skill_exp");
            select.innerHTML = "";
            select.innerHTML += '<option>Select Experience</option>';
            _skillData[0]?.skillcostings.forEach(item => {
                select.innerHTML += `<option value="${item.expname}">${item.expname}</option>`;
            });

            const changeEvent = new Event("change");
            select.dispatchEvent(changeEvent);
            costSheetRow.querySelector(".cus-price").value = 0;
            costSheetRow.querySelector(".total-cost").value = 0;
            costSheetRow.querySelector(".total-price").value = 0;
        }

        function CalcAmount(inp) {
            const costSheetRow = inp.closest(".grid");
            const skillid = costSheetRow.querySelector(".skill_name").value;
            const _exp = costSheetRow.querySelector(".skill_exp").value;
            const no_of_resources = costSheetRow.querySelector(".required_resources");
            const finalAmountExp = costSheetRow.querySelector(".skill_cost");

            if (skillid) {
                let exp_amount;

                skillsData.forEach(skill => {
                    if (skill.skillid == skillid) {
                        skill.skillcostings.forEach(exp => {
                            if (exp.expname == _exp) {
                                exp_amount = exp.amount;
                            }
                        })
                    }
                })

                if (exp_amount && no_of_resources.value) {
                    const calculatedAmount = Number(exp_amount) * Number(no_of_resources.value);
                    finalAmountExp.value = calculatedAmount;
                } else {
                    finalAmountExp.value = "";
                }
            }
            const changeEvent = new Event("change");
            costSheetRow.querySelector(".cs-period").dispatchEvent(changeEvent);
            costSheetRow.querySelector(".x-value").dispatchEvent(changeEvent);
        }

        function handleXValueChange(inp) {
            const skillCost = inp.closest(".custom-grid").querySelector(".skill_cost")?.value;
            if (!skillCost) return;

            inp.closest(".custom-grid").querySelector(".cus-price").value = Number(skillCost) * Number(inp.value);

            const costSheetPeriod = inp.closest(".custom-grid").querySelector(".cs-period")?.value;

            if (!costSheetPeriod) return;

            inp.closest(".custom-grid").querySelector(".total-price").value = Number((Number(inp.closest(".custom-grid").querySelector(".cus-price")?.value) * Number(costSheetPeriod)) / 30).toFixed(2);
            dispatchChange(inp.closest(".custom-grid").querySelector(".total-cost"))
            dispatchChange(inp.closest(".custom-grid").querySelector(".total-price"))
        }

        function dispatchChange(el) {
            const changeEvt = new Event("change");
            el.dispatchEvent(changeEvt);
        }

        function handlePeriodChange(inp) {
            const skillCost = inp.closest(".custom-grid").querySelector(".skill_cost")?.value;
            if (!skillCost) return;

            inp.closest(".custom-grid").querySelector(".total-cost").value = Number((Number(skillCost) * Number(inp.value)) / 30).toFixed(2);

            const customerPrice = inp.closest(".custom-grid").querySelector(".cus-price")?.value;

            if (!customerPrice) return;

            inp.closest(".custom-grid").querySelector(".total-price").value = Number((Number(customerPrice) * Number(inp.value)) / 30).toFixed(2);

            dispatchChange(inp.closest(".custom-grid").querySelector(".total-cost"))
            dispatchChange(inp.closest(".custom-grid").querySelector(".total-price"))
        }

        function handleCPChange(inp) {
            const row = inp.closest(".custom-grid");
            if (!inp.value || !row.querySelector(".skill_cost").value) return;
            row.querySelector(".x-value").value = Number(Number(inp.value) / Number(row.querySelector(".skill_cost").value))
            const changeEvt = new Event("change");
            row.querySelector(".x-value").dispatchEvent(changeEvt);
        }

        function calculateTotalPrice() {
            const allCostInp = document.querySelectorAll(".total-price");
            let _total = 0;
            allCostInp.forEach(item => {
                const _price = Number(item.value);
                _total += _price ? _price : 0;
            })
            document.querySelector("#totalPriceFinal").innerHTML = formatCurrency(_total);
        }

        function calculateTotalCost() {
            const allCostInp = document.querySelectorAll(".total-cost");
            let _total = 0;
            allCostInp.forEach(item => {
                const _price = Number(item.value);
                _total += _price ? _price : 0;
            })
            document.querySelector("#totalCostFinal").innerHTML = formatCurrency(_total);
        }

        function formatCurrency(num) {
            return num.toLocaleString('en-IN', {
                maximumFractionDigits: 2,
                style: 'currency',
                currency: 'INR'
            });
        }

        function removeRow(btn) {
            btn.closest(".grid").remove();
            dispatchChange(btn.closest(".custom-grid").querySelector(".total-cost"))
            dispatchChange(btn.closest(".custom-grid").querySelector(".total-price"))
        }
        let iscostsheetunique = true;
        async function checkCostSheetName(inp) {
            if (!inp.value.trim()) {
                return;
            }

            const formData = new FormData();
            var costsheetid = $("#costsheetid").val();
            formData.append("costsheetname", inp.value.trim());
            formData.append("costsheetid", costsheetid);

            const response = await fetch("/CostingSheet/CheckCostSheetName", {
                method: "POST",
                body: formData
            })

            if (response.status === 200) {
                const data = await response.json();
                console.log(data);
                if (data.responseContent != "false") {
                    inp.classList.add("is-invalid");
                    iscostsheetunique = false;
                    document.querySelector("#alreadyexist").innerHTML = "Costsheet name already exist.";
                }
                else {
                    document.querySelector("#alreadyexist").innerHTML = "";
                    inp.classList.remove("is-invalid");
                    iscostsheetunique = true;
                }
            } else {
                toastr.error("Something went wong");
            }

        }
    </script>
