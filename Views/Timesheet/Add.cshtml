@section Scripts {
    <script src="https://code.jquery.com/ui/1.13.2/jquery-ui.js"></script>

    <script>
        var customers = @(ViewBag.activeCustomer != null ? Html.Raw(Json.Serialize(ViewBag.activeCustomer)) : "[]");
        var category = @(ViewBag.GetCategoryOfActivity != null ? Html.Raw(Json.Serialize(ViewBag.GetCategoryOfActivity)) : "[]");
        const rowData = [];

        var projectData;
        $(function () {
            setProject();
            const allCustomerSelects = document.querySelectorAll("select.customer");
            allCustomerSelects.forEach(item => {
                const rowInd = Number(item.closest("tr").getAttribute("data-rowindex"));
                const slimselect = initSlimSelect(item);
                if (rowData[rowInd]) {
                    rowData[rowInd] = {
                        ...rowData[rowInd],
                        customerSelect: slimselect
                    }
                } else {
                    rowData[rowInd] = {
                        customerSelect: slimselect
                    }
                }
            });

            const allProjects = document.querySelectorAll("select.project_name");
            allProjects.forEach(item => {
                const rowInd = Number(item.closest("tr").getAttribute("data-rowindex"));
                const slimselect = initSlimSelect(item);
                if (rowData[rowInd]) {
                    rowData[rowInd] = {
                        ...rowData[rowInd],
                        projectSelect: slimselect
                    }
                } else {
                    rowData[rowInd] = {
                        projectSelect: slimselect
                    }
                }
            });

            const allCategories = document.querySelectorAll("select.categoryofactivity");
            allCategories.forEach(item => {
                const rowInd = Number(item.closest("tr").getAttribute("data-rowindex"));
                const slimselect = initSlimSelect(item);
                if (rowData[rowInd]) {
                    rowData[rowInd] = {
                        ...rowData[rowInd],
                        categorySelect: slimselect
                    }
                } else {
                    rowData[rowInd] = {
                        categorySelect: slimselect
                    }
                }
            });

            addNewRow();
        @if (ViewData["error"] != null)
        {
                <text>
                            toastr.error("@ViewData["error"]", "Error", {"iconClass": 'new-error' });
                </text>
        }
        @if (ViewData["success"] != null)
        {
                <text>
                            toastr.success("@ViewData["success"]");
                </text>
        }
                });

        $(function () {
            $(".timesheet_date").datepicker({ maxDate: 0, dateFormat: 'dd MM yy', beforeShowDay: unavailable });
        });

        function initSlimSelect(select) {
            if (!select || select.hasAttribute('data-ssid')) {
                console.log("SlimSelect already initialized or invalid select:", select);
                return select?.slim || null;
            }
            console.log("Initializing SlimSelect for:", select, "Options:", select.options.length);
            const slimSelect = new SlimSelect({
                select: select,
                searchPlaceholder: 'Search...',
                searchText: 'No results found',
                allowDeselect: true
            });
            return slimSelect;
        }

        function unavailable(date) {
            const _d = date.getDate() < 10 ? `0${date.getDate()}` : date.getDate();
            const _m = (date.getMonth() + 1) < 10 ? `0${(date.getMonth() + 1)}` : (date.getMonth() + 1);
            const _y = date.getFullYear();
            dmy = _d + "-" + _m + "-" + _y;
            if ($.inArray(dmy, getDates) == -1) {
                return [true, ""];
            } else {
                return [false, "", "Unavailable"];
            }
        }

        function initDatepicker() {
            const _allDateInputs = document.querySelectorAll(".timesheet_date");
            var allowedDate = new Date((new URLSearchParams(window.location.search).get('month')).replace('-', ' '));
            var year = "20" + (new URLSearchParams(window.location.search).get('month')).split('-')[1];
            var month = (new URLSearchParams(window.location.search).get('month')).split('-')[0];
            var today = new Date();
            var minDate = new Date();
            minDate.setDate(today.getDate() - 3);

            _allDateInputs.forEach(inp => {
                $(inp).datepicker({
                    maxDate: 0,
                    dateFormat: 'dd MM yy',
                    defaultDate: new Date(year, getMonthIndex(month), 1),
                    beforeShowDay: function (date) {
                        return [date >= minDate && date <= today];
                    }
                });
            });
        }

        async function handleCustomerChange(e, select) {
            const rowInd = Number(select.closest("tr").getAttribute("data-rowindex"));
            const selectedCustomerId = select.value;
            if (!selectedCustomerId) return;
            const response = await fetch(`/Base/GetProjectAndPracticeByCustomerId?Customerid=${selectedCustomerId}`);

            if (response && response?.status === 200) {
                const customerProjects = await response.json();
                const _copyProject = select.closest("tr").querySelector(".project_name").getAttribute("data-copyproject");
                const selectProjectData = customerProjects.map(item => {
                    return {
                        text: item.projectName,
                        value: item.projectId,
                        selected: item.projectId == _copyProject
                    }
                });
                selectProjectData.unshift({ text: "Select Project", value: "0" });
                setTimeout(() => {
                    rowData[rowInd]?.projectSelect.setData(selectProjectData);
                }, 100);
            }
            checkRow(e);
        }

        function createRowsFromTemplate(n) {
            for (let i = 0; i < n; i++) {
                addNewRow();
            }
        }

        function removeAllTimesheetRowsExceptFirst() {
            const allRows = Array.from(document.querySelectorAll(".timesheet-row"));
            for (let i = 1; i < allRows.length; i++) {
                allRows[i].remove();
            }
        }

        function resetFirstRowData() {
            const allInputs = document.querySelectorAll(".timesheet-row select, .timesheet-row input, .timesheet-row textarea");
            allInputs.forEach(item => {
                item.value = "";
                item.classList.remove("is-invalid")
            });
        }

        async function selectTemplate(select) {
            var tempId = select.value;
            let response = await fetch(`/Template/GetTemplateById?id=${tempId}`);
            if (response != null) {
                let data = await response.json();
                const parseData = JSON.parse(data);
                const templateDetails = parseData.templatedetails;

                removeAllTimesheetRowsExceptFirst();
                resetFirstRowData();
                createRowsFromTemplate(templateDetails.length - 1);

                const allRows = document.querySelectorAll(".timesheet-row");
                allRows.forEach((row, index) => {
                    let currentRowData = templateDetails[index];
                    row.querySelector('#Hours').value = currentRowData.hours;
                    row.querySelector('#Remarks').value = currentRowData.remarks;
                    row.querySelector('#Activity').value = currentRowData.activity;
                    row.querySelector('#DepartmentName').value = currentRowData.departmentid;
                    row.querySelector('#ProjectName').value = currentRowData.projectid;
                });
                const event = new Event('change');
                document.querySelector('#Hours').dispatchEvent(event);
            }
        }

        function getDateFromPicker() {
            const date = $('#TsDate').datepicker('getDate');
            if (!date) {
                return;
            }
            const _d = date.getDate() < 10 ? `0${date.getDate()}` : date.getDate();
            const _m = (date.getMonth() + 1) < 10 ? `0${(date.getMonth() + 1)}` : (date.getMonth() + 1);
            const _y = date.getFullYear();
            return `${_y}-${_m}-${_d}`;
        }

        function handleSubmit(e) {
            e.preventDefault();

            if (isRowValid(e.target.closest("tr"))) {
                document.querySelector("#loader").style.display = "flex";
                const allinput = document.querySelectorAll(".timesheet-row");

                allinput.forEach(item => {
                    var timesheetDetail = {
                        Departmentid: 22,
                        Projectid: Number(item.querySelector("#ProjectName").getAttribute("data-projidinp")),
                        Activity: item.querySelector("#Activity").value,
                        Hours: item.querySelector("#Hours").value
                    }
                    timesheetDetails.push(timesheetDetail);
                });

                const timesheetData = {
                    Timesheetdate: getDateFromPicker(),
                    TimesheetDetails: timesheetDetails
                };

                $.ajax({
                    url: '/Timesheet/Add',
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(timesheetData),
                    success: function (response) {
                        if (response.success == true) {
                            $("#loader").hide();
                            toastr.success(response.msg);
                            setTimeout(() => {
                                window.location.href = "/Timesheet/Add"
                            }, 1500)
                        } else {
                            $("#loader").hide();
                            toastr.error(response.msg);
                            console.log("Failure");
                        }
                    }
                });
            }
        }

        var Timesheets = [];

        function handleSingleSubmit(row) {
            var dateString = $(row).find('.timesheet_date').val();

            const totalHoursUnderLimit = CalculateHours(dateString);

            if (!totalHoursUnderLimit) {
                document.querySelector("#loader").style.display = "none";
                toastr.error("Total hours for this date exceeds 14 Hours Limit");
                return;
            }

            var parts = dateString.split(' ');
            var month = monthNameToNumber(parts[1]);
            var day = parts[0];
            var year = parts[2];

            var formattedDate = year + '-' + month + '-' + day;
            var timesheetDetail = {
                timesheetdetailid: $(row).find('.timesheet_date').attr('timesheetdetailId') != undefined ? $(row).find('.timesheet_date').attr('timesheetdetailId') : 0,
                timesheetid: new URLSearchParams(window.location.search).get('id'),
                Departmentid: 22,
                timesheetdate: formattedDate,
                dayhours: $(row).find('.hours').val(),
                activity: $(row).find('.activity').val(),
                projectId: $(row).find('.project_name').val(),
                categoryofactivityid: $(row).find('.categoryofactivity').val(),
            };

            var fData = new FormData();
            fData.append("timesheetData", JSON.stringify(timesheetDetail));
            $(".ml-auto p").text("Saving...").show();

            $.ajax({
                url: '/Timesheet/Add',
                type: 'POST',
                contentType: false,
                data: fData,
                processData: false,
                success: function (response) {
                    $("#loader").hide();
                    if (response.success == true) {
                        $(row).find('.timesheet_date').attr('timesheetdetailId', response.msg);
                        $(row).find('.timesheetcheckbox').attr('timesheetId', response.msg);
                        $(".ml-auto p").text("Saved").show();
                        setTimeout(function () {
                            $(".ml-auto p").hide();
                        }, 2000);
                    } else {
                        $("#loader").hide();
                        toastr.error(response.msg);
                        console.log("Failure");
                    }
                }
            });
        }

        function checkAll(input) {
            const checkedAction = input.checked ? true : false;
            const allCheckBox = document.querySelectorAll("#datatable tbody input[type='checkbox'][timesheetid]:not(:disabled)");
            allCheckBox.forEach(item => {
                item.checked = checkedAction;
            });
        }

        function singleSubmit(btn) {
            var timesheetid = $(btn).closest('tr').find('.timesheetcheckbox').attr('timesheetId');
            if (!timesheetid) {
                toastr.error("Timesheet should be saved in draft first before submitting.");
                return;
            }
            var data = [];
            data.push(timesheetid);
            submitTimeSheet(data);
        }

        function SubmitAll() {
            const allCheckedRows = document.querySelectorAll("#datatable tbody input[type='checkbox'][timesheetid]:checked:not(:disabled)");
            if (!allCheckedRows.length) {
                toastr.error("No rows selected");
                return;
            }
            var data = [];
            for (var i = 0; i < allCheckedRows.length; i++) {
                data.push(parseInt(allCheckedRows[i].getAttribute('timesheetid')));
            }

            submitTimeSheet(data);
        }

        function submitTimeSheet(data) {
            document.querySelector("#loader").style.display = "flex";
            $.ajax({
                url: '/Timesheet/SubmitTimeSheetDetails',
                type: 'POST',
                dataType: 'json',
                data: { ids: data },
                traditional: true,
                success: function (res) {
                    if (res.success == true) {
                        $("#loader").hide();
                        toastr.success(res.msg);
                        setTimeout(() => {
                            window.location.reload();
                        }, 1500)
                    } else {
                        toastr.error(res.msg);
                        $("#loader").hide();

                    }
                }
            });
        }

        function Validation() {
            RemoveValidation();
            var isAllowed = true;
            // console.log($("#TsDate").val())
            if (!$("#TsDate").val()) {
                isAllowed = false;
                $("#TsDate").addClass('is-invalid');
            }
            var tsDivs = $(".timesheet-row");
            for (i = 0; i < tsDivs.length; i++) {
                if (!validinput(tsDivs[i])) {
                    isAllowed = false;
                    break;
                }

            }
        }


        function validinput(inputDiv) {
            var status = true;


            if ($(inputDiv).find("#Activity").val() === '' && $(inputDiv).find("#Activity").val().trim().length < 50) {
                status = false;
                $(inputDiv).find("#Activity").addClass('is-invalid');
            }

            var hoursInt = parseInt($(inputDiv).find("#Hours").val());
            //  console.log(hoursInt);
            if ($(inputDiv).find("#Hours").val() === '' || $(inputDiv).find("#Hours").val() === '0' || hoursInt < 0) {
                status = false;
                $(inputDiv).find("#Hours").addClass('is-invalid');
            }

            if ($(inputDiv).find("#DepartmentName").val() === '' || $(inputDiv).find("#DepartmentName").val() === '1') {
                status = false;
                $(inputDiv).find("#DepartmentName").addClass('is-invalid');
            }

            if ($(inputDiv).find("#ProjectName").val() === '' || $(inputDiv).find("#ProjectName").val() === '0') {
                status = false;
                $(inputDiv).find("#ProjectName").addClass('is-invalid');
            }
            return status;
        };

        function RemoveValidation() {
            $("#TsDate").removeClass('is-invalid');
            var inputDiv = $(".timesheet-row");
            for (i = 0; i < inputDiv.length; i++) {
                // $(inputDiv[i]).find("#Remarks").removeClass('is-invalid');
                $(inputDiv[i]).find("#Activity").removeClass('is-invalid');
                $(inputDiv[i]).find("#Hours").removeClass('is-invalid');
                $(inputDiv[i]).find("#DepartmentName").removeClass('is-invalid');
                $(inputDiv[i]).find("#ProjectName").removeClass('is-invalid');
            }

        }

        const timesheetDetails = [];

        function addNewRow(isEmpty = false) {
            var timestamp = Date.now();
            var dynamicId = "select_" + timestamp;

            document.querySelector("#datatable tbody tr.no-row")?.remove();
            let serialNo = document.querySelectorAll("#datatable tbody tr").length + 1;
            const _newRow = document.createElement("tr");
            _newRow.classList.add("divide-x")
            if (isEmpty) {
                _newRow.classList.add("empty-row")
            }
            let newRowHtml = getRowHtml();

            _newRow.innerHTML = newRowHtml;

            const tBody = document.querySelector("#datatable tbody");
            if (tBody) {
                tBody && tBody.appendChild(_newRow);
                initDatepicker();
            }

            const _customerSelect = _newRow.querySelector("select");
            const _projectSelect = _newRow.querySelector(".project_name");

            const _customerSlimSelect = initSlimSelect(_customerSelect);
            const _projectSlimSelect = initSlimSelect(_projectSelect);
            rowData[serialNo] = {
                customerSelect: _customerSlimSelect,
                projectSelect: _projectSlimSelect
            }
            setProject(dynamicId);
            reCalculateSerial();
        }
        function getMonthIndex(monthName) {
            return ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'].indexOf(monthName);
        }
        // no limit
        // no limit
        // function initDatepicker() {
        //     //   console.log("Limit off")
        //     const _allDateInputs = document.querySelectorAll(".timesheet_date");
        //     // console.log(_allDateInputs)
        //     var allowedDate = new Date((new URLSearchParams(window.location.search).get('month')).replace('-', ' '));
        //     var year = "20" + (new URLSearchParams(window.location.search).get('month')).split('-')[1];
        //     var month = (new URLSearchParams(window.location.search).get('month')).split('-')[0];

        //     _allDateInputs.forEach(inp => {
        //         $(inp).datepicker({
        //             maxDate: 0,
        //             dateFormat: 'dd MM yy',
        //             defaultDate: new Date(year, getMonthIndex(month), 1),
        //             beforeShowDay: function (date) {
        //                 return [(date.getMonth() === getMonthIndex(month) && date.getFullYear() === parseInt(year))];
        //             }
        //         });
        //     });
        // }



        function deleteRow(btn) {
            const tbody = btn.closest("tbody");
            var timesheetid = $(btn).closest('tr').find('.timesheetcheckbox').attr('timesheetId');
            const rowInd = Number(btn.closest("tr").getAttribute("data-rowindex"));
            if (timesheetid != undefined) {
                $.ajax({
                    url: '/Timesheet/Delete',
                    type: 'POST',
                    data: { id: timesheetid },
                    success: function (res) {
                        $("#loader").hide();
                        if (res.success == true) {
                            toastr.success(res.msg);
                            btn.closest("tr").remove();
                            reCalculateSerial();
                            if (!tbody.querySelectorAll("tr").length) {
                                const emptyTr = document.createElement("tr");
                                emptyTr.classList.add("no-row");
                                emptyTr.innerHTML = '<td colspan="7" class="p-2 text-center">No Timesheet found <button class="py-3 px-4 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent text-white bg-emerald-500 disabled:opacity-50 disabled:pointer-events-none" onclick="addNewRow();">Add New</button></td>';
                                tbody.appendChild(emptyTr);
                            }
                            setTimeout(() => {
                                window.location.reload();
                            }, 1500)

                        } else {
                            toastr.error(res.msg);
                        }
                    }
                });
            } else {
                btn.closest("tr").remove();
                reCalculateSerial();
                rowData.splice(rowInd, 1);
                if (!tbody.querySelectorAll("tr").length) {
                    const emptyTr = document.createElement("tr");
                    emptyTr.classList.add("no-row");
                    emptyTr.innerHTML = '<td colspan="7" class="p-2 text-center">No Timesheet found <button class="py-3 px-4 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent text-white bg-emerald-500 disabled:opacity-50 disabled:pointer-events-none" onclick="addNewRow();">Add New</button></td>';
                    tbody.appendChild(emptyTr);
                }
            }
        }


        function copyRow(btn) {
            const _currentRow = btn.closest("tr");
            const _rowInd = Number(_currentRow.getAttribute("data-rowindex"));
            let serialNo = document.querySelectorAll("#datatable tbody tr").length + 1;
            const _tbody = btn.closest("tbody");
            if (!isRowValid(_currentRow)) {
                return;
            }
            const _copyActivity = _currentRow.querySelector(".activity").value;
            const _copyHours = _currentRow.querySelector(".hours").value;
            //changes by GAUTAM (project and customer set empty string)

            //const _copyProject = _currentRow.querySelector(".project_name").value;
            const _copyProject = "";
            const _copyDate = "";
            const _copyCustomer = "";
            //const _copyCustomer = _currentRow.querySelector("select").value;
            // const _copyDept = _currentRow.querySelector(".department").value;

            const _newRow = document.createElement("tr");
            _newRow.classList.add("divide-x");
            let newRowHtml = getRowHtml(_copyDate, _copyHours, null, _copyActivity, _copyCustomer, _copyProject);

            _newRow.innerHTML = newRowHtml;

            // if (_currentRow.nextElementSibling) {
            //     _tbody.insertBefore(_newRow, _currentRow.nextElementSibling);
            // } else {
            //     _tbody.appendChild(_newRow);
            // }

            _tbody.appendChild(_newRow);
            reCalculateSerial();
            initDatepicker();

            const _customerSelect = _newRow.querySelector("select");
            const _projectSelect = _newRow.querySelector(".project_name");

            const _customerSlimSelect = initSlimSelect(_customerSelect);
            const _projectSlimSelect = initSlimSelect(_projectSelect);
            rowData[serialNo] = {
                customerSelect: _customerSlimSelect,
                projectSelect: _projectSlimSelect
            }
            _customerSelect.dispatchEvent(new Event("change"));
        }


        function getRowHtml(_copyDate = null, _copyHours = null, _copyCategoryactivity = null, _copyActivity = null, _copyCustomer = null, _copyProject = "") {
            let newRowHtml = "";
            newRowHtml += `<td width="5%" class="p-2 whitespace-nowrap text-sm font-medium text-gray-800">
                                                                                                <div class="flex items-center gap-2">
                                                                                                                    <div class="flex">
                                                                                                                        <input type="checkbox" class="timesheetcheckbox shrink-0 mt-0.5 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="select-00">
                                                                                                                            <label for="select-00" class="sr-only">Select</label>
                                                                                                                    </div>
                                                                                                                    <span class="serial-no">00</span>
                                                                                                                </div>
                                                                                                </td>`;
            newRowHtml += `<td class="p-2 whitespace-nowrap text-sm text-gray-800" width="10%">
                                                                                                                                       <div class="relative"> <input type="text" onchange="checkRow(event);"
                                                                                                                            class="timesheet_date
                                                                                                                    py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none"
                                                                                                                    placeholder="Select Date" value="${_copyDate ? _copyDate : ""}" readonly></div>
                                                                                                            </td>`;
            newRowHtml += `<td class="p-2 whitespace-nowrap text-sm text-gray-800" width="12%">
                                                                                                                                              <div class="relative">  <input type="number" onchange="checkRow(event);" step="0.5" min="0" max="14" onkeypress="return (event.charCode !=8 && event.charCode ==0 || (event.charCode >= 49 && event.charCode <= 57))"
                                                                                                                    class="hours py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none"
                                                                                                                                    placeholder="Hours" value="${_copyHours ? _copyHours : ""}"></div>
                                                                                                            </td>`;
