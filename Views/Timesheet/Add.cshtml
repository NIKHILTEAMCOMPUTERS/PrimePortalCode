        function CalculateHours(targetDate) {
            var rows = getRowsWithSameDate(targetDate);
            var sum = 0;
            for (var i = 0; i < rows.length; i++) {
                sum += $(rows[i]).find('td:eq(2)').find('.hours').val() != '' ? Number($(rows[i]).find('td:eq(2)').find('.hours').val()) : 0;
            }
            return sum <= 14 ? true : false;
        }

        function getRowsWithSameDate(targetDate) {
            var rows = [];
            $('table tbody tr').each(function () {
                var cellValue = $(this).find('td:eq(1)').find('.timesheet_date').val(); // Change the index (e.g., 'td:eq(1)') to the index of the target cell
                if (cellValue === targetDate) {
                    rows.push($(this));
                }
            });
            return rows;
        }

        function calculateWorkingDays(monthYear) {
            // Convert "Oct-24" to a Date object
            const [monthStr, yearStr] = monthYear.split('-');
            const month = new Date(Date.parse(monthStr + " 1, 2024")).getMonth(); // Get month index (0-11)
            const year = parseInt('20' + yearStr, 10); // Convert "24" to "2024"

            let totalDays = new Date(year, month + 1, 0).getDate(); // Get total days in the month
            let workingDays = 0;

            for (let day = 1; day <= totalDays; day++) {
                let currentDate = new Date(year, month, day); // month is 0-based in JavaScript
                let dayOfWeek = currentDate.getDay(); // 0: Sunday, 6: Saturday

                if (dayOfWeek !== 0 && dayOfWeek !== 6) { // Exclude Sunday (0) and Saturday (6)
                    workingDays++;
                }
            }

            return workingDays;
        }

