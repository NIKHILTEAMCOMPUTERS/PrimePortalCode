@model IEnumerable<RMS.Client.Models.Timesheet.TimesheetsDetailDTO>;
@{
    Layout = "Timesheet";
}
@section PageStyles {
    <style>
        .error-inp::before {
            z-index: 99;
        }

        .ss-main {
            padding-left: 1rem;
            z-index: 1000 !important; /* Ensure SlimSelect dropdowns are above other elements */
        }

        .ss-content {
            max-height: 200px !important; /* Ensure dropdown has enough space */
            overflow-y: auto !important;
        }

        .ss-search {
            display: block !important; /* Ensure search bar is visible */
        }

        .ss-values {
            flex-grow: 1;
        }

        .ss-single {
            max-width: 10rem;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .activity-detail-container {
            position: absolute;
            background-color: white;
            left: 0;
            right: 0;
            top: 0;
            border-radius: 1rem;
            height: 5rem;
            padding: .5rem;
            overflow-y: auto;
            border: 1px solid;
        }

        .showActivityDetailBtn {
            position: absolute;
            top: 0;
            bottom: 0;
            right: .5rem;
            margin-block: auto;
            width: 1.25rem;
            height: 1.25rem;
            padding: 0;
            background: none;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .showActivityDetailBtn svg {
                width: 1.25rem;
                height: 1.25rem;
            }

            .showActivityDetailBtn path {
                fill: rgb(59 130 246);
            }

        .detailModal {
            max-width: 32rem;
            border-radius: 1rem;
        }

            .detailModal::backdrop {
                background: rgba(17, 24, 39, .5);
            }

            .detailModal .modalHeader {
                padding: 1rem;
                display: flex;
                justify-content: flex-end;
            }

                .detailModal .modalHeader button {
                    width: 1.5rem;
                    height: 1.5rem;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }

                    .detailModal .modalHeader button path {
                        fill: #222
                    }

                    .detailModal .modalHeader button:hover path {
                        fill: #dc2626;
                    }

            .detailModal .modalBody {
                padding-inline: 1rem;
                padding-bottom: 1rem;
            }

        .greetings-cards-wrapper {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
        }
    </style>
}

<div class="greetings-cards-wrapper flex items-center justify-center gap-4 gap-4 relative" style="margin-bottom: 1rem;">
    <div class="greeting-card bg-white rounded shadow p-4 flex items-center gap-4">
        <img style="width: 4rem; height: auto;" src="~/assets/images/card_total_month.svg" alt="">
        <div class="text-left">
            <p>Total Working Day</p>
            <p class="text-2xl font-bold" id="workingDays">04</p>
        </div>
    </div>
    <input type="hidden" id="timesheetsid" value="@Model.Select(a => a.Timesheetid).FirstOrDefault()" />
    <div class="greeting-card bg-white rounded shadow p-4 flex items-center gap-4">
        <img style="width: 4rem; height: auto;" src="~/assets/images/total_tiesheet_pending.svg" alt="">
        <div class="text-left">
            <p>Total Timesheet Entries</p>
            <p class="text-2xl font-bold" id="totalEntries">@Model.GroupBy(a => a.Timesheetdate).Count()</p>
        </div>
    </div>
    <div class="greeting-card bg-white rounded shadow p-4 flex items-center gap-4">
        <img style="width: 4rem; height: auto;" src="~/assets/images/total_leaves.svg" alt="">
        <div class="text-left">
            <p>Total Leaves</p>
            <p class="text-2xl font-bold" id="totalLeave">@ViewBag.LeaveCount</p>
        </div>
    </div>
    <div class="greeting-card bg-white rounded shadow p-4 flex items-center gap-4">
        <img style="width: 4rem; height: auto;" src="~/assets/images/total_tiesheet_pending.svg" alt="">
        <div class="text-left">
            <p>Total Timesheet Pending</p>
            <p class="text-2xl font-bold" id="totalPending">00</p>
        </div>
    </div>
</div>

<div class="relative w-full flex-1 flex flex-col bg-white p-4 rounded-md">
    <div class="border-b p-2 mb-4 flex items-center" style="margin-top: -1rem; margin-left: -1rem; margin-right: -1rem;">
        <a asp-action="Index" asp-controller="Timesheet" class="flex items-center gap-1 rounded-full px-2 py-1 text-gray-800 hover:bg-gray-800 hover:text-white text-sm">
            <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 512 512"><path fill="currentColor" d="M48 256c0 114.87 93.13 208 208 208s208-93.13 208-208S370.87 48 256 48S48 141.13 48 256m212.65-91.36a16 16 0 0 1 .09 22.63L208.42 240H342a16 16 0 0 1 0 32H208.42l52.32 52.73A16 16 0 1 1 238 347.27l-79.39-80a16 16 0 0 1 0-22.54l79.39-80a16 16 0 0 1 22.65-.09" /></svg>
            Back
        </a>
        <span class="text-white flex items-center gap-1 ml-2 text-sm" style="border: 1px solid #89d3ca; background-color: #d7faf6; color: #059080; border-radius: 5rem; padding: .25rem .5rem;">
            <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="M8 14q-.425 0-.712-.288T7 13t.288-.712T8 12t.713.288T9 13t-.288.713T8 14m4 0q-.425 0-.712-.288T11 13t.288-.712T12 12t.713.288T13 13t-.288.713T12 14m4 0q-.425 0-.712-.288T15 13t.288-.712T16 12t.713.288T17 13t-.288.713T16 14M5 22q-.825 0-1.412-.587T3 20V6q0-.825.588-1.412T5 4h1V2h2v2h8V2h2v2h1q.825 0 1.413.588T21 6v14q0 .825-.587 1.413T19 22zm0-2h14V10H5z" /></svg>
            @ViewBag.month
        </span>
        <button id="downloadExcel" onclick="downloadTimesheetExcel()" class="flex items-center gap-2 ml-auto">
            <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 32 32"><defs><linearGradient id="vscodeIconsFileTypeExcel0" x1="4.494" x2="13.832" y1="-2092.086" y2="-2075.914" gradientTransform="translate(0 2100)" gradientUnits="userSpaceOnUse"><stop offset="0" stop-color="#18884f" /><stop offset=".5" stop-color="#117e43" /><stop offset="1" stop-color="#0b6631" /></linearGradient></defs><path fill="#185c37" d="M19.581 15.35L8.512 13.4v14.409A1.19 1.19 0 0 0 9.705 29h19.1A1.19 1.19 0 0 0 30 27.809V22.5Z" /><path fill="#21a366" d="M19.581 3H9.705a1.19 1.19 0 0 0-1.193 1.191V9.5L19.581 16l5.861 1.95L30 16V9.5Z" /><path fill="#107c41" d="M8.512 9.5h11.069V16H8.512Z" /><path d="M16.434 8.2H8.512v16.25h7.922a1.2 1.2 0 0 0 1.194-1.191V9.391A1.2 1.2 0 0 0 16.434 8.2" opacity="0.1" /><path d="M15.783 8.85H8.512V25.1h7.271a1.2 1.2 0 0 0 1.194-1.191V10.041a1.2 1.2 0 0 0-1.194-1.191" opacity="0.2" /><path d="M15.783 8.85H8.512V23.8h7.271a1.2 1.2 0 0 0 1.194-1.191V10.041a1.2 1.2 0 0 0-1.194-1.191" opacity="0.2" /><path d="M15.132 8.85h-6.62V23.8h6.62a1.2 1.2 0 0 0 1.194-1.191V10.041a1.2 1.2 0 0 0-1.194-1.191" opacity="0.2" /><path fill="url(#vscodeIconsFileTypeExcel0)" d="M3.194 8.85h11.938a1.193 1.193 0 0 1 1.194 1.191v11.918a1.193 1.193 0 0 1-1.194 1.191H3.194A1.19 1.19 0 0 1 2 21.959V10.041A1.19 1.19 0 0 1 3.194 8.85" /><path fill="#fff" d="m5.7 19.873l2.511-3.884l-2.3-3.862h1.847L9.013 14.6c.116.234.2.408.238.524h.017q.123-.281.26-.546l1.342-2.447h1.7l-2.359 3.84l2.419 3.905h-1.809l-1.45-2.711A2.4 2.4 0 0 1 9.2 16.8h-.024a1.7 1.7 0 0 1-.168.351l-1.493 2.722Z" /><path fill="#33c481" d="M28.806 3h-9.225v6.5H30V4.191A1.19 1.19 0 0 0 28.806 3" /><path fill="#107c41" d="M19.581 16H30v6.5H19.581Z" /></svg>
            <span class="text-sm text-gray-600">Export to Excel</span>
        </button>
    </div>

    <div class="flex justify-between items-center mb-4">
        <div class="flex items-center gap-2">
            <img class="w-8 h-8" src="@Url.Content("~/assets/images/fill_timesheet_icon.svg")" alt="timesheet icon">
            <div>
                <p class="font-bold text-xl">Fill Timesheet</p>
                <p class="text-sm">Fill In the given details below</p>
            </div>
        </div>

        <button onclick="addNewRow()"
                class="flex items-center gap-2 bg-blue-500 text-white rounded-full px-6 py-3 hover:shadow-2xl transition-all">
            <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 32 32"><path fill="currentColor" d="M16 2A14.173 14.173 0 0 0 2 16a14.173 14.173 0 0 0 14 14a14.173 14.173 0 0 0 14-14A14.173 14.173 0 0 0 16 2m8 15h-7v7h-2v-7H8v-2h7V8h2v7h7Z" /><path fill="none" d="M24 17h-7v7h-2v-7H8v-2h7V8h2v7h7z" /></svg>
            Add Row
        </button>
    </div>

    <div class="table-wrapper flex-1 overflow-y-auto">
        <div class="flex flex-col">
            <div class="-m-1.5 overflow-x-auto">
                <div class="p-1.5 min-w-full inline-block align-middle">
                    <div class="border rounded-lg overflow-hidden">
                        <table class="min-w-full divide-y divide-gray-200" id="datatable">
                            <thead class="bg-[#F2F3F8]">
                                <tr class="divide-x">
                                    <th scope="col"
                                        class="px-2 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600">
                                        <div class="flex items-center gap-2">
                                            <div class="flex">
                                                <input onchange="checkAll(this);" type="checkbox" class="shrink-0 mt-0.5 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="select-all">
                                                <label for="select-all" class="sr-only">Select</label>
                                            </div>
                                            S.No
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-2 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600">
                                        <div class="flex items-center gap-2">
                                            <img class="w-6 h-6" src="@Url.Content("~/assets/images/select_date_icon.svg")" alt="date icon">
                                            Date
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-2 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600">
                                        <div class="flex items-center gap-2">
                                            <img class="w-6 h-6" src="@Url.Content("~/assets/images/select_hours_icon.svg")" alt="hour icon">
                                            Hours
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-2 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600">
                                        <div class="flex items-center gap-2">
                                            <img class="w-6 h-6" src="@Url.Content("~/assets/images/activity_icon.svg")" alt="activity icon">
                                            Category Of Activity
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-2 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600">
                                        <div class="flex items-center gap-2">
                                            <img class="w-6 h-6" src="@Url.Content("~/assets/images/activity_icon.svg")" alt="activity icon">
                                            Activity
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-2 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600">
                                        <div class="flex items-center gap-2">
                                            <img class="w-6 h-6" src="@Url.Content("~/assets/images/activity_icon.svg")" alt="activity icon">
                                            Customer
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-2 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600">
                                        <div class="flex items-center gap-2">
                                            <img class="w-6 h-6" src="@Url.Content("~/assets/images/project_name_icon.svg")" alt="project icon">
                                            Project Name
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-2 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600">
                                        <div class="flex items-center gap-2">
                                            <img class="w-6 h-6" src="@Url.Content("~/assets/images/status_action_icon.svg")" alt="status icon">
                                            Status
                                        </div>
                                    </th>
                                    <th scope="col"
                                        class="px-2 py-3 text-sm font-bold whitespace-nowrap text-gray-600 text-center">
                                        <div class="flex items-center gap-2">
                                            <img class="w-6 h-6" src="@Url.Content("~/assets/images/status_action_icon.svg")" alt="action icon">
                                        </div>
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                @if (Model != null)
                                {
                                    int count = 1;
                                    @foreach (var detail in Model)
                                    {
                                        <tr class="timesheet-row divide-x" data-rowindex="@count">
                                            <td width="5%" class="p-2 whitespace-nowrap text-sm font-medium text-gray-800">
                                                <div class="flex items-center gap-2">
                                                    <div class="flex">
                                                        <input timesheetId="@detail.Timesheetdetailid" type="checkbox" @(detail.Isdrafted ? "" : "disabled checked ") class="timesheetcheckbox shrink-0 mt-0.5 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                                        <label for="select-01" class="sr-only">Select</label>
                                                    </div>
                                                    <span class="serial-no">@count </span>
                                                </div>
                                            </td>
                                            <td class="p-2 whitespace-nowrap text-sm text-gray-800" width="14%">
                                                <div class="relative">
                                                    <input type="text" @(detail.Isdrafted ? "" : "disabled ") onchange="@(detail.Isdrafted == false ? "" : "checkRow(event);")" timesheetdetailId="@detail.Timesheetdetailid" value="@detail.Timesheetdate.ToString("dd MMMM yyyy")"
                                                           class="timesheet_date py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none"
                                                           placeholder="Select Date" readonly>
                                                </div>
                                            </td>
                                            <td class="p-2 whitespace-nowrap text-sm text-gray-800" width="12%">
                                                <div class="relative">
                                                    <input type="number" @(detail.Isdrafted ? "" : "disabled ") onchange="@(detail.Isdrafted == false ? "" : "checkRow(event);")" step="0.5" value="@detail.Dayhours" min="0" max="15" onkeypress="return (event.charCode !=8 && event.charCode ==0 || (event.charCode >= 49 && event.charCode <= 57))"
                                                           class="hours py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none"
                                                           placeholder="Hours">
                                                </div>
                                            </td>
                                            <td class="p-2 whitespace-nowrap text-sm text-gray-800">
                                                <div class="relative">
                                                    <select name="categoryofactivityId" onchange="forLeave(this); checkRow(event);" @(!detail.Isdrafted ? "disabled" : "") class="categoryofactivity py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none"
                                                            style="min-width: 12rem;">
                                                        <option value="0">Select Category Of Activity</option>
                                                        @foreach (var Category in ViewBag.GetCategoryOfActivity)
                                                        {
                                                            var isSelected = Category.Value == detail.categoryofactivityid.ToString() ? "selected" : "";
                                                            if (isSelected == "selected")
                                                            {
                                                                <option value="@Category.Value" selected>@Category.Text</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@Category.Value">@Category.Text</option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                            </td>
                                            <td class="p-2 whitespace-nowrap text-sm text-gray-800" width="46%">
                                                <div class="relative">
                                                    <input type="text" @(detail.Isdrafted ? "" : "disabled ") onchange="@(detail.Isdrafted == false ? "" : "checkRow(event); handleActivityError(this);")" value="@detail.Activity"
                                                           class="activity py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none"
                                                           placeholder="Activity (At least 50 characters required)">
                                                    @if (!detail.Isdrafted)
                                                    {
                                                        <button onclick="showDetail(this);" class="showActivityDetailBtn" title="Show Detail">
                                                            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="#ff5252" d="M12 9a3 3 0 0 0-3 3a3 3 0 0 0 3 3a3 3 0 0 0 3-3a3 3 0 0 0-3-3m0 8a5 5 0 0 1-5-5a5 5 0 0 1 5-5a5 5 0 0 1 5 5a5 5 0 0 1-5 5m0-12.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5" /></svg>
                                                        </button>
                                                    }
                                                </div>
                                            </td>
                                            <td class="p-2 whitespace-nowrap text-sm text-gray-800">
                                                <div class="relative">
                                                    <select name="Customerid" @(!detail.Isdrafted ? "disabled" : "") onchange="handleCustomerChange(event, this);" class="customer activity py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none"
                                                            style="min-width: 12rem;">
                                                        <option value="0">Select Customer</option>
                                                        @foreach (var customer in ViewBag.activeCustomer)
                                                        {
                                                            var isSelected = customer.Value == detail.CustomerId.ToString() ? "selected" : "";
                                                            if (isSelected == "selected")
                                                            {
                                                                <option value="@customer.Value" selected>@customer.Text</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@customer.Value">@customer.Text</option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                            </td>
                                            <td class="p-2 whitespace-nowrap text-sm text-gray-800" width="12%">
                                                <div class="relative">
                                                    <select @(!detail.Isdrafted ? "disabled" : "") class="project_name py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none">
                                                        <option>Select Project</option>
                                                        <option selected value="@detail.ProjectId">@detail.Projectname</option>
                                                    </select>
                                                </div>
                                            </td>
                                            <td class="p-2 whitespace-nowrap text-sm text-gray-800" width="7%">
                                                <span class="text-xs font-bold @(detail.Isdrafted ? "text-orange-500" : "text-emerald-400")">@(detail.Isdrafted ? "Draft" : "Submitted")</span>
                                            </td>
                                            <td class="p-2 whitespace-nowrap text-sm text-gray-800 text-center" width="4%">
                                                <div class="hs-dropdown ml-auto relative inline-flex">
                                                    <button id="hs-dropdown-with-header" type="button"
                                                            class="hs-dropdown-toggle overflow-hidden inline-flex justify-center items-center gap-2 rounded-md border font-medium bg-white text-gray-700 shadow-sm align-middle hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-white focus:ring-emerald-500 transition-all text-sm">
                                                        <svg class="w-6 h-6" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 20 20"><g fill="currentColor"><circle cx="10" cy="15" r="2" /><circle cx="10" cy="10" r="2" /><circle cx="10" cy="5" r="2" /></g></svg>
                                                    </button>

                                                    <div style="z-index:99;" class="hs-dropdown-menu transition-[opacity,margin] duration hs-dropdown-open:opacity-100 opacity-0 hidden bg-white shadow-md rounded-lg p-2 mt-2"
                                                         aria-labelledby="hs-dropdown-with-header">
                                                        <div class="mt-2 py-2 first:pt-0 last:pb-0">
                                                            <div class="flex items-center gap-1">
                                                                @if (detail.Isdrafted)
                                                                {
                                                                    <button title="Submit" type="button" onclick="singleSubmit(this);"
                                                                            class="w-8 h-8 inline-flex items-center justify-center gap-x-2 text-sm font-semibold rounded-full border border-transparent text-gray-400 bg-gray-200 hover:bg-emerald-400 hover:text-white disabled:opacity-50 disabled:pointer-events-none">
                                                                        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg"
                                                                             width="24" height="24" viewBox="0 0 24 24">
                                                                            <path fill="currentColor"
                                                                                  d="M5 21h14a2 2 0 0 0 2-2V8a1 1 0 0 0-.29-.71l-4-4A1 1 0 0 0 16 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2m10-2H9v-5h6zM13 7h-2V5h2zM5 5h2v4h8V5h.59L19 8.41V19h-2v-5a2 2 0 0 0-2-2H9a2 2 0 0 0-2 2v5H5z" />
                                                                        </svg>
                                                                    </button>
                                                                }
                                                                <button title="Copy" onclick="copyRow(this);" type="button"
                                                                        class="w-8 h-8 inline-flex items-center justify-center gap-x-2 text-sm font-semibold rounded-full border border-transparent text-gray-400 bg-gray-200 hover:bg-yellow-400 hover:text-white disabled:opacity-50 disabled:pointer-events-none">
                                                                    <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg"
                                                                         width="24" height="24" viewBox="0 0 24 24">
                                                                        <path fill="currentColor"
                                                                              d="M20 2H10c-1.103 0-2 .897-2 2v4H4c-1.103 0-2 .897-2 2v10c0 1.103.897 2 2 2h10c1.103 0 2-.897 2-2v-4h4c1.103 0 2-.897 2-2V4c0-1.103-.897-2-2-2M4 20V10h10l.002 10zm16-6h-4v-4c0-1.103-.897-2-2-2h-4V4h10z" />
                                                                        <path fill="currentColor" d="M6 12h6v2H6zm0 4h6v2H6z" />
                                                                    </svg>
                                                                </button>
                                                                @if (detail.Isdrafted)
                                                                {
                                                                    <button onclick="deleteRow(this);" type="button" title="Discard"
                                                                            class="w-8 h-8 inline-flex items-center justify-center gap-x-2 text-sm font-semibold rounded-full border border-transparent text-gray-400 bg-gray-200 hover:bg-gray-800 hover:text-white disabled:opacity-50 disabled:pointer-events-none">
                                                                        <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg"
                                                                             width="24" height="24" viewBox="0 0 24 24">
                                                                            <path fill="currentColor"
