<div id="rejectModal" class="hs-overlay hs-overlay-open:opacity-100 hs-overlay-open:duration-500 hidden w-full h-screen fixed top-0 start-0 z-[80] opacity-0 overflow-x-hidden transition-all overflow-y-auto pointer-events-none">
    <div class="sm:max-w-lg sm:w-full m-3 sm:mx-auto h-screen flex items-center justify-center">
        <div class="flex flex-col bg-white border shadow-sm rounded-xl pointer-events-auto w-full max-w-xl">
            <div class="flex justify-between items-center py-3 px-4 border-b">
                <h3 class="font-bold text-gray-800">
                    Reject Timesheet
                </h3>
                <button type="button" class="flex justify-center items-center w-7 h-7 text-sm font-semibold rounded-full border border-transparent text-gray-800 hover:bg-gray-100 disabled:opacity-50 disabled:pointer-events-none" data-hs-overlay="#rejectModal">
                    <span class="sr-only">Close</span>
                    <svg class="flex-shrink-0 w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 6 6 18"></path>
                        <path d="m6 6 12 12"></path>
                    </svg>
                </button>
            </div>
            <div class="p-4 overflow-y-auto">
                <div>
                    <label for="reject-reason-modal" class="block text-sm font-medium mb-2">Enter Reason</label>
                    <textarea id="reject-reason-modal" class="py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" rows="3" placeholder="Reason"></textarea>
                </div>
            </div>
            <div class="flex justify-end items-center gap-x-2 py-3 px-4 border-t">
                <button type="button" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-medium rounded-lg border border-gray-200 bg-white text-gray-800 shadow-sm hover:bg-gray-50 disabled:opacity-50 disabled:pointer-events-none" data-hs-overlay="#rejectModal">
                    Cancel
                </button>
                <button type="button" id="rejectTimesheetModalBtn" onclick="rejectTimesheetMultiple(this);" class="py-2 px-3 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent bg-red-600 text-white hover:bg-red-700 disabled:opacity-50 disabled:pointer-events-none">
                    Reject
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts{
    @* <link href="https://unpkg.com/tabulator-tables@6.2.1/dist/css/tabulator.min.css" rel="stylesheet">
    <script type="text/javascript" src="https://unpkg.com/tabulator-tables@6.2.1/dist/js/tabulator.min.js"></script> *@
    <script>

        function todayDate() {
            const today = Date.now();
            const month = today.getMonth
        }

        window.addEventListener("DOMContentLoaded", () => {
            initdatatable();
            setMonthSelectLimits();

            document.querySelector("#select-month").value = document.querySelector("#select-month").getAttribute("value");

            GetDetails(document.querySelector("#select-month"), 3)
        })

        var monthName = "";
        var projectId = 0;
        var employeeId = 0;

        let datatable;

        function initdatatable() {
            datatable = new DataTable("#datatable", {
                ordering: false,
                destroy: true,
                scrollX: true
            })
            // datatable = new Tabulator("#datatable")
        }

        function setMonthSelectLimits() {
            const monthSelect = document.querySelector("#select-month");
            const currentDate = new Date();
            const maxValue = `${currentDate.getFullYear()}-${currentDate.getMonth() + 1 < 10 ? '0' + (currentDate.getMonth() + 1) : currentDate.getMonth() + 1}`;
            monthSelect.setAttribute("max", maxValue);
        }

        const multiSelect = new SlimSelect({
            select: "#projects",
            settings: {
                allowDeselect: false,
                closeOnSelect: true,
                maxValuesShown: 1
            }
        })

        const multiSelect1 = new SlimSelect({
            select: "#resource",
            settings: {
                allowDeselect: false,
                closeOnSelect: true,
                maxValuesShown: 1
            }
        })

        let months = ["January", "February", "March", "April", "May", "June",
            "July", "August", "September", "October", "November", "December"];
        function downloadTimesheetExcel() {
            var formData = new FormData();
            formData.append("date", monthName);
            //formData.append("projectId", Number(projectId));
            //formData.append("employeeId", Number(employeeId));
            // var projectId = Number(projectId);
            // var employeeId = Number(employeeId);

            var date = monthName;
            var projectId = $('#projects').val();
            var employeeId = $('#resource').val();
            var headerId = 0;

            $.ajax({
                url: `/Timesheet/TimesheetExcel?date=${date}&projectId=${projectId}&employeeId=${employeeId}&headerId=${headerId}`,
                type: 'GET',
                success: function (response) {
                    if (response.success) {
                        var downloadUrl = response.fileUrl;
                        window.location.href = downloadUrl;
                    } else {
                        alert('Error: ' + response.msg);
                    }
                },
                error: function (xhr, status, error) {
                    console.error('An error occurred:', error);
                    alert('Failed to download the file. Please try again.');
                }
            });
        }

        function getData() {
            // //console.log(input.value);
            // document.querySelector("#loader").style.display = "flex";
            // let monthData = input.value.split("-");
            // monthName = `${months[Number(monthData[1]) - 1]}-${monthData[0]}`;
            var formData = new FormData();
            formData.append("date", monthName);
            formData.append("projectId", Number(projectId));
            formData.append("employeeId", Number(employeeId));

            $.ajax({
                url: '/Timesheet/GetManagerTimesheet',
                type: 'Get',
                data: {
                    date: monthName,
                    projectId: Number(projectId),
                    employeeId: Number(employeeId)
                },
                success: function (res) {
                    console.log(res);
                    datatable.destroy();
                    $("#datatable tbody").html("");
                    $("#loader").hide();
                    if (res.success == true) {
                        var data = aggregateDataByDate(JSON.parse(res.msg));
                        console.log(data);
                        if (data.length) {
                            data.forEach((item, index) => {
                                const sNo = (index + 1) < 10 ? '0' + (index + 1) : (index + 1);
                                const tr = document.createElement("tr");
                                const hiddenTr = document.createElement("tr");
                                hiddenTr.style.border = "none";
                                let trHtml = ``;
                                // trHtml += `<td class="pl-6 py-3"><button data-details='${JSON.stringify(item)}' onclick="toggleDetails(this);">
                                //                     <svg class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="M8 6.82v10.36c0 .79.87 1.27 1.54.84l8.14-5.18a1 1 0 0 0 0-1.69L9.54 5.98A.998.998 0 0 0 8 6.82"/></svg>
                                //                 </button></td>`;
                                trHtml += `<td class="pl-6 py-3">${sNo}</td>`
                                trHtml += `<td class="pl-6 py-3">${item?.employeename}</td>`;
                                const date = new Date(item?.timesheetdate);

                                // Format the date to dd/MMM/yyyy
                                const formattedDate = date.toLocaleDateString('en-GB', {
                                    day: '2-digit',
                                    month: 'short',
                                    year: 'numeric'
                                });

                                // Create the table cell with the formatted date
                                trHtml += `<td class="pl-6 py-3">${formattedDate}</td>`;
                                trHtml += `<td class="pl-6 py-3">${item?.totalhours} ${Number(item?.totalhours) > 1 ? 'Hours' : 'Hour'}</td>`;
                                // trHtml += `<td class="pl-6 py-3">${item?.companyemail}</td>`;
                                trHtml += `<td class="pl-6 py-3">9 Hours</td>`;
                                // trHtml += `<td class="pl-6 py-3">${item?.timesheetdetailid}</td>`;
                                // trHtml += `<td class="pl-6 py-3">${item?.timesheetid}</td>`;
                                trHtml += `<td class="pl-6 py-3">
                                                    <button type="button" class="toggleTimesheetDetailBtn py-1 px-4 inline-flex items-center gap-x-2 text-sm font-semibold rounded-lg border border-transparent text-gray-800 hover:text-emerald-600 disabled:opacity-50 disabled:pointer-events-none">
                                                        View Timesheet
                                                        <svg class="arrow flex-shrink-0 w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                            <path d="m6 9 6 6 6-6"></path>
                                                        </svg>
                                                    </button>
                                                   </td>`;



                                tr.innerHTML = trHtml;

                                const toggleTimesheetDetailBtn = tr.querySelector(".toggleTimesheetDetailBtn");
                                if (toggleTimesheetDetailBtn) {
                                    toggleTimesheetDetailBtn.addEventListener("click", (e) => {
                                        toggleDetails(e.target, item?.activities);
                                    })
                                }
                                // hiddenTr.innerHTML = `<td colspan="6">
                                //                             <div id="timesheet_collapse_${sNo}" class="p-2 hs-collapse hidden transition-[height] duration-300 w-full overflow-hidden transition-[height] duration-300" aria-labelledby="Timesheet Detail">
                                //                             ${getDetailHtml(item?.activities)}
                                //                         </div>
                                //                       </td>`
                                // hiddenTr.innerHTML = getHiddentrHtml(item);
                                document.querySelector("#datatable tbody").appendChild(tr);
                                // document.querySelector("#datatable tbody").appendChild(hiddenTr);
                            })
                            console.log(data);
                        }
                    } else {
                        toastr.error(res.msg);
                    }
                    initdatatable();
                }
            });
        }

        function getDetailHtml(activities) {
            if (!activities || activities.length === 0) {
                return `<td colspan="6"><p class="text-center">No Activities found</p></td>`;
            }

            let activitiesHtml = ``;
            activitiesHtml += `<td colspan="6" class="p-2">`;
            activitiesHtml += '<div class="flex flex-col">'
            activitiesHtml += '<div class="-m-1.5 overflow-x-auto">'
            activitiesHtml += '<div class="p-1.5 min-w-full inline-block align-middle">'
            activitiesHtml += '<div class="border rounded-lg overflow-hidden">'
            activitiesHtml += '<table class="min-w-full divide-y divide-gray-200 activityTable" id="datatable1">'
            activitiesHtml += '<thead class="bg-[#F2F3F8]">'
            activitiesHtml += `<tr class="divide-x">`

            activitiesHtml += `<th scope="col" class="px-2 py-3 text-left text-sm font-bold whitespace-nowrap text-gray-600" width="10%">`
            activitiesHtml += `<div class="flex items-center gap-2">`
            activitiesHtml += `<div class="flex">`
            activitiesHtml += `<input onchange="checkAll(this);" type="checkbox" class="shrink-0 mt-0.5 border-gray-200 rounded text-emerald-600 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" id="select-all">`
            activitiesHtml += `<label for="select-all" class="sr-only">Select</label>`;
            activitiesHtml += `</div>S.No</div>`
