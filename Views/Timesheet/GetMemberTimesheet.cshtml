        function toggleDetails(btn, activities) {
            const data = btn.getAttribute("data-details");
            if (btn.closest("tr").nextElementSibling && btn.closest("tr").nextElementSibling.classList.contains("hidden-row")) {
                btn.closest("tr").nextElementSibling.remove();
            } else {
                const hiddenrow = document.createElement("tr");
                hiddenrow.classList.add("hidden-row");
                hiddenrow.innerHTML = getDetailHtml(activities);
                btn.closest("tr").parentElement.insertBefore(hiddenrow, btn.closest("tr").nextElementSibling);
            }
        }

