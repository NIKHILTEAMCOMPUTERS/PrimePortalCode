@model IEnumerable<RMS.Client.Models.Timesheet.Timesheets>;
@{
    Layout = "Timesheet";
}
@section PageStyles {
    <style>
        .arrow {
            transition: transform .25s ease;
        }

        tr:has(+ .hidden-row) .arrow {
            transform: rotate(-180deg);
        }

        .hidden-row td:nth-child(1) {
            width: 5rem;       
        }.hidden-row td:nth-child(2) {
            width: 12rem;       
        }.hidden-row td:nth-child(3) {
            width: 8rem;       
        }.hidden-row td:nth-child(5) {
            width: 10rem;       
        }.hidden-row td:nth-child(4) {
            width: 18rem;       
        }

        .declineSelectedBtn {
            display: none;
            /* visibility: hidden; */
            /* pointer-events: none; */
        }

        .activityTable:has(input[type='checkbox']:checked) .declineSelectedBtn {
            display: flex;
            /* visibility: visible; */
            /* pointer-events: all; */
        }

        .activityTable tr:has(input[type='checkbox']:checked) .declineBtn {
            visibility: hidden;
            pointer-events: none;
        }
    </style>
}

