        function checkAll(chk) {
            const allTbodyCheckbox = chk.closest("table").querySelector("tbody").querySelectorAll("input[type='checkbox']");
            const isToBeChecked = chk.checked;

            allTbodyCheckbox.forEach(item => {
                item.checked = isToBeChecked;
            })
        }

        function declineSelected(btn) {
            const allSelectedRows = btn.closest("table").querySelector("tbody").querySelectorAll("tr:has(input[type='checkbox']:checked)");
            
            const allSelectedIds = [];
            
            allSelectedRows.forEach(item => {
                const _id = item.getAttribute("data-id");
                allSelectedIds.push(_id);
            })

            console.log(allSelectedIds);
            document.querySelector("#rejectTimesheetModalBtn").setAttribute("data-selected", allSelectedIds.join(","));
            HSOverlay.open(document.querySelector("#rejectModal"));
        }

