        function GetDetails(inp, inpType) {
            switch (inpType) {
                case 1:
                    projectId = $(inp).val();
                    break;
                case 2:
                    employeeId = $(inp).val();
                    break;
                case 3: document.querySelector("#loader").style.display = "flex";
                    setMonthName(inp);
                    let monthData = inp.value.split("-");
                    monthName = `${months[Number(monthData[1]) - 1]}-${monthData[0]}`;
                    break;
                default: break;

            }
            getData();
        }

        function setMonthName(input) {
            if (!input.value) return;
            const date = new Date(input.value);
            const monthName = date.toLocaleString('default', { month: 'long' });
            input.parentElement.querySelector("span").innerText = monthName;
        }

        function aggregateDataByDate(data) {
            const aggregate = {};

            data.forEach(entry => {
                const key = `${entry.employeename}-${entry.companyemail}-${entry.timesheetdate}`;

                if (!aggregate[key]) {
                    aggregate[key] = {
                        employeename: entry.employeename,
                        companyemail: entry.companyemail,
                        timesheetdate: entry.timesheetdate,
                        totalhours: 0,
                        activities: []
                    };
                }

                aggregate[key].totalhours += entry.dayhours;
                aggregate[key].activities.push({
                    projectname: entry.projectname,
                    activity: entry.activity,
                    Categoryofactivityname: entry.categoryofactivityname,
                    dayhours: entry.dayhours,
                    timesheetdetailid: entry.timesheetdetailid
                });
            });

            return Object.values(aggregate);
        }

        function rejectTimesheet(btn) {
            var id = Number(btn.closest("div").getAttribute("data-id"));
            const rejectReason = btn.parentElement.querySelector(".reject-reason").value;
            if (!rejectReason) {
                btn.parentElement.querySelector(".reject-reason").classList.add("is-invalid");
                return;
            } else {
                btn.parentElement.querySelector(".reject-reason").classList.remove("is-invalid");
            }
            const fData = new FormData();
            fData.append("data", JSON.stringify([{ Timesheetdetailid: id, Remarks: rejectReason }]))
            // fData.append("id", id)
            // fData.append("reason", rejectReason);
            $.ajax({
                url: '/Timesheet/ManagerAction',
                type: 'POST',
                // contentType: 'application/json',
                // processData: false,
                processData: false,
                contentType: false,
                data: fData,
                // data: JSON.stringify({ Id: id }),
                success: function (response) {
                    if (response.success) {
                        toastr.success("Timesheet Declined");
                        window.location.reload();
                    }
                    console.log('Success:', response);
                },
                error: function (xhr, status, error) {
                    console.log('Error:', error);
                }
            });
        }

        function rejectTimesheetMultiple(btn) {
            var ids = btn.getAttribute("data-selected");
            if(!ids) {
                toastr.error("There was some problem in declining timesheet. Please try again.");
                return;
            }
            const rejectReason = document.querySelector("#reject-reason-modal").value;
            if (!rejectReason) {
                document.querySelector("#reject-reason-modal").classList.add("is-invalid");
                return;
            } else {
                document.querySelector("#reject-reason-modal").classList.remove("is-invalid");
            }

            const rejectData = [];

            ids.split(",").forEach(item => {
                rejectData.push({
                    Timesheetdetailid: item,
                    Remarks: rejectReason
                })
            })

            const fData = new FormData();
            fData.append("data", JSON.stringify(rejectData));
            // fData.append("id", id)
            // fData.append("reason", rejectReason);
            $.ajax({
                url: '/Timesheet/ManagerAction',
                type: 'POST',
                // contentType: 'application/json',
                // processData: false,
                processData: false,
                contentType: false,
                data: fData,
                // data: JSON.stringify({ Id: id }),
                success: function (response) {
                    if (response.success) {
                        toastr.success("Timesheet Declined");
                        window.location.reload();
                    }
                    console.log('Success:', response);
                },
                error: function (xhr, status, error) {
                    console.log('Error:', error);
                }
            });
        }


        function handleDecline(btn) {
            const row = btn.closest("tr");
            const detailId = row.getAttribute("data-id")

            const declineOverlay = document.createElement("div");
            declineOverlay.classList.add("absolute", "rejectOverlay", "h-full");
            declineOverlay.style.backgroundColor = "white";
            declineOverlay.style.inset = `0`;

            declineOverlay.innerHTML = `<div class="flex items-center gap-4 h-full px-1" data-id="${detailId}">
                                            <input type="text" placeholder="Enter reject reason" class="reject-reason flex-1 py-3 px-4 block w-full border-gray-200 rounded-lg text-sm focus:border-emerald-500 focus:ring-emerald-500 disabled:opacity-50 disabled:pointer-events-none" />
                                            <button class="flex items-center gap-2 bg-blue-500 text-white rounded-full px-6 py-3 hover:shadow-2xl transition-all" onclick="rejectTimesheet(this);">Save</button>
                                            <button onclick="handleRejectOverlayCancel(this);" class="flex items-center gap-2 bg-gray-200 rounded-full px-6 py-3 hover:shadow-2xl transition-all">Cancel</button>
                                        </div>`;

            btn.parentElement.appendChild(declineOverlay);

        }

        function handleRejectOverlayCancel(btn) {
            btn.closest(".rejectOverlay").remove();
        }

