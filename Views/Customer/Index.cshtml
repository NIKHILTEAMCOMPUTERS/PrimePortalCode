@model List<RMS.Client.Models.Customer.CustomerWithDetailsDto>
@{
    bool lReadPermit = false;
    bool lWritePermit = false;
    bool lDeletePermit = false;
    string role = Context.Session.GetString("RoleName");
    if (ViewBag.AuthPages != null)
    {
        var pages = (List<RMS.Client.Models.Account.AuthorizePages>)ViewBag.AuthPages;
        var pageFound = pages.FirstOrDefault(x => x.Controller == "Customer");
        if (pageFound != null)
        {
            lReadPermit = pageFound.Isreadpermit??false;
            lWritePermit = pageFound.Iswritepermit??false;
            lDeletePermit = pageFound.Isdeletepermit??false;
        }
    }
    var colLists = new List<string> { "Customer Name", "Resource Deployed", "Total Projects", "Total Project Cost"};
    if (lReadPermit)
        colLists.Add("Detailed View");
    if (role == "DA" || lWritePermit)
    {
        colLists.Add("Edit");
    }

}

<partial name="~/Views/Shared/Controls/_PageHead.cshtml" model="@(new RMS.Client.Models.Common.PageHead 
{ PageHeading="List of Customers", LinkText="Add Customer", LinkController="Customer", LinkAction="Create", Columns = colLists})" />

<div class="flex flex-col">
    <div class="-m-1.5 overflow-x-auto">
        <div class="p-1.5 min-w-full inline-block align-middle">
            <div class="overflow-hidden">
                <table id="tblData" class="last-column-fixed min-w-full divide-y divide-gray-200">
                    <thead>
                        <tr>
                            @foreach (var col in colLists)
                            {
                                <th scope="col"
                                    class="whitespace-nowrap px-2 py-3 text-left text-xs 2xl:text-sm font-medium text-black uppercase">
                                    @col
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @if (Model != null)
                        {
                            foreach (var customer in Model)
                            {
                                <tr>
                                    <td class="px-2 py-4 text-sm font-medium text-gray-800 ">
                                        <div class="flex items-center gap-2">
                                            <img class="w-6 h-6 2xl:w-8 2xl:h-8 rounded-full overflow-hidden"
                                                    src="@(string.IsNullOrEmpty(customer.CustomerCompanyLogoUrl) ? "./assets/images/customer_default.svg" :customer.CustomerCompanyLogoUrl)" alt="">
                                            @customer.CustomerCompanyName
                                        </div>
                                       
                                    </td>
                                    <td class="px-6 py-2 2xl:py-4 whitespace-nowrap text-xs 2xl:text-sm text-gray-800 ">
                                        @customer.ProjectsInfo.Sum(projectInfo => projectInfo.TotalEmployees)
                                    </td>
                                    <td class="px-6 py-2 2xl:py-4 whitespace-nowrap text-xs 2xl:text-sm text-gray-800 ">@customer.TotalProjects</td>
                                    <td class="px-6 py-2 2xl:py-4 whitespace-nowrap text-xs 2xl:text-sm text-gray-800 ">
                                        @{
                                            var s = customer.ProjectsInfo.Sum(cf => (decimal?)cf.TotalAmount) ?? 0;
                                            @s.ToString("F2");
                                        }
                                    </td>

                                    @if (lReadPermit)
                                    {
                                        <td class="px-6 py-2 2xl:py-4 whitespace-nowrap text-xs 2xl:text-sm text-gray-800 ">
                                            <a asp-action="View" asp-controller="Customer" asp-route-id="@customer.CustomerId" class="hover:underline">Detailed View</a>
                                        </td>
                                    }

                                    @if (lWritePermit || role == "DA")
                                    {
                                        <td class="px-6 py-2 2xl:py-4 whitespace-nowrap text-xs 2xl:text-sm font-medium">
                                            <a type="button"
                                               class="inline-flex flex-shrink-0 justify-center items-center gap-2 h-6 w-6 rounded-md border border-transparent font-medium bg-white text-gray-700 shadow-sm align-middle hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2 focus:ring-offset-white transition-all text-xs"
                                               href="Customer/Create?customerid=@customer.CustomerId">
                                                <svg class="w-5 h-5 text-gray-800 hover:text-emerald-500"
                                                     xmlns="http://www.w3.org/2000/svg" width="24" height="24"
                                                     viewBox="0 0 24 24">
                                                    <g fill="none">
                                                        <path d="M24 0v24H0V0h24ZM12.593 23.258l-.011.002l-.071.035l-.02.004l-.014-.004l-.071-.035c-.01-.004-.019-.001-.024.005l-.004.01l-.017.428l.005.02l.01.013l.104.074l.015.004l.012-.004l.104-.074l.012-.016l.004-.017l-.017-.427c-.002-.01-.009-.017-.017-.018Zm.265-.113l-.013.002l-.185.093l-.01.01l-.003.011l.018.43l.005.012l.008.007l.201.093c.012.004.023 0 .029-.008l.004-.014l-.034-.614c-.003-.012-.01-.02-.02-.022Zm-.715.002a.023.023 0 0 0-.027.006l-.006.014l-.034.614c0 .012.007.02.017.024l.015-.002l.201-.093l.01-.008l.004-.011l.017-.43l-.003-.012l-.01-.01l-.184-.092Z" />
                                                        <path fill="currentColor"
                                                              d="M13 3a1 1 0 0 1 .117 1.993L13 5H5v14h14v-8a1 1 0 0 1 1.993-.117L21 11v8a2 2 0 0 1-1.85 1.995L19 21H5a2 2 0 0 1-1.995-1.85L3 19V5a2 2 0 0 1 1.85-1.995L5 3h8Zm6.243.343a1 1 0 0 1 1.497 1.32l-.083.095l-9.9 9.899a1 1 0 0 1-1.497-1.32l.083-.094l9.9-9.9Z" />
                                                    </g>
                                                </svg>
                                            </a>
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


@section Scripts{

    <script type="text/javascript">

        $(function () {
        @if (ViewData["error"] != null)
        {
            <text>
                    toastr.error("@ViewData["error"]", "Error", { "iconClass": 'new-error' });
            </text>
        }
        @if (ViewData["success"] != null)
        {
            <text>
                    toastr.success("@ViewData["success"]");
            </text>
        }
                });



        let datatable = new DataTable("#tblData", {
            scrollX: true,
            scrollY: '55vh',
            dom: "lBfrtip",
            buttons: [{
                extend: 'excelHtml5',
                exportOptions: {
                    trim: false,
                    stripHtml: false,
                    format: {
                        header: function (html, index, node) {
                            return node.innerText;
                        },
                        body: function (data, row, column, node) {
                            return node.innerText;
                        }
                    }
                }
            }]
        });

     
    </script>
}