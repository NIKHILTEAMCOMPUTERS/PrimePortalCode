                                //             <li>
                                //                 <a asp-controller="@item.Controller" asp-action="@item.Action"
                                //                    class="@(ViewData["controller"].ToString() == @item.Controller ? "active" : "") menu-item text-xs lg:text-sm xl:text-base 2xl:text-xl px-2 py-2 xl:px-3 2xl:px-5 2xl:py-3 rounded-lg flex items-center gap-2">
                                //                     <img class="float-left" src="@item.PageIcon" />
                                //                     <span class="menu-item-text flex-1 overflow-hidden text-ellipsis">@item.PageName</span>
                                //                 </a>
                                //             </li>
                                //         }
                                //     </ul>
                                // </li>
                                <li class="relative">
                                    <a data-hs-collapse="#@(rpt.ModuleName.ToString().Trim().Replace(" ", ""))"
                                       class="hs-collapse-toggle menu-item text-xs lg:text-sm xl:text-base 2xl:text-xl px-2 py-2 xl:px-3 2xl:px-5 2xl:py-3 rounded-lg flex items-center gap-2">
                                        <img class="w-3 h-3 xl:w-4 xl:h-4 2xl:w-5 2xl:h-5" src="@rpt.ModuleIcon" />
                                        @if (rpt.ModuleName == "Task Box")
                                        {
                                            <span class="absolute top-0 right-0 block text-white text-xs font-bold rounded-full px-2 ring-2 ring-white" style="background-color: #FF9E2C; transform: translate(0%, -50%)">@Count</span>

                                        }
                                        <span class="menu-item-text flex-1 overflow-hidden text-ellipsis whitespace-nowrap cursor-pointer">
                                            @rpt.ModuleName
                                        </span>
                                        <svg class="sidebar-dropdown-icon hs-collapse-open:rotate-180 flex-shrink-0 w-6 h-6 transition-transform text-gray-300" xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 512 512"><path fill="currentColor" d="M256 464c114.87 0 208-93.13 208-208S370.87 48 256 48S48 141.13 48 256s93.13 208 208 208m-96-270.63l96 96l96-96L374.63 216L256 334.63L137.37 216Z" /></svg>
                                    </a>
                                    <div id="@(rpt.ModuleName.ToString().Trim().Replace(" ", ""))"
                                         class="hs-collapse hidden w-full overflow-hidden transition-[height] duration-300 hs-collapse-open:bg-white hs-collapse-open:rounded-e"
                                         aria-labelledby="hs-basic-collapse">
                                        <div class="m-2 pl-4">
                                            <ul class="sidebar-dropdown-menu flex flex-col gap-2">
                                                @foreach (var item in pages.Where(c => c.ModuleName == rpt.ModuleName))
                                                {
                                                    <li>
                                                        @{
                                                             controllerName = ViewContext.RouteData.Values["controller"].ToString();
                                                             actionName = ViewContext.RouteData.Values["action"].ToString();
                                                        }

                                                        <a asp-controller="@item.Controller" asp-action="@item.Action"
                                                           class="@((controllerName == item.Controller && actionName == item.Action) ? "active" : "") menu-item-inner text-xs lg:text-sm xl:text-base 2xl:text-xl px-2 py-2 xl:px-3 2xl:px-5 2xl:py-3 rounded-lg flex items-center gap-2">
                                                            <img class="w-4 h-4" src="@item.PageIcon" />
                                                            <span class="menu-item-text flex-1 overflow-hidden text-ellipsis">@item.PageName</span>
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </li>
                            }
                        }
                    }
                </ul>
            }
        }
    </div>
</div>

