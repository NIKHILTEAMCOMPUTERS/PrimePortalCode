        @{
            var pages = (List<RMS.Client.Models.Account.AuthorizePages>)Model;
            var role = @Context.Session.GetString("RoleName");
            var Provisioncount = @Context.Session.GetInt32("ProvisionsRequestCount");
            var revisionsCount = @Context.Session.GetInt32("RevisionsRequestCount");
            var Count = Provisioncount + revisionsCount;
            var controllerName = ViewContext.RouteData.Values["controller"].ToString();
            var actionName = ViewContext.RouteData.Values["action"].ToString();
            if (pages != null && pages.Count() > 0)
            {

                <ul class="menu flex-1 overflow-y-auto flex flex-col gap-3 xl:gap-4 2xl:gap-5 px-4">
                    @{
                        List<string> modules = new List<string>();
                        foreach (var rpt in pages)
                        {
                            if (string.IsNullOrEmpty(rpt.ModuleName))
                            {
                                <li>
                                    <a asp-controller="@rpt.Controller" asp-action="@rpt.Action" class="@(controllerName.ToString() == @rpt.Controller ? "active" : "") menu-item px-2 py-2 xl:px-3 2xl:px-5 2xl:py-3 rounded-lg flex items-center gap-2">
                                        <img class="w-4 h-4" src="@rpt.PageIcon" />
                                        <span class="menu-item-text flex-1 overflow-hidden text-ellipsis whitespace-nowrap">@rpt.PageName</span>
                                    </a>
                                </li>
                            }

                            else if (!modules.Contains(rpt.ModuleName))
                            {
                                modules.Add(rpt.ModuleName);

                                // <li class="side_nav_ul_li side_nav_ul_li_dd">
                                //     <a class="outer_link">
                                //         <div class="d-flex align-items-center gap-2">
                                //             <img class="float-left" src="@rpt.ModuleIcon" />
                                //             <span class="fs-400 fw-medium">@rpt.ModuleName</span>
                            //         </div>

                                //         <div class="arrow">
                                //             <img src="~/img/droparrow.svg" alt="" class="dropdown_arrow">
                                //         </div>
                                //     </a>
                                //     <ul class="sub_dropdown">
